    clinical_setting:  List[str] = Field(default_factory=list)
    context_sentences: List[str] = Field(default_factory=list)


class FlatRetrievalSignals(BaseModel):
    """
    Flat, single-level retrieval context used by FinalCandidateItem.

    Every dimension is a comma-separated string so downstream applications
    can consume the entire context in one read — no nested traversal needed.
    context_sentences are pre-assembled narrative sentences that describe
    the full documentation footprint — ready for direct embedding or prompt
    injection without any further assembly.

    Shape:
        {
          "document_types":   "primary care progress note, lab order, urology consultation note",
          "author_roles":     "primary care physician, urologist, oncology nurse",
          "temporal_signals": "initial presentation, active monitoring, follow-up visit",
          "content_signals":  "assessment and plan documentation, referral documentation",
          "clinical_setting": "outpatient primary care clinic, urology specialty clinic",
          "context_sentences": [
            "PSA level, documented in primary care progress note by primary care physician ...",
            "PSA level, documented in urology consultation note by urologist ..."
          ]
        }
    """
    document_types:    str = ""
    author_roles:      str = ""
    temporal_signals:  str = ""   # renamed from temporal_scope for clarity
    content_signals:   str = ""
    clinical_setting:  str = ""
    context_sentences: List[str] = Field(default_factory=list)

    @classmethod
    def from_retrieval_context(cls, ctx: "RetrievalContext") -> "FlatRetrievalSignals":
        """Convert a structured RetrievalContext into a flat, comma-joined form."""
        def _strip(v: str) -> str:
            return v.split(" - ", 1)[0].replace("_", " ").strip() if v else ""

        def _join(lst: List[str]) -> str:
            cleaned = [_strip(v) for v in lst if v]
            return ", ".join(dict.fromkeys(cleaned))  # dedup, preserve order

        return cls(
            document_types    = _join(ctx.document_types),
            author_roles      = _join(ctx.author_roles),
            temporal_signals  = _join(ctx.temporal_scope),
            content_signals   = _join(ctx.content_signals),
            clinical_setting  = _join(ctx.clinical_setting),
            context_sentences = ctx.context_sentences or [],
        )


