"""
Stage 2 of 2: form topics on top of the expansion pickle.

Reads:  cui_expansion_lookup.pkl   (built by run_builder.py)
Writes: cui_topic_lookup.pkl       (same data + topic_id_overlap + topic_id_louvain)

The original expansion pickle is not modified, so this stage can be re-run
with different clustering parameters without rebuilding from BigQuery.

Per semantic type, runs both clustering approaches:
  Interpretation 1 (overlap threshold):
    - Edge between two CUIs if Jaccard(expansion_a, expansion_b) >= JACCARD_THRESHOLD
    - Topic = connected component
    - Explainable, threshold-sensitive

  Interpretation 2 (Louvain community detection):
    - Weighted edge with Jaccard as weight (no thresholding)
    - Topic = Louvain community (modularity-maximizing)
    - Automated, robust, deterministic with seed

Both topic IDs are scoped per semantic type. Format:
    "<semantic_type>::<int>"           (multi-CUI topic)
    "<semantic_type>::singleton::<cui>" (CUI alone in its topic)
"""

import os
import pickle
import sys
import time
from collections import defaultdict

import networkx as nx
from networkx.algorithms.community import louvain_communities

try:
    sys.stdout.reconfigure(line_buffering=True)
except AttributeError:
    pass


INPUT  = "cui_expansion_lookup.pkl"
OUTPUT = "cui_topic_lookup.pkl"

JACCARD_THRESHOLD  = 0.3   # Interpretation 1 minimum overlap to connect
LOUVAIN_RESOLUTION = 1.0   # Interpretation 2 granularity (1.0 = default)
LOUVAIN_SEED       = 42


# ─────────────────────────────────────────────────────────────
# CLUSTERING
# ─────────────────────────────────────────────────────────────

def assign_topics(lookup, jaccard_threshold, louvain_resolution, louvain_seed):
    """Run BOTH clustering approaches per semantic type and write topic
    IDs back into the lookup. Returns the same lookup dict, mutated.
    """
    print(f"  Forming topics (jaccard>={jaccard_threshold}, "
          f"louvain res={louvain_resolution}, seed={louvain_seed})...")
    t = time.time()

    # Bucket CUIs by semantic type
    by_type = defaultdict(list)
    for cui, entry in lookup.items():
        by_type[entry["semantic_type"]].append(cui)

    # Pre-extract expansion as a set of CUI strings (drops label/centrality
    # which aren't needed for overlap)
    expansion_set = {
        cui: {e["cui"] for e in lookup[cui]["expansion"]}
        for cui in lookup
    }

    overlap_assignments = {}
    louvain_assignments = {}

    n_types = len(by_type)
    for type_idx, (sem_type, cuis_in_type) in enumerate(by_type.items(), 1):
        n_cuis = len(cuis_in_type)
        if type_idx % 20 == 0 or type_idx == 1 or type_idx == n_types:
            print(f"    [{type_idx}/{n_types}] semantic_type={sem_type!r}  "
                  f"CUIs={n_cuis:,}", flush=True)

        # Inverted index: expansion_member -> CUIs that have it
        # Lets us iterate only pairs that share a member, instead of all-pairs.
        member_index = defaultdict(list)
        for cui in cuis_in_type:
            for m in expansion_set[cui]:
                member_index[m].append(cui)

        # For each pair sharing a member, compute Jaccard once.
        seen_pairs = set()
        edges_threshold = []
        edges_louvain = []
        for member, sharers in member_index.items():
            if len(sharers) < 2:
                continue
            for i in range(len(sharers)):
                for j in range(i + 1, len(sharers)):
                    a, b = sharers[i], sharers[j]
                    pair = (a, b) if a < b else (b, a)
                    if pair in seen_pairs:
                        continue
                    seen_pairs.add(pair)
                    sa = expansion_set[a]
                    sb = expansion_set[b]
                    union = len(sa | sb)
                    if union == 0:
                        continue
                    inter = len(sa & sb)
                    jac = inter / union
                    if jac > 0:
                        edges_louvain.append((a, b, jac))
                    if jac >= jaccard_threshold:
                        edges_threshold.append((a, b))

        # ── Interpretation 1: connected components on threshold graph ──
        g_thresh = nx.Graph()
        g_thresh.add_nodes_from(cuis_in_type)
        g_thresh.add_edges_from(edges_threshold)

        for comp_idx, component in enumerate(nx.connected_components(g_thresh)):
            comp_list = list(component)
            if len(comp_list) == 1:
                cui = comp_list[0]
                overlap_assignments[cui] = f"{sem_type}::singleton::{cui}"
            else:
                tid = f"{sem_type}::{comp_idx}"
                for cui in comp_list:
                    overlap_assignments[cui] = tid

        # ── Interpretation 2: Louvain on weighted-overlap graph ──
        g_louvain = nx.Graph()
        g_louvain.add_nodes_from(cuis_in_type)
        for a, b, w in edges_louvain:
            g_louvain.add_edge(a, b, weight=w)

        try:
            communities = louvain_communities(
                g_louvain, weight="weight",
                resolution=louvain_resolution, seed=louvain_seed,
            )
        except Exception as e:
            print(f"      Louvain failed for {sem_type}: {e}")
            communities = [{cui} for cui in cuis_in_type]

        for comm_idx, community in enumerate(communities):
            comm_list = list(community)
            if len(comm_list) == 1:
                cui = comm_list[0]
                louvain_assignments[cui] = f"{sem_type}::singleton::{cui}"
            else:
                tid = f"{sem_type}::{comm_idx}"
                for cui in comm_list:
                    louvain_assignments[cui] = tid

    # Write topic IDs back into the lookup
    for cui, entry in lookup.items():
        entry["topic_id_overlap"] = overlap_assignments.get(
            cui, f"{entry['semantic_type']}::unassigned"
        )
        entry["topic_id_louvain"] = louvain_assignments.get(
            cui, f"{entry['semantic_type']}::unassigned"
        )

    overlap_topics = set(overlap_assignments.values())
    louvain_topics = set(louvain_assignments.values())
    overlap_singletons = sum(1 for x in overlap_topics if "::singleton::" in x)
    louvain_singletons = sum(1 for x in louvain_topics if "::singleton::" in x)

    print(f"  -> done ({time.time()-t:.1f}s)")
    print(f"    Interpretation 1 (overlap): "
          f"{len(overlap_topics):,} distinct topics "
          f"({overlap_singletons:,} singletons, "
          f"{len(overlap_topics) - overlap_singletons:,} multi-CUI)")
    print(f"    Interpretation 2 (Louvain): "
          f"{len(louvain_topics):,} distinct topics "
          f"({louvain_singletons:,} singletons, "
          f"{len(louvain_topics) - louvain_singletons:,} multi-CUI)")

    return lookup


# ─────────────────────────────────────────────────────────────
# IO
# ─────────────────────────────────────────────────────────────

def load_pickle(path):
    if not os.path.exists(path):
        raise FileNotFoundError(
            f"{path} not found. Run run_builder.py first to produce the "
            f"expansion pickle."
        )
    with open(path, "rb") as f:
        return pickle.load(f)


def save_pickle(obj, path):
    with open(path, "wb") as f:
        pickle.dump(obj, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = round(os.path.getsize(path) / 1e6, 1)
    print(f"  Saved {len(obj):,} entries -> {path}  ({size_mb} MB)")


# ─────────────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────────────

if __name__ == "__main__":
    start = time.time()

    print(f"\n{'='*60}")
    print(f"  Topic clustering (Stage 2)")
    print(f"  Input    : {INPUT}")
    print(f"  Output   : {OUTPUT}")
    print(f"  Jaccard  : {JACCARD_THRESHOLD}")
    print(f"  Louvain  : resolution={LOUVAIN_RESOLUTION}, seed={LOUVAIN_SEED}")
    print(f"{'='*60}\n")

    print("[1/3] Loading expansion pickle...")
    t = time.time()
    lookup = load_pickle(INPUT)
    print(f"  -> {len(lookup):,} entries  ({time.time()-t:.1f}s)")
    print()

    print("[2/3] Forming topics (both interpretations)...")
    lookup = assign_topics(
        lookup,
        jaccard_threshold=JACCARD_THRESHOLD,
        louvain_resolution=LOUVAIN_RESOLUTION,
        louvain_seed=LOUVAIN_SEED,
    )
    print()

    print("[3/3] Saving pickle...")
    save_pickle(lookup, OUTPUT)
    print(f"\nTotal time: {(time.time()-start)/60:.1f} min")
