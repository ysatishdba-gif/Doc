def create_map_table(client):

    query = f"""

    CREATE OR REPLACE TABLE `{MAP_TABLE}` AS

    WITH semantic_map AS (
        SELECT DISTINCT
            cui,
            semantic_type
        FROM `{SEMANTIC_TABLE}`
    ),

    base_relations AS (

        SELECT
            r.origin_cui,
            r.target_cui,
            r.relation,

            s1.semantic_type AS origin_semantic_type,
            s2.semantic_type AS target_semantic_type

        FROM `{RELATION_TABLE}` r

        LEFT JOIN semantic_map s1
            ON r.origin_cui = s1.cui

        LEFT JOIN semantic_map s2
            ON r.target_cui = s2.cui
    ),

    -- =====================================================
    -- SAME SEMANTIC TYPE
    -- =====================================================

    same_semantic_origin AS (

        SELECT DISTINCT

            origin_cui AS cui,

            CONCAT(
                'REL_',
                TO_HEX(MD5(
                    CONCAT(
                        origin_semantic_type,
                        '|',
                        relation
                    )
                ))
            ) AS cluster_id,

            'ORIGIN' AS mapping_role,

            'DIRECT_MEMBER' AS mapping_type,

            CURRENT_TIMESTAMP() AS created_at

        FROM base_relations

        WHERE origin_semantic_type = target_semantic_type
    ),

    same_semantic_target AS (

        SELECT DISTINCT

            target_cui AS cui,

            CONCAT(
                'REL_',
                TO_HEX(MD5(
                    CONCAT(
                        origin_semantic_type,
                        '|',
                        relation
                    )
                ))
            ) AS cluster_id,

            'TARGET' AS mapping_role,

            'DIRECT_MEMBER' AS mapping_type,

            CURRENT_TIMESTAMP() AS created_at

        FROM base_relations

        WHERE origin_semantic_type = target_semantic_type
    ),

    -- =====================================================
    -- CROSS SEMANTIC TYPE
    -- =====================================================

    cross_origin AS (

        SELECT DISTINCT

            origin_cui AS cui,

            CONCAT(
                'CROSS_',
                TO_HEX(MD5(
                    CONCAT(
                        origin_semantic_type,
                        '|',
                        target_semantic_type,
                        '|',
                        relation
                    )
                ))
            ) AS cluster_id,

            'ORIGIN' AS mapping_role,

            'DIRECT_MEMBER' AS mapping_type,

            CURRENT_TIMESTAMP() AS created_at

        FROM base_relations

        WHERE origin_semantic_type != target_semantic_type
    ),

    cross_target AS (

        SELECT DISTINCT

            target_cui AS cui,

            CONCAT(
                'CROSS_',
                TO_HEX(MD5(
                    CONCAT(
                        origin_semantic_type,
                        '|',
                        target_semantic_type,
                        '|',
                        relation
                    )
                ))
            ) AS cluster_id,

            'TARGET' AS mapping_role,

            'DIRECT_MEMBER' AS mapping_type,

            CURRENT_TIMESTAMP() AS created_at

        FROM base_relations

        WHERE origin_semantic_type != target_semantic_type
    )

    SELECT * FROM same_semantic_origin

    UNION DISTINCT

    SELECT * FROM same_semantic_target

    UNION DISTINCT

    SELECT * FROM cross_origin

    UNION DISTINCT

    SELECT * FROM cross_target

    """

    run_query(client, query, "Creating SCENARIO_4_MAP")



