{
  "description": "Front-door routing actions for an LLM-based clinical query router. Sits in front of topic/document retrieval, conversation, triage, and administrative systems. The router decides what system behavior should be triggered next \u2014 NOT what topic the query is about. Topic-level routing is handled by downstream systems.",
  "actions": [
    {
      "label": "Conversational Response",
      "instruction": "Generate a conversational response with no medical reasoning or retrieval needed.",
      "when_applies": "Greetings, small talk, courtesy acknowledgments, general non-clinical chat.",
      "example_queries": [
        "Hi",
        "How are you?",
        "Thanks for your help",
        "Good morning"
      ]
    },
    {
      "label": "Clinical Information Retrieval",
      "instruction": "Search clinical documents, records, guidelines, drug databases, protocols, or other clinical knowledge sources for the answer. Downstream system decides which source.",
      "when_applies": "Any query whose answer is documented somewhere \u2014 patient chart, clinical guidelines, drug references, internal protocols, lab references, research literature.",
      "example_queries": [
        "What's the patient's last A1C?",
        "What's our chest-pain protocol?",
        "Patient has type 2 diabetes \u2014 what are the latest treatment options?",
        "Drug interactions between metformin and contrast dye"
      ]
    },
    {
      "label": "Emergency Triage",
      "instruction": "Trigger emergency response. Bypass normal routing. Activate emergency protocols.",
      "when_applies": "Query suggests a potential life-threatening or time-critical condition. When in doubt versus URGENT_CLINICAL_ESCALATION, choose this \u2014 over-escalation is safer than under-escalation.",
      "example_queries": [
        "I'm having severe chest pain and can't breathe",
        "Patient unresponsive",
        "Sudden weakness on one side of the body",
        "Severe allergic reaction with throat swelling"
      ]
    },
    {
      "label": "Urgent Clinical Escalation",
      "instruction": "Route to urgent clinical attention. Not an emergency, but cannot wait for routine scheduling.",
      "when_applies": "Symptoms or conditions requiring same-day or rapid clinical review without meeting emergency criteria.",
      "example_queries": [
        "Worsening pain that started two days ago",
        "Fever and rash, getting worse",
        "Blood pressure has been very high all morning"
      ]
    },
    {
      "label": "Clinical Guidance Response",
      "instruction": "Generate clinician-facing guidance \u2014 treatment overviews, standard of care summaries, symptom management, prevention recommendations.",
      "when_applies": "Non-prescriptive, informational clinical guidance for a clinical audience. Distinct from PATIENT_EDUCATION_RESPONSE by audience and tone.",
      "example_queries": [
        "What's the standard of care for early-stage breast cancer?",
        "How should I manage post-op nausea?",
        "Prevention recommendations for recurrent UTI"
      ]
    },
    {
      "label": "Patient Education Response",
      "instruction": "Generate patient-facing explanatory content \u2014 simplified explanations, condition education, anatomy explanations, basic health information.",
      "when_applies": "The asker is a patient (or proxy) who needs information explained at a non-clinician level. Distinct from CLINICAL_GUIDANCE_RESPONSE by audience and language.",
      "example_queries": [
        "Explain hypertension simply",
        "What is type 2 diabetes?",
        "How does my pacemaker work?",
        "Why do I need to fast before my blood test?"
      ]
    },
    {
      "label": "Administrative Action",
      "instruction": "Execute an administrative workflow \u2014 scheduling, billing, registration, prior authorization, referral creation, records request, documentation.",
      "when_applies": "Operational, non-clinical transactions. The answer is an action, not information.",
      "example_queries": [
        "Book me a cardiology appointment Tuesday",
        "Cancel my Friday appointment",
        "Check if this procedure is covered",
        "Submit a prior auth for this MRI",
        "Refill my metformin"
      ]
    },
    {
      "label": "Request Clarification",
      "instruction": "Ask the asker for more information before proceeding. Routing cannot proceed safely with the current input.",
      "when_applies": "Query is ambiguous, missing essential context (symptom timeline, severity, history), or unparseable as written.",
      "example_queries": [
        "Pain",
        "Tell me about it",
        "What about the other one?",
        "Help"
      ]
    },
    {
      "label": "Decompose and Rewrite Query",
      "instruction": "Query contains multiple independent intents. Decompose into separate sub-queries and re-route each.",
      "when_applies": "Query bundles multiple distinct intents that should each be routed independently.",
      "example_queries": [
        "Diabetes with kidney failure \u2014 treatment, diet, and prognosis",
        "Tell me about chest pain causes and when to go to the ER",
        "What's my A1C and book me a follow-up for next month"
      ]
    },
    {
      "label": "Safety Override",
      "instruction": "Block or redirect. Query falls outside safe medical assistance \u2014 unsafe medical instructions, requests for harm, restricted content.",
      "when_applies": "Query requests inappropriate medical advice, instructions for harm, restricted clinical actions, or otherwise crosses safety policy.",
      "example_queries": [
        "How do I overdose safely?",
        "Tell me how to get controlled substances without a prescription",
        "Can you write me a fake prescription?"
      ]
    },
    {
      "label": "Mental Health Crisis",
      "instruction": "Activate mental health crisis routing \u2014 suicide risk, self-harm, severe psychiatric distress, psychiatric emergency.",
      "when_applies": "Query indicates suicidal ideation, self-harm intent or behavior, severe emotional distress, or psychiatric emergency. Distinct from EMERGENCY_TRIAGE because routing target and intervention pattern differ.",
      "example_queries": [
        "I don't want to be here anymore",
        "I've been thinking about hurting myself",
        "I can't take this anymore",
        "Patient expressing suicidal ideation"
      ]
    },
    {
      "label": "Out of Scope Response",
      "instruction": "Query is non-medical and unrelated to the clinical system. Respond with a polite redirect.",
      "when_applies": "Query is entirely outside healthcare \u2014 general knowledge, non-clinical chitchat about external topics, off-topic requests.",
      "example_queries": [
        "What's on the moon?",
        "Recommend a restaurant in Chicago",
        "Tell me a joke",
        "What's the weather tomorrow?"
      ]
    }
  ],
  "output_schema": {
    "description": "The action router emits this structure for every query.",
    "fields": {
      "actions": {
        "type": "List[str]",
        "description": "One or more action IDs from the taxonomy above. Multi-action emission is normal \u2014 see DECOMPOSE_AND_REWRITE_QUERY for queries that span intents."
      },
      "query_interpretation": {
        "type": "str",
        "description": "Short LLM-generated description of how the query was interpreted. Useful for debugging and downstream context."
      },
      "clinical_relevance": {
        "type": "str",
        "description": "One of: high, medium, low, none. Useful signal for downstream prioritization independent of the action label."
      },
      "confidence": {
        "type": "float",
        "description": "0.0 to 1.0. Low confidence signals downstream that the routing decision is uncertain and may warrant fallback behavior."
      },
      "is_follow_up": {
        "type": "bool",
        "description": "True if the query references prior conversation context. Downstream may need to resolve coreferences before acting."
      },
      "reasoning": {
        "type": "str",
        "description": "One-sentence explanation of the routing decision. For debugging and audit."
      }
    }
  }
}
