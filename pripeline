def create_member_table(client):

    query = f"""

    CREATE OR REPLACE TABLE `{MEMBER_TABLE}` AS

    WITH all_cuis AS (

        SELECT DISTINCT
            origin_cui AS cui,
            origin_cui_name AS cui_name
        FROM `{RELATION_TABLE}`

        UNION DISTINCT

        SELECT DISTINCT
            target_cui AS cui,
            target_cui_name AS cui_name
        FROM `{RELATION_TABLE}`
    )

    SELECT DISTINCT

        c.cui,

        c.cui_name,

        s.semantic_type,

        CURRENT_TIMESTAMP() AS created_at

    FROM all_cuis c

    LEFT JOIN `{SEMANTIC_TABLE}` s
        ON c.cui = s.cui

    """

    run_query(client, query, "Creating SCENARIO_4_MEMBER")

