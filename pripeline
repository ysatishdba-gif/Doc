# EXTRACTION RESULT — holds all intermediate data; emits all format views


class ExtractionResult:

    def __init__(
        self,
        original_query: str,
        expansion: QueryExpansionOutput,
        intents: IntentExtractionOutput,
        context: Optional[ContextualEnvironmentOutput],
        temporal: Optional[TemporalExtractionOutput],
        processing_time: float,
    ):
        self.original_query = original_query
        self.expansion = expansion
        self.intents = intents
        self.context = context
        self.temporal = temporal
        self.processing_time = processing_time

        # Build O(1) lookup index for concept contexts
        self._concept_index: Optional[Dict[str, ConceptContext]] = None
        if context and context.concepts_with_context:
            self._concept_index = {
                cc.atomic_concept.strip().lower(): cc
                for cc in context.concepts_with_context
            }

    # helpers

    @staticmethod
    def _aggregate_facets(
        concepts: List[ConceptContext],
    ) -> Tuple[List[str], List[str], List[str], List[str], List[str]]:
        """Union the five facets across one or more concept contexts, deduped."""
        records, authors, scope, signals, settings = [], [], [], [], []
        for cc in concepts or []:
            records.extend(cc.record_types or [])
            authors.extend(cc.author_roles or [])
            scope.extend(cc.longitudinal_scope or [])
            signals.extend(cc.content_signals or [])
            settings.extend(cc.clinical_settings or [])
        _dd = lambda xs: list(dict.fromkeys(x for x in xs if x))
        return _dd(records), _dd(authors), _dd(scope), _dd(signals), _dd(settings)

    def _get_concept_context(self, atomic_concept: str) -> Optional[ConceptContext]:
        """O(1) lookup via cached index."""
        if self._concept_index is None:
            return None
        return self._concept_index.get(atomic_concept.strip().lower())

    def _primary_record_types_from_concepts(self, concepts: List[str]) -> List[str]:
        """Most likely chart locations for a set of concepts, as a ranked list.

        Each concept's record_types arrive pre-sorted descending by relevance
        (enforced by the context prompt's ORDERING REQUIREMENT). We take each
        concept's top-1 ("definitive source"), then return all distinct values
        ordered by how many concepts placed them at top-1 — descending. Ties
        broken by first-seen order across the input list.

        Returns an empty list when no concept in the input has any record_types
        (e.g. context build failed)."""
        if not self._concept_index:
            return []

        top_choices: List[str] = []
        for c in concepts or []:
            cc = self._get_concept_context(c.strip())
            if cc and cc.record_types:
                top_choices.append(cc.record_types[0])

        if not top_choices:
            return []

        counts = Counter(top_choices)
        # Stable sort: primary key = count desc, secondary key = first-seen
        # index asc. Counter is insertion-ordered, so its keys() preserves
        # first-seen order for tie-breaking.
        first_seen = {rt: idx for idx, rt in enumerate(counts.keys())}
        return sorted(counts.keys(), key=lambda rt: (-counts[rt], first_seen[rt]))

    def _temporal_for_candidate(self, intent_title: str, candidate: str) -> List[str]:
        """Per-candidate temporal signal from Task 2.

        Primary: return the candidate's own emitted signal.
        Fallback: if the LLM left this candidate's signal blank but emitted
        a temporal signal for OTHER candidates under the same intent, the
        query clearly has a temporal cue and the prompt's CASCADE RULE
        should have propagated it. The LLM occasionally fails to cascade
        for temporal-worded candidates ("date of X", "timestamp", etc.);
        we catch that here by inheriting the intent-level union."""
        if not self.temporal or not self.temporal.intents:
            return []
        ikey = intent_title.strip().lower()
        ckey = candidate.strip().lower()
        for it in self.temporal.intents:
            if it.intent_title.strip().lower() != ikey:
                continue
            own: List[str] = []
            intent_union: List[str] = []
            seen: set = set()
            for co in it.candidates or []:
                sig = list(co.temporal_signal or [])
                if co.candidate.strip().lower() == ckey:
                    own = sig
                for s in sig:
                    k = s.strip().lower()
                    if k and k not in seen:
                        intent_union.append(s)
                        seen.add(k)
            # If this candidate got an explicit signal, use it.
            # If it's blank but its siblings under the same intent have
            # cues, inherit the intent-level union (cascade safety net).
            return own if own else intent_union
        return []

    def _build_ctx(self, concept_name: str) -> RetrievalContext:
        cc = self._get_concept_context(concept_name)
        if cc is None:
            return RetrievalContext()
        records, authors, scope, signals, settings = self._aggregate_facets([cc])
        return RetrievalContext(
            record_types=records,
            author_roles=authors,
            longitudinal_scope=scope,
            content_signals=signals,
            clinical_setting=settings,
        )

    # format methods

    def to_intent_extraction(self) -> Dict[str, Any]:
        items = [
            IntentSummaryItem(intent_title=i.intent_title, description=i.description)
            for i in self.intents.intents
        ]
        result = Format_IntentExtraction(
            user_query=self.original_query,
            intents=items,
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
        )
        return result.model_dump()

    def to_final_queries(self) -> Dict[str, Any]:
        candidates: List[FinalCandidateItem] = []
        seen: set = set()
        idx = 0
        for i in self.intents.intents:
            for sn in i.sub_natures:
                for c in sn.atomic_concepts:
                    key = c.strip().lower()
                    if not key or key in seen:
                        continue
                    seen.add(key)
                    idx += 1
                    rich_ctx = self._build_ctx(c.strip())
                    signals = FlatRetrievalSignals.from_retrieval_context(rich_ctx)
                    signals.temporal_signal = self._temporal_for_candidate(
                        i.intent_title, c.strip()
                    )
                    candidates.append(
                        FinalCandidateItem(
                            candidate_id=f"fc_{idx:03d}",
                            intent_title=i.intent_title,
                            nature=i.nature,
                            sub_nature=sn.category_path,
                            candidate=c.strip(),
                            retrieval_signals=signals,
                        )
                    )
        result = Format_FinalQueries(
            user_query=self.original_query,
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
            total_candidates=len(candidates),
            final_candidates=candidates,
        )
        return result.model_dump()

    def to_nature_breakdown(self) -> Dict[str, Any]:
        intents_no_queries = [
            IntentWithoutQueries(
                intent_title=i.intent_title,
                description=i.description,
                nature=i.nature,
                sub_natures=i.sub_natures,
            )
            for i in self.intents.intents
        ]
        result = Format_NatureBreakdown(
            is_clinical=self.intents.is_clinical,
            reason=self.intents.reason,
            original_query=self.intents.original_query,
            total_intents_detected=self.intents.total_intents_detected,
            intents=intents_no_queries,
        )
        return result.model_dump()

    @staticmethod
    def _merge_signals(candidates: List[FinalCandidateItem]) -> FlatRetrievalSignals:
        """Merge candidate-level signals into an intent-level view.
        Every facet (including temporal_signal) is the dedup'd union of
        its candidates' values."""
        def _union(getter) -> List[str]:
            seen_vals: dict = {}
            for fc in candidates:
                for val in getter(fc.retrieval_signals):
                    val = val.strip() if isinstance(val, str) else val
                    if val and val.lower() not in seen_vals:
                        seen_vals[val.lower()] = val
            return list(seen_vals.values())

        return FlatRetrievalSignals(
            record_types=_union(lambda s: s.record_types),
            author_roles=_union(lambda s: s.author_roles),
            longitudinal_scope=_union(lambda s: s.longitudinal_scope),
            temporal_signal=_union(lambda s: s.temporal_signal),
            content_signals=_union(lambda s: s.content_signals),
            clinical_setting=_union(lambda s: s.clinical_setting),
        )

    def to_full_pipeline(self) -> Dict[str, Any]:
        # Shared seen-set and counter so candidate_ids are identical to
        # those produced by to_final_queries() on the same ExtractionResult.
        seen: set = set()
        idx = 0

        def _make_candidates(intent: Intent) -> List[FinalCandidateItem]:
            nonlocal idx
            items = []
            for sn in intent.sub_natures:
                for c in sn.atomic_concepts:
                    key = c.strip().lower()
                    if not key or key in seen:
                        continue
                    seen.add(key)
                    idx += 1
                    rich_ctx = self._build_ctx(c.strip())
                    signals = FlatRetrievalSignals.from_retrieval_context(rich_ctx)
                    signals.temporal_signal = self._temporal_for_candidate(
                        intent.intent_title, c.strip()
                    )
                    items.append(
                        FinalCandidateItem(
                            candidate_id=f"fc_{idx:03d}",
                            intent_title=intent.intent_title,
                            nature=intent.nature,
                            sub_nature=sn.category_path,
                            candidate=c.strip(),
                            retrieval_signals=signals,
                        )
                    )
            return items

        intent_blocks = []
        for i in self.intents.intents:
            candidates = _make_candidates(i)
            # Intent-level signals = union of its own candidates' signals
            # (including temporal_signal — deduped across candidates).
            intent_signals = self._merge_signals(candidates)
            intent_blocks.append(
                IntentWithContext(
                    intent_title=i.intent_title,
                    description=i.description,
                    nature=i.nature,
                    sub_natures=i.sub_natures,
                    final_candidates=candidates,
                    retrieval_signals=intent_signals,
                )
            )

        result = Format_FullPipeline(
            is_clinical=self.intents.is_clinical,
            reason=self.intents.reason,
            original_query=self.original_query,
            expanded_query=self.expansion.expanded_query,
            total_intents_detected=self.intents.total_intents_detected,
            intents=intent_blocks,
        )
        return result.model_dump()

    def to_representative_terms(self) -> Dict[str, Any]:
        """Standalone chart-search routing view, aggregated across the whole query.

        Representative terms are derived structurally from each sub_nature's
        category_path — specifically the rightmost segment, which is the most
        specific concept the LLM committed to in the hierarchy. No separate
        LLM extraction step, no per-intent cap heuristic; the bound is the
        number of distinct sub_nature leaves in the query.

        - representative_terms: leaf segment of every sub_nature's
          category_path, deduped case-insensitively in first-seen order
          across the query. Lowercased on output. Empty list when the query
          has no sub_natures (non-clinical or extraction failure).
        - primary_record_types: top-1 record_type from EVERY distinct atomic
          concept in the query, ranked by frequency descending (ties broken
          by first-seen order).

        Both lists may be empty independently; both are empty for non-clinical
        queries."""
        rep_terms: List[str] = []
        seen_terms: set = set()
        # Walk atomic concepts in the same pass (deduped early so a concept
        # named in two intents doesn't double-weight the record_type ranking).
        all_concepts: List[str] = []
        seen_concepts: set = set()

        for i in self.intents.intents:
            for sn in i.sub_natures:
                # Leaf = rightmost ">>"-separated segment of the category_path.
                # The path is normalized to " >> " by SubNature's validator,
                # so a simple split is reliable. Skip empty/malformed paths.
                segments = [
                    s.strip()
                    for s in (sn.category_path or "").split(">>")
                    if s.strip()
                ]
                if segments:
                    leaf = segments[-1].lower()
                    if leaf and leaf not in seen_terms:
                        rep_terms.append(leaf)
                        seen_terms.add(leaf)

                for c in sn.atomic_concepts or []:
                    ck = c.strip().lower()
                    if ck and ck not in seen_concepts:
                        all_concepts.append(c.strip())
                        seen_concepts.add(ck)

        result = Format_RepresentativeTerms(
            user_query=self.original_query,
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
            representative_terms=rep_terms,
            primary_record_types=self._primary_record_types_from_concepts(all_concepts),
        )
        return result.model_dump()



# PIPELINE CLASS

class ContextualIntentPipeline:

    def __init__(
        self,
        project: str,
        location: str = "us-central1",
        model: str = "gemini-2.5-flash",
    ):
        self.project = project
        self.location = location
        self.model_name = model
        # Each thread gets its own genai.Client — the SDK's Client isn't
        # guaranteed thread-safe, so sharing under ThreadPoolExecutor
        # caused intermittent degraded responses.
        self._tls = threading.local()

    @property
    def client(self) -> "genai.Client":
        c = getattr(self._tls, "client", None)
        if c is None:
            c = genai.Client(
                vertexai=True, project=self.project, location=self.location
            )
            self._tls.client = c
        return c

    # low-level helpers

    def _extract_json(self, response) -> Any:
        """Parse JSON from a model response. Relies on response_mime_type=
        'application/json' to produce valid JSON; raises json.JSONDecodeError
        on malformed output. No regex fallback — a partial match is worse
        than a clear failure for a clinical system."""
        if hasattr(response, "text"):
            text = response.text
        elif hasattr(response, "candidates") and response.candidates:
            text = response.candidates[0].content.parts[0].text
        else:
            text = str(response)
        # Strip code fences defensively; the API contract says no markdown,
        # but some model versions have historically added them intermittently.
        text = re.sub(r"^```(?:json)?\s*", "", text.strip())
        text = re.sub(r"\s*```$", "", text)
        return json.loads(text)

    def _call_model(
        self,
        prompt: str,
        schema: type,
        fallback=None,
        max_tokens: int = 8192,
    ):
        """Call the LLM with structured output. Retry once on error.
        If still failing, return `fallback` (if provided) or re-raise."""
        for attempt in range(2):
            try:
                config = types.GenerateContentConfig(
                    temperature=0.0,
                    top_p=0.2,
                    seed=23,
                    max_output_tokens=max_tokens,
                    response_mime_type="application/json",
                    response_schema=schema,
                )
                response = self.client.models.generate_content(
                    model=self.model_name, contents=prompt, config=config
                )
                data = self._extract_json(response)
                if isinstance(data, list):
                    fields = schema.model_fields
                    list_field = next(
                        (k for k, v in fields.items() if "List" in str(v.annotation)),
                        None,
                    )
                    data = {list_field: data} if list_field else data
                return schema.model_validate(data)
            except Exception:
                if attempt == 0:
                    continue
                if fallback is not None:
                    return fallback
                raise

    # -- pipeline steps --

    def expand_query(self, query: str) -> QueryExpansionOutput:
        """Step 1 — normalize the query (abbreviations + explicit temporals)."""
        return self._call_model(
            QUERY_EXPANSION_PROMPT.format(query=query),
            QueryExpansionOutput,
            fallback=QueryExpansionOutput(expanded_query=query),
            max_tokens=2048,
        )

    def extract_intents(
        self, original_query: str, expanded_query: str,
    ) -> IntentExtractionOutput:
        """Step 2 — extract clinical intents with sub-natures."""
        prompt = INTENT_EXTRACTION_PROMPT.format(
            expanded_query=expanded_query,
            timestamp=datetime.utcnow().isoformat(),
        )
        raw: IntentExtractionResponse = self._call_model(
            prompt,
            IntentExtractionResponse,
            fallback=IntentExtractionResponse(
                is_clinical=False, reason="LLM call failed"
            ),
            max_tokens=16384,
        )
        return IntentExtractionOutput(
            is_clinical=raw.is_clinical,
            reason=raw.reason,
            original_query=original_query,
            expanded_query=expanded_query,
            total_intents_detected=len(raw.intents),
            intents=raw.intents,
        )

    def build_context(
        self,
        query: str,
        expanded_query: str,
        intent_out: IntentExtractionOutput,
    ) -> Optional[ContextualEnvironmentOutput]:
        """Step 3 — map each atomic concept's documentation facets AND
        produce temporal signals per intent / candidate in one LLM call."""
        if not intent_out.is_clinical or not intent_out.intents:
            return None

        # Flat list of unique concepts (Task 1 target list)
        concepts: List[Dict[str, str]] = []
        seen: set = set()
        for i in intent_out.intents:
            for sn in i.sub_natures:
                for c in sn.atomic_concepts:
                    k = c.strip().lower()
                    if k and k not in seen:
                        concepts.append(
                            {"atomic_concept": c.strip(), "intent_title": i.intent_title}
                        )
                        seen.add(k)
        if not concepts:
            return None

        # Rich per-intent structure (for Task 2 temporal reasoning)
        intents_payload: List[Dict[str, Any]] = []
        for i in intent_out.intents:
            cand_entries: List[str] = []
            seen_c: set = set()
            for sn in i.sub_natures:
                for c in sn.atomic_concepts:
                    k = c.strip().lower()
                    if k and k not in seen_c:
                        cand_entries.append(c.strip())
                        seen_c.add(k)
            intents_payload.append({
                "intent_title": i.intent_title,
                "description": i.description,
                "nature": i.nature,
                "sub_natures": [
                    {"category_path": sn.category_path,
                     "atomic_concepts": list(sn.atomic_concepts or [])}
                    for sn in i.sub_natures
                ],
                "candidates": cand_entries,
            })

        return self._call_model(
            CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                original_query=query,
                expanded_query=expanded_query,
                concepts_json=json.dumps(concepts, indent=2),
                concept_count=len(concepts),
                intents_json=json.dumps(intents_payload, indent=2),
            ),
            ContextualEnvironmentOutput,
            fallback=ContextualEnvironmentOutput(),
            max_tokens=32768,
        )

    # -- main entry points --

    def extract(self, query: str) -> ExtractionResult:
        if not query or not query.strip():
            raise ValueError("Empty query provided")

        t0 = datetime.utcnow()

        # Step 1 — query normalization
        t1 = datetime.utcnow()
        expansion = self.expand_query(query)
        t1e = (datetime.utcnow() - t1).total_seconds()

        # Step 2 — intent extraction
        t2 = datetime.utcnow()
        intent_out = self.extract_intents(query, expansion.expanded_query)
        t2e = (datetime.utcnow() - t2).total_seconds()

        # Step 3 — contextual environment (context + temporal in one LLM call)
        t3 = datetime.utcnow()
        context = self.build_context(query, expansion.expanded_query, intent_out)
        t3e = (datetime.utcnow() - t3).total_seconds()

        temporal: Optional[TemporalExtractionOutput] = None
        if context is not None:
            temporal = TemporalExtractionOutput(
                intents=list(context.temporal_by_intent or [])
            )

        processing_time = (datetime.utcnow() - t0).total_seconds()

        candidate_count = sum(
            len(sn.atomic_concepts)
            for i in intent_out.intents
            for sn in i.sub_natures
        )
        sub_nature_count = sum(len(i.sub_natures) for i in intent_out.intents)
        print(f"Query     : {query[:80]}")
        print(f"Expanded  : {expansion.expanded_query[:80]}")
        if intent_out.is_clinical:
            print("Status    : Clinical")
            print(
                f"Intents: {intent_out.total_intents_detected} | "
                f"sub natures: {sub_nature_count} | "
                f"candidates: {candidate_count}"
            )
            print(
                f"Timing    : expand={t1e:.1f}s  "
                f"intents={t2e:.1f}s  "
                f"context={t3e:.1f}s  "
                f"total={processing_time:.1f}s"
            )
        else:
            print(f"Status    : Non-clinical — {intent_out.reason}")
        print()

        return ExtractionResult(
            query, expansion, intent_out, context, temporal, processing_time,
        )

    def run(
        self,
        query: str,
        output_format: Literal[
            "intent_extraction",
            "final_queries",
            "nature_breakdown",
            "full_pipeline",
            "representative_terms",
        ] = "full_pipeline",
    ) -> Dict[str, Any]:
        try:
            result = self.extract(query)
            dispatch = {
                "intent_extraction": result.to_intent_extraction,
                "final_queries": result.to_final_queries,
                "nature_breakdown": result.to_nature_breakdown,
                "full_pipeline": result.to_full_pipeline,
                "representative_terms": result.to_representative_terms,
            }
            return dispatch[output_format]()
        except Exception as e:
            return {
                "error": str(e),
                "query": query,
                "timestamp": datetime.utcnow().isoformat(),
            }




def save_json(data: Dict, filename: str) -> None:
    with open(filename, "w") as f:
        json.dump(data, f, indent=2)
    print(f"Saved: {filename}")


@dataclass
class OutputConfig:
    intent_extraction: bool = True
    final_queries: bool = True
    nature_breakdown: bool = True
    full_pipeline: bool = True
    representative_terms: bool = True

    def enabled(self) -> List[str]:
        """Return list of format names that are turned on."""
        return [
            name
            for name in (
                "intent_extraction",
                "final_queries",
                "nature_breakdown",
                "full_pipeline",
                "representative_terms",
            )
            if getattr(self, name)
        ]


def run_single_query(
    pipeline: ContextualIntentPipeline,
    query: str,
    idx: int,
    config: Optional[OutputConfig] = None,
) -> Dict[str, Any]:
    if config is None:
        config = OutputConfig()

    enabled = config.enabled()
    if not enabled:
        return {"query": query, "status": "skipped", "files": []}

    try:
        result = pipeline.extract(query)
    except Exception as e:
        print(f"Failed: {type(e).__name__}:{e}")
        return {"query": query, "status": "failed", "error": str(e), "files": []}

    format_dispatch = {
        "intent_extraction": result.to_intent_extraction,
        "final_queries": result.to_final_queries,
        "nature_breakdown": result.to_nature_breakdown,
        "full_pipeline": result.to_full_pipeline,
        "representative_terms": result.to_representative_terms,
    }

    prefix = f"query{idx}"
    files: List[str] = []

    for name in enabled:
        data = format_dispatch[name]()
        filename = f"{prefix}_{name}.json"
        save_json(data, filename)
        files.append(filename)

    print("-" * 60)
    return {"query": query, "status": "completed", "files": files}



