results = []
    test_queries = questions[:86]

    def minimal_pipeline(q):
        # STEP 1: expansion
        expansion = pipeline.expand_query(q)

        # STEP 2: intent extraction
        intent_out = pipeline.extract_intents(q, expansion.expanded_query)

        terms = []

        if intent_out and intent_out.intents:
            for intent in intent_out.intents:
                
                terms.extend(intent.representative_terms or [])

        # clean + dedupe
        terms = list({t.strip() for t in terms if t and t.strip()})

        return {
            "question": q,
            "representative_terms": terms
        }

    with ThreadPoolExecutor(max_workers=10) as executor:
        futures = [executor.submit(minimal_pipeline, q) for q in test_queries]

        for f in as_completed(futures):
            results.append(f.result())

    with open("rep_term.json", "w") as f:
        json.dump(results, f, indent=2)

    print("rep_terms.json")
