if __name__ == "__main__":
    start = time.time()

    client = bigquery.Client(project=PROJECT)

    concepts = query_concepts(client)
    parents  = query_parents(client)

    tree        = build_tree(concepts, parents)
    desc_counts = build_desc_counts(tree)
    sr_map      = build_sr_map(tree, desc_counts)

    lookup = build_lookup(tree, desc_counts, sr_map)

    save_pickle(lookup, OUTPUT)

    print(f"\nTotal time: {(time.time()-start)/60:.1f} min")
