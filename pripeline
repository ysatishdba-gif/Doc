# CLUSTER TABLE
# =========================================================

def create_cluster_table(client):

    query = f"""

    CREATE OR REPLACE TABLE `{CLUSTER_TABLE}` AS

    WITH semantic_map AS (
        SELECT DISTINCT
            cui,
            semantic_type
        FROM `{SEMANTIC_TABLE}`
    ),

    base_relations AS (
        SELECT
            r.origin_cui,
            r.target_cui,
            r.relation,

            s1.semantic_type AS origin_semantic_type,
            s2.semantic_type AS target_semantic_type

        FROM `{RELATION_TABLE}` r

        LEFT JOIN semantic_map s1
            ON r.origin_cui = s1.cui

        LEFT JOIN semantic_map s2
            ON r.target_cui = s2.cui
    ),

    super_clusters AS (

        SELECT DISTINCT

            CONCAT(
                'SUPER_',
                TO_HEX(MD5(origin_semantic_type))
            ) AS cluster_id,

            CONCAT(
                'SemanticType_',
                origin_semantic_type
            ) AS cluster_name,

            'SUPER_SET' AS cluster_type,

            origin_semantic_type AS semantic_type,

            CAST(NULL AS STRING) AS relation,

            CAST(NULL AS STRING) AS parent_cluster_id,

            CURRENT_TIMESTAMP() AS created_at

        FROM base_relations
        WHERE origin_semantic_type IS NOT NULL
    ),

    relation_clusters AS (

        SELECT DISTINCT

            CONCAT(
                'REL_',
                TO_HEX(MD5(
                    CONCAT(
                        origin_semantic_type,
                        '|',
                        relation
                    )
                ))
            ) AS cluster_id,

            CONCAT(
                origin_semantic_type,
                '_',
                relation
            ) AS cluster_name,

            'RELATION_CLUSTER' AS cluster_type,

            origin_semantic_type AS semantic_type,

            relation,

            CONCAT(
                'SUPER_',
                TO_HEX(MD5(origin_semantic_type))
            ) AS parent_cluster_id,

            CURRENT_TIMESTAMP() AS created_at

        FROM base_relations

        WHERE origin_semantic_type = target_semantic_type
    ),

    cross_clusters AS (

        SELECT DISTINCT

            CONCAT(
                'CROSS_',
                TO_HEX(MD5(
                    CONCAT(
                        origin_semantic_type,
                        '|',
                        target_semantic_type,
                        '|',
                        relation
                    )
                ))
            ) AS cluster_id,

            CONCAT(
                origin_semantic_type,
                '_TO_',
                target_semantic_type,
                '_',
                relation
            ) AS cluster_name,

            'CROSS_SEMANTIC_CLUSTER' AS cluster_type,

            origin_semantic_type AS semantic_type,

            relation,

            CONCAT(
                'SUPER_',
                TO_HEX(MD5(origin_semantic_type))
            ) AS parent_cluster_id,

            CURRENT_TIMESTAMP() AS created_at

        FROM base_relations

        WHERE origin_semantic_type != target_semantic_type
    )

    SELECT * FROM super_clusters

    UNION ALL

    SELECT * FROM relation_clusters

    UNION ALL

    SELECT * FROM cross_clusters

    """

    run_query(client, query, "Creating SCENARIO_4_CLUSTER")

