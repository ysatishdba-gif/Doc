def extract_atomic_concepts_from_intent(intent: Dict[str, Any]) -> List[str]:
    """
    Flattens all atomic_concepts from an intent's sub_natures into a 
    deduplicated list. This is the primary input signal for contextual
    environment generation.
    
    Args:
        intent: A single intent dict with sub_natures containing atomic_concepts.
    
    Returns:
        Deduplicated list of atomic concept strings.
    """
    concepts = []
    seen = set()
    
    for sub_nature in intent.get("sub_natures", []):
        for concept in sub_nature.get("atomic_concepts", []):
            normalized = concept.strip().lower()
            if normalized and normalized not in seen:
                concepts.append(concept.strip())
                seen.add(normalized)
    
    return concepts


def prepare_intents_input(intents: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    """
    Transforms intents into focused input for the contextual environment prompt.
    Extracts only intent_title, nature, and flattened atomic_concepts — 
    eliminates noise from descriptions, category_paths, and final_queries.
    
    Args:
        intents: List of intent dicts from extraction step.
    
    Returns:
        List of focused intent dicts for the prompt.
    """
    focused = []
    for intent in intents:
        atomic_concepts = extract_atomic_concepts_from_intent(intent)
        focused.append({
            "intent_title": intent.get("intent_title", ""),
            "nature": intent.get("nature", ""),
            "atomic_concepts": atomic_concepts
        })
    return focused


def _validate_contextual_output(
    data: Dict[str, Any], 
    original_intents: List[Dict[str, Any]],
    verbose: bool = False
) -> Dict[str, Any]:
    """
    Validates and repairs LLM contextual environment output.
    
    Handles:
    - All required annotated facets present per intent
    - Each facet item has both 'value' and 'description'
    - Bare strings wrapped into {value, description}
    - Missing descriptions get placeholders
    - Un-annotated keys matched via prefix (fuzzy key matching)
    - Intent title mismatch warnings
    """
    validated_intents = []
    input_titles = {i.get("intent_title", "") for i in original_intents}
    
    for item in data.get("intents_with_context", []):
        title = item.get("intent_title", "")
        
        if title not in input_titles and verbose:
            print(f"  [Validation] Warning: '{title}' not found in input intents")
        
        context = item.get("context", {})
        validated_context = {}
        
        for facet_key in REQUIRED_FACETS:
            # Exact match first, then prefix match for fuzzy recovery
            facet_items = context.get(facet_key, None)
            
            if facet_items is None:
                prefix = facet_key.split("(")[0]
                for ctx_key in context:
                    if ctx_key.startswith(prefix):
                        facet_items = context[ctx_key]
                        if verbose:
                            print(f"  [Validation] Fuzzy key match: '{ctx_key}' → '{facet_key}'")
                        break
            
            if facet_items is None:
                facet_items = []
                if verbose:
                    print(f"  [Validation] Warning: No data for '{facet_key}' in '{title}'")
            
            validated_items = []
            for fi in facet_items:
                if isinstance(fi, dict):
                    value = fi.get("value", "")
                    description = fi.get("description", "")
                    if not value:
                        continue
                    if not description:
                        description = f"[No description provided for {value}]"
                        if verbose:
                            print(f"  [Validation] Missing description for {facet_key}.{value}")
                    validated_items.append({"value": value, "description": description})
                elif isinstance(fi, str):
                    validated_items.append({
                        "value": fi,
                        "description": f"[Auto-wrapped: no description provided for {fi}]"
                    })
                    if verbose:
                        print(f"  [Validation] Bare string in {facet_key}: '{fi}' — wrapped")
            
            validated_context[facet_key] = validated_items
        
        validated_intents.append({
            "intent_title": title,
            "context": validated_context
        })
    
    return {"intents_with_context": validated_intents}


def merge_context_into_intents(
    intents: List[Dict[str, Any]], 
    context_result: Dict[str, Any]
) -> List[Dict[str, Any]]:
    """
    Merges contextual environment data back into the intent structure.
    Produces final output format compatible with downstream consumers.
    """
    context_map = {}
    for ic in context_result.get("intents_with_context", []):
        context_map[ic["intent_title"]] = ic.get("context", {})
    
    merged = []
    for intent in intents:
        merged_intent = {
            "intent_title": intent.get("intent_title", ""),
            "description": intent.get("description", ""),
            "nature": intent.get("nature", ""),
            "sub_natures": intent.get("sub_natures", []),
            "final_queries": intent.get("final_queries", [])
        }
        
        title = intent.get("intent_title", "")
        if title in context_map:
            merged_intent["contextual_environment"] = context_map[title]
        
        merged.append(merged_intent)
    
    return merged


