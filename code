# --- ADDED BACK IN: Upload the topics table ---
pgbq.to_gbq(df_topics, destination_table='iceland.edu_mcasom_prj_iceland_topics_newprompt', project_id=PROJECT_ID, if_exists='replace')
print("Uploaded topics table.")
# --------------------------------------------

pgbq.to_gbq(df_themes, destination_table='iceland.edu_mcasom_prj_iceland_themes_newprompt', project_id=PROJECT_ID, if_exists='replace')
print("Uploaded dominant themes table.")
pgbq.to_gbq(df_insights, destination_table='iceland.edu_mcasom_prj_iceland_strategic_insights_newprompt', project_id=PROJECT_ID, if_exists='replace')
print("Uploaded strategic insights table.")
    
print("\nProcess finished successfully! (LCME Analysis Complete)")



