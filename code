# Initialize LLM - PIN THE MODEL VERSION
model = GenerativeModel(MODEL_VERSION)


# ============================================================================
# STEP 1: Row-Level Tagger (IMPROVED)
# ============================================================================
async def perform_row_level_analysis(response_text: str) -> dict:
    """
    Analyze a single student comment and return structured JSON.
    Now includes row_id tracking and forced JSON output.
    """

    prompt = f"""
**Persona:** You are a data annotation expert for a medical school, familiar with LCME accreditation standards from the provided reference document.

**Task:** Analyze the single student comment below. Extract the specified attributes into a valid JSON object.

**CRITICAL — Sentiment Classification Rules:**
You MUST classify sentiment based on the EVALUATIVE LANGUAGE in the comment, not the topic.

- **"Positive"**: The comment contains praise, approval, satisfaction, or appreciation.
  Examples: "Dr. X was excellent", "The sessions were very helpful", "Great teaching", "well organized"
- **"Negative"**: The comment contains criticism, dissatisfaction, complaint, or frustration.
  Examples: "The lectures were confusing", "Not enough time for questions", "Poor organization"
- **"Neutral"**: The comment is purely factual or descriptive with NO evaluative words whatsoever.
  Examples: "We had 3 lectures per week", "The course covered anatomy", "Class was held in Room 204"

KEY RULE: If ANY evaluative word is present (excellent, great, good, well done, helpful, poor, bad, confusing, etc.), the sentiment is NOT Neutral. Words like "excellent" and "very well done" are ALWAYS Positive.

**JSON Schema:**
- `sentiment_label`: (String) Exactly one of: "Positive", "Negative", or "Neutral".
- `sentiment_score`: (Float) -1.0 (most negative) to 1.0 (most positive). Must align with sentiment_label.
- `primary_theme`: (String) A brief, 2-5 word summary of the main point.
- `potential_lcme_standard`: (String or null) The single most relevant LCME standard number, or null.
- `topics`: (List of Strings) Specific, granular subjects mentioned (e.g., ["Lecture Quality", "Small Group Facilitation"]).

**Analyze this single student comment:**
"{response_text}"
"""

    generation_config = GenerationConfig(
        temperature=0.0,
        top_p=1.0,
        seed=34,
        response_mime_type="application/json",  # <-- FORCES valid JSON output
    )

    max_retries = 2
    for attempt in range(max_retries + 1):
        try:
            response = await model.generate_content_async(
                contents=[prompt, grounding_document_part],
                generation_config=generation_config,
            )
            result = json.loads(response.text)
            return result
        except Exception as e:
            if attempt < max_retries:
                await asyncio.sleep(1)  # Brief pause before retry
                continue
            return {"error": str(e), "original_text": response_text}


# ============================================================================
# STEP 2: Group-Level Synthesizer (IMPROVED)
# ============================================================================
async def generate_strategic_insights(group_df: pd.DataFrame) -> dict:
    """Generate strategic LCME insights for a group of comments."""
    if len(group_df) < 3:
        return None

    lcme_counts = group_df['potential_lcme_standard'].value_counts().to_string()
    sentiment_dist = group_df['sentiment_label'].value_counts(normalize=True).apply('{:.0%}'.format).to_string()
    sample_comments = "\n".join("- " + r for r in group_df['Response'].head(10).tolist())

    prompt = f"""
**Persona:**
You are an expert in analyzing qualitative text data, identifying key themes and topics, and deriving actionable insights. You have a deep understanding of medical education and are well-versed in the Liaison Committee on Medical Education (LCME) accreditation standards, which are provided as a reference document.

**Context:**
You are analyzing student feedback to support LCME accreditation preparation and continuous quality improvement. Your analysis must be framed through the lens of LCME compliance. The key standards of focus are: 3, 6, 7, 8, 10, 11, and 12.

**Input Data Provided:**
1.  **Statistical Summary:**
    - Overall Sentiment Distribution:
{textwrap.indent(sentiment_dist, '      ')}
    - Preliminary LCME Standard Mentions:
{textwrap.indent(lcme_counts, '      ')}
2.  **Sample of Raw Student Comments for Deeper Context:**
{textwrap.indent(sample_comments, '    ')}
3.  **Reference Document:** The full LCME Accreditation Standards handbook is provided for grounding.

**Task:**
Based on all the provided input data, perform a comprehensive analysis and return a single, valid JSON object with the following structure.

**JSON Output Schema:**
{{
  "dominant_themes": [
    {{
      "theme_title": "A short, concise title for a dominant recurring theme.",
      "theme_summary": "A 2-3 sentence summary explaining the theme in detail.",
      "overall_sentiment": "Positive, Negative, or Neutral",
      "mapped_lcme_standard": "The most relevant LCME standard and element (e.g., 'Standard 6.1 – Program Objectives'). Use the provided handbook to be specific.",
      "supporting_evidence_summary": "A brief summary of the patterns in student comments that support this theme."
    }}
  ],
  "strategic_insights": [
    "A concise, actionable insight for the curriculum committee based on the analysis.",
    "Another actionable insight."
  ]
}}

**Instructions:**
- Focus on recurring themes; do not include one-off outliers.
- Ensure the `mapped_lcme_standard` is specific and directly justified by the theme and the provided handbook.
- Insights must be evidence-based and suggest potential improvements or highlight areas of success relevant to accreditation.
"""

    generation_config = GenerationConfig(
        temperature=0.0,
        top_p=1.0,
        seed=34,
        response_mime_type="application/json",  # <-- FORCES valid JSON output
    )

    max_retries = 2
    for attempt in range(max_retries + 1):
        try:
            response = await model.generate_content_async(
                contents=[prompt, grounding_document_part],
                generation_config=generation_config,
            )
            result = json.loads(response.text)
            return result
        except Exception as e:
            if attempt < max_retries:
                await asyncio.sleep(1)
                continue
            return {"error": str(e)}


# ============================================================================
# MAIN SCRIPT EXECUTION
# ============================================================================
query_job = client.query(query)
df = query_job.to_dataframe()
df = df.reset_index().rename(columns={'index': 'Response_ID'})
print(f"Successfully loaded {len(df)} unique responses.")

# ---- STEP 1: Row-Level Tagging ----
print("\n--- Step 1: Performing Row-Level Tagging (LCME Triage) in Parallel ---")

# ==========================================================================
# CRITICAL FIX: Use asyncio.gather instead of as_completed
# asyncio.gather PRESERVES ORDER — result[i] corresponds to task[i]
# as_completed does NOT preserve order — this was causing row mismatches!
# ==========================================================================

BATCH_SIZE = 50  # Process in batches to avoid rate limits

analysis_results_list = []
for batch_start in range(0, len(df), BATCH_SIZE):
    batch_end = min(batch_start + BATCH_SIZE, len(df))
    batch_tasks = [
        perform_row_level_analysis(row['Response'])
        for _, row in df.iloc[batch_start:batch_end].iterrows()
    ]
    # gather() returns results in THE SAME ORDER as input tasks
    batch_results = await asyncio.gather(*batch_tasks)
    analysis_results_list.extend(batch_results)
    print(f"  Completed {batch_end}/{len(df)} rows...")

# Build master table — safe because asyncio.gather preserves order
master_data_list = []
topics_data_list = []
for i, result in enumerate(analysis_results_list):
    if result and "error" not in result:
        row = df.iloc[i]
        master_row = row.to_dict()
        master_row.update(result)
        master_data_list.append(master_row)

        topics = result.get('topics', [])
        if topics:
            for topic in topics:
                topics_data_list.append({'Response_ID': row['Response_ID'], 'Topic': topic})

df_master = pd.DataFrame(master_data_list)
df_topics = pd.DataFrame(topics_data_list)
if 'topics' in df_master.columns:
    df_master = df_master.drop(columns=['topics'])
print(f"\nRow-level tagging complete. Master table created with {len(df_master)} rows.")
print(f"Extracted {len(df_topics)} individual topic tags.")

# ---- STEP 2: Group-Level Synthesis ----
print("\n--- Step 2: Synthesizing Strategic LCME Insights in Parallel ---")
synthesis_tasks = []
group_identifiers = []
if not df_master.empty:
    grouping_cols = ['Academic Year', 'Course Id', 'Campus', 'Question Category']
    grouped = df_master.groupby(grouping_cols)
    for group_keys, group_df in grouped:
        synthesis_tasks.append(generate_strategic_insights(group_df))
        group_identifiers.append(dict(zip(grouping_cols, group_keys)))

    # Again use gather() to preserve order
    synthesis_results_list = await asyncio.gather(*synthesis_tasks)

themes_list = []
insights_list = []
for i, synthesis_json in enumerate(synthesis_results_list):
    if synthesis_json and "error" not in synthesis_json:
        group_identifier = group_identifiers[i]
        if 'dominant_themes' in synthesis_json:
            for theme in synthesis_json['dominant_themes']:
                themes_list.append({**group_identifier, **theme})
        if 'strategic_insights' in synthesis_json:
            for insight in synthesis_json['strategic_insights']:
                insights_list.append({**group_identifier, 'Insight': insight})

df_themes = pd.DataFrame(themes_list)
df_insights = pd.DataFrame(insights_list)
print(f"\nGenerated {len(df_themes)} dominant themes and {len(df_insights)} strategic insights.")

# ---- STEP 3: Upload Results to BigQuery ----
print("\n--- Step 3: Uploading Data to BigQuery ---")
pgbq.to_gbq(df_master, destination_table='iceland.edu_mcasom_prj_iceland_master_newprompt', project_id=PROJECT_ID, if_exists='replace')
print("Uploaded master tagged data table.")

pgbq.to_gbq(df_topics, destination_table='iceland.edu_mcasom_prj_iceland_topics_newprompt', project_id=PROJECT_ID, if_exists='replace')
print("Uploaded topics table.")

pgbq.to_gbq(df_themes, destination_table='iceland.edu_mcasom_prj_iceland_themes_newprompt', project_id=PROJECT_ID, if_exists='replace')
print("Uploaded dominant themes table.")

pgbq.to_gbq(df_insights, destination_table='iceland.edu_mcasom_prj_iceland_strategic_insights_newprompt', project_id=PROJECT_ID, if_exists='replace')
print("Uploaded strategic insights table.")

print("\nProcess finished successfully! (LCME Analysis Complete)")
