#                            PIPELINE CLASS
# ═════════════════════════════════════════════════════════════════════════════

class ContextualIntentPipeline:
    """
    Three-step pipeline: Query Expansion → Intent Extraction → Contextual Environment.
    
    Contextual environment uses atomic_concepts as input, produces annotated 
    facet keys with {value, description} pairs, no hardcoded vocabulary.
    """
    
    def __init__(self, project: str, location: str = "us-central1", 
                 model: str = "gemini-2.5-flash"):
        if not _GCP_AVAILABLE:
            raise ImportError(
                "google-cloud-aiplatform is required. "
                "Install with: pip install google-cloud-aiplatform"
            )
        aiplatform.init(project=project, location=location)
        self.model = GenerativeModel(model)
        self.project = project
        self.location = location
        self.model_name = model
    
    # ─────────────────────────────────────────────────────────────────────────
    # GENERATION CONFIGS — Per-Step
    # ─────────────────────────────────────────────────────────────────────────
    #
    # Each step has different output characteristics:
    #
    # ┌──────────────────┬───────────────┬───────────────┬────────────────────┐
    # │ Step             │ Output Size   │ Complexity    │ Risk               │
    # ├──────────────────┼───────────────┼───────────────┼────────────────────┤
    # │ 1. Expansion     │ ~200-500 tok  │ Low           │ Hallucinated terms │
    # │ 2. Intents       │ ~1000-6000    │ High          │ Token loops, miss  │
    # │ 3. Context Env   │ ~500-4000     │ Medium        │ Generic desc loops │
    # └──────────────────┴───────────────┴───────────────┴────────────────────┘
    #
    # Parameter reasoning:
    #
    # temperature:
    #   0.0 = pure greedy (single most likely token). Best for factual
    #         extraction where there's one correct answer.
    #   0.1 = near-deterministic with escape valve. Prevents degenerate
    #         token repetition loops in long outputs. Critical for Step 2
    #         and Step 3 where output can be 2000-6000 tokens.
    #   Rule: short output → 0.0, long structured output → 0.1
    #
    # top_p (nucleus sampling):
    #   0.95 = considers tokens covering 95% of probability mass.
    #          Filters out very unlikely tokens that cause JSON breaks.
    #   1.0  = no filtering. Fine when temperature is already 0.0.
    #   Rule: if temperature > 0, use top_p < 1.0 to guard output quality.
    #
    # Note: top_k is intentionally omitted. top_p is the superior filter
    # for structured output — it adapts to the actual probability distribution
    # rather than applying a fixed cutoff. Stacking both adds complexity
    # without benefit.
    #
    # max_output_tokens:
    #   Sized to the step's realistic output + 30% headroom.
    #   Undersizing causes truncated JSON (silent failures).
    #   Oversizing wastes quota/budget on unused allocation.
    #
    # seed:
    #   Fixed integer for reproducibility across runs. Same seed + same
    #   input + temperature=0 → identical output. At temperature>0, seed
    #   gives best-effort reproducibility (model-dependent).
    #
    # response_mime_type:
    #   "application/json" tells Gemini to constrain output to valid JSON.
    #   This is the single most impactful setting for structured output —
    #   eliminates markdown fences, preamble, and explanation text that 
    #   otherwise require regex cleanup. Available on Gemini 1.5+/2.x.
    #
    # ─────────────────────────────────────────────────────────────────────────
    
    # Step 1: Query Expansion
    # Short factual transformation. One correct answer per abbreviation.
    # Pure greedy is ideal — no creativity needed, output is small.
    EXPANSION_CONFIG = {
        "temperature": 0.0,         # Greedy: deterministic expansion
        "top_p": 1.0,               # No filtering needed at temp=0
        "max_output_tokens": 1024,  # Expansion output: ~200-500 tokens
        "seed": 42,                 # Reproducibility
        "response_mime_type": "application/json",
    }
    
    # Step 2: Intent Extraction
    # Complex multi-intent decomposition. Long structured output.
    # Slight temperature prevents repetition loops in long sequences.
    INTENT_CONFIG = {
        "temperature": 0.1,         # Near-greedy: prevents token loops in long output
        "top_p": 0.95,              # Filters unlikely tokens that break JSON structure
        "max_output_tokens": 8192,  # Multi-intent output can reach 4000-6000 tokens
        "seed": 42,                 # Best-effort reproducibility at temp > 0
        "response_mime_type": "application/json",
    }
    
    # Step 3: Contextual Environment
    # Medium complexity. Generates descriptions per facet value.
    # Slight temperature avoids repetitive description phrasing.
    CONTEXT_ENV_CONFIG = {
        "temperature": 0.1,         # Near-greedy: avoids repetitive descriptions
        "top_p": 0.95,              # Filters unlikely tokens
        "max_output_tokens": 4096,  # Context output: ~500-3000 tokens
        "seed": 42,                 # Best-effort reproducibility
        "response_mime_type": "application/json",
    }
    
    def _call_model(self, prompt: str, config: Dict[str, Any]) -> str:
        """
        Call Vertex AI model with step-specific generation config.
        
        Args:
            prompt: The formatted prompt string
            config: Generation config dict (use class-level step configs)
        
        Returns:
            Raw model response text, or "{}" on failure.
        """
        try:
            if hasattr(self.model, "session") and self.model.session is not None:
                self.model.session.reset()
            
            response = self.model.generate_content(
                prompt,
                generation_config=config
            )
            return response.text.strip()
        except Exception as e:
            print(f"Error calling model: {str(e)}")
            return "{}"
    
    # ─────────────────────────────────────────────────────────────────────────
    # STEP 1: Query Expansion
    # ─────────────────────────────────────────────────────────────────────────
    
    def expand_query(self, query: str) -> Dict[str, Any]:
        """Expand abbreviations and clarify clinical terms."""
        prompt = QUERY_EXPANSION_PROMPT.format(query=query)
        raw_response = self._call_model(prompt, self.EXPANSION_CONFIG)
        data = _safe_json(raw_response)
        
        if not _validate_json_structure(data, ["expanded_query"]):
            return {
                "expanded_query": query,
                "abbreviations_expanded": []
            }
        
        return {
            "expanded_query": data.get("expanded_query", query),
            "abbreviations_expanded": data.get("abbreviations_expanded", [])
        }
    
    # ─────────────────────────────────────────────────────────────────────────
    # STEP 2: Intent Extraction
    # ─────────────────────────────────────────────────────────────────────────
    
    def extract_intents(self, original_query: str, 
                       expanded_query: str) -> Dict[str, Any]:
        """Extract structured clinical intents with sub_natures and final_queries."""
        prompt = INTENT_EXTRACTION_PROMPT.format(
            original_query=original_query,
            expanded_query=expanded_query,
            timestamp=datetime.utcnow().isoformat()
        )
        
        raw_response = self._call_model(prompt, self.INTENT_CONFIG)
        data = _safe_json(raw_response)
        
        # Non-clinical rejection
        if not data.get("is_clinical", True):
            return {
                "intents": [],
                "total_intents_detected": 0,
                "is_clinical": False,
                "rejected_reason": data.get("reason", "Query is not clinical"),
                "original_query": original_query,
                "expanded_query": expanded_query
            }
        
        if not _validate_json_structure(data, ["intents"]):
            return {
                "intents": [],
                "total_intents_detected": 0,
                "error": "Failed to extract intents"
            }
        
        # Validate that all intents have final_queries
        intents = data.get("intents", [])
        validated_intents = []
        
        for idx, intent in enumerate(intents):
            if "final_queries" not in intent or not intent["final_queries"]:
                print(f"  Warning: Intent {idx + 1} "
                      f"'{intent.get('intent_title', 'Unknown')}' "
                      f"has no final_queries. Skipping.")
                continue
            validated_intents.append(intent)
        
        return {
            "intents": validated_intents,
            "total_intents_detected": data.get("total_intents_detected", 
                                               len(validated_intents)),
            "is_clinical": True,
            "original_query": data.get("original_query", original_query),
            "expanded_query": data.get("expanded_query", expanded_query)
        }
    
    # ─────────────────────────────────────────────────────────────────────────
    # STEP 3: Contextual Environment Generation
    # ─────────────────────────────────────────────────────────────────────────
    
    def generate_contextual_environment(
        self,
        original_query: str,
        expanded_query: str,
        intents: List[Dict[str, Any]],
        verbose: bool = False
    ) -> Dict[str, Any]:
        """
        Generate contextual environment metadata for each clinical intent.
        
        Uses atomic_concepts as primary input signal. Produces annotated
        facet keys with {value, description} pairs. No hardcoded vocabulary.
        
        Args:
            original_query: Raw user query
            expanded_query: Expanded clinical description
            intents: Intent dicts with sub_natures containing atomic_concepts
            verbose: Print debug info
        
        Returns:
            Dict with intents_with_context, each containing annotated context facets.
        """
        if not intents:
            if verbose:
                print("  [Contextual Env] No intents provided — skipping")
            return {"intents_with_context": []}
        
        # Extract focused input: atomic_concepts per intent
        focused_input = prepare_intents_input(intents)
        
        if verbose:
            for fi in focused_input:
                print(f"  [Contextual Env] Intent: {fi['intent_title']}")
                print(f"    Nature: {fi['nature']}")
                print(f"    Atomic Concepts ({len(fi['atomic_concepts'])}): "
                      f"{fi['atomic_concepts']}")
        
        intents_input_json = json.dumps(focused_input, indent=2)
        
        prompt = CONTEXTUAL_ENVIRONMENT_PROMPT.format(
            original_query=original_query,
            expanded_query=expanded_query,
            intents_input_json=intents_input_json
        )
        
        raw_response = self._call_model(prompt, self.CONTEXT_ENV_CONFIG)
        data = _safe_json(raw_response)
        
        if not data or "intents_with_context" not in data:
            print("  [Contextual Env] Warning: Failed to parse output")
            return {"intents_with_context": []}
        
        validated = _validate_contextual_output(data, intents, verbose)
        return validated
    
    # ─────────────────────────────────────────────────────────────────────────
    # PIPELINE EXECUTION
    # ─────────────────────────────────────────────────────────────────────────
    
    def run(self, query: str, verbose: bool = False) -> Dict[str, Any]:
        """
        Execute the full pipeline: Expand → Extract → Contextualize.
        
        Args:
            query: Raw user input
            verbose: Print step-by-step debug output
        
        Returns:
            Complete result with intents and contextual environments.
        """
        start_time = datetime.utcnow()
        
        if verbose:
            print(f"Original Query: {query}")
        
        # ── STEP 1: Query Expansion ──
        expansion_result = self.expand_query(query)
        expanded_query = expansion_result["expanded_query"]
        
        if verbose:
            print(f"Expanded Query: {expanded_query}")
        
        # ── STEP 2: Intent Extraction ──
        intent_result = self.extract_intents(query, expanded_query)
        
        # Handle non-clinical queries
        if not intent_result.get("is_clinical", True):
            processing_time = (datetime.utcnow() - start_time).total_seconds()
            
            if verbose:
                print(f"Status: NON-CLINICAL (rejected)")
                print(f"Processing Time: {processing_time:.2f}s\n")
            
            return {
                "original_query": query,
                "expanded_query": expanded_query,
                "is_clinical": False,
                "rejected_reason": intent_result.get("rejected_reason", 
                                                     "Query is not clinical"),
                "intents": [],
                "timestamp": datetime.utcnow().isoformat(),
                "processing_time_seconds": processing_time
            }
        
        intents = intent_result.get("intents", [])
        
        # ── STEP 3: Contextual Environment ──
        context_result = self.generate_contextual_environment(
            query, expanded_query, intents, verbose
        )
        
        # Merge contexts back into intents
        final_intents = merge_context_into_intents(intents, context_result)
        
        # ── Stats ──
        total_queries = sum(len(i.get('final_queries', [])) for i in intents)
        total_sub_natures = sum(len(i.get('sub_natures', [])) for i in intents)
        contexts_generated = len([i for i in final_intents 
                                  if "contextual_environment" in i])
        processing_time = (datetime.utcnow() - start_time).total_seconds()
        
        if verbose:
            print(f"Status: Clinical")
            print(f"Intents: {len(intents)} | Sub-natures: {total_sub_natures} "
                  f"| Queries: {total_queries}")
            print(f"Contextual Environments: {contexts_generated}")
            print(f"Processing Time: {processing_time:.2f}s\n")
        
        return {
            "original_query": query,
            "expanded_query": expanded_query,
            "is_clinical": True,
            "total_intents_detected": len(intents),
            "intents": final_intents,
        }


