"""
Query Runner — CUI Filter + Vector + Lin Scoring.

Takes clinical query text, reduces, matches against stored chunks.

Usage:
    python run_query.py

Flow:
    Query text → CUI extraction → Stages 1-4 reduction (fast)
    → Fetch embeddings for surviving CUIs → Compute centroid
    → Pass 1: Topic gate  (TopicIndex — hard exclusion on centroid similarity)
    → Pass 2: CUI scoring (within matched topics only)
    → Pass 3: Z-score normalisation
    → Pass 4: Confidence gap filter
    → Ranked results
    → LLM reasoning (optional)
"""

import os
import csv
import time
from typing import Dict, List, Optional, Tuple

from google.cloud import bigquery

from config import (
    PROJECT_ID, DATASET_ID, EMBEDDING_TABLE, CACHE_DIR, ALLOWED_SABS,
    API_URL, TOP_K, TOP_P, CLUSTER_SET, COMBINED, OUTPUT_DIR,
    LLM_PROJECT_ID, LLM_LOCATION, LLM_MODEL, LLM_MAX_TOKENS,
    hierarchy, ic_precomputed
)
from cui_reduction_system import (
    CUIReductionSystem, CUIExtractor, fetch_preferred_terms,
    TemporalContext, _TEMPORAL_PRIORITY,
)
from topic_matcher import (
    ChunkStore, ChunkMatcher, TopicIndex,
    compute_centroid, build_query_topics,
)

_LLM_TOP_K = 3


# ── Setup (runs once) ────────────────────────────────────────────────────────

os.makedirs(OUTPUT_DIR, exist_ok=True)
bq = bigquery.Client(project=PROJECT_ID)

system = CUIReductionSystem(
    project_id=PROJECT_ID, dataset_id=DATASET_ID,
    full_network=hierarchy, allowed_sabs=ALLOWED_SABS,
    embedding_table=EMBEDDING_TABLE, ic_scores=ic_precomputed,
    cache_dir=CACHE_DIR)

extractor = CUIExtractor(
    api_url=API_URL,
    top_k=10,
    top_p=TOP_P,
    cluster_set=CLUSTER_SET, combined=COMBINED,
    cache_dir=CACHE_DIR)

matcher = ChunkMatcher(hierarchy, ic_precomputed)

_fetch_terms = lambda cuis: fetch_preferred_terms(bq, PROJECT_ID, DATASET_ID, cuis)


# ── Helpers — work with both TopicGroupMatch and ChunkMatch ──────────────────

def _is_topic_result(r) -> bool:
    """True if r is a TopicGroupMatch (TopicIndex path)."""
    return hasattr(r, 'group_id')


def _matched_cuis(r) -> List[str]:
    """CUIs matched in this result, regardless of result type."""
    if _is_topic_result(r):
        return list(r.matched_cuis)
    return list(getattr(r, 'overlapping_cuis', []))


def _display_result(rank: int, r, terms: dict) -> str:
    """Single-line display for either result type."""
    if _is_topic_result(r):
        variant_flag = " [VARIANT]" if r.is_variant else ""
        matched_terms = ", ".join(terms.get(c, c) for c in r.matched_cuis)
        return (f"#{rank}  chunk={r.chunk_id}  topic={r.topic_label}  "
                f"score={r.score:.3f}  CUI={r.cui_overlap_ratio:.2f}  "
                f"Lin={r.lin_score:.3f}{variant_flag}\n"
                f"       matched: {matched_terms}")
    # ChunkMatch (legacy)
    return f"#{rank}  {ChunkMatcher.explain(r, terms)}"


def _collect_term_cuis(results: list) -> set:
    """All CUIs that need term resolution across results of either type."""
    cuis = set()
    for r in results:
        cuis.update(_matched_cuis(r))
        if not _is_topic_result(r):
            for t_info in getattr(r, 'topics_matched', {}).values():
                tc = t_info.get("topic_cui")
                if tc:
                    cuis.add(tc)
                cuis.update(t_info.get("matched_cuis", []))
            for d in getattr(r, 'lin_details', []):
                if d.chunk_cui:  cuis.add(d.chunk_cui)
                if d.mica_cui:   cuis.add(d.mica_cui)
                cuis.add(d.query_cui)
    return cuis


def _csv_row(query_text: str, rank: int, r, terms: dict) -> list:
    """Build a CSV row for either result type."""
    matched_names = " | ".join(terms.get(c, c) for c in _matched_cuis(r))

    if _is_topic_result(r):
        return [
            query_text, rank, r.chunk_id, r.document_id,
            r.score, len(r.matched_cuis), r.cui_overlap_ratio,
            r.lin_score, "",          # total_chunk_cuis — not on TopicGroupMatch
            r.topic_label,
            matched_names,
        ]
    # ChunkMatch
    topic_parts = []
    for tid, t_info in sorted(getattr(r, 'topics_matched', {}).items()):
        t_cui   = t_info.get("topic_cui")
        t_label = terms.get(t_cui, t_cui) if t_cui else ""
        hits    = [terms.get(c, c) for c in t_info.get("matched_cuis", [])]
        topic_parts.append(f"{t_label}({', '.join(hits)})")
    return [
        query_text, rank, r.chunk_id, r.document_id,
        r.score, r.cui_overlap, r.cui_overlap_ratio,
        r.lin_score, r.total_chunk_cuis,
        " | ".join(topic_parts),
        matched_names,
    ]


# ── Query processing ─────────────────────────────────────────────────────────

def process_query(query_text: str) -> Optional[Dict]:
    """Extract CUIs, reduce, compute embedding for query."""
    print(f"\n{'='*80}")
    print(f"QUERY: {query_text}")
    print(f"{'='*80}")

    print("  → Extracting CUIs...", flush=True)
    per_phrase = extractor.extract([query_text], [query_text])
    extractor._cache.flush()

    if not per_phrase:
        print("  → No CUIs extracted (all negated or empty)")
        return None

    per_phrase_cuis: Dict[str, Dict] = {}
    query_temporal:  Dict[str, TemporalContext] = {}

    for ph, tagged in per_phrase.items():
        cui_dists = tagged.get("cuis") or {}
        if not cui_dists:
            continue
        temporal = TemporalContext(tagged.get("temporal", TemporalContext.CURRENT))
        per_phrase_cuis[ph] = cui_dists
        for cui in cui_dists:
            existing = query_temporal.get(cui)
            if existing is None or (
                _TEMPORAL_PRIORITY.get(temporal, 99)
                < _TEMPORAL_PRIORITY.get(existing, 99)
            ):
                query_temporal[cui] = temporal

    if not per_phrase_cuis:
        print("  → No CUIs after unpacking")
        return None

    total_cuis = sum(len(cd) for cd in per_phrase_cuis.values())
    print(f"  → Extracted: {total_cuis} CUIs", flush=True)

    non_current = {c: t.value for c, t in query_temporal.items()
                   if t != TemporalContext.CURRENT}
    if non_current:
        print(f"  → Temporal tags: {non_current}")

    print("\n  ── Raw CUIs from API (before reduction) ──")
    all_raw_cuis: List[str] = []
    for phrase, cd in per_phrase_cuis.items():
        print(f"    Phrase: '{phrase}'")
        for cui, dist in sorted(cd.items(), key=lambda x: (x[1] is None, x[1])):
            dist_str = f"{dist:.4f}" if dist is not None else "?"
            print(f"      {cui}  dist={dist_str}")
            all_raw_cuis.append(cui)

    raw_terms = _fetch_terms(set(all_raw_cuis))
    print("\n  ── Raw CUIs with names ──")
    for cui in sorted(set(all_raw_cuis)):
        print(f"    {cui} | {raw_terms.get(cui, '?')}")
    print()

    print("  → Reducing (stages 1-4)...", flush=True)
    surviving = system.reduce_query(all_raw_cuis)
    if not surviving:
        print("  → No CUIs survived reduction")
        return None

    print(f"  → Surviving: {len(surviving)} CUIs (from {total_cuis} raw)", flush=True)

    print(f"  → Fetching embeddings for {len(surviving)} surviving CUIs...", flush=True)
    query_embeddings = system.emb_fetcher.fetch(list(surviving))
    query_embedding  = compute_centroid(surviving, query_embeddings)
    query_topics     = build_query_topics(surviving, query_embeddings)

    print(f"  → Query topics: {len(query_topics)}")
    for tid, qt in query_topics.items():
        print(f"      Topic {tid}: {len(qt.get('members', []))} CUIs")

    terms = _fetch_terms(surviving)
    for cui in surviving:
        t = query_temporal.get(cui, TemporalContext.CURRENT)
        t_suffix = f" [{t.value}]" if t != TemporalContext.CURRENT else ""
        print(f"      {cui} | {terms.get(cui, cui)}{t_suffix}")

    surviving_temporal: Dict[str, TemporalContext] = {
        c: query_temporal.get(c, TemporalContext.CURRENT) for c in surviving
    }

    return {
        "surviving_cuis": surviving,
        "embedding":      query_embedding,
        "query_topics":   query_topics,
        "terms":          terms,
        "temporal_map":   surviving_temporal,
    }


# ── Full query → ranked results ───────────────────────────────────────────────

def run_query(
    query_text: str,
    store_path: Optional[str] = None,
    top_k: int = 10,
) -> Optional[Tuple[list, dict, dict]]:
    """Run a clinical query against stored chunks.

    Returns:
        (results, terms, chunks) or None
    """
    t0 = time.perf_counter()

    store_path = store_path or os.path.join(OUTPUT_DIR, "chunk_store.pkl")
    if not os.path.exists(store_path):
        print(f"ERROR: chunk store not found at {store_path}")
        print("  → Run run_cui_reduction_api.py first to build the store")
        return None

    store  = ChunkStore.load(store_path)
    chunks = store.get_all()
    if not chunks:
        print("ERROR: no chunks in store")
        return None

    stats = store.stats()
    print(f"\nStore: {stats['chunks']} chunks, {stats['total_cuis']} stored CUIs, "
          f"{stats['chunks_with_embeddings']} with embeddings")

    query_result = process_query(query_text)
    if not query_result:
        return None

    query_cuis      = query_result["surviving_cuis"]
    query_embedding = query_result["embedding"]
    query_topics    = query_result.get("query_topics")
    query_temporal  = query_result.get("temporal_map", {})
    terms           = query_result["terms"]

    print(f"\n  → Matching against {len(chunks)} chunks...", flush=True)

    # ── Two-pass matching ─────────────────────────────────────────────────────
    # TopicIndex = production path:
    #   Pass 1 — topic centroid gate (hard exclusion, gap_split)
    #   Pass 2 — CUI scoring within matched topics only
    #   Pass 3 — z-score normalisation (no manual weights)
    #   Pass 4 — confidence gap filter
    #
    # ChunkMatcher = legacy path for stores without per-topic centroids.
    has_topic_centroids = any(
        any(t.get("centroid") is not None
            for t in cd.get("topics", {}).values())
        for cd in chunks.values()
    )

    if has_topic_centroids and query_topics:
        print("  → Path: TopicIndex (topic gate → CUI scoring within matched topics)")
        topic_index = TopicIndex()
        topic_index.build(chunks, graph=hierarchy)
        results = topic_index.match(
            query_topics, query_cuis, query_embedding,
            matcher, top_k=top_k,
        )
        if results:
            print(f"  → TopicIndex: {len(results)} results")
        else:
            print("  → TopicIndex: no groups cleared the topic gate — 0 results")
            print("     (query concepts may not be represented in the store)")
    else:
        print("  → Path: ChunkMatcher (legacy — store has no topic centroids)")
        results = matcher.match(
            query_cuis, query_embedding, chunks,
            top_k=top_k,
            query_topics=query_topics,
            query_temporal=query_temporal,
        )

    # Resolve terms for all matched CUIs (both result types)
    missing = _collect_term_cuis(results) - set(terms.keys())
    if missing:
        terms.update(_fetch_terms(missing))

    elapsed = (time.perf_counter() - t0) * 1000

    print(f"\n{'='*80}")
    print(f"RESULTS: {len(results)} chunks matched ({elapsed:.0f}ms total)")
    print(f"{'='*80}\n")

    if not results:
        print("  No matching chunks found.")
    else:
        for rank, r in enumerate(results, 1):
            print(f"  {_display_result(rank, r, terms)}")
            print()

    return results, terms, chunks


# ── LLM Reasoning ────────────────────────────────────────────────────────────

def build_reasoning_prompt(
    query_text: str,
    results: list,
    chunks: dict,
    terms: dict,
    top_k: int = _LLM_TOP_K,
) -> str:
    sections = []
    for rank, r in enumerate(results[:top_k], 1):
        chunk_data = chunks.get(r.chunk_id, {})
        chunk_text = chunk_data.get("text", "(text not available)")
        chunk_cui_list = ", ".join(
            f"{c} ({terms.get(c, c)})" for c in sorted(chunk_data.get("cuis", set()))
        )
        # Match analysis — both types have score, cui_overlap_ratio, lin_score
        match_explain = (
            f"Topic: {r.topic_label}  score={r.score:.3f}  "
            f"CUI overlap={r.cui_overlap_ratio:.2f}  Lin={r.lin_score:.3f}"
            if _is_topic_result(r)
            else ChunkMatcher.explain(r, terms)
        )
        sections.append(
            f"--- CHUNK #{rank} ---\n"
            f"Chunk ID: {r.chunk_id}\n"
            f"Document: {r.document_id}\n"
            f"Score: {r.score:.3f} (CUI overlap={r.cui_overlap_ratio:.2f}, "
            f"Lin={r.lin_score:.3f})\n\n"
            f"Clinical Text:\n{chunk_text}\n\n"
            f"Medical Concepts (after CUI reduction):\n{chunk_cui_list}\n\n"
            f"Match Analysis:\n{match_explain}"
        )

    # Query CUIs — use matched_cuis from results (works for both types)
    all_matched = set(c for r in results[:top_k] for c in _matched_cuis(r))
    query_cuis_str = ", ".join(
        f"{c} ({terms.get(c, c)})" for c in sorted(all_matched)
    )

    return (
        "You are a clinical information retrieval expert. "
        "Analyze the following query and retrieved document chunks.\n\n"
        f"CLINICAL QUERY: {query_text}\n\n"
        f"QUERY CONCEPTS (after CUI extraction and reduction):\n{query_cuis_str}\n\n"
        f"RETRIEVED CHUNKS (ranked by relevance):\n\n"
        + "\n\n".join(sections)
        + "\n\nINSTRUCTIONS:\n"
        "1. For each retrieved chunk, explain WHY it matches the query from a "
        "clinical perspective. Reference specific medical concepts, not just CUI codes.\n"
        "2. Identify which chunk BEST answers the query and explain your clinical reasoning.\n"
        "3. Note any important clinical concepts from the query that are NOT covered by "
        "any retrieved chunk.\n"
        "4. Rate the overall retrieval quality: Excellent / Good / Fair / Poor, "
        "with justification.\n\n"
        "Provide your analysis in clear, structured prose."
    )


def llm_reason(
    query_text: str,
    results: list,
    chunks: dict,
    terms: dict,
    top_k: int = _LLM_TOP_K,
) -> str:
    if not results:
        return "No chunks matched the query. Cannot reason about matches."

    prompt = build_reasoning_prompt(query_text, results, chunks, terms, top_k)

    try:
        from google.cloud import aiplatform
        from vertexai.generative_models import GenerativeModel

        aiplatform.init(project=LLM_PROJECT_ID, location=LLM_LOCATION)
        model = GenerativeModel(LLM_MODEL)
        response = model.generate_content(
            prompt,
            generation_config={"max_output_tokens": LLM_MAX_TOKENS, "temperature": 0.2},
        )
        return response.text

    except ImportError:
        print("\n  LLM reasoning skipped (install: pip install google-cloud-aiplatform)")
        return prompt
    except Exception as e:
        print(f"\n  LLM reasoning failed: {e}")
        return prompt


# ── main ─────────────────────────────────────────────────────────────────────

if __name__ == "__main__":

    STORE_PATH = os.path.join(OUTPUT_DIR, "chunk_store.pkl")

    QUERIES = [
        "left knee osteoarthritis treatment with methotrexate",
        "rheumatoid arthritis of knee",
        "elevated CRP and ESR",
        "methotrexate side effects",
    ]

    all_rows: List[list] = []
    all_reasoning: Dict[str, str] = {}

    for query_text in QUERIES:
        result = run_query(query_text, STORE_PATH, top_k=5)
        if not result:
            continue
        results, terms, chunks = result

        print(f"\n{'='*80}")
        print("LLM REASONING")
        print(f"{'='*80}")
        reasoning = llm_reason(query_text, results, chunks, terms)
        if reasoning:
            all_reasoning[query_text] = reasoning
            if not reasoning.startswith("You are a clinical"):
                print(reasoning)
                print()

        for rank, r in enumerate(results, 1):
            all_rows.append(_csv_row(query_text, rank, r, terms))

    if all_rows:
        csv_path = os.path.join(OUTPUT_DIR, "query_results.csv")
        with open(csv_path, "w", newline="") as f:
            w = csv.writer(f)
            w.writerow(["query", "rank", "chunk_id", "document_id",
                        "score", "cui_overlap", "cui_overlap_ratio",
                        "lin_score", "total_chunk_cuis",
                        "topics_hit", "matched_cuis"])
            w.writerows(all_rows)
        print(f"\n{'='*80}")
        print(f"Results saved to {csv_path}")

    if all_reasoning:
        reasoning_path = os.path.join(OUTPUT_DIR, "query_reasoning.txt")
        with open(reasoning_path, "w") as f:
            for qt, reasoning in all_reasoning.items():
                f.write(f"{'='*80}\nQUERY: {qt}\n{'='*80}\n\n{reasoning}\n\n")
        print(f"Reasoning saved to {reasoning_path}")

    print(f"\nDONE — {len(QUERIES)} queries processed")
