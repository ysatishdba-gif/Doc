# topic_labeler.py
# Standalone topic label assignment. Zero hardcoded thresholds.
#
# Three tiers:
#   1. medlineplus: topic_cui directly in MedlinePlus dict
#   2. ancestor:    unbounded BFS up from members, Otsu threshold on coverage counts,
#                   among winners pick one closest to members (avg hop distance)
#   3. member:      fallback to the topic's highest-IC member preferred term
#
# Usage:
#   from topic_labeler import TopicLabeler
#   labeler = TopicLabeler()
#   labeled = labeler.relabel(topics_result, ic_map=ic_map)

import logging
from collections import defaultdict
from google.cloud import bigquery
from config import PROJECT_ID, DATASET_ID, hierarchy, medlineplus
from cui_core import fetch_preferred_terms, _otsu_threshold

log = logging.getLogger(__name__)


class TopicLabeler:

    def __init__(self):
        self._graph = hierarchy
        self._mp_keys = set(medlineplus.keys())
        self._bq = bigquery.Client(project=PROJECT_ID)
        self._pid, self._did = PROJECT_ID, DATASET_ID

    def relabel(self, topics_result, ic_map=None):
        """Returns a NEW dict with updated topic_label and label_source.
        The input is not mutated. ic_map only used for final tie-breaking."""
        if not topics_result or "topics" not in topics_result:
            return topics_result

        # first pass: compute the chosen ancestor CUI for each topic & subtopic
        # so we can batch-fetch all preferred terms in one BQ query
        topic_ancestors = {}       # tid -> ancestor_cui or None
        subtopic_ancestors = {}    # (tid, sid) -> ancestor_cui or None

        for topic in topics_result["topics"]:
            tid = topic.get("topic_id")
            member_cuis = [m["cui"] for m in topic.get("members", [])]
            topic_ancestors[tid] = self._best_ancestor(member_cuis, ic_map)

            for st in topic.get("subtopics", []):
                sid = st.get("subtopic_id")
                sub_members = [m["cui"] for m in st.get("members", [])]
                subtopic_ancestors[(tid, sid)] = self._best_ancestor(sub_members, ic_map)

        # batch-fetch all ancestor preferred terms in ONE BQ query
        all_ancs = {a for a in topic_ancestors.values() if a} | \
                   {a for a in subtopic_ancestors.values() if a}
        anc_terms = {}
        if all_ancs:
            anc_terms = fetch_preferred_terms(
                self._bq, self._pid, self._did, list(all_ancs))

        # second pass: build the relabeled output
        out = dict(topics_result)
        out["topics"] = []
        counts = {"medlineplus": 0, "ancestor": 0, "member": 0}

        for topic in topics_result["topics"]:
            tid = topic.get("topic_id")
            new_topic = dict(topic)
            new_cui, new_label, source = self._pick_label(
                topic.get("topic_cui", ""),
                topic.get("topic_label", ""),
                topic_ancestors.get(tid),
                anc_terms)
            new_topic["topic_cui"] = new_cui
            new_topic["topic_label"] = new_label
            new_topic["label_source"] = source
            counts[source] = counts.get(source, 0) + 1

            new_subs = []
            for st in topic.get("subtopics", []):
                sid = st.get("subtopic_id")
                new_st = dict(st)
                new_sc, new_st_label, st_source = self._pick_label(
                    st.get("subtopic_cui", ""),
                    st.get("subtopic_label", ""),
                    subtopic_ancestors.get((tid, sid)),
                    anc_terms)
                new_st["subtopic_cui"] = new_sc
                new_st["subtopic_label"] = new_st_label
                new_st["label_source"] = st_source
                new_subs.append(new_st)
            new_topic["subtopics"] = new_subs

            out["topics"].append(new_topic)

        log.info(f"TopicLabeler: {counts['medlineplus']} medlineplus, "
                 f"{counts['ancestor']} ancestor, {counts['member']} member")
        return out

    # ── Core selection logic ────────────────────────────────────────────────

    def _pick_label(self, topic_cui, member_label, ancestor_cui, anc_terms):
        """Returns (cui, label, source). Tier priority: medlineplus > ancestor > member."""
        # Tier 1: MedlinePlus direct on topic_cui
        if topic_cui and topic_cui in self._mp_keys:
            return topic_cui, medlineplus[topic_cui], "medlineplus"

        # Tier 2: ancestor found via Otsu-based selection
        if ancestor_cui:
            # prefer MedlinePlus label for the ancestor if available
            if ancestor_cui in self._mp_keys:
                return ancestor_cui, medlineplus[ancestor_cui], "medlineplus"
            label = anc_terms.get(ancestor_cui)
            if label:
                return ancestor_cui, label, "ancestor"

        # Tier 3: fallback to member label
        return topic_cui, member_label, "member"

    def _best_ancestor(self, member_cuis, ic_map):
        """Walk UP from each member unbounded. Collect coverage counts.
        Use Otsu on coverage counts to find the natural 'common ancestor' threshold.
        Among winners, pick the one closest to members (lowest avg hop distance).
        Tie-break on lower IC (more general = better topic anchor).

        Returns ancestor CUI or None if no suitable candidate.
        """
        if not member_cuis or len(member_cuis) < 2:
            return None

        # coverage[anc] = set of members that reached it
        # hops[anc] = list of hop distances (one per member that reached it)
        coverage = defaultdict(set)
        hops = defaultdict(list)

        for member in member_cuis:
            # BFS up from this member, walk to root (UMLS finite ~10 hops deep)
            if member not in self._graph:
                continue
            visited = {member}
            frontier = [(member, 0)]
            while frontier:
                next_frontier = []
                for node, dist in frontier:
                    for parent in self._graph.predecessors(node):
                        if parent in visited:
                            continue
                        visited.add(parent)
                        coverage[parent].add(member)
                        hops[parent].append(dist + 1)
                        next_frontier.append((parent, dist + 1))
                frontier = next_frontier

        if not coverage:
            return None

        # build list of (ancestor, coverage_count) and apply Otsu
        anc_counts = [(a, len(m)) for a, m in coverage.items()]
        counts_only = [c for _, c in anc_counts]

        # need at least 2 distinct counts for Otsu to be meaningful
        unique_counts = set(counts_only)
        if len(unique_counts) < 2:
            # degenerate: all ancestors have same coverage
            # pick the one covering most members (or any if all tied)
            max_cov = max(counts_only)
            winners = [a for a, c in anc_counts if c == max_cov]
        else:
            threshold = _otsu_threshold(counts_only)
            # ancestors at or above the threshold are the "common" ones
            winners = [a for a, c in anc_counts if c >= threshold]

        if not winners:
            return None

        # require at least 2 members' coverage to prevent singleton leakage
        # (if a winner only has 1 member reaching it, it's not really shared)
        winners = [a for a in winners if len(coverage[a]) >= 2]
        if not winners:
            return None

        # drop ancestors that are themselves in the input (already a member)
        member_set = set(member_cuis)
        winners = [a for a in winners if a not in member_set]
        if not winners:
            return None

        # among winners, pick the one closest to members
        # score = avg hop distance (lower = closer = better)
        # tie-break: lower IC (more general = better topic anchor)
        def score(a):
            avg_hop = sum(hops[a]) / len(hops[a])
            cov = len(coverage[a])
            anc_ic = (ic_map or {}).get(a, 0.0)
            # sort key: fewer hops first, more coverage second, lower IC third
            return (avg_hop, -cov, anc_ic)

        winners.sort(key=score)
        return winners[0]

    def close(self):
        pass
