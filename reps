from google.cloud import bigquery

def create_all_definitions_relationship_context(
    project_id="",
    dataset_id="",
    transformed_table="",
    raw_text_table="",
    _table="",
    output_table="all_definitions_relationship_context"
):
    """
    Create relationship context table for all definitions.

    Parameters
    ----------
    project_id : str
        GCP project ID
    dataset_id : str
        BigQuery dataset ID
    transformed_table : str
        Source transformed data table
    raw_text_table : str
        Raw text table
    _table : str
         relationship table
    output_table : str
        Output table name
    """

    client = bigquery.Client(project=project_id)

    query = f"""
    CREATE OR REPLACE TABLE `{project_id}.{dataset_id}.{output_table}` AS

    WITH non_problematic_definitions AS (
      SELECT DISTINCT
        CUI,
        CUIName
      FROM `{project_id}.{dataset_id}.{transformed_table}`
    ),

    first_concept_per_cui2 AS (
      SELECT
        r.CUI AS CUI2,
        r.Name,
        ROW_NUMBER() OVER (
          PARTITION BY r.CUI
          ORDER BY r.Name
        ) AS rn
      FROM `{project_id}.{dataset_id}.{raw_text_table}` r
      QUALIFY rn = 1
    )

    SELECT
      p.CUI AS CUI1,
      p.CUIName AS CUIName,
      r.CUI2,
      r.REL,
      r.RELA,
      c2.Name AS RelatedConceptName

    FROM non_problematic_definitions p

    LEFT JOIN `{project_id}.{dataset_id}.{_table}` r
      ON p.CUI = r.CUI1

    LEFT JOIN first_concept_per_cui2 c2
      ON r.CUI2 = c2.CUI2
    ;
    """

    job = client.query(query)
    job.result()

    print(
        f"Table {output_table} created successfully."
    )


# Example usage
create_all_definitions_relationship_context()

from google.cloud import bigquery

def create_subset_src_system_cuis(
    source_system,
    project_id="",
    dataset_id="",
    output_table="subset_src_system_cuis"
):
    """
    Create a table containing distinct CUIs for a given source system.

    Parameters
    ----------
    source_system : str or list[str]
        Source system name(s), e.g. 'ICD10' or ['ICD10', 'SNOMEDCT_US']
    project_id : str
        GCP project ID
    dataset_id : str
        BigQuery dataset ID
    output_table : str
        Output table name
    """

    client = bigquery.Client(project=project_id)

    # Handle single string vs list
    if isinstance(source_system, str):
        source_system = [source_system]

    # Build IN clause safely
    source_system_list = ", ".join([f"'{s}'" for s in source_system])

    query = f"""
    CREATE OR REPLACE TABLE `{project_id}.{dataset_id}.{output_table}` AS

    SELECT DISTINCT s1.CUI
    FROM `{project_id}.{dataset_id}.Umls_SourceSystem` s1
    WHERE s1.SourceSystem IN ({source_system_list})
    ;
    """

    job = client.query(query)
    job.result()

    print(f"Table {output_table} created successfully for {source_system}")


# Example usage
create_subset_src_system_cuis(source_system)

