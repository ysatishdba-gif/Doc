DATASET = ""
CLUSTER_TABLE = f"{PROJECT_ID}.{DATASET}.SCENARIO_4_CLUSTER"
MEMBER_TABLE = f"{PROJECT_ID}.{DATASET}.SCENARIO_4_MEMBER"
MAP_TABLE = f"{PROJECT_ID}.{DATASET}.SCENARIO_4_MAP"

def create_scenario_4_tables(
    project_id="",
    dataset_id=""
):
    """
    Create output tables if not exists
    """
    
    client = bigquery.Client(project=project_id)
    cluster_ddl = f"""
    CREATE TABLE IF NOT EXISTS `{CLUSTER_TABLE}`
    (
        cluster_id STRING,
        cluster_name STRING,
        cluster_type STRING,
        semantic_type STRING,
        relation STRING,
        parent_cluster_id STRING,
        created_at TIMESTAMP
    )
    """

    member_ddl = f"""
    CREATE TABLE IF NOT EXISTS `{MEMBER_TABLE}`
    (
        cluster_id STRING,
        cui STRING,
        cui_name STRING,
        semantic_type STRING,
        role STRING,
        created_at TIMESTAMP
    )
    """

    map_ddl = f"""
    CREATE TABLE IF NOT EXISTS `{MAP_TABLE}`
    (
        source_cluster_id STRING,
        target_cluster_id STRING,
        mapping_type STRING,
        created_at TIMESTAMP
    )
    """

    client.query(cluster_ddl).result()
    client.query(member_ddl).result()
    client.query(map_ddl).result()

    print("Scenario 4 tables created")

