create_subset_src_system_definitions_more_context()
from google.cloud import bigquery

def create_subset_src_system_definitions_all_context(
    project_id="",
    dataset_id="",
    input_cui_table="subset_src_system_cuis",
    relationship_context_table="all_definitions_relationship_context",
    output_table="subset_src_system_definitions_all_context"
):
    """
    Create a second-level contextual relationship table for subset source system CUIs.

    Parameters
    ----------
    project_id : str
        GCP project ID
    dataset_id : str
        BigQuery dataset ID
    input_cui_table : str
        Table containing subset CUIs
    relationship_context_table : str
        Relationship context table
    output_table : str
        Output table name
    """

    client = bigquery.Client(project=project_id)

    query = f"""
    CREATE OR REPLACE TABLE `{project_id}.{dataset_id}.{output_table}` AS

    SELECT
      a.CUI1 AS origin_cui,
      a.CUIName AS origin_cui_name,
      a.CUI2 AS intermediate_cui,
      a.RelatedConceptName AS intermediate_cui_name,
      a.RELA AS first_level_rela,
      b.CUI2 AS target_cui,
      b.RelatedConceptName AS target_cui_name,
      b.RELA AS second_level_rela

    FROM `{project_id}.{dataset_id}.{input_cui_table}` c

    JOIN `{project_id}.{dataset_id}.{relationship_context_table}` a
      ON c.CUI = a.CUI2

    JOIN `{project_id}.{dataset_id}.{relationship_context_table}` b
      ON a.CUI2 = b.CUI1
    where a.CUI1 != b.CUI2
    ;
    """

    job = client.query(query)
    job.result()

    print(
        f"Table {output_table} created successfully "
        f"using {relationship_context_table}"
    )


# Example usage
create_subset_src_system_definitions_all_context()
from google.cloud import bigquery

def create_subset_src_system_semantic_types(project_id=""):
    """
    Creates or replaces the table:
    .subset_src_system_semantic_types
    by joining MRSTY with subset_src_system_cuis.
    """

    client = bigquery.Client(project=project_id)

    query = """
    CREATE OR REPLACE TABLE `..subset_src_system_semantic_types` AS
    SELECT  distinct
        m.CUI as cui,
        m.STY as semantic_Type
    FROM `..MRSTY` m
    JOIN `..subset_src_system_cuis` s
        ON m.CUI = s.CUI
    ORDER BY m.CUI
    """

    job = client.query(query)
    job.result()  # waits for completion

    print("Table created successfully: subset_src_system_semantic_types")
    
