def create_subset_src_system_definitions_more_context(
    project_id="",
    dataset_id="",
    input_cui_table="subset_src_system_cuis",
    output_table="subset_src_system_defintions_more_context"
):
    """
    Create a contextual relationship table for CUIs from a subset source system.

    Parameters
    ----------
    project_id : str
        GCP project ID
    dataset_id : str
        BigQuery dataset ID
    input_cui_table : str
        Table containing subset CUIs
    output_table : str
        Output table name
    """

    client = bigquery.Client(project=project_id)

    query = f"""
    CREATE OR REPLACE TABLE `{project_id}.{dataset_id}.{output_table}` AS

    WITH subset_src_system_definitions AS (
      SELECT
        p.CUI,
        p.CUIName
      FROM `{project_id}.{dataset_id}.UMLS_PROCESSED_DATA` p
      WHERE p.CUI IN (
        SELECT CUI
        FROM `{project_id}.{dataset_id}.{input_cui_table}`
      )
    ),

    first_concept_per_cui2 AS (
      SELECT
        r.CUI AS CUI2,
        r.Name,
        ROW_NUMBER() OVER (
          PARTITION BY r.CUI
          ORDER BY r.Name
        ) AS rn
      FROM `{project_id}.{dataset_id}.` r
      QUALIFY rn = 1
    )

    SELECT
      p.CUI AS CUI1,
      p.CUIName AS CUIName,
      r.CUI2,
      r.REL,
      r.RELA,
      c2.Name AS RelatedConceptName
    FROM subset_src_system_definitions p
    LEFT JOIN `{project_id}.{dataset_id}.` r
      ON p.CUI = r.CUI1
    LEFT JOIN first_concept_per_cui2 c2
      ON r.CUI2 = c2.CUI2
    where p.CUI != r.CUI2
    ;
    """

    job = client.query(query)
    job.result()

    print(
        f"Table {output_table} created successfully "
        f"using CUIs from {input_cui_table}"
    )


