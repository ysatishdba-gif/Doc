from google.cloud import bigquery

def create_transformed_subset_src_system_definitions_relations(
    project_id="",
    dataset_id=""
):
    """
    Creates or replaces the transformed_subset_src_system_definitions_relations table
    while restricting BOTH origin and target CUIs to subset_src_system_cuis.
    """

    client = bigquery.Client(project=project_id)

    query = f"""
    CREATE OR REPLACE TABLE `{project_id}.{dataset_id}.transformed_subset_src_system_definitions_relations` AS

    WITH subset_cuis AS (
        SELECT DISTINCT CUI
        FROM `{project_id}.{dataset_id}.subset_src_system_cuis`
    )

    -- First source
    SELECT
        d.cui1 AS origin_cui,
        d.CUIName AS origin_cui_name,
        d.cui2 AS target_cui,
        d.RelatedConceptName AS target_cui_name,
        "" AS intermediate_cui,
        "" AS intermediate_cui_name,
        RELA AS relation,
        'first' AS Type
    FROM `{project_id}.{dataset_id}.subset_src_system_defintions_more_context` d
    JOIN subset_cuis s_origin
        ON d.cui1 = s_origin.CUI
    JOIN subset_cuis s_target
        ON d.cui2 = s_target.CUI

    UNION DISTINCT

    -- Second source
    SELECT
        origin_cui,
        origin_cui_name,
        target_cui,
        target_cui_name,
        intermediate_cui,
        intermediate_cui_name,
        CONCAT(first_level_rela, " to ", second_level_rela) AS relation,
        'second' AS Type
    FROM `{project_id}.{dataset_id}.subset_src_system_definitions_all_context` d
    JOIN subset_cuis s_origin
        ON d.origin_cui = s_origin.CUI
    JOIN subset_cuis s_target
        ON d.target_cui = s_target.CUI
    """

    job = client.query(query)
    job.result()

    print(
        f"Table created: "
        f"{project_id}.{dataset_id}.transformed_subset_src_system_definitions_relations"
    )


create_transformed_subset_src_system_definitions_relations()

