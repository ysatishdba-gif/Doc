"""
CUI Pipeline — Configuration
Edit the values below for your environment.
"""

import os
import sys
import pickle
import networkx

# ── GCP ──────────────────────────────────────────────────────────────────────
PROJECT_ID      = "your-project-id"
DATASET_ID      = "your-dataset-id"
EMBEDDING_TABLE = "cui_embeddings"

# ── Extraction API ───────────────────────────────────────────────────────────
API_URL         = "your-extraction-api-url"
TOP_K           = 6
TOP_P           = 5000
CLUSTER_SET     = "umls"
COMBINED        = True

# ── Paths ────────────────────────────────────────────────────────────────────
OUTPUT_DIR      = "output/"
HIERARCHY_PATH  = "umls_hierarchy.pkl"
IC_PATH         = "ic_precomputed.pkl"

# ── Pipeline options ─────────────────────────────────────────────────────────
ALLOWED_SABS    = {"SNOMEDCT_US"}

# ── LLM Reasoning (Vertex AI) ───────────────────────────────────────────────
LLM_PROJECT_ID  = PROJECT_ID
LLM_LOCATION    = "us-central1"
LLM_MODEL       = "gemini-2.0-flash"
LLM_MAX_TOKENS  = 1500

# ── Load hierarchy + IC ──────────────────────────────────────────────────────

os.makedirs(OUTPUT_DIR, exist_ok=True)

if not os.path.exists(HIERARCHY_PATH):
    print(f"ERROR: {HIERARCHY_PATH} not found"); sys.exit(1)
with open(HIERARCHY_PATH, "rb") as f:
    hierarchy = pickle.load(f)
assert isinstance(hierarchy, networkx.DiGraph)

if not os.path.exists(IC_PATH):
    print(f"ERROR: {IC_PATH} not found. Run ic_precompute.py first."); sys.exit(1)
with open(IC_PATH, "rb") as f:
    ic_precomputed = pickle.load(f)
assert isinstance(ic_precomputed, dict) and len(ic_precomputed) > 0

print(f"Config: {hierarchy.number_of_nodes()} nodes, {len(ic_precomputed)} IC scores")
