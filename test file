# ── Mock embeddings (random but consistent) ──────────────────────────────────

np.random.seed(42)
embeddings = {}
# make related concepts have similar embeddings
base_arthritis = np.random.randn(768).astype(np.float32)
base_drug = np.random.randn(768).astype(np.float32)
base_lab = np.random.randn(768).astype(np.float32)
base_finding = np.random.randn(768).astype(np.float32)

def make_emb(base, noise=0.1):
    v = base + np.random.randn(768).astype(np.float32) * noise
    return v / np.linalg.norm(v)

for cui in ["C0003873", "C0481906", "C0409959", "C0409958", "C0029410"]:
    embeddings[cui] = make_emb(base_arthritis, 0.15)
