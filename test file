    embeddings[cui] = make_emb(base_drug, 0.1)
for cui in ["C0418840", "C1534290"]:
    embeddings[cui] = make_emb(base_lab, 0.1)
for cui in ["C0582801", "C0582802", "C0018681"]:
    embeddings[cui] = make_emb(base_finding, 0.15)
embeddings["C0020538"] = make_emb(np.random.randn(768).astype(np.float32), 0.1)
base_neuro = np.random.randn(768).astype(np.float32)
embeddings["C0014544"] = make_emb(base_neuro, 0.1)   # Epilepsy
