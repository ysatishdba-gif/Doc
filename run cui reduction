bq = bigquery.Client(project=PROJECT_ID)
os.makedirs(OUTPUT_DIR, exist_ok=True)


# ── helpers ──────────────────────────────────────────────────────────────────

def load_pickles_from_gcs(bucket_name, prefix):
    client = storage.Client()
    bucket = client.bucket(bucket_name)
    blobs = list(bucket.list_blobs(prefix=prefix))
    print(f"  Found {len(blobs)} blobs in gs://{bucket_name}/{prefix}")
    results = []
    for blob in blobs:
        if blob.name.endswith("/"):
            continue
        if blob.name.endswith((".pk", ".pkl", ".pickle")):
            data = pickle.loads(blob.download_as_bytes())
            fname = blob.name.split("/")[-1]
            results.append((fname, data))
            print(f"  Loaded: {fname}")
    print(f"Total pickle files: {len(results)}")
    return results


def parse_pickle(data):
    text = data.get("text", "")
    entities = []
    extracted = data.get("extracted", {})
    for key, block in extracted.items():
        for item in block.get("matching_items", []):
            entity_text = item[0]
            sentence = item[1]
            cui_list = item[2] if len(item) > 2 else []
            cuis, distances = [], {}
            for entry in cui_list:
                cuis.append(entry[0])
                distances[entry[0]] = entry[1]
            if cuis:
                entities.append((entity_text, sentence, cuis, distances))
    return text, entities


def fetch_preferred_terms(cuis):
    if not cuis:
        return {}
    terms, cuis = {}, list(cuis)
    for i in range(0, len(cuis), 500):
        batch = cuis[i:i+500]
        query = f"""
        SELECT CUI, STR
        FROM `{PROJECT_ID}.{DATASET_ID}.MRCONSO`
        WHERE CUI IN UNNEST(@cuis) AND LAT = 'ENG' AND ISPREF = 'Y' AND TS = 'P' AND STT = 'PF'
        """
        jc = bigquery.QueryJobConfig(query_parameters=[
            bigquery.ArrayQueryParameter("cuis", "STRING", batch)])
        for row in bq.query(query, job_config=jc).result():
            if row.CUI not in terms:
                terms[row.CUI] = row.STR
    for c in cuis:
        if c not in terms:
            terms[c] = c
    return terms


def save_csv(path, headers, rows):
    with open(path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(headers)
        w.writerows(rows)


# ── core: process one pickle → anchors ───────────────────────────────────────

def process_one_pickle(fname, data):
    """Full pipeline for one pickle file.

    Returns:
        dict with keys: case_name, anchors, ic_map, terms, h_topics,
                        topic_reps, entity_results, all_embeddings, metadata,
                        metric_rows, recon_rows
        or None if no entities found
    """
    text, entities = parse_pickle(data)
    if not entities:
        print(f"  {fname} — no entities found")
        return None

    case_name = fname.rsplit(".", 1)[0]
    total_cuis = sum(len(c) for _, _, c, _ in entities)
    print(f"\n{'='*80}")
    print(f"CASE: {fname}")
    print(f"TEXT: {text[:150]}...")
    print(f"ENTITIES: {len(entities)}, TOTAL INPUT CUIs: {total_cuis}")
    print(f"{'='*80}")

    # batch reduction
    batch_inputs = [(cuis, entity_text, distances)
                    for entity_text, sentence, cuis, distances in entities]
    print(f"  → Batch reduction ({len(batch_inputs)} entities, {total_cuis} CUIs)...", flush=True)
    results = system.reduce_batch(batch_inputs)
    print(f"  → Batch reduction done", flush=True)
    entity_results = [(entities[i][0], results[i]) for i in range(len(entities))]

    all_surviving = set()
    all_cuis = set()
    for _, result in entity_results:
        all_surviving.update(result.all_reduced_cuis)
        for e in result.confidence:
            all_cuis.update(e.explains_cuis)
        for a in result.audit_trail:
            all_cuis.add(a.removed_cui)
            if a.kept_cui:
                all_cuis.add(a.kept_cui)
    for _, _, cuis, _ in entities:
        all_cuis.update(cuis)
    all_cuis.update(all_surviving)
    print(f"  → Surviving: {len(all_surviving)} CUIs, Total tracked: {len(all_cuis)}", flush=True)

    # hierarchical topics
    print(f"  → Building hierarchical topics...", flush=True)
    ic_map = system.ic_computer.compute(list(all_surviving), {})
    h_topics = HierarchicalTopicBuilder.build(list(all_surviving), hierarchy, ic_map)
    print(f"  → Topics: {len(h_topics)}", flush=True)

    ancestor_cuis = set()
    for tid, t in h_topics.items():
        if t["topic_cui"]:
            ancestor_cuis.add(t["topic_cui"])
        for stid, st in t.get("subtopics", {}).items():
            if st["subtopic_cui"]:
                ancestor_cuis.add(st["subtopic_cui"])
    all_cuis.update(ancestor_cuis)

    print(f"  → Fetching terms...", flush=True)
    terms = fetch_preferred_terms(all_cuis)
    print(f"  → Terms: {len(terms)}", flush=True)

    # embeddings (surviving only — removed fetched only if evaluating)
    surviving_list = list(all_surviving)
    print(f"  → Fetching embeddings ({len(surviving_list)} surviving)...", flush=True)
    embeddings = system.emb_fetcher.fetch(surviving_list)
    all_embeddings = dict(embeddings)
    print(f"  → Embeddings done ({len(all_embeddings)} total)", flush=True)

    # metadata + representatives
    print(f"  → Fetching metadata + selecting representatives...", flush=True)
    metadata = system.fetcher.fetch(list(all_cuis))
    topic_reps = TopicRepresentativeSelector.select(
        h_topics, metadata, all_embeddings, ic_map, hierarchy)
    print(f"  → Representatives done", flush=True)

    # anchors
    print(f"  → Assigning anchors...", flush=True)
    anchors = TopicAnchorAssigner.assign(topic_reps, ic_map, hierarchy)
    print(f"  → Anchors done ({len(anchors)})", flush=True)

    anchor_cuis_for_terms = set(a.anchor_cui for a in anchors)
    anchor_cuis_for_terms.update(c for a in anchors for c in a.ancestor_cuis or [])
    extra_terms = fetch_preferred_terms(anchor_cuis_for_terms - set(terms.keys()))
    terms.update(extra_terms)

    # print summary
    for entity_text, result in entity_results:
        print(f"  ENTITY: \"{entity_text}\" "
              f"({result.input_count} → {result.after_redundancy_count})")

    print(f"\n  ANCHORS: {len(anchors)}")
    for a in anchors:
        rep_terms = [terms.get(rc, rc) for rc in a.rep_cuis]
        print(f"    {a.anchor_cui} | {terms.get(a.anchor_cui, a.anchor_cui)} "
              f"(IC={a.anchor_ic:.1f}, reps=[{', '.join(rep_terms)}], "
              f"topics={a.topic_ids})")

    # evaluation (fetch removed embeddings only here — not needed for matching)
    flat_topics = {tid: t["members"] for tid, t in h_topics.items()}
    removed_embs = system.emb_fetcher.fetch(list(all_cuis - all_surviving))
    eval_embeddings = {**all_embeddings, **removed_embs}
    metric_rows = evaluator.intrinsic_metrics(case_name, entity_results, flat_topics, eval_embeddings)
    recon_rows = evaluator.reconstruction_check(case_name, entity_results, eval_embeddings, metadata, terms)

    return {
        "case_name": case_name,
        "surviving_cuis": all_surviving,
        "anchors": anchors,
        "ic_map": ic_map,
        "terms": terms,
        "h_topics": h_topics,
        "topic_reps": topic_reps,
        "entity_results": entity_results,
        "all_embeddings": all_embeddings,
        "metadata": metadata,
        "metric_rows": metric_rows,
        "recon_rows": recon_rows,
    }


# ── CSV writers ──────────────────────────────────────────────────────────────

INCLUDE_SUBTOPICS = False   # set True to include subtopic columns in topics CSV

def write_case_csvs(result):
    """Write all CSVs for one processed pickle."""
    case = result["case_name"]
    terms = result["terms"]
    h_topics = result["h_topics"]

    # ── entities CSV (unchanged) ─────────────────────────────────────────
    entity_rows = []
    for entity_text, r in result["entity_results"]:
        for e in r.confidence:
            explains_str = " | ".join(
                f"{ec}:{terms.get(ec, ec)}" for ec in e.explains_cuis
            ) if e.explains_cuis else ""
            entity_rows.append([
                entity_text, e.cui, terms.get(e.cui, e.cui),
                round(e.confidence, 4), round(e.extraction_proximity, 3),
                round(e.centrality, 3), round(e.retention_power, 3),
                len(e.explains_cuis), explains_str])
    save_csv(os.path.join(OUTPUT_DIR, f"{case}_entities.csv"),
             ["entity", "cui", "preferred_term", "confidence", "prox", "cent", "ret",
              "explains_count", "explains"], entity_rows)

    # ── topics CSV: topic_id + CUIs, no ancestor labels ──────────────────
    topic_rows = []
    if INCLUDE_SUBTOPICS:
        for tid, t in sorted(h_topics.items()):
            for stid, st in sorted(t.get("subtopics", {}).items()):
                st_cui = st["subtopic_cui"] or ""
                st_name = terms.get(st_cui, st_cui) if st_cui else ""
                for c in st["members"]:
                    topic_rows.append([tid, stid, st_name, c, terms.get(c, c)])
            for c in sorted(t.get("ungrouped", [])):
                topic_rows.append([tid, "", "", c, terms.get(c, c)])
        save_csv(os.path.join(OUTPUT_DIR, f"{case}_topics.csv"),
                 ["topic_id", "subtopic_id", "subtopic_name",
                  "cui", "preferred_term"], topic_rows)
    else:
        for tid, t in sorted(h_topics.items()):
            for c in t["members"]:
                topic_rows.append([tid, c, terms.get(c, c)])
        save_csv(os.path.join(OUTPUT_DIR, f"{case}_topics.csv"),
                 ["topic_id", "cui", "preferred_term"], topic_rows)

    # ── representatives CSV: one rep per row, simple ─────────────────────
    rep_rows = []
    for tid in sorted(result["topic_reps"].keys()):
        for r in result["topic_reps"][tid]:
            rep_rows.append([
                tid, r.cui, terms.get(r.cui, r.cui),
                r.method, r.member_count, round(r.ic_score, 2),
                " | ".join(f"{m}:{terms.get(m, m)}" for m in r.members)])
    save_csv(os.path.join(OUTPUT_DIR, f"{case}_representatives.csv"),
             ["topic_id", "rep_cui", "rep_term", "method", "member_count",
              "ic_score", "members"], rep_rows)

    # ── anchors CSV: what gets stored for matching ───────────────────────
    anchor_rows = []
    for a in result["anchors"]:
        rep_detail = " | ".join(f"{rc}:{terms.get(rc, rc)}" for rc in a.rep_cuis)
        # build topic detail: for each topic_id, list its member CUIs
        topic_detail_parts = []
        for tid in a.topic_ids:
            t = h_topics.get(tid, {})
            member_count = len(t.get("members", []))
            topic_detail_parts.append(f"topic_{tid}({member_count} CUIs)")
        topic_detail = " | ".join(topic_detail_parts)

        anchor_rows.append([
            a.anchor_cui, terms.get(a.anchor_cui, a.anchor_cui),
            round(a.anchor_ic, 2),
            rep_detail,
            len(a.topic_ids), topic_detail,
            len(a.ancestor_cuis) if a.ancestor_cuis else 0])
    save_csv(os.path.join(OUTPUT_DIR, f"{case}_anchors.csv"),
             ["anchor_cui", "anchor_term", "anchor_ic",
              "representatives", "topics_covered", "topic_details",
              "ancestor_count"], anchor_rows)


# ── main ─────────────────────────────────────────────────────────────────────

if __name__ == "__main__":

    # ── CONFIG (edit these) ──────────────────────────────────────────────
    PATIENT_ID = "patient_001"           # patient these documents belong to
    STORE_PATH = os.path.join(OUTPUT_DIR, "chunk_store.pkl")  # where to save

    # ═════════════════════════════════════════════════════════════════════
    # Process all pickle files + store surviving CUIs
    # ═════════════════════════════════════════════════════════════════════
    pickles = load_pickles_from_gcs(GCS_BUCKET, PICKLE_PREFIX)
    store = ChunkStore()

    all_metric_rows, all_recon_rows = [], []

    for fname, data in pickles:
        result = process_one_pickle(fname, data)
        if result:
            write_case_csvs(result)
            all_metric_rows.extend(result["metric_rows"])
            all_recon_rows.extend(result["recon_rows"])

            # store surviving CUIs + topics for matching
            store.add(
                patient_id=PATIENT_ID,
                chunk_id=result["case_name"],
                document_id=fname,
                surviving_cuis=result["surviving_cuis"],
                topics=result["h_topics"]
            )

    # save store
    store.save(STORE_PATH)

    # evaluation summary
    save_csv(os.path.join(OUTPUT_DIR, "eval_metrics.csv"),
             Evaluator.metric_headers(), all_metric_rows)
    save_csv(os.path.join(OUTPUT_DIR, "eval_reconstruction.csv"),
             Evaluator.reconstruction_headers(), all_recon_rows)

    suspect = sum(1 for r in all_recon_rows if "SUSPECT" in str(r[-1]))
    ok = sum(1 for r in all_recon_rows if r[-1] == "OK")
    total = len(all_recon_rows)
    stats = store.stats(PATIENT_ID)
    print(f"\n{'='*80}\nSUMMARY\n{'='*80}")
    if total:
        print(f"  Reconstruction: {ok}/{total} OK, {suspect}/{total} SUSPECT")
    print(f"  Patient {PATIENT_ID}: {stats['chunks']} chunks, "
          f"{stats['total_cuis']} surviving CUIs stored")
    print(f"  Store saved to: {STORE_PATH}")
    print(f"\nDONE — {len(pickles)} cases")
