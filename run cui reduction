"""
CUI Reduction Runner — Pickle Files (GCS)
Loads pickle files, batch reduction per entity, topics, reps, anchors, CSVs.

Usage:
    python run_cui_reduction.py

    # Or import:
    from run_cui_reduction import process_one_pickle
"""

import os
import csv
import pickle
import numpy as np
from google.cloud import storage, bigquery

from config import (
    PROJECT_ID, DATASET_ID, EMBEDDING_TABLE, CACHE_DIR,
    ALLOWED_SABS, GCS_BUCKET, PICKLE_PREFIX, OUTPUT_DIR,
    hierarchy, ic_precomputed
)
from cui_reduction_system import (
    CUIReductionSystem, HierarchicalTopicBuilder, Evaluator,
    TopicRepresentativeSelector, TopicAnchorAssigner
)
from topic_matcher import ChunkStore


# ── shared instances (initialized once) ──────────────────────────────────────

system = CUIReductionSystem(
    project_id=PROJECT_ID, dataset_id=DATASET_ID, full_network=hierarchy,
    allowed_sabs=ALLOWED_SABS, embedding_table=EMBEDDING_TABLE,
    ic_scores=ic_precomputed, cache_dir=CACHE_DIR)

