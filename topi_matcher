"""
Topic Matcher — CUI Filter + Vector + Lin Similarity.

Three-signal retrieval for clinical chunk matching:
  Signal 1: CUI overlap ratio  (W=0.40) — exact concept match (precision)
  Signal 2: Vector similarity   (W=0.30) — semantic closeness (recall)
  Signal 3: Lin similarity      (W=0.30) — hierarchy-aware match via MICA

Filter step: CUI overlap + hierarchy subsumption → candidates.
Scoring: three signals on candidates only.

Components:
  ChunkStore:       Stores CUIs + embedding centroid + topics + text per chunk
  ChunkMatcher:     Three-signal scorer with filter step
  compute_centroid: Helper to average CUI embeddings into one vector

Usage:
    from topic_matcher import ChunkStore, ChunkMatcher, compute_centroid

    # Offline: store chunks
    store = ChunkStore()
    emb = compute_centroid(surviving_cuis, embeddings)
    store.add("chunk_1", "doc_1", surviving_cuis, embedding=emb,
              topics=h_topics, text=chunk_text)
    store.save("chunk_store.pkl")

    # Online: match
    store = ChunkStore.load("chunk_store.pkl")
    matcher = ChunkMatcher(graph, ic_map)
    q_emb = compute_centroid(query_cuis, embeddings)
    results = matcher.match(query_cuis, q_emb, store.get_all())

References:
    Lin 1998     — IC-based similarity via MICA
    Pesquita 2009 — BMA for set-to-set similarity
"""

import pickle
import time
import logging
import numpy as np
from typing import Dict, List, Optional
from dataclasses import dataclass

logger = logging.getLogger("cui_reduction")


# ── Private implementation constants ──────────────────────────────────────────
_W_CUI   = 0.40
_W_VEC   = 0.30
_W_LIN   = 0.30
_IC_MIN    = 2.0
_ANC_DEPTH = 8    # BFS hops — clinical paths are 5-10 deep, admin paths limited by hop count
_MIN_OVERLAP = 1
_SCORE_MIN = 0.01
_IC_MIN_SIBLING = 4.0   # shared ancestor must have IC >= 4.0 to count as sibling match


# ── Data model ────────────────────────────────────────────────────────────────

@dataclass
class CUIMatchDetail:
    """Best Lin match for one query CUI."""
    query_cui: str
    chunk_cui: Optional[str]   # best matching CUI in chunk
    mica_cui: Optional[str]    # Most Informative Common Ancestor
    lin_sim: float             # Lin similarity [0, 1]
    match_type: str            # exact | subsumption | shared_ancestor | no_match

@dataclass
class ChunkMatch:
    """Result of matching one chunk against the query."""
    chunk_id: str
    document_id: str
    score: float               # combined weighted score [0, 1]
    cui_overlap: int           # exact CUI overlap count
    cui_overlap_ratio: float   # overlap / query CUI count
    vector_sim: float          # cosine similarity of embedding centroids
    lin_score: float           # average best Lin similarity (BMA)
    total_chunk_cuis: int
    total_query_cuis: int
    overlapping_cuis: List[str]
    topics_matched: Dict
    lin_details: List[CUIMatchDetail]


# ── ChunkStore ────────────────────────────────────────────────────────────────

class ChunkStore:
    """Stores surviving CUIs, embedding centroid, topics, and text per chunk."""

    def __init__(self):
        self._data = {}

    def add(self, chunk_id, document_id, surviving_cuis,
            embedding=None, topics=None, text=None):
        """Store one chunk.

        Args:
            chunk_id: chunk identifier
            document_id: source document identifier
            surviving_cuis: set/list of CUI strings
            embedding: numpy array — centroid of CUI embeddings
            topics: dict from HierarchicalTopicBuilder
            text: original chunk text (for LLM reasoning)
        """
        self._data[chunk_id] = {
            "doc_id": document_id,
            "cuis": set(surviving_cuis),
            "embedding": embedding,
            "topics": topics or {},
            "text": text or ""
        }

    def get_all(self):
        return dict(self._data)

    def get_chunk(self, chunk_id):
        return self._data.get(chunk_id)

    def chunk_ids(self):
        return list(self._data.keys())

    def stats(self):
        total_cuis = sum(len(c.get("cuis", set())) for c in self._data.values())
        has_emb = sum(1 for c in self._data.values() if c.get("embedding") is not None)
        return {
            "chunks": len(self._data),
            "total_cuis": total_cuis,
            "avg_cuis_per_chunk": round(total_cuis / len(self._data), 1) if self._data else 0,
            "chunks_with_embeddings": has_emb,
        }

    def save(self, path):
        with open(path, "wb") as f:
            pickle.dump(dict(self._data), f, protocol=pickle.HIGHEST_PROTOCOL)
        logger.info(f"ChunkStore saved: {len(self._data)} chunks to {path}")

    @classmethod
    def load(cls, path):
        store = cls()
        with open(path, "rb") as f:
            store._data = pickle.load(f)
        # backfill missing fields from older pickle versions
        for chunk_id, chunk in store._data.items():
            if "doc_id" not in chunk:
                chunk["doc_id"] = chunk_id
            if "cuis" not in chunk:
                chunk["cuis"] = set()
            if "embedding" not in chunk:
                chunk["embedding"] = None
            if "topics" not in chunk:
                chunk["topics"] = {}
            if "text" not in chunk:
                chunk["text"] = ""
        logger.info(f"ChunkStore loaded: {len(store._data)} chunks from {path}")
        return store


# ── Helpers ───────────────────────────────────────────────────────────────────

def compute_centroid(cuis, embeddings):
    """Compute normalized centroid of CUI embeddings.

    Args:
        cuis: list/set of CUI strings
        embeddings: dict {cui: numpy array}

    Returns:
        numpy array (L2-normalized) or None if no embeddings found
    """
    vecs = [embeddings[c] for c in cuis if c in embeddings]
    if not vecs:
        return None
    centroid = np.mean(vecs, axis=0).astype(np.float32)
    norm = np.linalg.norm(centroid)
    return centroid / norm if norm > 0 else centroid


# ── ChunkMatcher ──────────────────────────────────────────────────────────────

class ChunkMatcher:
    """Three-signal clinical chunk retrieval.

    Filter: CUI overlap OR hierarchy subsumption → candidates
    Score candidates with:
      1. CUI overlap ratio  (W=0.40) — exact matches / query CUI count
      2. Vector similarity   (W=0.30) — cosine of embedding centroids
      3. Lin similarity      (W=0.30) — BMA of best pairwise Lin via MICA
    """

    def __init__(self, graph=None, ic_map=None):
        self.graph = graph
        self.ic_map = ic_map or {}
        self._ancestor_cache = {}

    def _get_ancestors(self, cui):
        """BFS ancestors up to _ANC_DEPTH hops, cached.

        Uses fixed hop limit (8) to prevent following long admin chains.
        Also stops following parents with IC < _IC_MIN (too broad).
        Combined: covers deep clinical branches, blocks admin paths.
        """
        if cui in self._ancestor_cache:
            return self._ancestor_cache[cui]
        result = {cui}
        if self.graph is not None and self.graph.has_node(cui):
            frontier = {cui}
            for _ in range(_ANC_DEPTH):
                nxt = set()
                for n in frontier:
                    for parent in self.graph.predecessors(n):
                        if parent not in result:
                            pic = self.ic_map.get(parent, 0.0)
                            if pic >= _IC_MIN:
                                result.add(parent)
                                nxt.add(parent)
                frontier = nxt
                if not frontier:
                    break
        result = frozenset(result)
        self._ancestor_cache[cui] = result
        return result

    def _lin_sim(self, c1, c2, c1_anc, c2_anc):
        """Lin similarity between two CUIs given precomputed ancestors."""
        if c1 == c2:
            return 1.0, c1, "exact"
        ic1 = self.ic_map.get(c1, 0.0)
        ic2 = self.ic_map.get(c2, 0.0)
        denom = ic1 + ic2
        if denom < 1e-9:
            return 0.0, None, "no_match"
        # subsumption (one IS the ancestor of the other)
        if c1 in c2_anc:
            mica_ic = ic1
            if mica_ic >= _IC_MIN:
                return min(2.0 * mica_ic / denom, 1.0), c1, "subsumption"
        if c2 in c1_anc:
            mica_ic = ic2
            if mica_ic >= _IC_MIN:
                return min(2.0 * mica_ic / denom, 1.0), c2, "subsumption"
        # shared ancestor — MICA
        shared = c1_anc & c2_anc
        if not shared:
            return 0.0, None, "no_match"
        # A real shared ancestor must be LESS specific (lower IC) than both CUIs.
        # "Terminal bronchus" (high IC) cannot be ancestor of "Seizure" — that's
        # a cross-domain UMLS artifact from walking to root through coding systems.
        min_ic = min(ic1, ic2)
        valid = [c for c in shared if self.ic_map.get(c, 0.0) < min_ic]
        if not valid:
            return 0.0, None, "no_match"
        mica = max(valid, key=lambda c: self.ic_map.get(c, 0.0))
        mica_ic = self.ic_map.get(mica, 0.0)
        if mica_ic < _IC_MIN:
            return 0.0, None, "no_match"
        return min(2.0 * mica_ic / denom, 1.0), mica, "shared_ancestor"

    def match(self, query_cuis, query_embedding, chunks, top_k=10):
        """Match query against stored chunks using three signals.

        CUI matches are weighted by IDF (inverse document frequency).
        A CUI appearing in every chunk has IDF=0 — no discriminative power.
        A CUI appearing in 1 chunk has high IDF — strong signal.

        Args:
            query_cuis: list/set of query CUI strings (after reduction)
            query_embedding: numpy array (centroid) or None
            chunks: dict from ChunkStore.get_all()
            top_k: max results

        Returns:
            list[ChunkMatch] sorted by score descending
        """
        t0 = time.perf_counter()
        query_cuis = set(query_cuis)
        if not query_cuis or not chunks:
            return []

        has_graph = self.graph is not None and len(self.ic_map) > 0
        n_chunks = len(chunks)

        # ── Compute IDF for each CUI across all chunks ───────────────────
        # IDF = log(N / df) where df = number of chunks containing the CUI
        # CUI in all chunks → IDF = 0 (useless). CUI in 1 chunk → IDF high.
        import math
        cui_doc_freq = {}
        for chunk_data in chunks.values():
            for cui in chunk_data.get("cuis", set()):
                cui_doc_freq[cui] = cui_doc_freq.get(cui, 0) + 1

        def idf(cui):
            df = cui_doc_freq.get(cui, 0)
            if df >= n_chunks:
                return 0.0   # in every chunk → no discriminative power
            if df == 0:
                return math.log(n_chunks + 1)  # not in any chunk → max weight (rare match)
            return math.log(n_chunks / df)

        # precompute query ancestors
        query_ancestors = {}
        if has_graph:
            for q in query_cuis:
                query_ancestors[q] = self._get_ancestors(q)

        # precompute all stored CUI ancestors (cached)
        if has_graph:
            for chunk_data in chunks.values():
                for cui in chunk_data["cuis"]:
                    self._get_ancestors(cui)

        results = []
        scored_chunk_ids = set()

        for chunk_id, chunk_data in chunks.items():
            chunk_cuis = chunk_data["cuis"]
            doc_id = chunk_data["doc_id"]
            if not chunk_cuis:
                continue

            # ── Filter: exact CUI overlap OR hierarchy (both directions) ──
            exact_overlap = query_cuis & chunk_cuis

            hierarchy_query_hits = set()  # query CUIs matched via hierarchy
            hierarchy_chunk_hits = set()  # chunk CUIs matched via hierarchy
            shared_ancestor_hits = {}     # {query_cui: (chunk_cui, mica, mica_ic)}
            if has_graph and len(exact_overlap) < len(query_cuis):
                unmatched_query = query_cuis - exact_overlap
                for q_cui in unmatched_query:
                    q_anc = query_ancestors.get(q_cui, frozenset())
                    matched = False
                    for d_cui in chunk_cuis:
                        if d_cui in exact_overlap:
                            continue
                        d_anc = self._ancestor_cache.get(d_cui, frozenset())
                        # Direction 1: query CUI is ancestor of chunk CUI
                        # Direction 2: chunk CUI is ancestor of query CUI
                        if q_cui in d_anc or d_cui in q_anc:
                            hierarchy_query_hits.add(q_cui)
                            hierarchy_chunk_hits.add(d_cui)
                            matched = True
                            break
                    # Direction 3: shared ancestor (sibling match)
                    #   e.g., query "Medical-seizure" and chunk "Focal epilepsy"
                    #   both have "Seizure" as ancestor but neither is parent of other
                    if not matched:
                        best_mica_ic = 0.0
                        best_pair = None
                        q_ic = self.ic_map.get(q_cui, 0.0)
                        for d_cui in chunk_cuis:
                            if d_cui in exact_overlap:
                                continue
                            d_anc = self._ancestor_cache.get(d_cui, frozenset())
                            shared = q_anc & d_anc
                            if shared:
                                d_ic = self.ic_map.get(d_cui, 0.0)
                                min_ic = min(q_ic, d_ic)
                                # shared ancestor must be LESS specific than both CUIs
                                valid = [c for c in shared
                                         if self.ic_map.get(c, 0.0) < min_ic]
                                if valid:
                                    mica = max(valid, key=lambda c: self.ic_map.get(c, 0.0))
                                    mica_ic = self.ic_map.get(mica, 0.0)
                                    if mica_ic > best_mica_ic:
                                        best_mica_ic = mica_ic
                                        best_pair = (d_cui, mica, mica_ic)
                        # only accept if shared ancestor is specific enough (IC > 4.0)
                        if best_pair and best_mica_ic >= _IC_MIN_SIBLING:
                            hierarchy_query_hits.add(q_cui)
                            hierarchy_chunk_hits.add(best_pair[0])
                            shared_ancestor_hits[q_cui] = best_pair

            all_matched_chunk_cuis = exact_overlap | hierarchy_chunk_hits
            if not (exact_overlap or hierarchy_query_hits):
                continue

            scored_chunk_ids.add(chunk_id)

            # ── Signal 1: IDF-weighted CUI overlap (W=0.40) ────────────────
            # CUIs appearing in every chunk have IDF=0 — no discriminative power.
            # CUIs appearing in 1 chunk have high IDF — strong signal.
            matched_query_cuis = set(exact_overlap)
            if has_graph:
                for q_cui in query_cuis - exact_overlap:
                    q_anc = query_ancestors.get(q_cui, frozenset())
                    found = False
                    for d_cui in chunk_cuis:
                        d_anc = self._ancestor_cache.get(d_cui, frozenset())
                        if q_cui in d_anc or d_cui in q_anc:
                            matched_query_cuis.add(q_cui)
                            found = True
                            break
                    # count sibling matches (shared ancestor) if parent-child didn't fire
                    if not found and q_cui in shared_ancestor_hits:
                        matched_query_cuis.add(q_cui)

            idf_matched = sum(idf(q) for q in matched_query_cuis)
            idf_total = sum(idf(q) for q in query_cuis)
            if idf_total > 0:
                cui_ratio = min(idf_matched / idf_total, 1.0)
            else:
                # all query CUIs in every chunk → simple count fallback
                cui_ratio = len(matched_query_cuis) / len(query_cuis)
            matched_query_count = len(matched_query_cuis)

            # ── Signal 2: Vector similarity (W=0.30) ─────────────────────
            vector_sim = 0.0
            chunk_emb = chunk_data.get("embedding")
            has_vectors = query_embedding is not None and chunk_emb is not None
            if has_vectors:
                vector_sim = float(np.dot(query_embedding, chunk_emb))
                vector_sim = max(0.0, min(1.0, vector_sim))
                # sharpen: cube to increase spread between similar scores
                # 0.78 → 0.47, 0.69 → 0.33. Difference grows from 0.09 to 0.14
                vector_sim = vector_sim ** 3

            # ── Signal 3: Lin similarity — IDF-weighted BMA (W=0.30) ──────
            lin_details = []
            lin_weighted_sum = 0.0
            lin_weight_total = 0.0
            if has_graph:
                for q_cui in query_cuis:
                    q_anc = query_ancestors.get(q_cui, frozenset())
                    best_lin = 0.0
                    best_detail = CUIMatchDetail(q_cui, None, None, 0.0, "no_match")
                    if q_cui in chunk_cuis:
                        best_lin = 1.0
                        best_detail = CUIMatchDetail(q_cui, q_cui, q_cui, 1.0, "exact")
                    else:
                        for d_cui in chunk_cuis:
                            d_anc = self._ancestor_cache.get(d_cui, frozenset())
                            lin, mica, mtype = self._lin_sim(q_cui, d_cui, q_anc, d_anc)
                            if lin > best_lin:
                                best_lin = lin
                                best_detail = CUIMatchDetail(
                                    q_cui, d_cui, mica, round(lin, 4), mtype)
                                if lin >= 1.0:
                                    break
                    w = idf(q_cui)
                    lin_weighted_sum += best_lin * w
                    lin_weight_total += w
                    lin_details.append(best_detail)
                lin_avg = (lin_weighted_sum / lin_weight_total) if lin_weight_total > 0 else 0.0
            else:
                lin_avg = len(exact_overlap) / len(query_cuis)

            # ── Combined score ────────────────────────────────────────────
            if has_vectors and has_graph:
                score = (_W_CUI * cui_ratio +
                         _W_VEC * vector_sim +
                         _W_LIN * lin_avg)
            elif has_vectors:
                score = 0.5 * cui_ratio + 0.5 * vector_sim
            elif has_graph:
                score = 0.5 * cui_ratio + 0.5 * lin_avg
            else:
                score = cui_ratio

            if score < _SCORE_MIN:
                continue

            # ── Topic grouping ────────────────────────────────────────────
            topics_matched = {}
            stored_topics = chunk_data.get("topics", {})
            if stored_topics:
                for tid, t_info in stored_topics.items():
                    topic_members = set(t_info.get("members", []))
                    hits = all_matched_chunk_cuis & topic_members
                    if hits:
                        topics_matched[tid] = {
                            "topic_cui": t_info.get("topic_cui"),
                            "matched_cuis": sorted(hits),
                            "total_members": len(topic_members),
                        }

            lin_details.sort(key=lambda d: (-d.lin_sim, d.match_type != "exact"))

            results.append(ChunkMatch(
                chunk_id=chunk_id,
                document_id=doc_id,
                score=round(score, 4),
                cui_overlap=matched_query_count,
                cui_overlap_ratio=round(cui_ratio, 4),
                vector_sim=round(vector_sim, 4),
                lin_score=round(lin_avg, 4),
                total_chunk_cuis=len(chunk_cuis),
                total_query_cuis=len(query_cuis),
                overlapping_cuis=sorted(matched_query_cuis),
                topics_matched=topics_matched,
                lin_details=lin_details
            ))

        results.sort(key=lambda r: (-r.score, -r.cui_overlap, r.chunk_id))

        # ── Pass 2: Vector fallback for remaining slots ──────────────
        # If CUI filter found fewer than top_k, fill with vector-similar chunks.
        # These have no CUI match but high embedding similarity.
        if query_embedding is not None and len(results) < top_k:
            vector_candidates = []
            for chunk_id, chunk_data in chunks.items():
                if chunk_id in scored_chunk_ids:
                    continue
                chunk_emb = chunk_data.get("embedding")
                if chunk_emb is None:
                    continue
                vsim = float(np.dot(query_embedding, chunk_emb))
                vsim = max(0.0, min(1.0, vsim))
                if vsim >= 0.4:   # minimum vector similarity for fallback
                    vector_candidates.append((chunk_id, chunk_data, vsim))
            vector_candidates.sort(key=lambda x: -x[2])

            for chunk_id, chunk_data, vsim in vector_candidates[:top_k - len(results)]:
                results.append(ChunkMatch(
                    chunk_id=chunk_id,
                    document_id=chunk_data["doc_id"],
                    score=round(0.30 * vsim, 4),  # vector weight only
                    cui_overlap=0,
                    cui_overlap_ratio=0.0,
                    vector_sim=round(vsim, 4),
                    lin_score=0.0,
                    total_chunk_cuis=len(chunk_data.get("cuis", set())),
                    total_query_cuis=len(query_cuis),
                    overlapping_cuis=[],
                    topics_matched={},
                    lin_details=[]
                ))

        elapsed = (time.perf_counter() - t0) * 1000
        logger.debug(f"    ChunkMatcher: {len(chunks)} chunks → "
                     f"{len(results)} matches ({elapsed:.1f}ms)")
        return results[:top_k]

    @staticmethod
    def explain(result, terms=None):
        """Human-readable explanation."""
        terms = terms or {}
        lines = [
            f"Chunk: {result.chunk_id}  Doc: {result.document_id}",
            f"  Score: {result.score:.3f}  "
            f"(CUI: {result.cui_overlap_ratio:.2f}, "
            f"Vec: {result.vector_sim:.3f}, "
            f"Lin: {result.lin_score:.3f})"
        ]
        if result.topics_matched:
            for tid, t_info in sorted(result.topics_matched.items()):
                t_cui = t_info.get("topic_cui")
                t_label = terms.get(t_cui, t_cui) if t_cui else "(ungrouped)"
                hit_names = [terms.get(c, c) for c in t_info["matched_cuis"]]
                lines.append(
                    f"  Topic {tid} [{t_label}]: "
                    f"{len(t_info['matched_cuis'])}/{t_info['total_members']} CUIs hit "
                    f"({', '.join(hit_names)})")
        if result.overlapping_cuis:
            cui_names = [terms.get(c, c) for c in result.overlapping_cuis]
            lines.append(f"  Exact CUIs: {', '.join(cui_names)}")
        for d in result.lin_details:
            if d.match_type == "exact":
                continue
            if d.match_type == "no_match":
                q_term = terms.get(d.query_cui, d.query_cui)
                lines.append(f"    ✗ {q_term} — no hierarchy match")
            else:
                q_term = terms.get(d.query_cui, d.query_cui)
                d_term = terms.get(d.chunk_cui, d.chunk_cui) if d.chunk_cui else "?"
                mica_term = terms.get(d.mica_cui, d.mica_cui) if d.mica_cui else "?"
                lines.append(
                    f"    ~ {d.match_type} (Lin={d.lin_sim:.3f}): "
                    f"{q_term} ↔ {d_term} via [{mica_term}]")
        return "\n".join(lines)
