"""
Query Runner — CUI Filter + Vector + Lin Scoring.

Takes clinical query text, reduces, matches against stored chunks.

Usage:
    python run_query.py

Flow:
    Query text → CUI extraction → Stages 1-4 reduction (fast)
    → Fetch embeddings for surviving CUIs → Compute centroid
    → CUI filter + hierarchy subsumption → candidates
    → Three-signal scoring → Ranked chunks
    → LLM reasoning (optional)
"""

import os
import csv
import time

from google.cloud import bigquery

from config import (
    PROJECT_ID, DATASET_ID, EMBEDDING_TABLE, CACHE_DIR, ALLOWED_SABS,
    API_URL, TOP_K, TOP_P, CLUSTER_SET, COMBINED, OUTPUT_DIR,
    LLM_PROJECT_ID, LLM_LOCATION, LLM_MODEL, LLM_MAX_TOKENS,
    hierarchy, ic_precomputed
)
from cui_reduction_system import CUIReductionSystem, CUIExtractor, fetch_preferred_terms
from topic_matcher import ChunkStore, ChunkMatcher, compute_centroid

_LLM_TOP_K = 3  # top chunks sent for reasoning


# ── Setup (runs once) ────────────────────────────────────────────────────────

os.makedirs(OUTPUT_DIR, exist_ok=True)
bq = bigquery.Client(project=PROJECT_ID)

system = CUIReductionSystem(
    project_id=PROJECT_ID, dataset_id=DATASET_ID,
    full_network=hierarchy, allowed_sabs=ALLOWED_SABS,
    embedding_table=EMBEDDING_TABLE, ic_scores=ic_precomputed,
    cache_dir=CACHE_DIR)

extractor = CUIExtractor(
    api_url=API_URL, top_k=TOP_K, top_p=TOP_P,
    cluster_set=CLUSTER_SET, combined=COMBINED,
    cache_dir=CACHE_DIR)

matcher = ChunkMatcher(hierarchy, ic_precomputed)


# ── Term lookup ──────────────────────────────────────────────────────────────

_fetch_terms = lambda cuis: fetch_preferred_terms(bq, PROJECT_ID, DATASET_ID, cuis)


# ── Query processing ─────────────────────────────────────────────────────────

def process_query(query_text):
    """Extract CUIs and reduce for query.

    Returns:
        dict with: surviving_cuis, terms
        or None if nothing extracted
    """
    print(f"\n{'='*80}")
    print(f"QUERY: {query_text}")
    print(f"{'='*80}")

    # extract
    print(f"  → Extracting CUIs...", flush=True)
    per_phrase = extractor.extract([query_text], [query_text])
    extractor._cache.flush()

    if not per_phrase:
        print(f"  → No CUIs extracted")
        return None

    total_cuis = sum(len(cd) for cd in per_phrase.values())
    print(f"  → Extracted: {total_cuis} CUIs", flush=True)

    # reduce (stages 1-4: metadata, IC, SAB filter, hierarchy reduce)
    print(f"  → Reducing (stages 1-4)...", flush=True)
    all_raw_cuis = []
    for cd in per_phrase.values():
        all_raw_cuis.extend(cd.keys())
    surviving = system.reduce_query(all_raw_cuis)

    if not surviving:
        print(f"  → No CUIs survived reduction")
        return None

    print(f"  → Surviving: {len(surviving)} CUIs (from {total_cuis} raw)", flush=True)

    # fetch embeddings for ONLY surviving CUIs (5-10 CUIs, one small BQ call)
    # then compute centroid for vector similarity signal
    print(f"  → Fetching embeddings for {len(surviving)} surviving CUIs...", flush=True)
    query_embeddings = system.emb_fetcher.fetch(list(surviving))
    query_embedding = compute_centroid(surviving, query_embeddings)

    # terms
    terms = _fetch_terms(surviving)
    for cui in surviving:
        print(f"      {cui} | {terms.get(cui, cui)}")

    return {
        "surviving_cuis": surviving,
        "embedding": query_embedding,
        "terms": terms,
    }


# ── Full query → ranked chunks ───────────────────────────────────────────────

def run_query(query_text, store_path=None, top_k=10):
    """Run a clinical query against stored chunks.

    Args:
        query_text: clinical question in free text
        store_path: path to chunk_store.pkl
        top_k: max results

    Returns:
        tuple (list[ChunkMatch], dict of terms) or None
    """
    t0 = time.perf_counter()

    # load stored chunks
    store_path = store_path or os.path.join(OUTPUT_DIR, "chunk_store.pkl")
    if not os.path.exists(store_path):
        print(f"ERROR: chunk store not found at {store_path}")
        print(f"  → Run run_cui_reduction.py first to build the store")
        return None

    store = ChunkStore.load(store_path)
    chunks = store.get_all()
    if not chunks:
        print(f"ERROR: no chunks in store")
        return None

    stats = store.stats()
    print(f"\nStore: {stats['chunks']} chunks, {stats['total_cuis']} stored CUIs, "
          f"{stats['chunks_with_embeddings']} with embeddings")

    # process query
    query_result = process_query(query_text)
    if not query_result:
        return None

    query_cuis = query_result["surviving_cuis"]
    query_embedding = query_result["embedding"]
    terms = query_result["terms"]

    # match (three signals: CUI overlap + vector cosine + Lin similarity)
    print(f"\n  → Matching against {len(chunks)} chunks...", flush=True)
    results = matcher.match(query_cuis, query_embedding, chunks, top_k=top_k)

    # fetch terms for matched CUIs, topic labels, and Lin details
    all_cuis_to_resolve = set()
    for r in results:
        all_cuis_to_resolve.update(r.overlapping_cuis)
        for tid, t_info in r.topics_matched.items():
            if t_info.get("topic_cui"):
                all_cuis_to_resolve.add(t_info["topic_cui"])
            all_cuis_to_resolve.update(t_info.get("matched_cuis", []))
        for d in r.lin_details:
            if d.chunk_cui:
                all_cuis_to_resolve.add(d.chunk_cui)
            if d.mica_cui:
                all_cuis_to_resolve.add(d.mica_cui)
            all_cuis_to_resolve.add(d.query_cui)
    missing = all_cuis_to_resolve - set(terms.keys())
    if missing:
        terms.update(_fetch_terms(missing))

    elapsed = (time.perf_counter() - t0) * 1000

    # display results
    print(f"\n{'='*80}")
    print(f"RESULTS: {len(results)} chunks matched ({elapsed:.0f}ms total)")
    print(f"{'='*80}\n")

    if not results:
        print("  No matching chunks found.")
    else:
        for rank, r in enumerate(results, 1):
            print(f"  #{rank}  {ChunkMatcher.explain(r, terms)}")
            print()

    return results, terms, chunks


# ── LLM Reasoning ────────────────────────────────────────────────────────────

def build_reasoning_prompt(query_text, results, chunks, terms, top_k=_LLM_TOP_K):
    """Build a structured prompt for LLM to reason about match quality.

    Args:
        query_text: original clinical query
        results: list of ChunkMatch from matcher
        chunks: dict from ChunkStore.get_all()
        terms: dict {cui: preferred_term}
        top_k: how many top results to include

    Returns:
        str — the prompt for LLM
    """
    sections = []
    for rank, r in enumerate(results[:top_k], 1):
        chunk_data = chunks.get(r.chunk_id, {})
        chunk_text = chunk_data.get("text", "(text not available)")

        # match explanation
        match_explain = ChunkMatcher.explain(r, terms)

        # surviving CUIs in this chunk with terms
        chunk_cui_list = ", ".join(
            f"{c} ({terms.get(c, c)})" for c in sorted(chunk_data.get("cuis", set()))
        )

        sections.append(
            f"--- CHUNK #{rank} ---\n"
            f"Chunk ID: {r.chunk_id}\n"
            f"Document: {r.document_id}\n"
            f"Score: {r.score:.3f} (CUI overlap={r.cui_overlap_ratio:.2f}, "
            f"Lin={r.lin_score:.3f})\n\n"
            f"Clinical Text:\n{chunk_text}\n\n"
            f"Medical Concepts (after CUI reduction):\n{chunk_cui_list}\n\n"
            f"Match Analysis:\n{match_explain}"
        )

    # query CUIs
    query_cuis_str = ", ".join(
        f"{c} ({terms.get(c, c)})" for c in sorted(
            set(d.query_cui for r in results[:top_k] for d in r.lin_details)
        )
    )

    prompt = f"""You are a clinical information retrieval expert. Analyze the following query and retrieved document chunks.

CLINICAL QUERY: {query_text}

QUERY CONCEPTS (after CUI extraction and reduction):
{query_cuis_str}

RETRIEVED CHUNKS (ranked by relevance):

{chr(10).join(sections)}

INSTRUCTIONS:
1. For each retrieved chunk, explain WHY it matches the query from a clinical perspective. Reference specific medical concepts, not just CUI codes.
2. Identify which chunk BEST answers the query and explain your clinical reasoning.
3. Note any important clinical concepts from the query that are NOT covered by any retrieved chunk.
4. Rate the overall retrieval quality: Excellent / Good / Fair / Poor, with justification.

Provide your analysis in clear, structured prose."""

    return prompt


def llm_reason(query_text, results, chunks, terms, top_k=_LLM_TOP_K):
    """Call Vertex AI LLM to reason about match quality.

    Uses your GCP project — same credentials as BigQuery.
    Set LLM_PROJECT_ID, LLM_LOCATION, LLM_MODEL in config.py.

    Args:
        query_text: original clinical query
        results: list of ChunkMatch
        chunks: dict from ChunkStore.get_all()
        terms: dict {cui: preferred_term}
        top_k: how many top results to reason about

    Returns:
        str — LLM reasoning text, or prompt string if API fails
    """
    if not results:
        return "No chunks matched the query. Cannot reason about matches."

    prompt = build_reasoning_prompt(query_text, results, chunks, terms, top_k)

    try:
        from google.cloud import aiplatform
        from vertexai.generative_models import GenerativeModel

        aiplatform.init(project=LLM_PROJECT_ID, location=LLM_LOCATION)
        model = GenerativeModel(LLM_MODEL)
        response = model.generate_content(
            prompt,
            generation_config={
                "max_output_tokens": LLM_MAX_TOKENS,
                "temperature": 0.2,
            }
        )
        reasoning = response.text
        return reasoning

    except ImportError:
        print("\n  LLM reasoning skipped (install: pip install google-cloud-aiplatform)")
        print(f"\n  Prompt ({len(prompt)} chars) saved for manual use.")
        return prompt
    except Exception as e:
        print(f"\n  LLM reasoning failed: {e}")
        return prompt


# ── main ─────────────────────────────────────────────────────────────────────

if __name__ == "__main__":

    STORE_PATH = os.path.join(OUTPUT_DIR, "chunk_store.pkl")

    QUERIES = [
        "left knee osteoarthritis treatment with methotrexate",
        "rheumatoid arthritis of knee",
        "elevated CRP and ESR",
        "methotrexate side effects",
    ]

    # run all queries, collect for CSV
    all_rows = []
    all_reasoning = {}

    for query_text in QUERIES:
        result = run_query(query_text, STORE_PATH, top_k=5)
        if result:
            results, terms, chunks = result

            # LLM reasoning
            print(f"\n{'='*80}")
            print("LLM REASONING")
            print(f"{'='*80}")
            reasoning = llm_reason(query_text, results, chunks, terms)
            if reasoning:
                all_reasoning[query_text] = reasoning
                # if it's actual LLM output (not the prompt), print it
                if not reasoning.startswith("You are a clinical"):
                    print(reasoning)
                    print()

            for rank, r in enumerate(results, 1):
                topic_parts = []
                for tid, t_info in sorted(r.topics_matched.items()):
                    t_cui = t_info.get("topic_cui")
                    t_label = terms.get(t_cui, t_cui) if t_cui else ""
                    hit_names = [terms.get(c, c) for c in t_info["matched_cuis"]]
                    topic_parts.append(f"{t_label}({', '.join(hit_names)})")

                matched_names = [terms.get(c, c) for c in r.overlapping_cuis]
                all_rows.append([
                    query_text, rank, r.chunk_id, r.document_id,
                    r.score, r.cui_overlap, r.cui_overlap_ratio,
                    r.lin_score, r.total_chunk_cuis,
                    " | ".join(topic_parts),
                    " | ".join(matched_names)
                ])

    if all_rows:
        csv_path = os.path.join(OUTPUT_DIR, "query_results.csv")
        with open(csv_path, "w", newline="") as f:
            w = csv.writer(f)
            w.writerow(["query", "rank", "chunk_id", "document_id",
                         "score", "cui_overlap", "cui_overlap_ratio",
                         "lin_score", "total_chunk_cuis",
                         "topics_hit", "matched_cuis"])
            w.writerows(all_rows)
        print(f"\n{'='*80}")
        print(f"Results saved to {csv_path}")

    # save LLM reasoning
    if all_reasoning:
        reasoning_path = os.path.join(OUTPUT_DIR, "query_reasoning.txt")
        with open(reasoning_path, "w") as f:
            for query_text, reasoning in all_reasoning.items():
                f.write(f"{'='*80}\n")
                f.write(f"QUERY: {query_text}\n")
                f.write(f"{'='*80}\n\n")
                f.write(reasoning)
                f.write(f"\n\n")
        print(f"Reasoning saved to {reasoning_path}")

    print(f"\nDONE — {len(QUERIES)} queries processed")
