"""
Wraps CUI reduction stages 2-5 into a standalone summarization module.
Input: raw CUI codes. Output: concise set + metrics + optional network graph.
"""

import os, time, pickle, logging
import numpy as np
import networkx
from google.cloud import bigquery

from cui_core import (
    MetadataFetcher, ICComputer, SABFilter, HierarchyReducer,
    EmbeddingFetcher, EmbeddingReducer, AuditEntry,
    _compute_ancestor_depth, _clear_ancestor_cache,
    fetch_preferred_terms,
)

log = logging.getLogger("cui_summarizer")
log.setLevel(logging.INFO)
log.propagate = False
if not log.handlers:
    log.addHandler(logging.StreamHandler())


class CUISummarizer:

    def __init__(self, project_id, dataset_id, hierarchy_path, ic_path,
                 embedding_table="cui_embeddings"):
        with open(hierarchy_path, "rb") as f:
            self._graph = pickle.load(f)
        with open(ic_path, "rb") as f:
            self._ic_pre = pickle.load(f)

        self._bq = bigquery.Client(project=project_id)
        self._pid = project_id
        self._did = dataset_id
        self._meta = MetadataFetcher(self._bq, project_id, dataset_id)
        self._ic = ICComputer(self._graph, self._ic_pre)
        self._hier = HierarchyReducer(self._graph)
        self._emb = EmbeddingFetcher(self._bq, project_id, dataset_id, embedding_table)
        self._depth = _compute_ancestor_depth(self._graph)

    def summarize(self, cuis, sources=None, return_network_object=False):
        """
        cuis:    list of CUI strings
        sources: optional vocab filter, e.g. ["SNOMEDCT_US"]. None = keep all.
        return_network_object: include node/edge graph in output
        """
        t0 = time.perf_counter()
        _clear_ancestor_cache()

        if not cuis:
            return self._empty(return_network_object)

        cuis = list(dict.fromkeys(cuis))
        n_in = len(cuis)
        audit = []

        # metadata + IC + terms
        metadata = self._meta.fetch(cuis)
        ic_map = self._ic.compute(cuis, metadata)
        terms = fetch_preferred_terms(self._bq, self._pid, self._did, cuis)

        # source filter
        if sources:
            after_src, a = SABFilter(set(sources)).run(cuis, metadata)
            audit += a
        else:
            after_src = [c for c in cuis if c in metadata]
            audit += [AuditEntry(c, "", "no_metadata", "not in BQ")
                      for c in cuis if c not in metadata]
        n_src = len(after_src)

        if not after_src:
            return self._build(cuis, [], audit, metadata, ic_map, terms,
                               set(), return_network_object,
                               n_src, 0, 0, self._ms(t0))

        # hierarchy reduction
        after_hier, a, hier_edges = self._hier.run(after_src, ic_map, metadata)
        audit += a
        n_hier = len(after_hier)

        # nothing left to dedup
        if len(after_hier) <= 1:
            return self._build(cuis, after_hier, audit, metadata, ic_map, terms,
                               hier_edges, return_network_object,
                               n_src, n_hier, n_hier, self._ms(t0))

        # embedding dedup
        embeddings = self._emb.fetch(after_hier)
        n_with_emb = sum(1 for c in after_hier if c in embeddings)
        if n_with_emb <= 1:
            after_emb = after_hier
        else:
            _, after_emb, a = EmbeddingReducer.run(
                after_hier, metadata, embeddings, ic_map,
                hier_edges, self._graph, self._depth)
            audit += a
        n_emb = len(after_emb)

        ms = self._ms(t0)
        log.info(f"{n_in} -> src:{n_src} -> hier:{n_hier} -> emb:{n_emb} ({ms:.0f}ms)")

        return self._build(cuis, after_emb, audit, metadata, ic_map, terms,
                           hier_edges, return_network_object,
                           n_src, n_hier, n_emb, ms)

    # --- result assembly ---

    def _build(self, input_cuis, output, audit, meta, ic, terms,
               hier_edges, want_net, n_src, n_hier, n_emb, ms):
        n_in = len(input_cuis)
        out_set = set(output)

        concise = [self._cui(c, meta, ic, terms) for c in output]

        removed, seen = [], set()
        for e in audit:
            if e.removed_cui and e.removed_cui not in seen:
                seen.add(e.removed_cui)
                d = self._cui(e.removed_cui, meta, ic, terms)
                d["reason"] = e.reason
                d["retained_by"] = e.kept_cui or ""
                removed.append(d)

        retention = self._retention(input_cuis, out_set, audit, ic)

        result = {
            "concise_cuis": concise,
            "removed_cuis": removed,
            "metrics": {
                "input_code_count": n_in,
                "output_code_count": len(output),
                "information_retention_score": round(retention, 4),
                "reduction_ratio": round(len(output) / n_in, 4) if n_in else 0.0,
                "stages": {
                    "input": n_in,
                    "after_source_filter": n_src,
                    "after_hierarchy": n_hier,
                    "after_embedding_dedup": n_emb,
                },
                "processing_time_ms": round(ms, 1),
            },
            "network_object": None,
        }

        if want_net:
            result["network_object"] = self._net(
                input_cuis, out_set, hier_edges, meta, ic, audit, terms)

        return result

    def _empty(self, want_net):
        z = {"input_code_count": 0, "output_code_count": 0,
             "information_retention_score": 0.0, "reduction_ratio": 0.0,
             "stages": {"input": 0, "after_source_filter": 0,
                        "after_hierarchy": 0, "after_embedding_dedup": 0},
             "processing_time_ms": 0.0}
        net = {"nodes": [], "edges": [], "node_count": 0, "edge_count": 0} if want_net else None
        return {"concise_cuis": [], "removed_cuis": [], "metrics": z, "network_object": net}

    # --- helpers ---

    @staticmethod
    def _cui(cui, meta, ic, terms):
        m = meta.get(cui)
        return {
            "cui": cui,
            "preferred_term": terms.get(cui, cui),
            "ic": round(ic.get(cui, 0.0), 4),
            "semantic_types": list(m.semantic_types) if m and m.semantic_types else [],
        }

    @staticmethod
    def _retention(inputs, out_set, audit, ic):
        if not inputs:
            return 0.0
        total = sum(ic.get(c, 0.0) for c in inputs)
        if total <= 0:
            return 0.0
        kept_by = {e.removed_cui: e.kept_cui
                   for e in audit if e.removed_cui and e.kept_cui}
        ret = 0.0
        for c in inputs:
            v = ic.get(c, 0.0)
            if c in out_set:
                ret += v
            elif c in kept_by:
                ret += min(ic.get(kept_by[c], 0.0), v)
        return min(ret / total, 1.0)

    @staticmethod
    def _net(inputs, out_set, edges, meta, ic, audit, terms):
        cui_set = set(inputs)
        kept_by = {e.removed_cui: e.kept_cui
                   for e in audit if e.removed_cui and e.kept_cui}
        reasons = {e.removed_cui: e.reason for e in audit if e.removed_cui}

        nodes = []
        for c in inputs:
            m = meta.get(c)
            n = {"cui": c,
                 "preferred_term": terms.get(c, c),
                 "ic": round(ic.get(c, 0.0), 4),
                 "semantic_types": list(m.semantic_types) if m and m.semantic_types else [],
                 "source_vocabs": list(m.source_vocabs) if m and m.source_vocabs else [],
                 "is_selected": c in out_set}
            if c not in out_set:
                n["removal_reason"] = reasons.get(c, "unknown")
                n["retained_by"] = kept_by.get(c, "")
            nodes.append(n)

        edge_list = [{"source": p, "target": ch, "relationship": "parent_child",
                      "source_ic": round(ic.get(p, 0.0), 4),
                      "target_ic": round(ic.get(ch, 0.0), 4)}
                     for p, ch in edges if p in cui_set and ch in cui_set]

        return {"nodes": nodes, "edges": edge_list,
                "node_count": len(nodes), "edge_count": len(edge_list)}

    @staticmethod
    def _ms(t0):
        return (time.perf_counter() - t0) * 1000

    def close(self):
        self._emb.close()
