async def screen_comment(response_id: int, response_text: str, semaphore: asyncio.Semaphore) -> dict:
    """
    Asynchronously screens a student comment and extracts detailed information if flagged.
    """
    async with semaphore:
        # This is a high-accuracy, few-shot prompt. It shows the model examples of correct behavior.
        screener_prompt = f"""
**Role:** You are an expert content moderator for a Medical Education program. Your task is to analyze student feedback and flag comments for review based on a strict set of criteria. You must perform a step-by-step reasoning process before providing a final JSON output.

**Primary Goal:** Analyze the provided student comment. If it violates any of the flagging criteria, you must extract the specific problematic phrase and classify it. If it does not, mark it as clean.

**What NOT to Flag (Important Distinctions):**
- Critiques of course structure (e.g., "The course was disorganized," "This should be a 4-week course").
- Feedback on teaching methods (e.g., "Lectures were too fast," "I prefer more small group work").
- Comments on assessment fairness (e.g., "The exam questions were not representative of the lectures").
These are considered valid, professional feedback and should **NOT** be flagged.

**Flagging Criteria & Categories:**
1.  **Unprofessional Comments on Personal Attributes:** Flag comments not relevant to teaching effectiveness. This includes critiques/compliments on physical appearance, accent (not tied to clarity), or speculation about personal life.
2.  **Potentially Biased or Discriminatory Language:** Flag any language suggesting bias against a protected group. This includes inappropriate mentions of race, ethnicity, gender identity, age, sexual orientation, disability, or the use of slurs.
3.  **Emotionally Charged or Unsubstantiated Claims:** Flag language that is overly emotional, hostile, or makes strong personal attacks without evidence (e.g., 'worst course ever,' 'needs to be fired,' 'antagonized us').

--- 
**Student Comment to Analyze:**
```{response_text}```
--- 

**Your Step-by-Step Reasoning Process (Chain of Thought):**
1.  **Initial Assessment:** Briefly summarize the comment's main point.
2.  **Rule Check:** Systematically check the comment against each of the three strict rules. For each rule, state "Violation" or "No Violation."
3.  **Final Conclusion:** Based on your rule check, state your final conclusion about whether the comment should be flagged. If it is flagged, identify the category and the specific text.

**Final JSON Output:**
After your reasoning, provide a single, valid JSON object with the final verdict.

--- 
**EXAMPLE 1 (FLAGGED - Discriminatory Language)**
**Student Comment to Analyze:**
"During the AML small group, the leader referred to a cell that is laden with Auer bodies as f*ggot cells. It was mentioned upwards of 5-7 times... I understand that this is the actual name for the cells, but it is also a violent slur..."

**Reasoning:**
1.  **Initial Assessment:** The student is reporting the use of a violent slur by a group leader.
2.  **Rule Check:**
    - Unprofessional Comments on Personal Attributes: No Violation.
    - Potentially Biased or Discriminatory Language: Violation. The use of a slur, regardless of historical medical context, is discriminatory and creates a hostile environment.
    - Emotionally Charged or Unsubstantiated Claims: No Violation. The student is providing a factual report.
3.  **Final Conclusion:** The comment reports a clear violation of Rule 2. It must be flagged for immediate review.

**Final JSON Output:**
```json
{{
  "is_inappropriate": true,
  "full_student_comment": "During the AML small group, the leader referred to a cell that is laden with Auer bodies as f*ggot cells. It was mentioned upwards of 5-7 times... I understand that this is the actual name for the cells, but it is also a violent slur...",
  "flagged_content": "referred to a cell that is laden with Auer bodies as f*ggot cells",
  "category_of_concern": "Potentially Biased or Discriminatory Language",
  "reviewer_notes": "High Priority: Reports use of a violent slur by faculty."
}}
```

--- 
**EXAMPLE 2 (FLAGGED - Emotionally Charged)**
**Student Comment to Analyze:**
"Overall, this was the worst course I have taken at Mayo. I actually found the basic content interesting from neuro... but Dr. Hoerth's approach/presentation as the course director made the course feel like a chore... he had already antagonized us as students so much that he was not willing to listen to us."

**Reasoning:**
1.  **Initial Assessment:** The student is expressing extreme dissatisfaction with the course director, using strong personal language.
2.  **Rule Check:**
    - Unprofessional Comments on Personal Attributes: No Violation.
    - Potentially Biased or Discriminatory Language: No Violation.
    - Emotionally Charged or Unsubstantiated Claims: Violation. The phrases 'worst course' and 'antagonized us' are highly emotional and constitute personal attacks rather than constructive feedback.
3.  **Final Conclusion:** The comment violates Rule 3. It should be flagged for its emotionally charged language.

**Final JSON Output:**
```json
{{
  "is_inappropriate": true,
  "full_student_comment": "Overall, this was the worst course I have taken at Mayo. I actually found the basic content interesting from neuro... but Dr. Hoerth's approach/presentation as the course director made the course feel like a chore... he had already antagonized us as students so much that he was not willing to listen to us.",
  "flagged_content": "worst course I have taken at Mayo... antagonized us as students",
  "category_of_concern": "Emotionally Charged or Unsubstantiated Claims",
  "reviewer_notes": "Comment contains strong, emotionally charged language and personal criticism."
}}
```

--- 
**EXAMPLE 3 (NOT FLAGGED)**
**Student Comment to Analyze:**
"The course organization needs a major re-work. It is evident that this course did not re-organize well into the compressed curriculum timeline. There is too much time dedicated to minutiae."

**Reasoning:**
1.  **Initial Assessment:** The student is providing a critique of the course's organization and pacing.
2.  **Rule Check:**
    - Unprofessional Comments on Personal Attributes: No Violation.
    - Potentially Biased or Discriminatory Language: No Violation.
    - Emotionally Charged or Unsubstantiated Claims: No Violation. This is a critique of the course, not a personal attack.
3.  **Final Conclusion:** The comment does not violate any rules. It is professional feedback.

**Final JSON Output:**
```json
{{
  "is_inappropriate": false,
  "full_student_comment": "The course organization needs a major re-work. It is evident that this course did not re-organize well into the compressed curriculum timeline. There is too much time dedicated to minutiae.",
  "flagged_content": null,
  "category_of_concern": null,
  "reviewer_notes": null
}}
```
"""

        default_error_output = {
            "is_inappropriate": True,
            "response_id": response_id,
            "full_student_comment": response_text,
            "flagged_content": "Error during processing",
            "category_of_concern": "System Flag",
            "reviewer_notes": "Model failed to return a valid response."
        }
        
        try:
            generation_config = GenerationConfig(temperature=0.0, top_p=0.95)
            response = await screener_model.generate_content_async(
                contents=[screener_prompt],
                generation_config=generation_config
            )

            match = re.search(r"```json\s*(\{.*?\})\s*```", response.text, re.DOTALL)
            if not match:
                match = re.search(r"(\{.*?\})", response.text, re.DOTALL)

            if not match:
                default_error_output["reviewer_notes"] = "Model Output Error: No JSON found."
                return default_error_output

            json_str = match.group(1)
            result = json.loads(json_str)
            
            result['response_id'] = response_id
            return result

        except Exception as e:
            default_error_output["reviewer_notes"] = f"Processing Error: {e}"
            return default_error_output

# --- PHASE 1: INDIVIDUAL COMMENT ANALYSIS ---
async def analyze_comment_phase1(response_text: str) -> dict or None:
    """Analyzes a single row for primary theme, sentiment, and LCME standard."""
    prompt = f"""
**Persona:** You are a data annotation expert for a medical school, familiar with LCME accreditation standards from the provided reference document.
**Task:** Analyze the single student comment below. Your goal is to extract key information into a valid JSON object.
**CRITICAL — Sentiment Classification Rules:**
- Classify sentiment based on the EVALUATIVE LANGUAGE in the comment, not the topic.
- **"Positive"**: Contains praise, approval, satisfaction, or appreciation.
- **"Negative"**: Contains criticism, dissatisfaction, complaint, or frustration.
- **"Neutral"**: Purely factual or descriptive with NO evaluative langauge.
**JSON Schema and Definitions:**
- `sentiment_label`: (String) Exactly one of: "Positive", "Negative", or "Neutral".
- `sentiment_score`: (Float) -1.0(most Negative) to 1.0(most positive). Must align with sentiment_label.
- `primary_theme`: (String) A brief, 2-5 word summary of the main point of THIS comment (e.g., "Excellent Small Group Facilitation", "Exam Question Unfairness").
- `theme_description`: (String) A concise, 2-3 sentence summary that elaborates on the `primary_theme`, capturing the core feedback.
- `potential_lcme_standard`: (String) Based on the provided LCME handbook, identify the single most relevant standard number this comment might relate to (e.g., "6.3", "8.1"). If none, return null.
---
**Analyze this single student comment:**
"{response_text}"
"""
    generation_config = GenerationConfig(temperature=0.0, seed=42)
    try:
        response = await model.generate_content_async(
            contents=[prompt, grounding_document_part],
            generation_config=generation_config,
        )
        llm_output_text = response.text
        match = re.search(r'\{.*\}', llm_output_text, re.DOTALL)
        if not match: raise ValueError("No JSON object found.")
        return json.loads(match.group(0))
    except Exception as e:
        return {"error": str(e), "original_text": response_text}

# --- PHASE 2: DOMINANT THEME SYNTHESIS ---
async def synthesize_themes_phase2(primary_themes_list: list) -> dict or None:
    """Takes a list of primary themes and synthesizes them into dominant themes."""
    
    formatted_themes = "- " + "\n- ".join(primary_themes_list)

    prompt = f"""
**Persona:** You are an expert in curriculum evaluation and meta-analysis of qualitative data.
**Task:** You are provided with a list of primary themes from thousands of student comments. Synthesize these into a small, distinct set of overarching, dominant themes.

**Instructions & Guidance:**
- Merge synonyms and abstract related concepts.
- Ensure each dominant theme you create is distinct and not redundant.
- **Crucially, align the terminology and scope of your generated themes with the following examples from medical education curriculum evaluation. These examples are a guide, not an exhaustive list; you can create new themes if the data strongly supports it and they dont fit into any of the examples below.**

**Examples of High-Quality Dominant Themes:**
- Learning Environment & Climate
- Teaching Quality & Instructional Effectiveness
- Curriculum Design & Alignment
- Assessment, Evaluation & Feedback
- Clinical Training & Experiential Learning
- Supervision, Mentorship & Coaching
- Workload, Time Demands & Efficiency
- Learner Well Being & Burnout
- Professional Identity Formation
- Interprofessional Education & Teamwork
- Diversity, Equity & Inclusion
- Learning Resources & Infrastructure
- Program Organization & Administration
- Preparedness for Practice
- Meaning, Motivation & Engagement

**Required Output:** Return a single, valid JSON object.
**JSON Schema:**
{{
  "dominant_themes": [
    {{
      "dominant_theme": "The 2-5 word name for the overarching theme (e.g., 'Clinical Training & Experiential Learning').",
      "theme_description": "A 2-3 sentence summary of what this dominant theme covers.",
      "potential_lcme_standard": "The single most relevant LCME standard for this entire theme (e.g., 'Standard 9'), or null."
    }}
  ]
}}
---
**Analyze this list of primary themes from student comments:**
{formatted_themes}
"""
    generation_config = GenerationConfig(temperature=0.0, seed=42)
    
    try:
        response = await model.generate_content_async(
            contents=[prompt, grounding_document_part],
            generation_config=generation_config
        )
        llm_output_text = response.text
        match = re.search(r'\{.*\}', llm_output_text, re.DOTALL)
        if not match: raise ValueError("No JSON object found for synthesis.")
        return json.loads(match.group(0))
    except Exception as e:
        return {"error": str(e)}

# --- PHASE 3: MAPPING TO DOMINANT THEMES ---
async def map_theme_phase3(primary_theme: str, dominant_theme_names: list) -> str or None:
    """Maps a single primary theme to the most appropriate dominant theme."""

    formatted_dominant_themes = "- " + "\n- ".join(dominant_theme_names)

    prompt = f"""
**Task:** You are given a single "Primary Theme" from a student's comment and a list of "Dominant Themes". Your task is to choose which single Dominant Theme is the best fit for the Primary Theme. Respond with only the name of the chosen Dominant Theme, nothing else.
---
**Primary Theme:** "{primary_theme}"
---
**List of Dominant Themes to choose from:**
{formatted_dominant_themes}
---
**Best Fit Dominant Theme:**
"""
    generation_config = GenerationConfig(temperature=0.0, seed=42)
    
    try:
        response = await model.generate_content_async(
            contents=[prompt],
            generation_config=generation_config
        )
        return response.text.strip()
    except Exception as e:
        return f"ERROR: {str(e)}"
    
