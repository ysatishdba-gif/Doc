class FlatRetrievalSignals(BaseModel):
    
    document_types:    str = ""
    author_roles:      str = ""
    temporal_signals:  str = ""   # renamed from temporal_scope for clarity
    content_signals:   str = ""
    clinical_setting:  str = ""
    context_sentences: List[str] = Field(default_factory=list)

    @classmethod
    def from_retrieval_context(cls, ctx: "RetrievalContext") -> "FlatRetrievalSignals":
        """Convert a structured RetrievalContext into a flat, comma-joined form."""
        def _strip(v: str) -> str:
            return v.split(" - ", 1)[0].replace("_", " ").strip() if v else ""

        def _join(lst: List[str]) -> str:
            cleaned = [_strip(v) for v in lst if v]
            return ", ".join(dict.fromkeys(cleaned))  # dedup, preserve order

        return cls(
            document_types    = _join(ctx.document_types),
            author_roles      = _join(ctx.author_roles),
            temporal_signals  = _join(ctx.temporal_scope),
            content_signals   = _join(ctx.content_signals),
            clinical_setting  = _join(ctx.clinical_setting),
            context_sentences = ctx.context_sentences or [],
        )


