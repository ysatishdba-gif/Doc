from cui_core import CUIExtractor
from cui_summarizer import CUISummarizer
from cui_topics import CUITopics

e = CUIExtractor("api-url", top_k=6, top_p=5000, combined=True)
s = CUISummarizer("project", "dataset", "hierarchy.pkl", "ic.pkl", "emb_table")
t = CUITopics("project", "dataset", "hierarchy.pkl", "ic.pkl", "emb_table")

query = "severe persistent asthma"
raw = e.extract([query], [query])
cuis = [c for d in raw.values() for c in d["cuis"]]

result = s.summarize(cuis, sources=["SNOMEDCT_US"])
topics = t.build_topics([c["cui"] for c in result["concise_cuis"]])
