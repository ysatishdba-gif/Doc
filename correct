analysis_semaphore = asyncio.Semaphore(ANALYSIS_CONCURRENT)
phase3_semaphore = asyncio.Semaphore(CONCURRENT_REQUESTS)

# Create batches of comments (reused by both Phase 0 and Phase 1)
comment_batches = []
for i in range(0, len(df), BATCH_SIZE_LLM):
    batch = df.iloc[i:i + BATCH_SIZE_LLM][['Response_ID', 'Response']].to_dict('records')
    comment_batches.append(batch)

# =============================================================================
# PARALLEL EXECUTION: Phase 0 + Phase 1 run at the SAME TIME
# =============================================================================
# Phase 0 uses screener_model → screener_semaphore
# Phase 1 uses model → analysis_semaphore
# They don't depend on each other, so running in parallel cuts wall-clock
# time nearly in half for these two phases.
# =============================================================================

print(f"\n{'='*70}")
print("Phase 0 + Phase 1: Running SCREENING and ANALYSIS in PARALLEL")
print(f"{'='*70}")
print(f"Processing {len(df)} comments in {len(comment_batches)} batches of {BATCH_SIZE_LLM}...")
print(f"  Phase 0 (screening): {SCREENER_CONCURRENT} concurrent batches → screener_model")
print(f"  Phase 1 (analysis):  {ANALYSIS_CONCURRENT} concurrent batches → model")

start_time = time.time()

# Build task lists for both phases
screening_tasks = [screen_comment_batch(batch, screener_semaphore) for batch in comment_batches]
analysis_tasks = [analyze_comment_batch(batch, analysis_semaphore) for batch in comment_batches]

# Run BOTH phases simultaneously
screening_results, analysis_results = await asyncio.gather(
    an_tqdm.gather(*screening_tasks, desc="Phase 0: Screening"),
    an_tqdm.gather(*analysis_tasks, desc="Phase 1: Analysis"),
)

elapsed = time.time() - start_time
print(f"\nPhase 0 + Phase 1 completed in {elapsed:.1f}s (ran in parallel)")

# --- Process Phase 0 results ---
screening_flat = []
for batch_result in screening_results:
    screening_flat.extend(batch_result)

df_screener = pd.DataFrame(screening_flat)
df_screener.set_index('response_id', inplace=True)
flagged_count = df_screener['is_inappropriate'].sum()
print(f"  Phase 0: Screened {len(df_screener)} comments, flagged {int(flagged_count)} as inappropriate.")

# --- Process Phase 1 results ---
analysis_flat = []
for batch_result in analysis_results:
    analysis_flat.extend(batch_result)

# Separate successful and error rows (same as original)
processed_rows = []
error_rows = []
for i, result in enumerate(analysis_flat):
    original_row = df.iloc[i].to_dict()
    if result and "error" not in result:
        original_row.update(result)
        processed_rows.append(original_row)
    else:
        original_row.update(result if result else {"error": "Unknown failure."})
        error_rows.append(original_row)

df_master = pd.DataFrame(processed_rows)
df_errors = pd.DataFrame(error_rows)
print(f"  Phase 1: Analyzed {len(df_master)} comments, {len(df_errors)} errors.")

# --- MERGE STEP 1: COMBINE THEMATIC AND SCREENER RESULTS (same as original) ---
print("\n--- Merging Screener and Thematic Analysis Results into Master Table ---")
df_master = df_master.merge(df_screener, left_on='Response_ID', right_index=True, how='left')
if 'full_student_comment' in df_master.columns:
    df_master.drop(columns=['full_student_comment'], inplace=True)
# Drop helper columns from batching
if 'comment_index' in df_master.columns:
    df_master.drop(columns=['comment_index'], inplace=True)
print("Screener data merged.")


# --- PHASE 2: Synthesize Dominant Themes (unchanged — single call) ---
print(f"\n{'='*70}")
print("PHASE 2: Synthesizing Dominant Themes")
print(f"{'='*70}")

if 'primary_theme' not in df_master.columns or df_master['primary_theme'].dropna().empty:
    print("Error: No 'primary_theme' data. Aborting.")
else:
    all_primary_themes = df_master['primary_theme'].dropna().tolist()
    sample_themes = random.sample(
        all_primary_themes, min(len(all_primary_themes), SAMPLE_SIZE_FOR_SYNTHESIS)
    )
    synthesis_result = await synthesize_themes_phase2(sample_themes)

    if not synthesis_result or 'dominant_themes' not in synthesis_result:
        print("Error: Could not synthesize dominant themes. Aborting.")
    else:
        dominant_themes_list = synthesis_result.get('dominant_themes', [])
        dominant_theme_names = [t['dominant_theme'] for t in dominant_themes_list]
        description_lookup = {
            t['dominant_theme']: t['theme_description'] for t in dominant_themes_list
        }
        print(f"Phase 2 Complete: Identified {len(dominant_theme_names)} dominant themes.")

        # --- PHASE 3: Map to Dominant Themes ---
        print(f"\n{'='*70}")
        print("PHASE 3: Mapping Comments to Dominant Themes")
        print(f"{'='*70}")

        primary_themes_to_map = df_master['primary_theme'].fillna("Unknown").tolist()

        print("Using BATCHED LLM mapping with deduplication...")
        mapping_results = await map_themes_batched_llm(
            primary_themes_to_map, dominant_theme_names, phase3_semaphore,
            batch_size=PHASE3_BATCH_SIZE
        )

        df_master['Dominant_Theme'] = mapping_results
        df_master['Dominant_Theme_Description'] = df_master['Dominant_Theme'].map(
            description_lookup
        )
        print(f"Phase 3 Complete: All {len(df_master)} comments mapped.")


