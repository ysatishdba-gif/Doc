python3 -c "
import pickle
with open('umls_hierarchy.pkl', 'rb') as f:
    g = pickle.load(f)
with open('medlineplus.pkl', 'rb') as f:
    mp = pickle.load(f)

members = ['C0348819', 'C4039294', 'C4040055', 'C4040662', 'C4041037']
print('C0004096 in MedlinePlus?', 'C0004096' in mp)
print()
for m in members:
    print(f'{m}:')
    parents = list(g.predecessors(m))
    for p in parents:
        mark = ' <- MEDLINEPLUS' if p in mp else ''
        print(f'  hop1: {p}{mark}')
"
