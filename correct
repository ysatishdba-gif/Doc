# EXTRACTION RESULT  -holds all intermediate data; emits all format views


class ExtractionResult:

    def __init__(self,
                 original_query: str,
                 expansion: QueryExpansionOutput,
                 intents: IntentExtractionOutput,
                 context: Optional[ContextualEnvironmentOutput],
                 processing_time: float):
        self.original_query = original_query
        self.expansion = expansion
        self.intents = intents
        self.context = context
        self.processing_time = processing_time
        self.timestamp = datetime.utcnow().isoformat()

    # helpers

    @staticmethod
    def _clean(v: str) -> str:
        if not v:
            return ""
        if " - " in v:
            k, d = v.split(" - ", 1)
            return k.replace("_", " ") + " - " + d
        return v.replace("_", " ")

    @staticmethod
    def _pfx(v: str) -> str:
        if not v:
            return ""
        return (v.split(" - ", 1)[0].replace("_", " ")
                if " - " in v else v.replace("_", " "))

    @staticmethod
    def _join(items: List[str]) -> str:
        parts = [ExtractionResult._pfx(v) for v in (items or []) if v]
        if not parts:
            return ""
        if len(parts) == 1:
            return parts[0]
        if len(parts) == 2:
            return f"{parts[0]} and {parts[1]}"
        return ", ".join(parts[:-1]) + f", and {parts[-1]}"

    @staticmethod
    def _dedup(values: List[str]) -> List[str]:
        seen, out = set(), []
        for v in (values or []):
            if not v:
                continue
            k = v.split(" - ", 1)[0].strip().lower()
            if k and k not in seen:
                out.append(v)
                seen.add(k)
        return out

    @staticmethod
    def _flatten_and_build(concept_name: str,
                           phases: List[TemporalPhase]) -> Tuple:
        docs, auths, temps, sigs, setts, sentences = [], [], [], [], [], []
        for p in (phases or []):
            if not p.document_types or not p.author_roles:
                continue
            if p.phase_name:
                temps.append(p.phase_name)
            docs.extend(p.document_types or [])
            auths.extend(p.author_roles or [])
            sigs.extend(p.content_signals or [])
            setts.extend(p.clinical_settings or [])
            d  = ExtractionResult._join(p.document_types)
            a  = ExtractionResult._join(p.author_roles)
            se = ExtractionResult._join(p.clinical_settings)
            si = ExtractionResult._join(p.content_signals)
            parts = [concept_name, f"documented in {d}", f"by {a}"]
            if se:
                parts.append(f"at {se}")
            if si:
                parts.append(f"capturing {si}")
            sentences.append(", ".join(parts) + ".")
        cl = ExtractionResult._clean
        dd = ExtractionResult._dedup
        return (dd([cl(v) for v in docs]),
                dd([cl(v) for v in auths]),
                dd([cl(v) for v in temps]),
                dd([cl(v) for v in sigs]),
                dd([cl(v) for v in setts]),
                sentences)

    def _get_phases(self, atomic_concept: str) -> List[TemporalPhase]:
        if not self.context or not self.context.concepts_with_context:
            return []
        key = atomic_concept.strip().lower()
        for cc in self.context.concepts_with_context:
            if cc.atomic_concept.strip().lower() == key:
                return cc.temporal_phases or []
        return []

    def _build_ctx(self, concept_name: str) -> RetrievalContext:
        phases = self._get_phases(concept_name)
        if not phases:
            return RetrievalContext()
        docs, auths, temps, sigs, setts, sents = (
            self._flatten_and_build(concept_name, phases))
        return RetrievalContext(
            document_types=docs,
            author_roles=auths,
            temporal_scope=temps,
            content_signals=sigs,
            clinical_setting=setts,
            context_sentences=sents)

    def _build_intent_ctx(self, intent_title: str) -> RetrievalContext:
        if not self.context or not self.context.concepts_with_context:
            return RetrievalContext()
        all_phases: List[TemporalPhase] = []
        key = intent_title.strip().lower()
        for cc in self.context.concepts_with_context:
            if cc.intent_title.strip().lower() == key:
                all_phases.extend(cc.temporal_phases or [])
        if not all_phases:
            return RetrievalContext()
        docs, auths, temps, sigs, setts, sents = (
            self._flatten_and_build(intent_title, all_phases))
        return RetrievalContext(
            document_types=docs,
            author_roles=auths,
            temporal_scope=temps,
            content_signals=sigs,
            clinical_setting=setts,
            context_sentences=sents)

    #  format methods

    def to_intent_extraction(self) -> Dict[str, Any]:
        items = [
            IntentSummaryItem(
                intent_title=i.intent_title,
                description=i.description)
            for i in self.intents.intents
        ]
        result = Format_IntentExtraction(
            user_query=self.original_query,
            intents=items,
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
            timestamp=self.timestamp)
        return result.model_dump()

    def to_final_queries(self) -> Dict[str, Any]:
        candidates: List[FinalCandidateItem] = []
        seen: set = set()
        idx = 0
        for i in self.intents.intents:
            for sn in i.sub_natures:
                for c in sn.atomic_concepts:
                    key = c.strip().lower()
                    if not key or key in seen:
                        continue
                    seen.add(key)
                    idx += 1
                    rich_ctx = self._build_ctx(c.strip())
                    candidates.append(FinalCandidateItem(
                        candidate_id=f"fc_{idx:03d}",
                        intent_title=i.intent_title,
                        nature=i.nature,                         
                        sub_nature=sn.category_path,             
                        # atomic_concept=c.strip(),              
                        candidate=c.strip(),
                        retrieval_signals=FlatRetrievalSignals.from_retrieval_context(rich_ctx)
                    ))
        result = Format_FinalQueries(
            user_query=self.original_query,
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
            total_candidates=len(candidates),
            final_candidates=candidates,
            timestamp=self.timestamp)
        return result.model_dump()

    def to_nature_breakdown(self) -> Dict[str, Any]:
        intents_no_queries = [
            IntentWithoutQueries(
                intent_title=i.intent_title,
                description=i.description,
                nature=i.nature,
                sub_natures=i.sub_natures)
            for i in self.intents.intents
        ]
        result = Format_NatureBreakdown(
            is_clinical=self.intents.is_clinical,
            reason=self.intents.reason,
            original_query=self.intents.original_query,
            total_intents_detected=self.intents.total_intents_detected,
            intents=intents_no_queries,
            timestamp=self.timestamp)
        return result.model_dump()

    @staticmethod
    def _merge_signals(candidates: List[FinalCandidateItem]) -> FlatRetrievalSignals:
      
        def _union(getter) -> str:
            seen_vals: dict = {}
            for fc in candidates:
                for val in getter(fc.retrieval_signals).split(", "):
                    val = val.strip()
                    if val and val.lower() not in seen_vals:
                        seen_vals[val.lower()] = val
            return ", ".join(seen_vals.values())

        return FlatRetrievalSignals(
            document_types   = _union(lambda s: s.document_types),
            author_roles     = _union(lambda s: s.author_roles),
            temporal_signals = _union(lambda s: s.temporal_signals),
            content_signals  = _union(lambda s: s.content_signals),
            clinical_setting = _union(lambda s: s.clinical_setting),
            context_sentences= [
                sent
                for fc in candidates
                for sent in fc.retrieval_signals.context_sentences
            ],
        )

    def to_full_pipeline(self) -> Dict[str, Any]:
        # Shared seen-set and counter so candidate_ids are identical to
        # those produced by to_final_queries() on the same ExtractionResult.
        seen: set = set()
        idx = 0

        def _make_candidates(intent) -> List[FinalCandidateItem]:
            nonlocal idx
            items = []
            for sn in intent.sub_natures:
                for c in sn.atomic_concepts:
                    key = c.strip().lower()
                    if not key or key in seen:
                        continue
                    seen.add(key)
                    idx += 1
                    rich_ctx = self._build_ctx(c.strip())
                    items.append(FinalCandidateItem(
                        candidate_id=f"fc_{idx:03d}",
                        intent_title=intent.intent_title,
                        nature=intent.nature,                   
                        sub_nature=sn.category_path,           
                        # atomic_concept=c.strip(),              
                        candidate=c.strip(),
                        retrieval_signals=FlatRetrievalSignals.from_retrieval_context(rich_ctx)
                    ))
            return items

        intent_blocks = []
        for i in self.intents.intents:
            candidates = _make_candidates(i)
            # Intent-level signals = union of its own candidates' signals.
            # Consistent with and never wider than the candidate-level data.
            intent_signals = self._merge_signals(candidates)
            intent_blocks.append(IntentWithContext(
                intent_title=i.intent_title,
                description=i.description,
                nature=i.nature,
                sub_natures=i.sub_natures,
                final_candidates=candidates,
                retrieval_signals=intent_signals))

        result = Format_FullPipeline(
            is_clinical=self.intents.is_clinical,
            reason=self.intents.reason,
            original_query=self.original_query,
            expanded_query=self.expansion.expanded_query,
            total_intents_detected=self.intents.total_intents_detected,
            intents=intent_blocks,
            timestamp=self.timestamp)
        return result.model_dump()

    def to_all_formats(self) -> Dict[str, Dict[str, Any]]:
        return {
            "intent_extraction": self.to_intent_extraction(),
            "final_queries":     self.to_final_queries(),
            "nature_breakdown":  self.to_nature_breakdown(),
            "full_pipeline":     self.to_full_pipeline(),
        }



# PIPELINE CLASS


class ContextualIntentPipeline:

    def __init__(self, project: str, location: str = "us-central1",
                 model: str = "gemini-2.5-flash"):
        self.client = genai.Client(
            vertexai=True,
            project=project,
            location=location)
        self.project  = project
        self.location = location
        self.model_name = model

    # low-level helpers

    def _extract_json(self, response) -> Dict[str, Any]:
        if hasattr(response, 'text'):
            text = response.text
        elif hasattr(response, 'candidates') and response.candidates:
            text = response.candidates[0].content.parts[0].text
        else:
            text = str(response)
        text = re.sub(r'```json\s*', '', text)
        text = re.sub(r'```\s*',     '', text)
        text = text.strip()
        try:
            return json.loads(text)
        except Exception:
            pass
        for pattern, flags in [(r'\{.*?\}', re.DOTALL), (r'\[.*?\]', re.DOTALL)]:
            matches = sorted(re.finditer(pattern, text, flags),
                             key=lambda m: len(m.group(0)), reverse=True)
            for match in matches:
                try:
                    return json.loads(match.group(0))
                except Exception:
                    continue
        raise ValueError(f"Could not parse JSON from response: {text[:500]}...")

    def _call_model(self, prompt: str, schema: type,
                    fallback=None, max_tokens: int = 8192):
        for attempt in range(2):
            try:
                config = types.GenerateContentConfig(
                    temperature=0.0,
                    top_p=0.2,
                    seed=34,
                    max_output_tokens=max_tokens,
                    response_mime_type="application/json",
                    response_schema=schema)
                response = self.client.models.generate_content(
                    model=self.model_name, contents=prompt, config=config)
                data = self._extract_json(response)
                # If the model returned a bare list instead of a wrapped dict,
                # coerce it using the schema's first list field name.
                if isinstance(data, list):
                    fields = schema.model_fields
                    list_field = next(
                        (k for k, v in fields.items()
                         if "List" in str(v.annotation)), None)
                    data = {list_field: data} if list_field else data
                return schema.model_validate(data)
            except Exception as e:
                if attempt == 0:
                    print(f"  Retry ({schema.__name__}): {str(e)[:100]}")
                    continue
                print(f"  Failed ({schema.__name__}): {str(e)[:150]}")
                if fallback is not None:
                    return fallback
                raise
        return fallback

    #  pipeline steps 

    def expand_query(self, query: str) -> QueryExpansionOutput:
        """Step 1 — expand abbreviations and add clinical context."""
        return self._call_model(
            QUERY_EXPANSION_PROMPT.format(query=query),
            QueryExpansionOutput,
            fallback=QueryExpansionOutput(expanded_query=query),
            max_tokens=2048)

    def extract_intents(self, original_query: str,
                        expanded_query: str) -> IntentExtractionOutput:
        """Step 2 — extract clinical intents with sub-natures."""
        prompt = INTENT_EXTRACTION_PROMPT.format(
            expanded_query=expanded_query,
            timestamp=datetime.utcnow().isoformat())
        raw: IntentExtractionResponse = self._call_model(
            prompt,
            IntentExtractionResponse,
            fallback=IntentExtractionResponse(
                is_clinical=False, reason="LLM call failed"),
            max_tokens=8192)
        return IntentExtractionOutput(
            is_clinical=raw.is_clinical,
            reason=raw.reason,
            original_query=original_query,
            expanded_query=expanded_query,
            total_intents_detected=len(raw.intents),
            intents=raw.intents)

    # Step 3 

    def build_context(self, query: str, expanded_query: str,
                      intent_out: IntentExtractionOutput,
                      ) -> Optional[ContextualEnvironmentOutput]:
    
        if not intent_out.is_clinical or not intent_out.intents:
            return None

        # collect unique atomic concepts
        concepts: List[Dict[str, str]] = []
        seen: set = set()
        for i in intent_out.intents:
            for sn in i.sub_natures:
                for c in sn.atomic_concepts:
                    k = c.strip().lower()
                    if k and k not in seen:
                        concepts.append({"atomic_concept": c.strip(),
                                         "intent_title": i.intent_title})
                        seen.add(k)
        if not concepts:
            return None

        return self._call_model(
            CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                original_query=query,
                expanded_query=expanded_query,
                concepts_json=json.dumps(concepts, indent=2),
                concept_count=len(concepts)),
            ContextualEnvironmentOutput,
            fallback=ContextualEnvironmentOutput(),
            max_tokens=32768)


    #  main entry points

    def extract(self, query: str, verbose: bool = False) -> ExtractionResult:
        if not query or not query.strip():
            raise ValueError("Empty query provided")

        t0 = datetime.utcnow()

        # Step 1 — query expansion (fast, ~2–3 s)
        t1 = datetime.utcnow()
        expansion = self.expand_query(query)
        t1e = (datetime.utcnow() - t1).total_seconds()

        # Step 2 — intent extraction (sequential dependency on step 1)
        t2 = datetime.utcnow()
        intent_out = self.extract_intents(query, expansion.expanded_query)
        t2e = (datetime.utcnow() - t2).total_seconds()

        # Step 3 — contextual environment (parallel chunks, the heavy step)
        t3 = datetime.utcnow()
        context = self.build_context(
            query, expansion.expanded_query, intent_out)
        t3e = (datetime.utcnow() - t3).total_seconds()

        processing_time = (datetime.utcnow() - t0).total_seconds()

        if verbose:
            nc = len(context.concepts_with_context) if context else 0
            total_concepts = sum(
                len(sn.atomic_concepts)
                for i in intent_out.intents
                for sn in i.sub_natures)
            print(f"Query     : {query[:80]}")
            print(f"Expanded  : {expansion.expanded_query[:80]}")
            if intent_out.is_clinical:
                ts = sum(len(i.sub_natures) for i in intent_out.intents)
                print(f"Status    : Clinical")
                print(f"Intents   : {intent_out.total_intents_detected} | "
                      f"Sub-natures: {ts} | "
                      f"Concepts: {total_concepts} | "
                      f"Contexts: {nc}")
                print(f"Timing    : expand={t1e:.1f}s  "
                      f"intents={t2e:.1f}s  "
                      f"context={t3e:.1f}s  "
                      f"total={processing_time:.1f}s")
            else:
                print(f"Status    : Non-clinical — {intent_out.reason}")
            print()

        return ExtractionResult(query, expansion, intent_out,
                                context, processing_time)

    def run(self,
            query: str,
            output_format: Literal[
                "intent_extraction",
                "final_queries",
                "nature_breakdown",
                "full_pipeline"] = "full_pipeline",
            verbose: bool = False) -> Dict[str, Any]:

        try:
            result = self.extract(query, verbose)
            dispatch = {
                "intent_extraction": result.to_intent_extraction,
                "final_queries":     result.to_final_queries,
                "nature_breakdown":  result.to_nature_breakdown,
                "full_pipeline":     result.to_full_pipeline,
            }
            return dispatch[output_format]()
        except ValueError as e:
            return {"error": str(e), "query": query,
                    "timestamp": datetime.utcnow().isoformat()}
        except Exception as e:
            if verbose:
                print(f"Error: {e}\n")
            return {"error": str(e), "query": query,
                    "timestamp": datetime.utcnow().isoformat()}


# UTILITIES


def save_json(data: Dict, filename: str) -> None:
    with open(filename, 'w') as f:
        json.dump(data, f, indent=2)
    print(f"  Saved: {filename}")


def print_results(result: Dict) -> None:
    print(json.dumps(result, indent=2))


def validate_schema(result: Dict, format_type: str) -> Tuple[bool, Optional[str]]:
    schema_map = {
        "intent_extraction": Format_IntentExtraction,
        "final_queries":     Format_FinalQueries,
        "nature_breakdown":  Format_NatureBreakdown,
        "full_pipeline":     Format_FullPipeline,
    }
    schema = schema_map.get(format_type)
    if schema is None:
        return False, f"Unknown format type: {format_type}"
    try:
        schema.model_validate(result)
        return True, None
    except Exception as e:
        return False, str(e)



