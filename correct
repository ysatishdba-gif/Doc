# --- PHASE 1: PERFORM ROW-LEVEL THEMATIC ANALYSIS ---
BATCH_SIZE= 50
print("\n--- Phase 1: Performing Thematic Analysis ---")
analysis_results_list = []
for batch_start in range(0, len(df), BATCH_SIZE):
    batch_end = min(batch_start + BATCH_SIZE, len(df))
    batch_df = df.iloc[batch_start:batch_end]
    tasks = [analyze_comment_phase1(row['Response']) for _, row in batch_df.iterrows()]
    batch_results = await asyncio.gather(*tasks)
    analysis_results_list.extend(batch_results)
    print(f"  Completed {batch_end}/{len(df)} rows...")
    await asyncio.sleep(1)

processed_rows = []
error_rows = []
for i, result in enumerate(analysis_results_list):
    original_row = df.iloc[i].to_dict()
    if result and "error" not in result:
        original_row.update(result)
        processed_rows.append(original_row)
    else:
        original_row.update(result if result else {"error": "Unknown failure."})
        error_rows.append(original_row)

df_master = pd.DataFrame(processed_rows)
df_errors = pd.DataFrame(error_rows)
print(f"\nPhase 1 Complete: Successfully analyzed {len(df_master)} comments thematically.")
if not df_errors.empty:
    print(f"WARNING: Encountered {len(df_errors)} errors during thematic analysis.")

# --- MERGE STEP 1: COMBINE THEMATIC AND SCREENER RESULTS ---
print("\n--- Merging Screener and Thematic Analysis Results into Master Table ---")
df_master = df_master.merge(df_screener, left_on='Response_ID', right_index=True, how='left')
if 'full_student_comment' in df_master.columns:
    df_master.drop(columns=['full_student_comment'], inplace=True)
print("Screener data merged.")

# --- PHASE 2 & 3 (with integrated theme description merge) ---
SAMPLE_SIZE_FOR_SYNTHESIS = 750
print("\n--- Phase 2: Synthesizing Dominant Themes ---")
if 'primary_theme' not in df_master.columns or df_master['primary_theme'].empty:
    print("Error: No 'primary_theme' data generated in Phase 1. Aborting.")
else:
    all_primary_themes = df_master['primary_theme'].dropna().tolist()
    sample_themes = random.sample(all_primary_themes, min(len(all_primary_themes), SAMPLE_SIZE_FOR_SYNTHESIS))
    synthesis_result = await synthesize_themes_phase2(sample_themes)
    
    if not synthesis_result or 'dominant_themes' not in synthesis_result:
        print("Error: Could not synthesize dominant themes. Aborting.")
    else:
        dominant_themes_list = synthesis_result.get('dominant_themes', [])
        dominant_theme_names = [theme['dominant_theme'] for theme in dominant_themes_list]
        description_lookup = {theme['dominant_theme']: theme['theme_description'] for theme in dominant_themes_list}
        print(f"Phase 2 Complete: Identified {len(dominant_theme_names)} dominant themes.")

        print("\n--- Phase 3: Mapping Comments to Dominant Themes ---")
        mapping_results = []
        for batch_start in range(0, len(df_master), BATCH_SIZE):
            batch_end = min(batch_start + BATCH_SIZE, len(df_master))
            batch_df = df_master.iloc[batch_start:batch_end]
            tasks = [map_theme_phase3(row['primary_theme'], dominant_theme_names) for _, row in batch_df.iterrows()]
            batch_results = await asyncio.gather(*tasks)
            mapping_results.extend(batch_results)
            print(f"  Completed mapping for {batch_end}/{len(df_master)} rows...")
        df_master['Dominant_Theme'] = mapping_results
        print("\nPhase 3 Complete: All comments have been mapped.")

        # --- MERGE STEP 2: Add Dominant Theme Descriptions ---
        df_master['Dominant_Theme_Description'] = df_master['Dominant_Theme'].map(description_lookup)
        print("Dominant theme descriptions merged.")

