# =============================================================================
# OPTIMIZED STUDENT COMMENT ANALYSIS PIPELINE
# =============================================================================
# Key optimizations vs. original:
#   1. MERGED Phase 0 (screening) + Phase 1 (analysis) into ONE LLM call per comment
#      → Cuts total LLM calls by ~33%
#   2. BATCHED multiple comments per LLM call (10 comments per request)
#      → Cuts remaining calls by ~10x
#   3. BATCHED Phase 3 mapping (20 themes per call) + DEDUPLICATED unique themes
#      → Maps only unique primary themes, then applies lookup to all rows
#   4. ADDED concurrency (semaphore) to ALL phases consistently
#   5. ADDED retry logic with exponential backoff
#
# Expected speedup: 8 hours → ~45-90 minutes
# Expected cost reduction: ~80-85%
# =============================================================================

# --- IMPORTS ---
import pandas as pd
import pandas_gbq as pgbq
import json
import re
import random
from tqdm.asyncio import tqdm as an_tqdm
import asyncio

import vertexai
from vertexai.generative_models import (
    GenerativeModel,
    Part,
    GenerationConfig,
)
import google.cloud.aiplatform
from google.cloud import bigquery

print(f"Pandas version: {pd.__version__}")
print(f"SDK version: {google.cloud.aiplatform.__version__}")

# --- CONFIGURATION (same as original) ---
PROJECT_ID = PROJECT_ID
REGION = REGION
MODEL_VERSION = MODEL_VERSION
SCREENER_MODEL_NAME = SCREENER_MODEL_NAME

SOURCE_TABLE_ID = SOURCE_TABLE_ID
OUTPUT_MASTER_TABLE_ID = OUTPUT_MASTER_TABLE_ID
GCS_CORPUS_URI = GCS_CORPUS_URI
MIME_TYPE = MIME_TYPE

# --- TUNED PROCESSING CONFIGURATION ---
CONCURRENT_REQUESTS = 60          # Increased from 50
BATCH_SIZE_LLM = 10               # NEW: Comments per LLM call (batching)
BATCH_SIZE_API = 60                # Concurrent API batches
SAMPLE_SIZE_FOR_SYNTHESIS = 750
PHASE3_BATCH_SIZE = 20             # Primary themes per LLM call in Phase 3

print(f"PROJECT_ID: {PROJECT_ID}")
print(f"REGION: {REGION}")
print(f"SCREENER_MODEL_NAME: {SCREENER_MODEL_NAME}")
print(f"MODEL_VERSION: {MODEL_VERSION}")

# --- INITIALIZE ---
vertexai.init(project=PROJECT_ID, location=REGION)
model = GenerativeModel(MODEL_VERSION)
screener_model = GenerativeModel(SCREENER_MODEL_NAME)
client = bigquery.Client(project=PROJECT_ID)

grounding_document_part = Part.from_uri(uri=GCS_CORPUS_URI, mime_type=MIME_TYPE)
print(f"Grounding document prepared from: {GCS_CORPUS_URI}")

# --- LOAD DATA ---
query = f"""
SELECT DISTINCT `Academic Year`, Campus, `Course Id`, `Question Category`, Question, Response
FROM `{SOURCE_TABLE_ID}`
WHERE Response IS NOT NULL AND TRIM(Response) != ''
ORDER BY `Academic Year`, Campus, `Course Id`, `Question Category` ASC
"""
query_job = client.query(query)
df = query_job.to_dataframe()
df = df.reset_index().rename(columns={'index': 'Response_ID'})
print(f"Successfully loaded {len(df)} unique responses.")


# =============================================================================
# OPTIMIZATION 1: MERGED Phase 0 + Phase 1 into a single batched LLM call
# =============================================================================
# Instead of 2 separate calls per comment (screen + analyze), we do 1 call
# that handles BOTH tasks. And instead of 1 comment per call, we batch 10.
# Net effect: ~20x fewer API calls for these phases.
# =============================================================================

async def screen_and_analyze_batch(
    batch: list[dict],
    semaphore: asyncio.Semaphore,
    retry_count: int = 2
) -> list[dict]:
    """
    MERGED + BATCHED: Screens AND analyzes multiple comments in ONE LLM call.
    Each item in `batch` is a dict with 'Response_ID' and 'Response'.
    Returns a list of result dicts, one per comment.
    """
    async with semaphore:
        # Build the batch prompt with numbered comments
        comments_block = ""
        for i, item in enumerate(batch):
            comments_block += f'\n[COMMENT_{i}] (ID={item["Response_ID"]}):\n"""{item["Response"]}"""\n'

        prompt = f"""
**Role:** You are an expert content analyst for a Medical Education program. You will process MULTIPLE student comments in a single pass. For each comment, you must perform TWO tasks:

**TASK A — SCREENING:** Determine if the comment should be flagged.
**What NOT to Flag:** Critiques of course structure, teaching methods, or assessment fairness are valid feedback — do NOT flag them.
**Flagging Criteria:**
1. **Unprofessional Comments on Personal Attributes:** Critiques/compliments on appearance, accent (not clarity), or personal life speculation.
2. **Potentially Biased or Discriminatory Language:** Language suggesting bias against protected groups, slurs, inappropriate mentions of race/ethnicity/gender/age/orientation/disability.
3. **Emotionally Charged or Unsubstantiated Claims:** Hostile, overly emotional language or strong personal attacks without evidence (e.g., 'worst ever,' 'needs to be fired,' 'antagonized us').

**TASK B — THEMATIC ANALYSIS:** Extract theme and sentiment.
- `sentiment_label`: Exactly "Positive", "Negative", or "Neutral" based on EVALUATIVE LANGUAGE, not topic.
- `sentiment_score`: Float from -1.0 (most negative) to 1.0 (most positive), aligned with label.
- `primary_theme`: 2-5 word summary of the main point.
- `theme_description`: 2-3 sentence elaboration of the primary theme.
- `potential_lcme_standard`: Most relevant LCME standard number (e.g., "6.3", "8.1"), or null.

**OUTPUT FORMAT:** Return a JSON array with one object per comment, in order. Each object must have this exact schema:
```json
[
  {{
    "comment_index": 0,
    "response_id": <ID>,
    "is_inappropriate": <true/false>,
    "flagged_content": <string or null>,
    "category_of_concern": <string or null>,
    "reviewer_notes": <string or null>,
    "sentiment_label": "<Positive|Negative|Neutral>",
    "sentiment_score": <float>,
    "primary_theme": "<2-5 words>",
    "theme_description": "<2-3 sentences>",
    "potential_lcme_standard": "<string or null>"
  }}
]
```

**COMMENTS TO PROCESS:**
{comments_block}

Return ONLY the JSON array. No other text.
"""

        for attempt in range(retry_count + 1):
            try:
                generation_config = GenerationConfig(temperature=0.0, top_p=0.95)
                response = await model.generate_content_async(
                    contents=[prompt, grounding_document_part],
                    generation_config=generation_config,
                )

                # Parse JSON array from response
                text = response.text
                # Try to find JSON array
                match = re.search(r'\[.*\]', text, re.DOTALL)
                if not match:
                    raise ValueError("No JSON array found in response.")

                results = json.loads(match.group(0))

                # Validate we got the right number of results
                if len(results) != len(batch):
                    raise ValueError(
                        f"Expected {len(batch)} results, got {len(results)}"
                    )

                # Ensure response_id is set correctly from our input
                for i, result in enumerate(results):
                    result['response_id'] = batch[i]['Response_ID']

                return results

            except Exception as e:
                if attempt < retry_count:
                    await asyncio.sleep(2 ** attempt)
                    continue
                # On final failure, return error entries for each comment
                return [
                    {
                        "response_id": item["Response_ID"],
                        "is_inappropriate": True,
                        "flagged_content": "Error during processing",
                        "category_of_concern": "System Flag",
                        "reviewer_notes": f"Batch processing error: {e}",
                        "sentiment_label": "Neutral",
                        "sentiment_score": 0.0,
                        "primary_theme": "Processing Error",
                        "theme_description": f"Error: {e}",
                        "potential_lcme_standard": None,
                    }
                    for item in batch
                ]


# =============================================================================
# OPTIMIZATION 2: Phase 2 stays the same (it's already a single call)
# =============================================================================

async def synthesize_themes_phase2(primary_themes_list: list) -> dict or None:
    """Takes a list of primary themes and synthesizes them into dominant themes."""
    formatted_themes = "- " + "\n- ".join(primary_themes_list)

    prompt = f"""
**Persona:** You are an expert in curriculum evaluation and meta-analysis of qualitative data.
**Task:** Synthesize the provided primary themes into a small, distinct set of overarching dominant themes.

**Instructions:**
- Merge synonyms and abstract related concepts.
- Ensure each dominant theme is distinct and not redundant.
- Align terminology with these examples (create new ones if data supports it):

**Example Dominant Themes:**
- Learning Environment & Climate
- Teaching Quality & Instructional Effectiveness
- Curriculum Design & Alignment
- Assessment, Evaluation & Feedback
- Clinical Training & Experiential Learning
- Supervision, Mentorship & Coaching
- Workload, Time Demands & Efficiency
- Learner Well Being & Burnout
- Professional Identity Formation
- Interprofessional Education & Teamwork
- Diversity, Equity & Inclusion
- Learning Resources & Infrastructure
- Program Organization & Administration
- Preparedness for Practice
- Meaning, Motivation & Engagement

**Required Output:** Return a single valid JSON object.
**JSON Schema:**
{{
  "dominant_themes": [
    {{
      "dominant_theme": "2-5 word theme name",
      "theme_description": "2-3 sentence summary.",
      "potential_lcme_standard": "Standard number or null"
    }}
  ]
}}
---
**Primary themes to synthesize:**
{formatted_themes}
"""
    generation_config = GenerationConfig(temperature=0.0, seed=42)
    try:
        response = await model.generate_content_async(
            contents=[prompt, grounding_document_part],
            generation_config=generation_config,
        )
        match = re.search(r'\{.*\}', response.text, re.DOTALL)
        if not match:
            raise ValueError("No JSON object found for synthesis.")
        return json.loads(match.group(0))
    except Exception as e:
        return {"error": str(e)}


# =============================================================================
# OPTIMIZATION 3: Batched LLM mapping with DEDUPLICATION
# =============================================================================
# The original made one LLM call PER comment (N calls). This version:
#   a) Deduplicates: only maps each UNIQUE primary theme once (typically 60-80%
#      fewer themes to map than total comments)
#   b) Batches 20 unique themes per LLM call
#   c) Builds a lookup dict, then applies it to all rows instantly
# Net effect: if you have 10,000 comments but only 800 unique primary themes,
#   original = 10,000 calls → optimized = 40 calls (800 / 20)
# =============================================================================

async def map_themes_batched_llm(
    all_primary_themes: list[str],
    dominant_theme_names: list[str],
    semaphore: asyncio.Semaphore,
    batch_size: int = 20,
    retry_count: int = 2
) -> list[str]:
    """
    Maps primary themes to dominant themes using batched LLM calls.
    DEDUPLICATES first so the LLM only processes each unique theme once.
    """
    formatted_dominant = "- " + "\n- ".join(dominant_theme_names)

    # Step 1: Deduplicate — only map unique primary themes
    unique_themes = list(set(all_primary_themes))
    print(f"  Deduplication: {len(all_primary_themes)} total → {len(unique_themes)} unique themes to map")
    print(f"  Batching into {len(range(0, len(unique_themes), batch_size))} LLM calls (batch size={batch_size})")

    # Step 2: Map unique themes in batched LLM calls
    theme_lookup = {}  # unique_primary_theme → dominant_theme

    async def map_batch(batch_themes: list[str]):
        async with semaphore:
            themes_block = "\n".join(
                [f'{i}: "{t}"' for i, t in enumerate(batch_themes)]
            )
            prompt = f"""**Task:** Map each numbered primary theme below to the single BEST matching dominant theme from the provided list.

**Dominant Themes (choose from these ONLY):**
{formatted_dominant}

**Primary Themes to Map:**
{themes_block}

**Output:** Return ONLY a JSON array. Each element must have "index" (the number) and "dominant_theme" (exact name from the list above).
Example: [{{"index": 0, "dominant_theme": "Teaching Quality & Instructional Effectiveness"}}, ...]
"""
            config = GenerationConfig(temperature=0.0, seed=42)

            for attempt in range(retry_count + 1):
                try:
                    resp = await model.generate_content_async(
                        contents=[prompt], generation_config=config
                    )
                    match = re.search(r'\[.*\]', resp.text, re.DOTALL)
                    if match:
                        mappings = json.loads(match.group(0))
                        for m in mappings:
                            idx = m.get("index")
                            dt = m.get("dominant_theme", "").strip()
                            if idx is not None and 0 <= idx < len(batch_themes):
                                # Validate it's actually one of the dominant themes
                                if dt in dominant_theme_names:
                                    theme_lookup[batch_themes[idx]] = dt
                                else:
                                    # Fuzzy fallback: pick closest by checking if it's a substring
                                    for dn in dominant_theme_names:
                                        if dt.lower() in dn.lower() or dn.lower() in dt.lower():
                                            theme_lookup[batch_themes[idx]] = dn
                                            break
                        return  # Success
                except Exception as e:
                    if attempt < retry_count:
                        await asyncio.sleep(2 ** attempt)
                        continue
                    print(f"  WARNING: Batch mapping failed after retries: {e}")

    # Create and run all batch tasks concurrently
    tasks = []
    for i in range(0, len(unique_themes), batch_size):
        batch = unique_themes[i:i + batch_size]
        tasks.append(map_batch(batch))

    await an_tqdm.gather(*tasks, desc="Mapping Themes (Batched LLM)")

    # Step 3: Apply lookup to ALL primary themes (including duplicates) — instant
    default_theme = dominant_theme_names[0] if dominant_theme_names else "Unknown"
    mapped = [theme_lookup.get(t, default_theme) for t in all_primary_themes]

    unmapped_count = sum(1 for t in all_primary_themes if t not in theme_lookup)
    if unmapped_count > 0:
        print(f"  Note: {unmapped_count} themes fell back to default ('{default_theme}')")

    return mapped


# =============================================================================
# MAIN EXECUTION
# =============================================================================

# --- PHASE 0+1 MERGED: Screen AND Analyze in batched calls ---
print(f"\n{'='*70}")
print("PHASE 0+1 (MERGED): Screening + Thematic Analysis in batched calls")
print(f"{'='*70}")
print(f"Processing {len(df)} comments in batches of {BATCH_SIZE_LLM}...")

semaphore = asyncio.Semaphore(CONCURRENT_REQUESTS)

# Create batches of comments
comment_batches = []
for i in range(0, len(df), BATCH_SIZE_LLM):
    batch = df.iloc[i:i + BATCH_SIZE_LLM][['Response_ID', 'Response']].to_dict('records')
    comment_batches.append(batch)

print(f"Created {len(comment_batches)} batches (vs {len(df)} individual calls in original)")

# Process all batches concurrently
batch_tasks = [
    screen_and_analyze_batch(batch, semaphore)
    for batch in comment_batches
]
batch_results = await an_tqdm.gather(*batch_tasks, desc="Processing Batches")

# Flatten results
all_results = []
for batch_result in batch_results:
    all_results.extend(batch_result)

df_results = pd.DataFrame(all_results)
df_results.set_index('response_id', inplace=True)

# Merge with original data
df_master = df.merge(df_results, left_on='Response_ID', right_index=True, how='left')

# Drop helper columns if present
for col in ['comment_index', 'full_student_comment']:
    if col in df_master.columns:
        df_master.drop(columns=[col], inplace=True)

flagged_count = df_master['is_inappropriate'].sum() if 'is_inappropriate' in df_master.columns else 0
error_count = df_master['primary_theme'].isna().sum() if 'primary_theme' in df_master.columns else 0
print(f"\nPhase 0+1 Complete:")
print(f"  - Analyzed {len(df_master)} comments")
print(f"  - Flagged {int(flagged_count)} as inappropriate")
print(f"  - Errors: {error_count}")


# --- PHASE 2: Synthesize Dominant Themes (unchanged — single call) ---
print(f"\n{'='*70}")
print("PHASE 2: Synthesizing Dominant Themes")
print(f"{'='*70}")

if 'primary_theme' not in df_master.columns or df_master['primary_theme'].dropna().empty:
    print("Error: No 'primary_theme' data. Aborting.")
else:
    all_primary_themes = df_master['primary_theme'].dropna().tolist()
    sample_themes = random.sample(
        all_primary_themes, min(len(all_primary_themes), SAMPLE_SIZE_FOR_SYNTHESIS)
    )
    synthesis_result = await synthesize_themes_phase2(sample_themes)

    if not synthesis_result or 'dominant_themes' not in synthesis_result:
        print("Error: Could not synthesize dominant themes. Aborting.")
    else:
        dominant_themes_list = synthesis_result.get('dominant_themes', [])
        dominant_theme_names = [t['dominant_theme'] for t in dominant_themes_list]
        description_lookup = {
            t['dominant_theme']: t['theme_description'] for t in dominant_themes_list
        }
        print(f"Phase 2 Complete: Identified {len(dominant_theme_names)} dominant themes.")

        # --- PHASE 3: Map to Dominant Themes ---
        print(f"\n{'='*70}")
        print("PHASE 3: Mapping Comments to Dominant Themes")
        print(f"{'='*70}")

        primary_themes_to_map = df_master['primary_theme'].fillna("Unknown").tolist()

        print("Using BATCHED LLM mapping with deduplication...")
        mapped_themes = await map_themes_batched_llm(
            primary_themes_to_map, dominant_theme_names, semaphore,
            batch_size=PHASE3_BATCH_SIZE
        )

        df_master['Dominant_Theme'] = mapped_themes
        df_master['Dominant_Theme_Description'] = df_master['Dominant_Theme'].map(
            description_lookup
        )
        print(f"Phase 3 Complete: All {len(df_master)} comments mapped.")


# =============================================================================
# FINAL STEP: Upload to BigQuery
# =============================================================================
print(f"\n{'='*70}")
print("FINAL: Uploading to BigQuery")
print(f"{'='*70}")

if not df_master.empty:
    print(f"Final table: {len(df_master)} rows, {len(df_master.columns)} columns.")
    pgbq.to_gbq(
        df_master,
        destination_table=OUTPUT_MASTER_TABLE_ID,
        project_id=PROJECT_ID,
        if_exists='replace',
    )
    print(f"Successfully uploaded {len(df_master)} rows to '{OUTPUT_MASTER_TABLE_ID}'.")
else:
    print("Master DataFrame is empty. Skipping upload.")

print("\nProcess finished successfully!")
