def save_csv(path: str, headers: List[str], rows: List[list]) -> None:
    with open(path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(headers)
        w.writerows(rows)


# ── Typed pipeline result ─────────────────────────────────────────────────────

@dataclass
class PipelineResult:
    """Typed container for process_text() output."""
    surviving_cuis:  Set[str]                        = field(default_factory=set)
    text:            str                             = ""
    anchors:         list                            = field(default_factory=list)
    ic_map:          Dict[str, float]                = field(default_factory=dict)
    terms:           Dict[str, str]                  = field(default_factory=dict)
    h_topics:        Dict                            = field(default_factory=dict)
    topic_reps:      Dict                            = field(default_factory=dict)
    entity_results:  List                            = field(default_factory=list)
    all_embeddings:  Dict[str, np.ndarray]           = field(default_factory=dict)
    metadata:        Dict                            = field(default_factory=dict)
    # temporal_map: CUI → ClinicalContext (booleans from ConText)
    temporal_map:    Dict[str, ClinicalContext]      = field(default_factory=dict)


# ── core pipeline ─────────────────────────────────────────────────────────────

def _resolve_context(existing: Optional[ClinicalContext],
                     new: ClinicalContext) -> ClinicalContext:
    """When a CUI appears in multiple phrases, prefer current context."""
    if existing is None:
        return new
    if new.is_current() and not existing.is_current():
        return new
    return existing


def process_text(
    text_list: List[str],
    context: str,
    label: str = "doc",
) -> Optional[PipelineResult]:
    """Full pipeline: text → extract → reduce → topics → reps → anchors."""
    if not text_list:
        print(f"[{label}] No phrases supplied")
        return None

    context_list = [context] * len(text_list)
    per_phrase = extractor.extract(text_list, context_list)
    extractor._cache.flush()

    # per_phrase: {phrase: {"cuis": {cui: dist}, "context": ClinicalContext}}
    per_phrase_cuis: Dict[str, Dict] = {}
    temporal_map:    Dict[str, ClinicalContext] = {}

    for phrase, tagged in per_phrase.items():
        cui_dists = tagged.get("cuis") or {}
        if not cui_dists:
            continue
        cc: ClinicalContext = tagged.get("context", ClinicalContext())
        per_phrase_cuis[phrase] = cui_dists
        for cui in cui_dists:
            temporal_map[cui] = _resolve_context(temporal_map.get(cui), cc)

    print(f"\n[{label}] Extracted CUIs for {len(per_phrase_cuis)} phrases")
    for phrase, cui_dists in per_phrase_cuis.items():
        cc = per_phrase[phrase].get("context", ClinicalContext())
        flags = []
        if cc.historical:   flags.append("historical")
        if cc.hypothetical: flags.append("hypothetical")
        if cc.family:       flags.append("family")
        tag = f" [{', '.join(flags)}]" if flags else ""
        print(f"  \"{phrase}\"{tag}: {len(cui_dists)} CUIs")

    if not per_phrase_cuis:
        print(f"[{label}] No CUIs extracted (all negated or empty)")
        return None

    batch_inputs = [(list(cd.keys()), ph, cd) for ph, cd in per_phrase_cuis.items()]
    results = system.reduce_batch(batch_inputs)
    entity_results = [(batch_inputs[i][1], results[i]) for i in range(len(results))]

    all_surviving: Set[str] = set()
    all_cuis:      Set[str] = set()
    for _entity_text, result in entity_results:
        all_surviving.update(result.all_reduced_cuis)
        for e in result.confidence:
            all_cuis.update(e.explains_cuis)
        for a in result.audit_trail:
            all_cuis.add(a.removed_cui)
            if a.kept_cui:
                all_cuis.add(a.kept_cui)
    all_cuis.update(all_surviving)
    for cd in per_phrase_cuis.values():
        all_cuis.update(cd.keys())

    if not all_surviving:
        print(f"[{label}] No CUIs survived reduction")
        return None

    ic_map       = system.ic_computer.compute(list(all_surviving), {})
    h_topics     = HierarchicalTopicBuilder.build(list(all_surviving), hierarchy, ic_map)
    terms        = _fetch_terms(all_cuis)
    embeddings   = system.emb_fetcher.fetch(list(all_surviving))
    removed_embs = system.emb_fetcher.fetch(list(all_cuis - all_surviving))
    all_embeddings = {**embeddings, **removed_embs}

    metadata   = system.fetcher.fetch(list(all_cuis))
    topic_reps = TopicRepresentativeSelector.select(
        h_topics, metadata, all_embeddings, ic_map, hierarchy)
    HierarchicalTopicBuilder.label_topics(h_topics, topic_reps)

    label_cuis = {t["topic_cui"] for t in h_topics.values() if t.get("topic_cui")}
    missing_label_terms = label_cuis - set(terms.keys())
    if missing_label_terms:
        terms.update(_fetch_terms(missing_label_terms))

    anchors = TopicAnchorAssigner.assign(topic_reps, ic_map, hierarchy)
    anchor_cuis = set(a.anchor_cui for a in anchors)
    anchor_cuis.update(c for a in anchors for c in (a.ancestor_cuis or []))
    terms.update(_fetch_terms(anchor_cuis - set(terms.keys())))

    surviving_temporal: Dict[str, ClinicalContext] = {
        c: temporal_map.get(c, ClinicalContext()) for c in all_surviving
    }

    raw_count = sum(len(cd) for cd in per_phrase_cuis.values())
    print(f"[{label}] {raw_count} raw → {len(all_surviving)} surviving "
          f"→ {len(h_topics)} topics → {len(anchors)} anchors")

    non_current = {c: cc for c, cc in surviving_temporal.items()
                   if not cc.is_current()}
    if non_current:
        hist  = sum(1 for cc in non_current.values() if cc.historical)
        hypo  = sum(1 for cc in non_current.values() if cc.hypothetical)
        fam   = sum(1 for cc in non_current.values() if cc.family)
        print(f"  Temporal: historical={hist} hypothetical={hypo} family={fam}")

    for a in anchors:
        rep_terms_list = [terms.get(rc, rc) for rc in a.rep_cuis]
        print(f"    {a.anchor_cui} | {terms.get(a.anchor_cui, a.anchor_cui)} "
              f"(IC={a.anchor_ic:.1f}, reps=[{', '.join(rep_terms_list)}])")

    return PipelineResult(
        surviving_cuis = all_surviving,
        text           = context,
        anchors        = anchors,
        ic_map         = ic_map,
        terms          = terms,
        h_topics       = h_topics,
        topic_reps     = topic_reps,
        entity_results = entity_results,
        all_embeddings = all_embeddings,
        metadata       = metadata,
        temporal_map   = surviving_temporal,
    )


# ── CSV writers ───────────────────────────────────────────────────────────────

def write_csvs(result: PipelineResult, label: str = "doc") -> None:
    terms    = result.terms
    h_topics = result.h_topics

    entity_rows = []
    for entity_text, r in result.entity_results:
        for e in r.confidence:
            explains_str = " | ".join(
                f"{ec}:{terms.get(ec, ec)}" for ec in e.explains_cuis
            ) if e.explains_cuis else ""
            entity_rows.append([
                entity_text, e.cui, terms.get(e.cui, e.cui),
                round(e.confidence, 4), round(e.extraction_proximity, 3),
                round(e.centrality, 3), round(e.retention_power, 3),
                len(e.explains_cuis), explains_str,
            ])
    save_csv(os.path.join(OUTPUT_DIR, f"{label}_entities.csv"),
             ["entity","cui","preferred_term","confidence","prox","cent","ret",
              "explains_count","explains"], entity_rows)

    topic_rows = []
    if INCLUDE_SUBTOPICS:
        for tid, t in sorted(h_topics.items()):
            t_label_cui = t.get("topic_cui") or ""
            t_label = terms.get(t_label_cui, t_label_cui) if t_label_cui else ""
            for stid, st in sorted(t.get("subtopics", {}).items()):
                st_cui  = st.get("subtopic_cui") or ""
                st_name = terms.get(st_cui, st_cui) if st_cui else ""
                for c in st.get("members", []):
                    topic_rows.append([tid, t_label, stid, st_name, c, terms.get(c, c)])
            for c in sorted(t.get("ungrouped", [])):
                topic_rows.append([tid, t_label, "", "", c, terms.get(c, c)])
        save_csv(os.path.join(OUTPUT_DIR, f"{label}_topics.csv"),
                 ["topic_id","topic_label","subtopic_id","subtopic_name",
                  "cui","preferred_term"], topic_rows)
    else:
        for tid, t in sorted(h_topics.items()):
            t_label_cui = t.get("topic_cui") or ""
            t_label = terms.get(t_label_cui, t_label_cui) if t_label_cui else ""
            for c in t.get("members", []):
                topic_rows.append([tid, t_label, c, terms.get(c, c)])
        save_csv(os.path.join(OUTPUT_DIR, f"{label}_topics.csv"),
                 ["topic_id","topic_label","cui","preferred_term"], topic_rows)

    rep_rows = []
    for tid in sorted(result.topic_reps.keys()):
        for r in result.topic_reps[tid]:
            rep_rows.append([
                tid, r.cui, terms.get(r.cui, r.cui), r.method,
                r.member_count, round(r.ic_score, 2),
                " | ".join(f"{m}:{terms.get(m,m)}" for m in r.members),
            ])
    save_csv(os.path.join(OUTPUT_DIR, f"{label}_representatives.csv"),
             ["topic_id","rep_cui","rep_term","method","member_count",
              "ic_score","members"], rep_rows)

    anchor_rows = []
    for a in result.anchors:
        rep_detail = " | ".join(f"{rc}:{terms.get(rc,rc)}" for rc in a.rep_cuis)
        topic_parts = [
            f"topic_{tid}({len(h_topics.get(tid, {}).get('members', []))} CUIs)"
            for tid in a.topic_ids
        ]
        anchor_rows.append([
            a.anchor_cui, terms.get(a.anchor_cui, a.anchor_cui),
            round(a.anchor_ic, 2), rep_detail,
            len(a.topic_ids), " | ".join(topic_parts),
            len(a.ancestor_cuis) if a.ancestor_cuis else 0,
        ])
    save_csv(os.path.join(OUTPUT_DIR, f"{label}_anchors.csv"),
             ["anchor_cui","anchor_term","anchor_ic","representatives",
              "topics_covered","topic_details","ancestor_count"], anchor_rows)

    print(f"[{label}] CSVs written to {OUTPUT_DIR}")


def run_evaluation(result: PipelineResult, label: str = "doc"):
    flat_topics = {tid: t.get("members", []) for tid, t in result.h_topics.items()}
    metric_rows = evaluator.intrinsic_metrics(
        label, result.entity_results, flat_topics, result.all_embeddings)
    recon_rows  = evaluator.reconstruction_check(
        label, result.entity_results, result.all_embeddings,
        result.metadata, result.terms)
    save_csv(os.path.join(OUTPUT_DIR, f"{label}_eval_metrics.csv"),
             Evaluator.metric_headers(), metric_rows)
    save_csv(os.path.join(OUTPUT_DIR, f"{label}_eval_reconstruction.csv"),
             Evaluator.reconstruction_headers(), recon_rows)
    suspect = sum(1 for r in recon_rows if Verdict.SUSPECT.value in str(r[-1]))
    ok      = sum(1 for r in recon_rows if str(r[-1]) == Verdict.OK.value)
    total   = len(recon_rows)
    if total:
        print(f"[{label}] Evaluation: {ok}/{total} OK, {suspect}/{total} SUSPECT")
    return metric_rows, recon_rows


# ── main ──────────────────────────────────────────────────────────────────────

if __name__ == "__main__":

    CONTEXT = (
        "Patient presented with left knee pain and swelling for the past three days. "
        "Pain worsens with weight bearing and climbing stairs. No history of trauma. "
        "Mild effusion noted on examination."
    )
    TEXT_LIST = [
        "left knee pain", "swelling", "weight bearing pain",
        "climbing stairs difficulty", "knee effusion",
    ]

    CHUNK_ID   = "api_chunk_1"
    STORE_PATH = os.path.join(OUTPUT_DIR, "chunk_store.pkl")

    result = process_text(TEXT_LIST, CONTEXT, label="api")
    if result:
        write_csvs(result, label="api")
        run_evaluation(result, label="api")

        store     = ChunkStore()
        chunk_emb = compute_centroid(result.surviving_cuis, result.all_embeddings)
        store.add(
            CHUNK_ID, "api_doc",
            result.surviving_cuis,
            embedding    = chunk_emb,
            topics       = result.h_topics,
            text         = result.text,
            embeddings   = result.all_embeddings,
            temporal_map = result.temporal_map,
        )
        store.save(STORE_PATH)

        stats = store.stats()
        print(f"\n  Stored: {stats['total_cuis']} surviving CUIs "
              f"for {stats['chunks']} chunk(s)")
        print(f"  Store saved to: {STORE_PATH}")

    print(f"\n{'='*80}\nDONE\n{'='*80}")
