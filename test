"""Inspect raw MRREL rows for one CUI to verify cluster directionality.

Edit CUI below, then: python inspect_mrrel.py
"""
from google.cloud import bigquery

PROJECT = "your-gcp-project-id"
DATASET = "your-bigquery-dataset"

CUI = "C2142181"  # Pain of left knee joint

SQL = f"""
WITH labels AS (
  SELECT CUI, ANY_VALUE(STR) AS label
  FROM `{PROJECT}.{DATASET}.MRCONSO`
  WHERE SAB='SNOMEDCT_US' AND LAT='ENG' AND ISPREF='Y' AND SUPPRESS='N'
  GROUP BY CUI
)
SELECT
  r.CUI1,
  l1.label AS CUI1_label,
  r.CUI2,
  l2.label AS CUI2_label,
  r.REL,
  r.RELA
FROM `{PROJECT}.{DATASET}.MRREL` r
JOIN labels l1 ON r.CUI1 = l1.CUI
JOIN labels l2 ON r.CUI2 = l2.CUI
WHERE r.SAB='SNOMEDCT_US'
  AND r.SUPPRESS='N'
  AND (r.CUI1 = '{CUI}' OR r.CUI2 = '{CUI}')
ORDER BY r.REL, r.RELA
"""

client = bigquery.Client(project=PROJECT)
df = client.query(SQL).to_dataframe()

print(f"\nMRREL rows touching {CUI}: {len(df)}\n")
print(f"{'CUI1':14s}  {'REL':6s}  {'RELA':30s}  {'CUI2':14s}")
print("-" * 100)
for r in df.to_dict("records"):
    print(f"{r['CUI1']:14s}  {r['REL']:6s}  {str(r['RELA'] or ''):30s}  {r['CUI2']:14s}")
    print(f"  CUI1: {r['CUI1_label']}")
    print(f"  CUI2: {r['CUI2_label']}")
    print()
