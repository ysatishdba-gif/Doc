{
  "name": "Clinical Query Context Taxonomy",
  "version": "1.0",
  "description": "Top-level contexts that identify the intended source of truth for a clinical retrieval query. A query asked anywhere in a clinical environment (help desk, triage, exam room, billing, registration, patient portal, etc.) can be answered from one or more of these 9 sources. Use these IDs as values in a List[str] parameter when invoking the pipeline.",
  "usage_notes": [
    "Top-level context IDs are the contract — pipeline callers pass these as parameter values.",
    "Sub-topics are illustrative examples to make each context concrete; they are not exhaustive.",
    "A single query may map to multiple contexts (e.g., 'is this procedure covered?' touches both coverage_and_billing and patient_situation).",
    "Clinical specialty (cardiology, oncology, etc.) and chart section (labs, imaging, etc.) are NOT contexts — they are routing details handled by the pipeline's existing record_types and author_roles facets.",
    "Source tags reference UMLS Semantic Groups, SNOMED CT top-level hierarchies, or general clinical-domain vocabulary where applicable."
  ],
  "contexts": [
    {
      "id": "patient_situation",
      "label": "Patient Situation",
      "definition": "Anything documented about this specific patient — clinical, demographic, social, current, or historical.",
      "sub_topics": [
        { "name": "Conditions and diagnoses", "description": "Active and historical problems, comorbidities", "source": "SNOMED: Disorder, Clinical finding" },
        { "name": "Symptoms and complaints", "description": "What the patient is experiencing", "source": "UMLS: Disorders, Phenomena" },
        { "name": "Medications", "description": "Current, prior, allergies, adherence", "source": "UMLS: Chemicals & Drugs" },
        { "name": "Procedures performed", "description": "Surgical, diagnostic, therapeutic procedures performed on the patient", "source": "UMLS: Procedures" },
        { "name": "Lab results", "description": "Chemistry, hematology, microbiology, pathology results", "source": "Clinical domain" },
        { "name": "Imaging and radiology reports", "description": "Modality, findings, impressions", "source": "Clinical domain" },
        { "name": "Vital signs and measurements", "description": "Blood pressure, heart rate, weight, growth", "source": "UMLS: Physiology" },
        { "name": "Devices and implants", "description": "Pacemakers, prostheses, lines, ports", "source": "UMLS: Devices" },
        { "name": "Family history", "description": "Heritable conditions, genetic risk", "source": "SNOMED: Situation with explicit context" },
        { "name": "Social determinants of health", "description": "Housing, food security, transportation, employment", "source": "SNOMED: Social context" },
        { "name": "Behavioral health", "description": "Mental health diagnoses, screening results, substance use", "source": "Clinical domain" },
        { "name": "Genomic and molecular data", "description": "Mutations, biomarkers, sequencing results", "source": "UMLS: Genes & Molecular Sequences" },
        { "name": "Encounters and visit history", "description": "Admissions, discharges, transfers, outpatient visits", "source": "SNOMED: Event" },
        { "name": "Care team and communications about the patient", "description": "Consult notes, handoffs, messages about this patient", "source": "Clinical domain" },
        { "name": "Care plans", "description": "Problem list, goals, planned interventions", "source": "Clinical domain" },
        { "name": "Patient-reported data", "description": "Questionnaires, patient-reported outcomes, intake forms", "source": "Clinical domain" }
      ]
    },
    {
      "id": "medical_knowledge",
      "label": "Medical Knowledge",
      "definition": "General medical knowledge that applies to anyone, not specific to one patient.",
      "sub_topics": [
        { "name": "Disease information", "description": "Pathophysiology, presentation, prognosis", "source": "UMLS: Disorders" },
        { "name": "Drug references", "description": "Mechanism, dosing, interactions, contraindications", "source": "UMLS: Chemicals & Drugs" },
        { "name": "Anatomy and physiology", "description": "Structures, functions, normal ranges", "source": "UMLS: Anatomy, Physiology" },
        { "name": "Procedure descriptions", "description": "How procedures are performed, indications, risks", "source": "UMLS: Procedures" },
        { "name": "Diagnostic criteria", "description": "DSM criteria, ICD criteria, classification systems", "source": "Clinical domain" },
        { "name": "Clinical guidelines", "description": "Evidence-based recommendations from professional societies", "source": "Clinical domain" },
        { "name": "Staging and severity scales", "description": "TNM, NYHA, Glasgow Coma, MELD", "source": "SNOMED: Staging and scales" },
        { "name": "Lab reference ranges", "description": "Normal and abnormal cutoffs by demographic", "source": "Clinical domain" },
        { "name": "Drug-drug and drug-condition interactions", "description": "Interaction databases", "source": "Clinical domain" },
        { "name": "Genetic and genomic references", "description": "Gene functions, variant interpretation", "source": "UMLS: Genes" }
      ]
    },
    {
      "id": "decision_trees",
      "label": "Decision Trees",
      "definition": "Branching navigational logic the user steps through to reach an answer or determine a next action.",
      "sub_topics": [
        { "name": "Triage algorithms", "description": "Phone triage scripts, ED triage, urgency determination" },
        { "name": "Clinical decision support rules", "description": "Sepsis bundles, stroke alerts, MEWS-driven alerts" },
        { "name": "Best-practice advisories and alerts", "description": "Real-time prompts based on patient state" },
        { "name": "Order sets and SmartSets", "description": "Bundled orders for specific clinical scenarios" },
        { "name": "Screening pathways", "description": "Colorectal, breast, depression screening logic" },
        { "name": "Diagnostic workup algorithms", "description": "Chest pain, syncope, headache workups" },
        { "name": "Escalation rules", "description": "When to call rapid response, when to escalate to senior clinician" },
        { "name": "Workflow scripts", "description": "Help-desk scripts, registration scripts, scheduler decision logic" },
        { "name": "Code and emergency response protocols", "description": "ACLS, BLS, code stroke, code STEMI" }
      ]
    },
    {
      "id": "policies_and_protocols",
      "label": "Policies and Protocols",
      "definition": "Authored organizational, regulatory, or payer rules. Static documents that govern what is permitted, required, or recommended.",
      "sub_topics": [
        { "name": "Clinical care pathways", "description": "The institution's stepwise approach to common conditions" },
        { "name": "Treatment protocols", "description": "Chemotherapy regimens, antibiotic stewardship rules" },
        { "name": "Coverage and medical necessity criteria", "description": "Payer policies, prior authorization requirements" },
        { "name": "Formulary policies", "description": "Which drugs are preferred, restricted, or excluded" },
        { "name": "Infection control and isolation policies", "description": "Precautions, PPE requirements" },
        { "name": "Consent requirements", "description": "What requires written consent, who can consent" },
        { "name": "Privacy and HIPAA policies", "description": "Disclosure rules, minimum necessary standards" },
        { "name": "Mandatory reporting requirements", "description": "Communicable disease, abuse, adverse events" },
        { "name": "Controlled substance policies", "description": "DEA-related, prescription monitoring requirements" },
        { "name": "Credentialing and privileging rules", "description": "What providers may do, and where" },
        { "name": "Regulatory standards", "description": "Joint Commission, CMS conditions of participation" },
        { "name": "Quality measure definitions", "description": "HEDIS, CMS core measures, MIPS measures" }
      ]
    },
    {
      "id": "operational_state",
      "label": "Operational State",
      "definition": "The current logistical state of the organization — what's happening right now.",
      "sub_topics": [
        { "name": "Appointment schedule", "description": "Booked slots, availability, gaps" },
        { "name": "Bed and room status", "description": "Occupancy, cleaning state, isolation status", "source": "SNOMED: Environment" },
        { "name": "Provider availability", "description": "On-call rosters, scheduled providers, coverage" },
        { "name": "Queue and wait times", "description": "ED waiting, registration queue, triage queue" },
        { "name": "Patient flow", "description": "ADT events, admissions in progress, transfers pending" },
        { "name": "Resource availability", "description": "OR availability, imaging slot capacity, equipment status" },
        { "name": "In-flight orders", "description": "Orders placed, pending results, scheduled procedures" },
        { "name": "In-flight referrals", "description": "Outgoing referrals, status of incoming referrals" },
        { "name": "Staffing assignments", "description": "Nurse-patient assignments, charge nurse, attending of record" },
        { "name": "Equipment and inventory status", "description": "Crash carts, supply levels, equipment location" }
      ]
    },
    {
      "id": "coverage_and_billing",
      "label": "Coverage and Billing",
      "definition": "This patient's financial and insurance state.",
      "sub_topics": [
        { "name": "Insurance coverage", "description": "Payer, plan, group/member ID, effective dates" },
        { "name": "Eligibility and benefits", "description": "What's covered for this patient, deductibles, copays" },
        { "name": "Prior authorization status", "description": "Submitted, approved, denied, pending" },
        { "name": "Claims status", "description": "Submitted, adjudicated, paid, denied, appealed" },
        { "name": "Charges and encounters billed", "description": "What's been billed, by whom, for what" },
        { "name": "Payments and balances", "description": "What the patient owes, payment history" },
        { "name": "Financial assistance status", "description": "Qualified, applied, level of assistance" },
        { "name": "Network status", "description": "In-network, out-of-network, referral required" },
        { "name": "Authorizations on file", "description": "Referrals authorized, services authorized" },
        { "name": "Estimates and good-faith estimates", "description": "Pre-service cost estimates" }
      ]
    },
    {
      "id": "service_offering",
      "label": "Service Offering",
      "definition": "What the organization provides — the catalog of services, departments, and resources.",
      "sub_topics": [
        { "name": "Services and specialties", "description": "What clinical services exist and what they do" },
        { "name": "Departments and locations", "description": "Which departments, where they are, what they do", "source": "UMLS: Geographic Areas" },
        { "name": "Provider directory", "description": "Clinicians, their specialties, their availability for scheduling", "source": "UMLS: Occupations" },
        { "name": "Programs and clinics", "description": "Diabetes program, transplant program, wellness clinics" },
        { "name": "Ancillary services", "description": "Interpreter services, social work, chaplaincy, transport" },
        { "name": "Patient support services", "description": "Financial counseling, care navigation, patient advocate" },
        { "name": "Network and affiliates", "description": "Affiliated facilities, partner organizations" },
        { "name": "Vendor and external service relationships", "description": "Outside lab vendors, DME suppliers" },
        { "name": "Hours and accessibility", "description": "When services are available, accessibility accommodations" }
      ]
    },
    {
      "id": "instructional_content",
      "label": "Instructional Content",
      "definition": "Pre-authored content meant to be consumed by a patient or staff member as guidance.",
      "sub_topics": [
        { "name": "Patient education", "description": "Condition info, treatment overviews, lifestyle guidance" },
        { "name": "Procedure preparation instructions", "description": "Prep for colonoscopy, surgery, imaging" },
        { "name": "Post-discharge instructions", "description": "Wound care, activity, follow-up, warning signs" },
        { "name": "After-visit summary content", "description": "Visit recap, next steps, patient takeaways" },
        { "name": "Medication leaflets", "description": "How to take, what to expect, side effects to watch for" },
        { "name": "Self-management content", "description": "Diabetes self-care, asthma action plans, BP logs" },
        { "name": "Wellness and prevention content", "description": "Vaccination guidance, screening reminders" },
        { "name": "FAQ libraries", "description": "Common patient questions and standardized answers" },
        { "name": "Staff training and reference content", "description": "Orientation material, competency content" }
      ]
    },
    {
      "id": "aggregate_data",
      "label": "Aggregate Data",
      "definition": "Cross-patient metrics, population data, dashboards. Answers that span multiple patients or time periods rather than a single patient.",
      "sub_topics": [
        { "name": "Quality measure performance", "description": "Chart audit results, measure rates, gaps in care" },
        { "name": "Population health metrics", "description": "A1C control rates, mammogram completion rates" },
        { "name": "Cohort lookups", "description": "Patients overdue for screening, patients with a given condition" },
        { "name": "Outcome metrics", "description": "Readmission rates, mortality, infection rates" },
        { "name": "Operational metrics", "description": "No-show rates, wait time averages, throughput" },
        { "name": "Financial metrics", "description": "Denial rates, revenue cycle KPIs, payer mix" },
        { "name": "Risk stratification", "description": "High-risk patient lists, predictive scores at the cohort level" },
        { "name": "Utilization data", "description": "Service utilization patterns, capacity trends" },
        { "name": "Quality improvement data", "description": "PDSA cycle results, improvement project outcomes" }
      ]
    }
  ]
}
