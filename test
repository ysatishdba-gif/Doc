"""Inspect one CUI's clusters. Edit CUI below, then: python inspect_topics.py"""
import pickle

CUI         = "C0231807"
PICKLE_PATH = "cui_topic_lookup.pkl"

with open(PICKLE_PATH, "rb") as f:
    lookup = pickle.load(f)

entry = lookup.get(CUI)
if not entry:
    print(f"{CUI} not found")
    raise SystemExit

print(f"{CUI}  {entry['label']}  ({entry['semantic_type']})")
print(f"{len(entry['clusters'])} clusters\n")

for i, c in enumerate(entry["clusters"], 1):
    print(f"[{i}] {c['cluster_type']}  role={c['role']}  members={c['member_count']}")
    print(f"    {c['cluster_name']}")
    for s in (c.get("sample_members") or [])[:10]:
        print(f"      - {s['cui']}  {s['label']}")
    print()
