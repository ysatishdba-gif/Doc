@dataclass
class TopicGroupMatch:
    """Result of matching a query against topic groups."""
    group_id: int
    chunk_id: str
    document_id: str
    score: float
    topic_id: str              # which topic within the chunk matched
    topic_label: str           # human-readable label
    matched_cuis: List[str]
    is_variant: bool           # did CUI membership change at this chunk?
    added_cuis: List[str]      # CUIs added compared to previous entry
    removed_cuis: List[str]    # CUIs removed compared to previous entry
    change_type: str           # "medication_change", "new_finding", etc.
    chunk_date: str            # date of chunk for temporal sorting
    cui_overlap_ratio: float
    vector_sim: float
    lin_score: float


class TopicIndex:
    """Cross-chunk topic grouping with temporal variant detection.

    Builds in memory from ChunkStore data. No separate pickle.
    Groups similar topics across chunks into topic groups.
    Detects variants (CUI membership changes) within each group.

    Usage:
        chunks = store.get_all()
        index = TopicIndex()
        index.build(chunks)
        results = index.match(query_topics, query_cuis, query_embedding,
                              matcher, chunks)
    """

    def __init__(self, params=None):
        self.groups = []
        self.group_centroids = None
        self.p = {**DEFAULTS, **(params or {})}
        self._built = False

    def build(self, chunks, date_extractor=None, graph=None):
        """Build topic groups from all chunks.

        Args:
            chunks: dict from ChunkStore.get_all()
            date_extractor: optional callable(chunk_id, chunk_data) -> date string.
                            If None, uses chunk_id as sort key.
            graph: optional networkx DiGraph (UMLS hierarchy) for
                   hierarchy-aware variant classification.
        """
        self._graph = graph
        all_topics = []
        for chunk_id, chunk_data in chunks.items():
            doc_id = chunk_data.get("doc_id", chunk_id)
            stored_topics = chunk_data.get("topics", {})
            for tid, t_info in stored_topics.items():
                centroid = t_info.get("centroid")
                if centroid is not None:
                    date = (date_extractor(chunk_id, chunk_data)
                            if date_extractor else chunk_id)
                    all_topics.append({
                        "chunk_id": chunk_id,
                        "doc_id": doc_id,
                        "topic_id": tid,
                        "t_info": t_info,
                        "centroid": centroid,
                        "date": str(date),
                        "members": set(t_info.get("members", [])),
                        "topic_cui": t_info.get("topic_cui"),
                    })

        if not all_topics:
            self._built = True
            return

        centroids = np.array([t["centroid"] for t in all_topics])

        if len(all_topics) == 1:
            labels = [1]
        else:
            from scipy.cluster.hierarchy import fcluster, linkage
            from scipy.spatial.distance import pdist
            dists = pdist(centroids, metric="cosine")
            # Adaptive group distance: use gap_split on pairwise distances
            # to find the natural separation between same-cluster and
            # different-cluster topic centroids.
            # Falls back to DEFAULTS["group_dist"]=0.15 only if no gap found.
            if len(dists) >= 2:
                # gap_split works on "high values are good"; pass 1-dist (similarity)
                sims = 1.0 - dists
                t_sim = gap_split(sims, min_keep=1)
                adaptive_group_dist = round(1.0 - float(t_sim), 4) if t_sim is not None \
                    else self.p["group_dist"]
            else:
                adaptive_group_dist = self.p["group_dist"]
            logger.debug(f"    TopicIndex.build: adaptive_group_dist={adaptive_group_dist:.4f} "
                         f"(fallback={self.p['group_dist']})")
            Z = linkage(dists, method="average")
            labels = fcluster(Z, t=adaptive_group_dist, criterion="distance")

        group_map = {}
        for i, label in enumerate(labels):
            group_map.setdefault(int(label), []).append(all_topics[i])

        self.groups = []
        group_centroid_list = []

        for label, entries in sorted(group_map.items()):
            entries.sort(key=lambda e: e["date"])

            group_cent = np.mean([e["centroid"] for e in entries], axis=0).astype(np.float32)
            norm = np.linalg.norm(group_cent)
            if norm > 0:
                group_cent = group_cent / norm

            all_cuis = set()
            for e in entries:
                all_cuis |= e["members"]

            # variant detection: compare consecutive entries
            for i, entry in enumerate(entries):
                if i == 0:
                    entry["is_variant"] = False
                    entry["added"] = []
                    entry["removed"] = []
                    entry["change_type"] = "baseline"
                else:
                    prev = entries[i - 1]["members"]
                    curr = entry["members"]
                    added = curr - prev
                    removed = prev - curr
                    is_var = (len(added) + len(removed)) >= self.p["variant_min_change"]
                    entry["is_variant"] = is_var
                    entry["added"] = sorted(added)
                    entry["removed"] = sorted(removed)
                    entry["change_type"] = (
                        self._classify_change(added, removed) if is_var else "routine")

            # find representative entry (closest centroid to group centroid)
            if len(entries) > 1:
                entry_cents = np.array([e["centroid"] for e in entries])
                sims_to_group = entry_cents @ group_cent
                rep_idx = int(np.argmax(sims_to_group))
            else:
                rep_idx = 0

            group = {
                "group_id": len(self.groups),
                "centroid": group_cent,
                "entries": entries,
                "rep_idx": rep_idx,
                "all_cuis": all_cuis,
                "first_date": entries[0]["date"],
                "last_date": entries[-1]["date"],
                "entry_count": len(entries),
                "variant_count": sum(1 for e in entries if e.get("is_variant", False)),
            }
            self.groups.append(group)
            group_centroid_list.append(group_cent)

        self.group_centroids = np.array(group_centroid_list, dtype=np.float32)

        # calibrate topic filter threshold from data
        if len(self.groups) >= 2:
            all_sims = []
            for i in range(len(self.group_centroids)):
                for j in range(i + 1, len(self.group_centroids)):
                    s = float(np.dot(self.group_centroids[i], self.group_centroids[j]))
                    all_sims.append(s)
            if all_sims:
                # inter-group median = baseline similarity between unrelated groups
                # threshold = midpoint between baseline and 1.0
                median_sim = float(np.median(all_sims))
                self.calibrated_threshold = max(
                    self.p["topic_filter_sim"],
                    (median_sim + 1.0) / 2.0  # halfway between baseline and perfect
                )
            else:
                self.calibrated_threshold = self.p["topic_filter_sim"]
        else:
            self.calibrated_threshold = self.p["topic_filter_sim"]

        self._built = True
        logger.info(f"TopicIndex: {len(all_topics)} topics -> "
                     f"{len(self.groups)} groups, "
                     f"{sum(g['variant_count'] for g in self.groups)} variants, "
                     f"threshold={self.calibrated_threshold:.3f}")

    def _get_variant_ancestors(self, cui):
        """Cached BFS ancestors for variant classification.
        Depth derived from the graph density (same as main pipeline).
        """
        if not hasattr(self, '_var_anc_cache'):
            self._var_anc_cache = {}
        if cui in self._var_anc_cache:
            return self._var_anc_cache[cui]
        result = set()
        if self._graph is not None and self._graph.has_node(cui):
            # derive depth from graph density; import lazily to avoid circular dep
            try:
                from cui_reduction_system import _compute_ancestor_depth
                depth = _compute_ancestor_depth(self._graph)
            except ImportError:
                depth = 4   # structural fallback if not available
            frontier = {cui}
            for _ in range(depth):
                nxt = set()
                for n in frontier:
                    for p in self._graph.predecessors(n):
                        if p not in result:
                            result.add(p)
                            nxt.add(p)
                frontier = nxt
                if not frontier:
                    break
        self._var_anc_cache[cui] = frozenset(result)
        return self._var_anc_cache[cui]

    def _classify_change(self, added, removed):
        """Classify what kind of clinical change occurred.

        Uses hierarchy (if available) to distinguish real changes
        from extraction refinements:
          RA → RA of knee: parent-child → "refinement"
          Lisinopril → Amlodipine: different branch → "medication_change"
        """
        if added and removed and self._graph is not None:
            all_refinement = True
            for a_cui in added:
                is_refinement = False
                for r_cui in removed:
                    if self._graph.has_node(a_cui) and self._graph.has_node(r_cui):
                        a_anc = self._get_variant_ancestors(a_cui)
                        r_anc = self._get_variant_ancestors(r_cui)
                        # parent-child in either direction = refinement
                        if r_cui in a_anc or a_cui in r_anc:
                            is_refinement = True
                            break
                if not is_refinement:
                    all_refinement = False
                    break
            if all_refinement:
                return "refinement"

        if added and removed:
            return "medication_change"
        elif added and not removed:
            return "new_finding"
        elif removed and not added:
            return "resolved"
        return "changed"

    def match(self, query_topics, query_cuis, query_embedding,
              matcher, top_k=10, variants_first=False):
        """Match query against topic groups — strict two-pass architecture.

        Pass 1 — TOPIC GATE (coarse, fast, hard exclusion):
            Compare query topic centroids against all stored group centroids.
            gap_split finds the natural similarity threshold.
            Groups below the threshold are EXCLUDED — no fallback.
            Only groups that clear the gate proceed to Pass 2.

        Pass 2 — CUI SCORING (fine, within matched topics only):
            For each entry in every matched group, score using only the
            CUIs belonging to that topic — never the full chunk CUI set.
            Three signals: IC-weighted CUI overlap, vector cosine, Lin similarity.

        Pass 3 — Z-SCORE NORMALISATION:
            Signals are z-normalised across all Pass 2 candidates so their
            relative discrimination power drives final ranking — no manual weights.

        Pass 4 — CONFIDENCE FILTER:
            gap_split on final scores keeps the natural top cluster only.

        Args:
            query_topics:    dict from build_query_topics()
            query_cuis:      set of query CUI strings (after reduction)
            query_embedding: numpy centroid of query CUIs
            matcher:         ChunkMatcher instance (provides IC map + hierarchy)
            top_k:           max results
            variants_first:  if True, sort variants before routine entries

        Returns:
            list[TopicGroupMatch], empty if no groups cleared the topic gate.
        """
        if not self._built or not self.groups:
            return []

        query_cuis = set(query_cuis)

        # ── Derive adaptive params via the matcher (same as ChunkMatcher.match) ──
        # Reuse the chunks that were used to build this index via the matcher reference.
        # We reconstruct a minimal chunk representation from the groups for saturation.
        _mock_chunks = {}
        for g in self.groups:
            for entry in g["entries"]:
                _mock_chunks[entry["chunk_id"]] = {"cuis": entry["members"]}
        adaptive = matcher._compute_adaptive_params(query_cuis, _mock_chunks)
        filter_ic_gate        = adaptive["filter_min_ancestor_ic"]
        alpha                 = adaptive["ic_weight_alpha"]
        sibling_ic_ratio_adapt = adaptive["sibling_ic_ratio"]
        max_ic = max((matcher.ic_map.get(q, 0.0) for q in query_cuis), default=1.0)
        max_ic = max(max_ic, 1e-9)

        # Phase 1: hard topic gate — gap_split finds the natural separation
        # between clinically-related and unrelated topic groups.
        # Chunks that don't clear the threshold are EXCLUDED entirely.
        # No fallback to "at least return the closest group" — a chunk
        # with no topically relevant content should not appear in results.
        qtc_list = []
        if query_topics:
            for qt in query_topics.values():
                c = qt.get("centroid")
                if c is not None:
                    qtc_list.append(c)
        if not qtc_list and query_embedding is not None:
            qtc_list = [query_embedding]
        if not qtc_list:
            return []

        qtc_matrix = np.array(qtc_list, dtype=np.float32)
        sims = qtc_matrix @ self.group_centroids.T   # (n_qt, n_groups)

        # max similarity per group across all query topics
        max_sims = sims.max(axis=0)   # (n_groups,)

        # gap-based hard gate: groups below the natural gap are excluded
        threshold = gap_split(max_sims, min_keep=1)
        matched_group_ids = set(int(i) for i in np.where(max_sims >= threshold)[0])

        # Hard exit: no groups cleared the topic gate → no results.
        # This is intentional — do not fall through to CUI scoring on
        # unrelated content. The caller should widen the query or lower
        # the specificity of the search, not silently return poor matches.
        if not matched_group_ids:
            logger.debug("TopicIndex.match: no groups cleared topic gate — "
                         f"best_sim={float(max_sims.max()):.3f} threshold={threshold:.3f}")
            return []

        # Pass 2: CUI scoring within matched topics only.
        # _score_raw operates on entry["members"] — the CUIs of that specific
        # topic, never the full chunk CUI set. This is the key property:
        # CUI matching is scoped to topics that cleared the gate in Pass 1.
        raw_results = []
        has_graph = matcher.graph is not None and len(matcher.ic_map) > 0

        query_ancestors = {}
        if has_graph:
            for q in query_cuis:
                query_ancestors[q] = matcher._get_ancestors(q)

        def _score_raw(entry):
            topic_members = entry["members"]
            if not topic_members:
                return None

            # ── CUI overlap with IC gate on shared-ancestor filter ────────
            exact = query_cuis & topic_members
            hierarchy_hits = set()
            match_penalty  = {}   # query_cui → match quality [0, 1]

            if has_graph and len(exact) < len(query_cuis):
                for q_cui in query_cuis - exact:
                    q_anc = query_ancestors.get(q_cui, frozenset())
                    q_ic  = matcher.ic_map.get(q_cui, 1.0)
                    for d_cui in topic_members:
                        d_anc = matcher._ancestor_cache.get(d_cui, frozenset())
                        # Direct parent-child: always admit
                        if q_cui in d_anc or d_cui in q_anc:
                            hierarchy_hits.add(q_cui)
                            d_ic = matcher.ic_map.get(d_cui, q_ic)
                            match_penalty[q_cui] = min(d_ic / max(q_ic, 1e-9), 1.0)
                            break
                    else:
                        # Shared ancestor: apply IC gate
                        best_mica_ic, best_d = 0.0, None
                        sib_ratio = sibling_ic_ratio_adapt
                        for d_cui in topic_members:
                            d_anc = matcher._ancestor_cache.get(d_cui, frozenset())
                            shared = q_anc & d_anc
                            if shared:
                                d_ic = matcher.ic_map.get(d_cui, 0.0)
                                min_ic = min(q_ic, d_ic)
                                ic_gate = sib_ratio * min_ic
                                valid = [
                                    c for c in shared
                                    if ic_gate <= matcher.ic_map.get(c, 0.0) < min_ic
                                    and matcher.ic_map.get(c, 0.0) >= filter_ic_gate
                                ]
                                if valid:
                                    mica = max(valid, key=lambda c: matcher.ic_map.get(c, 0.0))
                                    mica_ic = matcher.ic_map.get(mica, 0.0)
                                    if mica_ic > best_mica_ic:
                                        best_mica_ic = mica_ic
                                        best_d = (d_cui, mica_ic)
                        if best_d:
                            hierarchy_hits.add(q_cui)
                            match_penalty[q_cui] = min(best_d[1] / max(q_ic, 1e-9), 1.0)

            # ── IC-weighted cui_ratio with subsumption penalty ────────────
            def cui_w(q, penalty=1.0):
                ic_w = matcher.ic_map.get(q, 0.0) / max_ic
                if alpha == 0.0:   return 1.0 * penalty
                if alpha == 1.0:   return ic_w * penalty
                return ((1.0 ** (1.0 - alpha)) * (ic_w ** alpha + 1e-9)) * penalty

            w_matched = sum(cui_w(q, match_penalty.get(q, 1.0))
                            for q in (exact | hierarchy_hits))
            w_total   = sum(cui_w(q) for q in query_cuis)
            cui_ratio = min(w_matched / max(w_total, 1e-9), 1.0)

            # ── Vector similarity — topic centroid cosine ─────────────────
            # The topic centroid (mean of member CUI embeddings) was computed
            # at ingestion time. Used here as a secondary signal alongside
            # CUI overlap and Lin — confirms semantic proximity of the match.
            tc = entry.get("centroid")
            vec_sim = 0.0
            if query_embedding is not None and tc is not None:
                vec_sim = max(0.0, min(1.0, float(np.dot(query_embedding, tc))))

            # ── Lin similarity (simple average — z-score handles weighting) ──
            lin_avg = 0.0
            if has_graph and query_cuis:
                non_exact_q = query_cuis - exact
                if not non_exact_q:
                    lin_avg = 1.0
                else:
                    lin_sum = 0.0
                    for q_cui in non_exact_q:
                        q_anc = query_ancestors.get(q_cui, frozenset())
                        best_lin = 0.0
                        for d_cui in topic_members:
                            d_anc = matcher._ancestor_cache.get(d_cui, frozenset())
                            lin, _, _ = matcher._lin_sim(q_cui, d_cui, q_anc, d_anc)
                            if lin > best_lin:
                                best_lin = lin
                                if lin >= 1.0:
                                    break
                        lin_sum += best_lin
                    lin_avg = lin_sum / len(non_exact_q)

            return cui_ratio, vec_sim, lin_avg, sorted(exact | hierarchy_hits), topic_members

        # score rep first, expand on accept
        for gid in matched_group_ids:
            group = self.groups[gid]
            rep_entry = group["entries"][group.get("rep_idx", 0)]
            rep_raw = _score_raw(rep_entry)
            if rep_raw is None:
                continue
            # quick reject: all signals zero
            if rep_raw[0] == 0.0 and rep_raw[1] == 0.0 and rep_raw[2] == 0.0:
                continue
            for entry in group["entries"]:
                if entry is rep_entry:
                    raw = rep_raw
                else:
                    raw = _score_raw(entry)
                    if raw is None:
                        continue
                raw_results.append((entry, gid, *raw))

        if not raw_results:
            return []

        # Pass 3: z-score normalise signals across all Pass 2 candidates.
        # No cap applied — all candidates that cleared Pass 1 are scored.
        # gap_split in Pass 4 is the natural filter. A hard cap silently
        # excluded valid results that ranked low on vector similarity but
        # high on CUI overlap. Z-score on arrays of N floats is O(N) and
        # fast regardless of candidate count.
        cuis = np.array([r[2] for r in raw_results])   # cui_ratio
        vecs = np.array([r[3] for r in raw_results])    # vec_sim
        lins = np.array([r[4] for r in raw_results])    # lin_avg

        if self.p["z_score_normalize"] and len(raw_results) >= 2:
            def _znorm(arr):
                s = np.std(arr)
                if s < 1e-9:
                    return np.zeros_like(arr)
                return (arr - np.mean(arr)) / s
            z_cui = _znorm(cuis)
            z_vec = _znorm(vecs)
            z_lin = _znorm(lins)
            scores = z_cui + z_vec + z_lin
            # shift to [0,1] range
            smin, smax = scores.min(), scores.max()
            if smax - smin > 1e-9:
                scores = (scores - smin) / (smax - smin)
            else:
                # all candidates are indistinguishable by z-score (all signals flat).
                # Fall back to normalised raw signal mean so scores reflect actual
                # magnitudes rather than a fixed midpoint.
                # w_cui/w_vec/w_lin are the manual-mode weights (DEFAULTS 0.40/0.30/0.30)
                raw_scores = (self.p["w_cui"] * cuis +
                              self.p["w_vec"] * vecs +
                              self.p["w_lin"] * lins)
                r_min, r_max = raw_scores.min(), raw_scores.max()
                if r_max - r_min > 1e-9:
                    scores = (raw_scores - r_min) / (r_max - r_min)
                else:
                    # truly identical across all signals — uniform score
                    scores = np.ones_like(scores) * float(np.mean(raw_scores))
        else:
            # fallback: manual weights
            scores = (self.p["w_cui"] * cuis +
                      self.p["w_vec"] * vecs +
                      self.p["w_lin"] * lins)

        # Pass 4: confidence filter — drop results below natural score gap.
        conf_floor = gap_split(scores, min_keep=1)
        results = []

        for i, (entry, gid, cui_ratio, vec_sim, lin_avg, matched, topic_members) in enumerate(raw_results):
            score = float(scores[i])
            if score < self.p["score_min"] or score < conf_floor:
                continue

            # Absolute CUI overlap floor: require raw cui_ratio >= min_cui_ratio
            # before z-score is applied. This prevents z-score normalisation from
            # amplifying candidates with near-zero concept overlap into apparently
            # confident results. Complements the zero-signal guard below:
            #   zero-signal guard catches cui_ratio == 0.0 exactly
            #   min_cui_ratio catches near-zero overlap (0 < cui_ratio < 0.05)
            # Both guards operate on the raw (pre-z-score) cui_ratio so they
            # reflect actual concept evidence rather than relative ranking.
            if cui_ratio < self.p["min_cui_ratio"] and lin_avg < self.p["min_cui_ratio"]:
                logger.debug(
                    f"  Weak-signal result suppressed: {entry.get('chunk_id')} "
                    f"topic={entry.get('topic_cui')} "
                    f"cui_ratio={cui_ratio:.4f} lin_avg={lin_avg:.4f} score={score:.3f}"
                )
                continue

            # Zero-signal guard: require at least one of CUI overlap or Lin > 0.
            if cui_ratio == 0.0 and lin_avg == 0.0:
                logger.debug(f"  Zero-signal result suppressed: {entry.get('chunk_id')} "
                             f"topic={entry.get('topic_cui')} score={score:.3f}")
                continue

            # matched_cuis: exact/hierarchy hits when available, otherwise
            # fall back to the topic members that drove the Lin similarity.
            # This ensures the CSV always shows which concepts were relevant
            # rather than an empty list for pure-Lin matches.
            display_matched = matched if matched else sorted(topic_members)

            rep = entry.get("topic_cui")
            topic_num = entry.get("topic_id", "")
            label = f"topic_{topic_num}" if topic_num != "" else f"group_{gid}"
            results.append(TopicGroupMatch(
                group_id=gid,
                chunk_id=entry.get("chunk_id", ""),
                document_id=entry.get("doc_id", ""),
                score=round(score, 4),
                topic_id=topic_num,
                topic_label=label,
                matched_cuis=display_matched,
                is_variant=entry.get("is_variant", False),
                added_cuis=entry.get("added", []),
                removed_cuis=entry.get("removed", []),
                change_type=entry.get("change_type", ""),
                chunk_date=entry.get("date", ""),
                cui_overlap_ratio=round(cui_ratio, 4),
                vector_sim=round(vec_sim, 4),
                lin_score=round(lin_avg, 4),
            ))

        # Dedup by chunk_id: keep the highest-scoring result per chunk.
        # Multiple topic groups can point to the same chunk — returning the
        # same chunk 5 times under different topic labels is unhelpful and
        # inflates the apparent result count.
        seen_chunks: dict = {}
        for r in results:
            if r.chunk_id not in seen_chunks or r.score > seen_chunks[r.chunk_id].score:
                seen_chunks[r.chunk_id] = r
        results = list(seen_chunks.values())

        if variants_first:
            results.sort(key=lambda r: (-r.is_variant, -r.score, r.chunk_date))
        else:
            results.sort(key=lambda r: (-r.score, -r.is_variant, r.chunk_date))

        return results[:top_k]

    def summary(self, terms=None):
        """Human-readable summary of all topic groups."""
        terms = terms or {}
        lines = [f"TopicIndex: {len(self.groups)} groups"]
        for g in self.groups:
            rep_cuis = set()
            for e in g["entries"]:
                if e.get("topic_cui"):
                    rep_cuis.add(e["topic_cui"])
            rep_label = ", ".join(terms.get(c, c) for c in sorted(rep_cuis))
            lines.append(f"  Group {g['group_id']}: {rep_label}")
            lines.append(
                f"    {g['entry_count']} entries, "
                f"{g['variant_count']} variants, "
                f"{g['first_date']} to {g['last_date']}")
            for e in g.get("entries", []):
                is_variant = e.get("is_variant", False)
                change_type = e.get("change_type", "")
                flag   = " VARIANT" if is_variant else ""
                change = f" ({change_type})" if is_variant and change_type else ""
                lines.append(f"    {e.get('date','')} {e.get('chunk_id','')}{flag}{change}")
                if e.get("added"):
                    added_names = [terms.get(c, c) for c in e["added"]]
                    lines.append(f"      + {', '.join(added_names)}")
                if e.get("removed"):
                    removed_names = [terms.get(c, c) for c in e["removed"]]
                    lines.append(f"      - {', '.join(removed_names)}")
        return "\n".join(lines)

    @staticmethod
    def explain(result, terms=None):
        """Human-readable explanation of a TopicGroupMatch."""
        terms = terms or {}
        label = terms.get(result.topic_label, result.topic_label)
        lines = [
            f"Chunk: {result.chunk_id}  Doc: {result.document_id}  "
            f"Date: {result.chunk_date}",
            f"  Group {result.group_id} [{label}]",
            f"  Score: {result.score:.3f}  "
            f"(CUI: {result.cui_overlap_ratio:.2f}, "
            f"Vec: {result.vector_sim:.3f}, Lin: {result.lin_score:.3f})",
        ]
        if result.matched_cuis:
            cui_names = [terms.get(c, c) for c in result.matched_cuis]
            lines.append(f"  Matched: {', '.join(cui_names)}")
        if result.is_variant:
            lines.append(f"  VARIANT: {result.change_type}")
            if result.added_cuis:
                added = [terms.get(c, c) for c in result.added_cuis]
                lines.append(f"    + Added: {', '.join(added)}")
            if result.removed_cuis:
                removed = [terms.get(c, c) for c in result.removed_cuis]
                lines.append(f"    - Removed: {', '.join(removed)}")
        return "\n".join(lines)
