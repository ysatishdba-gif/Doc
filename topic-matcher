    # If False, manual weights are used.
    "w_cui":              0.40,   # Signal 1 weight (manual mode only)
    "w_vec":              0.30,   # Signal 2 weight (manual mode only)
    "w_lin":              0.30,   # Signal 3 weight (manual mode only)
    "z_score_normalize":  True,   # True=data-driven scoring, False=manual weights

    # ── Hierarchy walk ───────────────────────────────────────────────────
    "anc_depth":          8,      # max BFS hops (structural limit)
    "ic_prune_ratio":     0.3,    # FALLBACK ONLY: ic_prune_ratio now derived at match()
                                  # time as percentile(store_ics,10) / median(store_ics).
                                  # Used only when ic_map is empty (bootstrap).
    # ── Sibling matching ─────────────────────────────────────────────────
    "sibling_ic_ratio":   0.6,    # FALLBACK ONLY: sibling_ic_ratio now derived at match()
                                  # time as percentile(store_ics,25) / percentile(store_ics,75).
                                  # Used only when ic_map is empty (bootstrap).

    # ── Topic filter ─────────────────────────────────────────────────────
    "topic_filter_pct":   85,     # FALLBACK ONLY: if gap_split finds no gap
    "topic_filter_sim":   0.3,    # ChunkMatcher backward compat (absolute gate)
    # max_candidates removed — no cap on Pass 2 candidates.
    # All candidates that clear Pass 1 are scored. gap_split in Pass 4
    # is the natural filter; a hard cap silently excluded valid results.

    # ── Output ───────────────────────────────────────────────────────────
    "score_min":          0.01,   # absolute floor (structural, not tuning)
    "min_cui_ratio":      0.05,   # absolute floor on raw cui_ratio before z-score.
                                  # Addresses the "all candidates are bad but still
                                  # ranked" problem: even if z-score normalisation
                                  # elevates a candidate, it must have demonstrated
                                  # at least 5% IC-weighted concept overlap.
                                  # Complements the zero-signal guard (which only
                                  # catches cui_ratio=0.0 exactly). This catches
                                  # near-zero overlap that z-score would otherwise
                                  # amplify into a seemingly confident result.
                                  # 0.05 = 5% of total query IC weight matched.
    "min_overlap":        1,      # ChunkMatcher backward compat
    "confidence_ratio":   0.5,    # FALLBACK ONLY: if gap_split finds no gap

