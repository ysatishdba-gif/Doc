"""
Topic Matcher — Three-signal clinical retrieval with topic-level matching.

Two retrieval paths:
  TopicIndex (production):  topic grouping + z-score scoring + gap-split filtering
  ChunkMatcher (backward):  chunk-level scoring with adaptive reranking

Three signals (scored independently, no double-counting):
  Signal 1: CUI overlap       — exact concept match (precision)
  Signal 2: Vector cosine      — embedding similarity (recall)
  Signal 3: Lin similarity     — hierarchy-aware match via MICA (non-exact pairs only)

Scoring (TopicIndex, default z_score_normalize=True):
  Each signal z-normalized across candidates, then summed.
  No manual weights. Data-driven.

Scoring (ChunkMatcher, backward compat):
  Weighted sum with adaptive variance-based reranking.

Components:
  ChunkStore:          Store CUIs + embedding centroid + topics + text per chunk
  ChunkMatcher:        Chunk-level scorer (backward compat)
  TopicIndex:          Cross-chunk topic grouping + variant detection (production)
  build_query_topics:  Form topics from query CUIs
  compute_centroid:    Average CUI embeddings into one vector
  gap_split:           Find natural separation in sorted values

Usage:
    from topic_matcher import ChunkStore, ChunkMatcher, compute_centroid

    # Offline: store chunks
    store = ChunkStore()
    emb = compute_centroid(surviving_cuis, embeddings)
    store.add("chunk_1", "doc_1", surviving_cuis, embedding=emb,
              topics=h_topics, text=chunk_text)
    store.save("chunk_store.pkl")

    # Online: match
    store = ChunkStore.load("chunk_store.pkl")
    matcher = ChunkMatcher(graph, ic_map)
    q_emb = compute_centroid(query_cuis, embeddings)
    results = matcher.match(query_cuis, q_emb, store.get_all())

References:
    Lin 1998     — IC-based similarity via MICA
    Pesquita 2009 — BMA for set-to-set similarity
"""

import math
import pickle
import time
import logging
import numpy as np
from typing import Dict, List, Optional
from dataclasses import dataclass

