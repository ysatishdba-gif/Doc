# cui_topics.py
# Groups surviving CUIs into topics via UMLS hierarchy.

import time, logging
import numpy as np
import networkx
from google.cloud import bigquery
from config import PROJECT_ID, DATASET_ID, EMBEDDING_TABLE, hierarchy, ic_precomputed, medlineplus

from cui_core import (
    MetadataFetcher, ICComputer, EmbeddingFetcher,
    HierarchicalTopicBuilder, fetch_preferred_terms,
)

log = logging.getLogger(__name__)


class CUITopics:

    def __init__(self):
        self._graph = hierarchy
        self._ic_pre = ic_precomputed
        self._mp_keys = set(medlineplus.keys())
        self._bq = bigquery.Client(project=PROJECT_ID)
        self._pid, self._did = PROJECT_ID, DATASET_ID
        self._meta = MetadataFetcher(self._bq, PROJECT_ID, DATASET_ID)
        self._ic = ICComputer(self._graph, self._ic_pre)
        self._emb = EmbeddingFetcher(self._bq, PROJECT_ID, DATASET_ID, EMBEDDING_TABLE)

    def build_topics(self, cuis):
        t0 = time.perf_counter()

        if not cuis:
            return {"topics": [], "metrics": {"input_cui_count": 0, "topic_count": 0,
                                               "singleton_count": 0, "processing_time_ms": 0.0}}

        cuis = list(dict.fromkeys(cuis))
        n_in = len(cuis)

        meta = self._meta.fetch(cuis)
        ic = self._ic.compute(cuis, meta)
        embs = self._emb.fetch(cuis)
        terms = fetch_preferred_terms(self._bq, self._pid, self._did, cuis)

        h = HierarchicalTopicBuilder.build(cuis, self._graph, ic)
        if not h:
            ms = (time.perf_counter() - t0) * 1000
            return {"topics": [], "metrics": {"input_cui_count": n_in, "topic_count": 0,
                                               "singleton_count": 0, "processing_time_ms": round(ms, 1)}}

        for t in h.values():
            g = t.get("_grouping_cui")
            t["topic_cui"] = g if g else max(t.get("members", [""]), key=lambda c: ic.get(c, 0.0))

        # collect all label CUIs (topic + subtopic)
        label_cuis = set()
        for t in h.values():
            if t.get("topic_cui"):
                label_cuis.add(t["topic_cui"])
            for st in t.get("subtopics", {}).values():
                if st.get("subtopic_cui"):
                    label_cuis.add(st["subtopic_cui"])

        # fill in MRCONSO preferred terms for any label CUIs not already in terms
        missing = label_cuis - set(terms)
        if missing:
            terms.update(fetch_preferred_terms(self._bq, self._pid, self._did, missing))

        centroids = {}
        for tid, t in h.items():
            vecs = [embs[c] for c in t.get("members", []) if c in embs]
            if vecs:
                mu = np.mean(vecs, axis=0, dtype=np.float32)
                n = np.linalg.norm(mu)
                centroids[tid] = (mu / n).tolist() if n > 0 else None
            else:
                centroids[tid] = None

        topics_out = []
        for tid in sorted(h):
            t = h[tid]
            tc = t.get("topic_cui", "")
            members_list = t.get("members", [])

            members = []
            for c in members_list:
                m = meta.get(c)
                members.append({"cui": c, "preferred_term": terms.get(c, c),
                                "ic": round(ic.get(c, 0.0), 4),
                                "semantic_types": list(m.semantic_types) if m and m.semantic_types else []})

            walker_tc = tc
            walker_label = terms.get(tc, tc) if tc else ""
            mp_cui, mp_votes = self._vote_medlineplus_label(members_list)
            if mp_cui and mp_cui not in terms:
                terms.update(fetch_preferred_terms(self._bq, self._pid, self._did, [mp_cui]))
            topic_label, topic_label_source = self._pick_label(mp_cui or tc, terms)
            final_tc = mp_cui or tc

            subtopics = []
            for sid in sorted(t.get("subtopics", {})):
                st = t["subtopics"][sid]
                sc = st.get("subtopic_cui", "")
                st_members = st.get("members", [])
                st_mem = [{"cui": c, "preferred_term": terms.get(c, c),
                           "ic": round(ic.get(c, 0.0), 4)} for c in st_members]
                walker_sc = sc
                walker_st_label = terms.get(sc, sc) if sc else ""
                mp_sc, mp_st_votes = self._vote_medlineplus_label(st_members)
                if mp_sc and mp_sc not in terms:
                    terms.update(fetch_preferred_terms(self._bq, self._pid, self._did, [mp_sc]))
                st_label, st_source = self._pick_label(mp_sc or sc, terms)
                subtopics.append({"subtopic_id": sid,
                                  "subtopic_cui": mp_sc or sc,
                                  "subtopic_label": st_label,
                                  "label_source": st_source,
                                  "walker_subtopic_cui": walker_sc,
                                  "walker_subtopic_label": walker_st_label,
                                  "medlineplus_votes": mp_st_votes,
                                  "members": st_mem})

            topics_out.append({"topic_id": tid,
                               "topic_cui": final_tc,
                               "topic_label": topic_label,
                               "label_source": topic_label_source,
                               "walker_topic_cui": walker_tc,
                               "walker_topic_label": walker_label,
                               "medlineplus_votes": mp_votes,
                               "members": members, "subtopics": subtopics,
                               "centroid": centroids.get(tid)})

        ms = (time.perf_counter() - t0) * 1000
        n_topics = len(topics_out)
        n_sing = sum(1 for t in topics_out if len(t["members"]) == 1)

        n_mtp = sum(1 for t in topics_out if t["label_source"] == "medlineplus")
        n_hier = n_topics - n_mtp
        log.info(f"{n_in} CUIs -> {n_topics} topics ({n_sing} singletons) "
                 f"labels: {n_mtp} medlineplus, {n_hier} hierarchy "
                 f"(swap: {swap_time*1000:.0f}ms) "
                 f"{ms:.0f}ms")

        return {"topics": topics_out,
                "metrics": {"input_cui_count": n_in, "topic_count": n_topics,
                            "singleton_count": n_sing, "processing_time_ms": round(ms, 1)}}

    @staticmethod
    def _pick_label(cui, terms):
        """MedlinePlus if available, else MRCONSO preferred term."""
        if not cui:
            return "", "hierarchy"
        if cui in medlineplus:
            return medlineplus[cui], "medlineplus"
        return terms.get(cui, cui), "hierarchy"

    def _vote_medlineplus_label(self, member_cuis):
        """Each member votes for its nearest MedlinePlus ancestor.
        Returns (winning_cui, vote_counts) or (None, {}) if no majority."""
        if not member_cuis:
            return None, {}

        votes = {}
        for member in member_cuis:
            hit = self._nearest_mp_ancestor(member)
            if hit:
                votes[hit] = votes.get(hit, 0) + 1

        if not votes:
            return None, {}

        # winner needs > 50% of members
        winner = max(votes, key=votes.get)
        if votes[winner] * 2 > len(member_cuis):
            return winner, votes
        return None, votes

    def _nearest_mp_ancestor(self, cui):
        """Walk up from cui, return the first MedlinePlus CUI hit (including cui itself)."""
        if cui in self._mp_keys:
            return cui
        try:
            ancestors = networkx.ancestors(self._graph, cui)
        except Exception:
            return None
        hits = ancestors & self._mp_keys
        if not hits:
            return None
        # pick the most specific (highest IC) among the hits
        return max(hits, key=lambda c: self._ic_pre.get(c, 0.0))

    def close(self):
        self._emb.close()
