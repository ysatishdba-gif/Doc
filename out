"""
Query-side processor.

Pipeline:
  query string
    -> ContextualIntentPipeline -> intents w/ atomic concepts
    -> for each intent's atomic concepts:
         CUIExtractor.extract per concept
    -> CUISummarizer per intent
  union all surviving CUIs across intents
    -> adaptor.cluster_ids_for(union) -> query cluster_ids

Usage:
    from query_processor import QueryProcessor
    qp = QueryProcessor()
    result = qp.process_query("Do you have constipation or diarrhea?")
    # result has: cluster_ids, surviving_cuis, intents, ...
"""

import time
from typing import Any, Dict, List, Optional, Set

from config import (
    API_URL, TOP_K, TOP_P, CLUSTER_SET, COMBINED,
    PROJECT_ID, LOCATION, MODEL_VERSION,
    CUI_TOPIC_LOOKUP_PATH,
)
from intents import ContextualIntentPipeline
from cui_core import CUIExtractor
from cui_summarizer import CUISummarizer
from adaptor import Adaptor


def _cui_id(c: Any) -> str:
    return c if isinstance(c, str) else c.get("cui", "")


def _cuis_from_raw(raw: Dict[str, Any]) -> List[Any]:
    out, seen = [], set()
    for d in raw.values():
        for c in d.get("cuis", []):
            key = c if isinstance(c, str) else c.get("cui", c)
            if key and key not in seen:
                seen.add(key)
                out.append(c)
    return out


def _split_path(path: str) -> List[str]:
    return [seg.strip() for seg in path.split(">>") if seg.strip()]


class QueryProcessor:

    def __init__(
        self,
        pipeline:   Optional[ContextualIntentPipeline] = None,
        extractor:  Optional[CUIExtractor] = None,
        summarizer: Optional[CUISummarizer] = None,
        adaptor:    Optional[Adaptor] = None,
        verbose: bool = True,
    ):
        self.verbose    = verbose
        self.pipeline   = pipeline   or ContextualIntentPipeline(
            project=PROJECT_ID, location=LOCATION, model=MODEL_VERSION,
        )
        self.extractor  = extractor  or CUIExtractor(
            API_URL, top_k=TOP_K, top_p=TOP_P,
            cluster_set=CLUSTER_SET, combined=COMBINED,
        )
        self.summarizer = summarizer or CUISummarizer()
        self.adaptor    = adaptor    or Adaptor(CUI_TOPIC_LOOKUP_PATH)

    def _extract_for_intent(self, intent: Dict[str, Any]) -> List[Any]:
        """Mirror demo.py PASS 2 logic but return only the surviving CUIs."""
        atomic_cuis: List[Any] = []
        seen: Set[str] = set()
        for sn in intent.get("sub_natures", []) or []:
            for concept in sn.get("atomic_concepts", []) or []:
                concept = (concept or "").strip()
                if not concept:
                    continue
                try:
                    raw = self.extractor.extract([concept], [concept])
                    cuis = _cuis_from_raw(raw)
                except Exception as e:
                    if self.verbose:
                        print(f"      extract FAILED for {concept!r}: {e}")
                    cuis = []
                for c in cuis:
                    cid = _cui_id(c)
                    if cid and cid not in seen:
                        seen.add(cid)
                        atomic_cuis.append(c)
        return atomic_cuis

    def process_query(self, query: str) -> Dict[str, Any]:
        if self.verbose:
            print(f"\nQuery: {query!r}")

        t_pipe = time.time()
        full = self.pipeline.run(query=query, output_format="full_pipeline")
        pipe_secs = time.time() - t_pipe

        if not full.get("is_clinical", False):
            if self.verbose:
                print(f"  non-clinical: {full.get('reason')}")
            return {
                "query":             query,
                "is_clinical":       False,
                "reason":            full.get("reason", ""),
                "surviving_cuis":    [],
                "cluster_ids":       set(),
                "pipeline_seconds":  pipe_secs,
                "extract_seconds":   0.0,
                "summarize_seconds": 0.0,
            }

        intents = full.get("intents", []) or []
        if self.verbose:
            print(f"  intents: {len(intents)}, pipeline {pipe_secs:.1f}s")

        # Atomic CUIs across intents (then summarize union)
        all_atomic: List[Any] = []
        all_seen: Set[str] = set()
        t_extract = time.time()
        for i, intent in enumerate(intents, 1):
            title = intent.get("intent_title", "")
            cuis = self._extract_for_intent(intent)
            if self.verbose:
                print(f"    intent {i} {title!r:60s} -> {len(cuis)} CUIs")
            for c in cuis:
                cid = _cui_id(c)
                if cid and cid not in all_seen:
                    all_seen.add(cid)
                    all_atomic.append(c)
        extract_secs = time.time() - t_extract

        if not all_atomic:
            if self.verbose:
                print("  no atomic CUIs to summarize")
            return {
                "query":             query,
                "is_clinical":       True,
                "intents":           intents,
                "surviving_cuis":    [],
                "cluster_ids":       set(),
                "pipeline_seconds":  pipe_secs,
                "extract_seconds":   extract_secs,
                "summarize_seconds": 0.0,
            }

        t_sum = time.time()
        s = self.summarizer.summarize(all_atomic, sources=["SNOMEDCT_US"])
        summarize_secs = time.time() - t_sum
        if self.verbose:
            m = s["metrics"]
            print(f"  summarize: {summarize_secs:.1f}s  "
                  f"{m['input_code_count']} in -> {m['output_code_count']} out")

        surviving_cuis = [c["cui"] for c in s["surviving_cuis"]]
        cluster_ids = self.adaptor.cluster_ids_for(surviving_cuis)

        if self.verbose:
            print(f"  cluster_ids: {len(cluster_ids)} distinct clusters")

        return {
            "query":             query,
            "is_clinical":       True,
            "intents":           intents,
            "raw_cuis":          all_atomic,
            "surviving_cuis":    s["surviving_cuis"],
            "removed_cuis":      s["removed_cuis"],
            "cluster_ids":       cluster_ids,
            "pipeline_seconds":  pipe_secs,
            "extract_seconds":   extract_secs,
            "summarize_seconds": summarize_secs,
        }


if __name__ == "__main__":
    qp = QueryProcessor()
    q = "Do you have constipation or diarrhea?"
    r = qp.process_query(q)
    print("="*70)
    print(f"Result: {len(r.get('surviving_cuis', []))} surviving CUIs, "
          f"{len(r.get('cluster_ids', set()))} cluster_ids")
