"""
Topic filter.

Runs after summarization. Given a list of surviving CUIs, returns the
cluster_ids that represent real topics in this CUI set — meaning clusters
where at least `min_members` of the input CUIs are members.

Singleton clusters (where only 1 input CUI is present) are dropped.
This avoids "topic expansion" beyond what's actually in the document/query.

Usage:
    from topic_filter import TopicFilter
    tf = TopicFilter(adaptor)
    topics = tf.filter_clusters(surviving_cuis)
    # topics is a set of cluster_ids
"""

from collections import defaultdict
from typing import Iterable, Optional, Set, Dict, List, Tuple

from adaptor import Adaptor


class TopicFilter:

    def __init__(
        self,
        adaptor: Optional[Adaptor] = None,
        pickle_path: Optional[str] = None,
        min_members: int = 2,
    ):
        """
        Parameters
        ----------
        adaptor : Adaptor or None
            Existing Adaptor to reuse. If None, builds one from pickle_path.
        pickle_path : str or None
            Path to lean pickle. Used only if adaptor is None.
        min_members : int
            Minimum number of input CUIs that must be in a cluster for it
            to be kept. Default 2 (drop singletons).
        """
        if adaptor is None:
            from config import CUI_TOPIC_LOOKUP_PATH
            adaptor = Adaptor(pickle_path or CUI_TOPIC_LOOKUP_PATH)
        self.adaptor = adaptor
        self.min_members = min_members

    def filter_clusters(
        self,
        cuis: Iterable[str],
        min_members: Optional[int] = None,
    ) -> Set[str]:
        """Return cluster_ids where at least `min_members` of `cuis` are members.

        Singletons (only 1 of `cuis` in the cluster) are dropped when
        min_members >= 2.
        """
        if min_members is None:
            min_members = self.min_members

        cui_set = set(cuis)
        cluster_hits: Dict[str, Set[str]] = defaultdict(set)
        for cui in cui_set:
            for cluster_id, _mc in self.adaptor.lookup.get(cui, []):
                cluster_hits[cluster_id].add(cui)

        return {
            cid for cid, hits in cluster_hits.items()
            if len(hits) >= min_members
        }

    def filter_with_details(
        self,
        cuis: Iterable[str],
        min_members: Optional[int] = None,
    ) -> List[Dict]:
        """Same filter but returns per-cluster details for inspection.

        Each dict: cluster_id, member_count (total in SNOMED), matched_cuis
        (the subset of input CUIs in this cluster).
        """
        if min_members is None:
            min_members = self.min_members

        cui_set = set(cuis)
        cluster_hits: Dict[str, Set[str]] = defaultdict(set)
        for cui in cui_set:
            for cluster_id, _mc in self.adaptor.lookup.get(cui, []):
                cluster_hits[cluster_id].add(cui)

        kept: List[Dict] = []
        for cid, hits in cluster_hits.items():
            if len(hits) < min_members:
                continue
            kept.append({
                "cluster_id":   cid,
                "member_count": self.adaptor.cluster_size.get(cid, 0),
                "matched_cuis": sorted(hits),
                "n_matched":    len(hits),
            })
        # Sort: most matched CUIs first, then smallest cluster size first
        kept.sort(key=lambda x: (-x["n_matched"], x["member_count"]))
        return kept
