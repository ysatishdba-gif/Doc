"""
Cluster-based retrieval adaptor.

Loads the lean cluster pickle and provides:
  - cluster_ids_for(cuis)            : map list of CUIs -> set of cluster_ids
  - score(query_cluster_ids, doc_cluster_ids): weighted overlap score
  - rank_documents(query_cuis, docs) : full pipeline

Matching logic:
  - Each CUI has a set of cluster_ids (precomputed in pickle)
  - Query CUIs and document CUIs are mapped to cluster_id sets
  - Score = sum over shared cluster_ids of (1 / member_count)
  - Big noisy clusters self-attenuate; small specific clusters dominate
"""

import os
import pickle


PICKLE_PATH = "cui_topic_lookup.pkl"  # lean production pickle


# ─────────────────────────────────────────────────────────────
# CORE ADAPTOR
# ─────────────────────────────────────────────────────────────

class Adaptor:
    def __init__(self, pickle_path=PICKLE_PATH):
        """Load the lean cluster pickle and build cluster_id -> size index."""
        if not os.path.exists(pickle_path):
            raise FileNotFoundError(
                f"{pickle_path} not found. Run run_topics.py first."
            )
        with open(pickle_path, "rb") as f:
            self.lookup = pickle.load(f)

        # Build inverse index: cluster_id -> member_count
        # One pass at startup.
        self.cluster_size = {}
        for cui, clusters in self.lookup.items():
            for cluster_id, member_count in clusters:
                self.cluster_size[cluster_id] = member_count

    def cluster_ids_for(self, cuis):
        """Return set of cluster_ids covering all CUIs in the input list."""
        out = set()
        for cui in cuis:
            for cluster_id, _mc in self.lookup.get(cui, []):
                out.add(cluster_id)
        return out

    def score(self, query_cluster_ids, doc_cluster_ids):
        """Weighted overlap score. Each shared cluster contributes 1/member_count."""
        shared = query_cluster_ids & doc_cluster_ids
        if not shared:
            return 0.0
        return sum(
            1.0 / self.cluster_size.get(cid, 1)
            for cid in shared
        )

    def rank_documents(self, query_cuis, docs):
        """Score and rank documents against a query.

        `docs` is a list of dicts each with at least:
          - "doc_id": str
          - "cuis":   list[str]   (summarized CUIs for the document)
        Optional:
          - "cluster_ids": set[str]  (pre-computed; otherwise computed here)

        Returns list of (doc, score, shared_clusters) sorted by score desc.
        """
        query_clusters = self.cluster_ids_for(query_cuis)

        results = []
        for doc in docs:
            doc_clusters = doc.get("cluster_ids")
            if doc_clusters is None:
                doc_clusters = self.cluster_ids_for(doc["cuis"])
            shared = query_clusters & doc_clusters
            s = self.score(query_clusters, doc_clusters)
            results.append((doc, s, shared))

        results.sort(key=lambda x: -x[1])
        return results
