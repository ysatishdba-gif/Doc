{
  "description": "Intended source for answering query",
  "Actions": [
    {
      "label": "Conversational Response",
      "instruction":"Generate a conversational response,Generate patient-facing explanatory content — simplified explanations, condition education, anatomy explanations, and basic health information.,Ask the asker for more information before proceeding when the query is ambiguous or missing context.",
      "when_applies": "Greetings, small talk, courtesy acknowledgments, and general non-clinical chat,Patient or proxy requests for non-clinician-level explanations,Queries that are ambiguous, incomplete, or unparseable.",
      "example_queries": [
        "Hi",
        "How are you?",
        "Thanks for your help",
        "Explain hypertension simply",
        "What is type 2 diabetes?",
        "How does my pacemaker work?",
        "Why do I need to fast before my blood test?",
        "Pain",
        "Tell me about it",
        "What about the other one?",
        "Help"
      ]
    },
    {
      "label": "Information Retrieval",
      "instruction": "Search clinical documents, records, guidelines, drug databases, protocols, or other clinical knowledge sources for the answer.",
      "when_applies": "Any query whose answer is documented in patient charts, clinical guidelines, drug references, internal protocols, lab references, or research literature.",
      "example_queries": [
        "What's the patient's last A1C?",
        "What's our chest-pain protocol?",
        "Patient has type 2 diabetes - what are the latest treatment options?",
        "Drug interactions between metformin and contrast dye"
      ]
    },
    {
      "label": "Knowledge/fact search",
      "instruction": "Generate clinician-facing guidance including treatment overviews, standards of care summaries, symptom management, and prevention recommendations.",
      "when_applies": "Non-prescriptive informational clinical guidance for a clinical audience.",
      "example_queries": [
        "What's the standard of care for early-stage breast cancer?",
        "How should I manage post-op nausea?",
        "Prevention recommendations for recurrent UTI"
      ]
    },
    {
      "label": "Admin response",
      "instruction": "Assess symptoms, urgency, and recommended level of care using symptom-based clinical reasoning and safety escalation.,Execute administrative workflows such as scheduling, billing, registration, prior authorization, referral creation, records requests, or documentation.",
      "when_applies":"Symptoms, acute complaints, possible emergencies, severity assessment, or disposition guidance.,Operational or non-clinical transactions where the response is an action.",
      "example_queries": [
        "Sudden weakness on one side",
        "Chest pain and sweating",
        "Should I go to the ER for this fever?",
        "Difficulty breathing after taking penicillin",
        "Book me a cardiology appointment Tuesday",
        "Cancel my Friday appointment",
        "Check if this procedure is covered",
        "Submit a prior auth for this MRI",
        "Refill my metformin",
        "Why was this claim denied?"
      ]
    },
    {
      "label": "Out of Scope Response",
      "instruction": "Block or redirect unsafe medical requests.,Politely redirect non-medical or unrelated requests.",
      "when_applies": "Unsafe medical instructions, self-harm, restricted clinical actions, or prohibited content.,Entirely non-medical or off-topic queries.",
      "example_queries": [
        "How do I overdose safely?",
        "Tell me how to get controlled substances without a prescription",
        "Can you write me a fake prescription?",
        "What's on the moon?",
        "Recommend a restaurant in Chicago",
        "Tell me a joke",
        "What's the weather tomorrow?"
      ]
    }
  ]
}
