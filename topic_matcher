@dataclass
class TopicGroupMatch:
    """Result of matching a query against topic groups."""
    group_id: int
    chunk_id: str
    document_id: str
    score: float
    topic_id: str              # which topic within the chunk matched
    topic_label: str           # human-readable label
    matched_cuis: List[str]
    is_variant: bool           # did CUI membership change at this chunk?
    added_cuis: List[str]      # CUIs added compared to previous entry
    removed_cuis: List[str]    # CUIs removed compared to previous entry
    change_type: str           # "medication_change", "new_finding", etc.
    chunk_date: str            # date of chunk for temporal sorting
    cui_overlap_ratio: float
    vector_sim: float
    lin_score: float


class TopicIndex:
    """Cross-chunk topic grouping with temporal variant detection.

    Builds in memory from ChunkStore data. No separate pickle.
    Groups similar topics across chunks into topic groups.
    Detects variants (CUI membership changes) within each group.

    Usage:
        chunks = store.get_all()
        index = TopicIndex()
        index.build(chunks)
        results = index.match(query_topics, query_cuis, query_embedding,
                              matcher, chunks)
    """

    def __init__(self, params=None):
        self.groups = []
        self.group_centroids = None
        self.p = {**DEFAULTS, **(params or {})}
        self._built = False

    def build(self, chunks, date_extractor=None, graph=None):
        """Build topic groups from all chunks.

        Args:
            chunks: dict from ChunkStore.get_all()
            date_extractor: optional callable(chunk_id, chunk_data) -> date string.
                            If None, uses chunk_id as sort key.
            graph: optional networkx DiGraph (UMLS hierarchy) for
                   hierarchy-aware variant classification.
        """
        self._graph = graph
        all_topics = []
        for chunk_id, chunk_data in chunks.items():
            doc_id = chunk_data.get("doc_id", chunk_id)
            stored_topics = chunk_data.get("topics", {})
            for tid, t_info in stored_topics.items():
                centroid = t_info.get("centroid")
                if centroid is not None:
                    date = (date_extractor(chunk_id, chunk_data)
                            if date_extractor else chunk_id)
                    all_topics.append({
                        "chunk_id": chunk_id,
                        "doc_id": doc_id,
                        "topic_id": tid,
                        "t_info": t_info,
                        "centroid": centroid,
                        "date": str(date),
                        "members": set(t_info.get("members", [])),
                        "topic_cui": t_info.get("topic_cui"),
                    })

        if not all_topics:
            self._built = True
            return

        centroids = np.array([t["centroid"] for t in all_topics])

        if len(all_topics) == 1:
            labels = [1]
        else:
            from scipy.cluster.hierarchy import fcluster, linkage
            from scipy.spatial.distance import pdist
            dists = pdist(centroids, metric="cosine")
            Z = linkage(dists, method="average")
            labels = fcluster(Z, t=self.p["group_dist"], criterion="distance")

        group_map = {}
        for i, label in enumerate(labels):
            group_map.setdefault(int(label), []).append(all_topics[i])

        self.groups = []
        group_centroid_list = []

        for label, entries in sorted(group_map.items()):
            entries.sort(key=lambda e: e["date"])

            group_cent = np.mean([e["centroid"] for e in entries], axis=0).astype(np.float32)
            norm = np.linalg.norm(group_cent)
            if norm > 0:
                group_cent = group_cent / norm

            all_cuis = set()
            for e in entries:
                all_cuis |= e["members"]

            # variant detection: compare consecutive entries
            for i, entry in enumerate(entries):
                if i == 0:
                    entry["is_variant"] = False
                    entry["added"] = []
                    entry["removed"] = []
                    entry["change_type"] = "baseline"
                else:
                    prev = entries[i - 1]["members"]
                    curr = entry["members"]
                    added = curr - prev
                    removed = prev - curr
                    is_var = (len(added) + len(removed)) >= self.p["variant_min_change"]
                    entry["is_variant"] = is_var
                    entry["added"] = sorted(added)
                    entry["removed"] = sorted(removed)
                    entry["change_type"] = (
                        self._classify_change(added, removed) if is_var else "routine")

            # find representative entry (closest centroid to group centroid)
            if len(entries) > 1:
                entry_cents = np.array([e["centroid"] for e in entries])
                sims_to_group = entry_cents @ group_cent
                rep_idx = int(np.argmax(sims_to_group))
            else:
                rep_idx = 0

            group = {
                "group_id": len(self.groups),
                "centroid": group_cent,
                "entries": entries,
                "rep_idx": rep_idx,
                "all_cuis": all_cuis,
                "first_date": entries[0]["date"],
                "last_date": entries[-1]["date"],
                "entry_count": len(entries),
                "variant_count": sum(1 for e in entries if e["is_variant"]),
            }
            self.groups.append(group)
            group_centroid_list.append(group_cent)

        self.group_centroids = np.array(group_centroid_list, dtype=np.float32)

        # calibrate topic filter threshold from data
        if len(self.groups) >= 2:
            all_sims = []
            for i in range(len(self.group_centroids)):
                for j in range(i + 1, len(self.group_centroids)):
                    s = float(np.dot(self.group_centroids[i], self.group_centroids[j]))
                    all_sims.append(s)
            if all_sims:
                # inter-group median = baseline similarity between unrelated groups
                # threshold = midpoint between baseline and 1.0
                median_sim = float(np.median(all_sims))
                self.calibrated_threshold = max(
                    self.p["topic_filter_sim"],
                    (median_sim + 1.0) / 2.0  # halfway between baseline and perfect
                )
            else:
                self.calibrated_threshold = self.p["topic_filter_sim"]
        else:
            self.calibrated_threshold = self.p["topic_filter_sim"]

        self._built = True
        logger.info(f"TopicIndex: {len(all_topics)} topics -> "
                     f"{len(self.groups)} groups, "
                     f"{sum(g['variant_count'] for g in self.groups)} variants, "
                     f"threshold={self.calibrated_threshold:.3f}")

    def _get_variant_ancestors(self, cui, depth=4):
        """Cached BFS ancestors for variant classification."""
        if not hasattr(self, '_var_anc_cache'):
            self._var_anc_cache = {}
        if cui in self._var_anc_cache:
            return self._var_anc_cache[cui]
        result = set()
        if self._graph is not None and self._graph.has_node(cui):
            frontier = {cui}
            for _ in range(depth):
                nxt = set()
                for n in frontier:
                    for p in self._graph.predecessors(n):
                        if p not in result:
                            result.add(p)
                            nxt.add(p)
                frontier = nxt
                if not frontier:
                    break
        self._var_anc_cache[cui] = frozenset(result)
        return self._var_anc_cache[cui]

    def _classify_change(self, added, removed):
        """Classify what kind of clinical change occurred.

        Uses hierarchy (if available) to distinguish real changes
        from extraction refinements:
          RA → RA of knee: parent-child → "refinement"
          Lisinopril → Amlodipine: different branch → "medication_change"
        """
        if added and removed and self._graph is not None:
            all_refinement = True
            for a_cui in added:
                is_refinement = False
                for r_cui in removed:
                    if self._graph.has_node(a_cui) and self._graph.has_node(r_cui):
                        a_anc = self._get_variant_ancestors(a_cui)
                        if r_cui in a_anc or a_cui in a_anc:
                            is_refinement = True
                            break
                        r_anc = self._get_variant_ancestors(r_cui)
                        if a_cui in r_anc:
                            is_refinement = True
                            break
                if not is_refinement:
                    all_refinement = False
                    break
            if all_refinement:
                return "refinement"

        if added and removed:
            return "medication_change"
        elif added and not removed:
            return "new_finding"
        elif removed and not added:
            return "resolved"
        return "changed"

    def match(self, query_topics, query_cuis, query_embedding,
              matcher, top_k=10, variants_first=False):
        """Match query against topic groups.

        Data-driven scoring:
          Phase 1: percentile-based topic filter (no fixed threshold)
          Phase 2: score per-topic (CUI + vec + Lin)
          Phase 3: z-score normalize signals across candidates (no manual weights)
          Phase 4: confidence filter (drop results far below best)

        Args:
            query_topics: dict from build_query_topics()
            query_cuis: set of query CUI strings
            query_embedding: numpy centroid
            matcher: ChunkMatcher instance
            top_k: max results
            variants_first: if True, sort variants before routine

        Returns:
            list[TopicGroupMatch]
        """
        if not self._built or not self.groups:
            return []

        query_cuis = set(query_cuis)

        # Phase 1: percentile-based topic filter
        qtc_list = []
        if query_topics:
            for qt in query_topics.values():
                c = qt.get("centroid")
                if c is not None:
                    qtc_list.append(c)
        if not qtc_list and query_embedding is not None:
            qtc_list = [query_embedding]
        if not qtc_list:
            return []

        qtc_matrix = np.array(qtc_list, dtype=np.float32)
        sims = qtc_matrix @ self.group_centroids.T   # (n_qt, n_groups)

        # take max similarity per group across all query topics
        max_sims = sims.max(axis=0)   # (n_groups,)

        # gap-based filter: find natural separation between relevant and irrelevant
        # always keep at least 1 group
        threshold = gap_split(max_sims, min_keep=1)
        matched_group_ids = set(int(i) for i in np.where(max_sims >= threshold)[0])

        if not matched_group_ids:
            # safety: always keep the best
            matched_group_ids = {int(np.argmax(max_sims))}

        # Phase 2: score entries (raw signals, no weighting yet)
        raw_results = []   # list of (entry_dict, cui_ratio, vec_sim, lin_avg, matched_cuis)
        has_graph = matcher.graph is not None and len(matcher.ic_map) > 0

        query_ancestors = {}
        if has_graph:
            for q in query_cuis:
                query_ancestors[q] = matcher._get_ancestors(q)

        def _score_raw(entry):
            topic_members = entry["members"]
            if not topic_members:
                return None
            exact = query_cuis & topic_members
            hierarchy_hits = set()
            if has_graph and len(exact) < len(query_cuis):
                for q_cui in query_cuis - exact:
                    q_anc = query_ancestors.get(q_cui, frozenset())
                    for d_cui in topic_members:
                        d_anc = matcher._ancestor_cache.get(d_cui, frozenset())
                        if q_cui in d_anc or d_cui in q_anc:
                            hierarchy_hits.add(q_cui)
                            break
            matched_count = len(exact) + len(hierarchy_hits)
            cui_ratio = matched_count / len(query_cuis) if query_cuis else 0.0
            tc = entry["centroid"]
            vec_sim = 0.0
            if query_embedding is not None and tc is not None:
                vec_sim = float(np.dot(query_embedding, tc))
                vec_sim = max(0.0, min(1.0, vec_sim))
            lin_avg = 0.0
            if has_graph and query_cuis:
                non_exact_q = query_cuis - exact
                if not non_exact_q:
                    # All exact: Lin=1.0 (best possible hierarchy agreement).
                    # With z-score: if all candidates are all-exact, z_lin=0 (neutral).
                    # If mixed, all-exact gets highest z_lin (correct — it IS best).
                    lin_avg = 1.0
                elif non_exact_q:
                    lin_sum = 0.0
                    for q_cui in non_exact_q:
                        q_anc = query_ancestors.get(q_cui, frozenset())
                        best_lin = 0.0
                        for d_cui in topic_members:
                            d_anc = matcher._ancestor_cache.get(d_cui, frozenset())
                            lin, _, _ = matcher._lin_sim(q_cui, d_cui, q_anc, d_anc)
                            if lin > best_lin:
                                best_lin = lin
                                if lin >= 1.0:
                                    break
                        lin_sum += best_lin
                    lin_avg = lin_sum / len(non_exact_q)
            return cui_ratio, vec_sim, lin_avg, sorted(exact | hierarchy_hits)

        # score rep first, expand on accept
        for gid in matched_group_ids:
            group = self.groups[gid]
            rep_entry = group["entries"][group.get("rep_idx", 0)]
            rep_raw = _score_raw(rep_entry)
            if rep_raw is None:
                continue
            # quick reject: all signals zero
            if rep_raw[0] == 0.0 and rep_raw[1] == 0.0 and rep_raw[2] == 0.0:
                continue
            for entry in group["entries"]:
                if entry is rep_entry:
                    raw = rep_raw
                else:
                    raw = _score_raw(entry)
                    if raw is None:
                        continue
                raw_results.append((entry, gid, *raw))

        if not raw_results:
            return []

        # cap candidates
        max_cand = self.p["max_candidates"]
        if len(raw_results) > max_cand:
            # keep top by vector sim (fastest discriminator)
            raw_results.sort(key=lambda r: -r[3])  # vec_sim is index 3
            raw_results = raw_results[:max_cand]

        # Phase 3: z-score normalize signals, then sum
        # tuple: (entry, gid, cui_ratio, vec_sim, lin_avg, matched_cuis)
        cuis = np.array([r[2] for r in raw_results])   # cui_ratio
        vecs = np.array([r[3] for r in raw_results])    # vec_sim
        lins = np.array([r[4] for r in raw_results])    # lin_avg

        if self.p["z_score_normalize"] and len(raw_results) >= 2:
            def _znorm(arr):
                s = np.std(arr)
                if s < 1e-9:
                    return np.zeros_like(arr)
                return (arr - np.mean(arr)) / s
            z_cui = _znorm(cuis)
            z_vec = _znorm(vecs)
            z_lin = _znorm(lins)
            scores = z_cui + z_vec + z_lin
            # shift to [0,1] range
            smin, smax = scores.min(), scores.max()
            if smax - smin > 1e-9:
                scores = (scores - smin) / (smax - smin)
            else:
                scores = np.ones_like(scores) * 0.5
        else:
            # fallback: manual weights
            scores = (self.p["w_cui"] * cuis +
                      self.p["w_vec"] * vecs +
                      self.p["w_lin"] * lins)

        # Phase 4: build results with gap-based confidence filter
        results = []
        # find natural score separation — keep top cluster only
        conf_floor = gap_split(scores, min_keep=1)

        for i, (entry, gid, cui_ratio, vec_sim, lin_avg, matched) in enumerate(raw_results):
            score = float(scores[i])
            if score < self.p["score_min"] or score < conf_floor:
                continue
            rep = entry.get("topic_cui")
            label = rep if rep else f"group_{gid}"
            results.append(TopicGroupMatch(
                group_id=gid,
                chunk_id=entry["chunk_id"],
                document_id=entry["doc_id"],
                score=round(score, 4),
                topic_id=entry["topic_id"],
                topic_label=label,
                matched_cuis=matched,
                is_variant=entry["is_variant"],
                added_cuis=entry.get("added", []),
                removed_cuis=entry.get("removed", []),
                change_type=entry.get("change_type", ""),
                chunk_date=entry["date"],
                cui_overlap_ratio=round(cui_ratio, 4),
                vector_sim=round(vec_sim, 4),
                lin_score=round(lin_avg, 4),
            ))

        if variants_first:
            results.sort(key=lambda r: (-r.is_variant, -r.score, r.chunk_date))
        else:
            results.sort(key=lambda r: (-r.score, -r.is_variant, r.chunk_date))

        return results[:top_k]

    def summary(self, terms=None):
        """Human-readable summary of all topic groups."""
        terms = terms or {}
        lines = [f"TopicIndex: {len(self.groups)} groups"]
        for g in self.groups:
            rep_cuis = set()
            for e in g["entries"]:
                if e.get("topic_cui"):
                    rep_cuis.add(e["topic_cui"])
            rep_label = ", ".join(terms.get(c, c) for c in sorted(rep_cuis))
            lines.append(f"  Group {g['group_id']}: {rep_label}")
            lines.append(
                f"    {g['entry_count']} entries, "
                f"{g['variant_count']} variants, "
                f"{g['first_date']} to {g['last_date']}")
            for e in g["entries"]:
                flag = " VARIANT" if e["is_variant"] else ""
                change = f" ({e['change_type']})" if e["is_variant"] else ""
                lines.append(f"    {e['date']} {e['chunk_id']}{flag}{change}")
                if e.get("added"):
                    added_names = [terms.get(c, c) for c in e["added"]]
                    lines.append(f"      + {', '.join(added_names)}")
                if e.get("removed"):
                    removed_names = [terms.get(c, c) for c in e["removed"]]
                    lines.append(f"      - {', '.join(removed_names)}")
        return "\n".join(lines)

    @staticmethod
    def explain(result, terms=None):
        """Human-readable explanation of a TopicGroupMatch."""
        terms = terms or {}
        label = terms.get(result.topic_label, result.topic_label)
        lines = [
            f"Chunk: {result.chunk_id}  Doc: {result.document_id}  "
            f"Date: {result.chunk_date}",
            f"  Group {result.group_id} [{label}]",
            f"  Score: {result.score:.3f}  "
            f"(CUI: {result.cui_overlap_ratio:.2f}, "
            f"Vec: {result.vector_sim:.3f}, Lin: {result.lin_score:.3f})",
        ]
        if result.matched_cuis:
            cui_names = [terms.get(c, c) for c in result.matched_cuis]
            lines.append(f"  Matched: {', '.join(cui_names)}")
        if result.is_variant:
            lines.append(f"  VARIANT: {result.change_type}")
            if result.added_cuis:
                added = [terms.get(c, c) for c in result.added_cuis]
                lines.append(f"    + Added: {', '.join(added)}")
            if result.removed_cuis:
                removed = [terms.get(c, c) for c in result.removed_cuis]
                lines.append(f"    - Removed: {', '.join(removed)}")
        return "\n".join(lines)
