"""
Topic Matcher — Three-signal clinical retrieval with topic-level matching.

Two retrieval paths:
  TopicIndex (production):  topic grouping + z-score scoring + gap-split filtering
  ChunkMatcher (backward):  chunk-level scoring with adaptive reranking

Three signals (scored independently, no double-counting):
  Signal 1: CUI overlap       — exact concept match (precision)
  Signal 2: Vector cosine      — embedding similarity (recall)
  Signal 3: Lin similarity     — hierarchy-aware match via MICA (non-exact pairs only)

Scoring (TopicIndex, default z_score_normalize=True):
  Each signal z-normalized across candidates, then summed.
  No manual weights. Data-driven.

Scoring (ChunkMatcher, backward compat):
  Weighted sum with adaptive variance-based reranking.

Components:
  ChunkStore:          Store CUIs + embedding centroid + topics + text per chunk
  ChunkMatcher:        Chunk-level scorer (backward compat)
  TopicIndex:          Cross-chunk topic grouping + variant detection (production)
  build_query_topics:  Form topics from query CUIs
  compute_centroid:    Average CUI embeddings into one vector
  gap_split:           Find natural separation in sorted values

Usage:
    from topic_matcher import ChunkStore, ChunkMatcher, compute_centroid

    # Offline: store chunks
    store = ChunkStore()
    emb = compute_centroid(surviving_cuis, embeddings)
    store.add("chunk_1", "doc_1", surviving_cuis, embedding=emb,
              topics=h_topics, text=chunk_text)
    store.save("chunk_store.pkl")

    # Online: match
    store = ChunkStore.load("chunk_store.pkl")
    matcher = ChunkMatcher(graph, ic_map)
    q_emb = compute_centroid(query_cuis, embeddings)
    results = matcher.match(query_cuis, q_emb, store.get_all())

References:
    Lin 1998     — IC-based similarity via MICA
    Pesquita 2009 — BMA for set-to-set similarity
"""

import pickle
import time
import logging
import numpy as np
from typing import Dict, List, Optional
from dataclasses import dataclass

logger = logging.getLogger("cui_reduction")


# ── Default parameters (override via constructor) ─────────────────────────────
DEFAULTS = {
    # ── Scoring ──────────────────────────────────────────────────────────
    # If z_score_normalize=True, weights are ignored (signals auto-balanced).
    # If False, manual weights are used.
    "w_cui":              0.40,   # Signal 1 weight (manual mode only)
    "w_vec":              0.30,   # Signal 2 weight (manual mode only)
    "w_lin":              0.30,   # Signal 3 weight (manual mode only)
    "z_score_normalize":  True,   # True=data-driven scoring, False=manual weights

    # ── Hierarchy walk ───────────────────────────────────────────────────
    "anc_depth":          8,      # max BFS hops (structural limit)
    "ic_prune_ratio":     0.3,    # prune parent if ic(parent) < ratio × ic(child)
                                  # replaces absolute ic_min=2.0
    # ── Sibling matching ─────────────────────────────────────────────────
    "sibling_ic_ratio":   0.6,    # mica_ic >= ratio × min(ic_q, ic_d)
                                  # replaces absolute ic_min_sibling=4.0

    # ── Topic filter ─────────────────────────────────────────────────────
    "topic_filter_pct":   85,     # FALLBACK ONLY: if gap_split finds no gap
    "topic_filter_sim":   0.3,    # ChunkMatcher backward compat (absolute gate)
    "max_candidates":     50,     # compute budget safety cap (after gap_split)

    # ── Output ───────────────────────────────────────────────────────────
    "score_min":          0.01,   # absolute floor (structural, not tuning)
    "min_overlap":        1,      # ChunkMatcher backward compat
    "confidence_ratio":   0.5,    # FALLBACK ONLY: if gap_split finds no gap

    # ── Vector ───────────────────────────────────────────────────────────
    "vector_sharpening":  1,      # 1=off (topic centroids are focused, no need)
    "vector_fallback_min": 0.4,   # ChunkMatcher backward compat only

    # ── Query topics ─────────────────────────────────────────────────────
    "query_hac_dist":     0.5,    # HAC distance for clustering query CUIs
    "query_singleton_max": 3,     # <= this: each CUI is own topic

    # ── Topic grouping ───────────────────────────────────────────────────
    "group_dist":         0.15,   # cosine distance for cross-chunk grouping
    "variant_min_change": 1,      # min CUI adds+removes to flag variant
}


# ── Data model ────────────────────────────────────────────────────────────────

@dataclass
class CUIMatchDetail:
    """Best Lin match for one query CUI."""
    query_cui: str
    chunk_cui: Optional[str]   # best matching CUI in chunk
    mica_cui: Optional[str]    # Most Informative Common Ancestor
    lin_sim: float             # Lin similarity [0, 1]
    match_type: str            # exact | subsumption | shared_ancestor | no_match

@dataclass
class ChunkMatch:
    """Result of matching one chunk against the query."""
    chunk_id: str
    document_id: str
    score: float               # combined weighted score [0, 1]
    cui_overlap: int           # exact CUI overlap count
    cui_overlap_ratio: float   # overlap / query CUI count
    vector_sim: float          # cosine similarity of embedding centroids
    lin_score: float           # average best Lin similarity (BMA)
    total_chunk_cuis: int
    total_query_cuis: int
    overlapping_cuis: List[str]
    topics_matched: Dict
    lin_details: List[CUIMatchDetail]


# ── ChunkStore ────────────────────────────────────────────────────────────────

class ChunkStore:
    """Stores surviving CUIs, embedding centroid, topics, and text per chunk."""

    def __init__(self):
        self._data = {}

    def add(self, chunk_id, document_id, surviving_cuis,
            embedding=None, topics=None, text=None, embeddings=None):
        """Store one chunk.

        Args:
            chunk_id: chunk identifier
            document_id: source document identifier
            surviving_cuis: set/list of CUI strings
            embedding: numpy array — centroid of CUI embeddings
            topics: dict from HierarchicalTopicBuilder
            text: original chunk text (for LLM reasoning)
            embeddings: dict {cui: numpy_array} — if provided, computes
                        per-topic centroids for embedding-based topic filter
        """
        topics = topics or {}
        # compute per-topic centroids if embeddings available
        if embeddings and topics:
            for tid, t_info in topics.items():
                members = t_info.get("members", [])
                tc = compute_centroid(members, embeddings)
                t_info["centroid"] = tc  # numpy array or None

        self._data[chunk_id] = {
            "doc_id": document_id,
            "cuis": set(surviving_cuis),
            "embedding": embedding,
            "topics": topics,
            "text": text or ""
        }

    def get_all(self):
        return dict(self._data)

    def get_chunk(self, chunk_id):
        return self._data.get(chunk_id)

    def chunk_ids(self):
        return list(self._data.keys())

    def stats(self):
        total_cuis = sum(len(c.get("cuis", set())) for c in self._data.values())
        has_emb = sum(1 for c in self._data.values() if c.get("embedding") is not None)
        return {
            "chunks": len(self._data),
            "total_cuis": total_cuis,
            "avg_cuis_per_chunk": round(total_cuis / len(self._data), 1) if self._data else 0,
            "chunks_with_embeddings": has_emb,
        }

    def save(self, path):
        with open(path, "wb") as f:
            pickle.dump(dict(self._data), f, protocol=pickle.HIGHEST_PROTOCOL)
        logger.info(f"ChunkStore saved: {len(self._data)} chunks to {path}")

    @classmethod
    def load(cls, path):
        store = cls()
        with open(path, "rb") as f:
            store._data = pickle.load(f)
        # backfill missing fields from older pickle versions
        for chunk_id, chunk in store._data.items():
            if "doc_id" not in chunk:
                chunk["doc_id"] = chunk_id
            if "cuis" not in chunk:
                chunk["cuis"] = set()
            if "embedding" not in chunk:
                chunk["embedding"] = None
            if "topics" not in chunk:
                chunk["topics"] = {}
            if "text" not in chunk:
                chunk["text"] = ""
        logger.info(f"ChunkStore loaded: {len(store._data)} chunks from {path}")
        return store


# ── Helpers ───────────────────────────────────────────────────────────────────

def gap_split(values, min_keep=1):
    """Find natural split point in sorted values using largest gap.

    Given values, sorts descending, finds the largest drop between
    consecutive values. Everything above the gap is "relevant".

    If no significant gap (largest gap < 2× median gap), keeps all.

    Args:
        values: 1D numpy array
        min_keep: always keep at least this many items

    Returns:
        threshold: values at or above this are kept
    """
    if len(values) <= min_keep:
        return float(values.min()) if len(values) > 0 else 0.0
    sorted_desc = np.sort(values)[::-1]
    gaps = np.diff(-sorted_desc)   # positive values = drops
    # search gaps starting after min_keep items
    # gap at index i splits items into [0..i] and [i+1..]
    # to keep min_keep items, search from gap index (min_keep - 1)
    search_start = max(0, min_keep - 1)
    candidate_gaps = gaps[search_start:]
    if len(candidate_gaps) == 0:
        return float(sorted_desc[-1])
    # check if largest gap is meaningful (at least 2× median gap)
    max_gap = float(candidate_gaps.max())
    median_gap = float(np.median(candidate_gaps))
    if len(candidate_gaps) > 1 and median_gap > 0 and max_gap < 2.0 * median_gap:
        return float(sorted_desc[-1])  # no standout gap → keep all
    # split at the largest gap
    split_idx = search_start + int(np.argmax(candidate_gaps)) + 1
    if split_idx >= len(sorted_desc):
        return float(sorted_desc[-1])
    return float((sorted_desc[split_idx - 1] + sorted_desc[split_idx]) / 2.0)

def compute_centroid(cuis, embeddings):
    """Compute normalized centroid of CUI embeddings.

    Args:
        cuis: list/set of CUI strings
        embeddings: dict {cui: numpy array}

    Returns:
        numpy array (L2-normalized) or None if no embeddings found

    Warning:
        Assumes input embeddings are L2-normalized. If not, cosine
        similarities computed via dot product will be incorrect.
    """
    vecs = [embeddings[c] for c in cuis if c in embeddings]
    if not vecs:
        return None
    # verify input normalization (check first vector, warn once)
    if not getattr(compute_centroid, '_norm_checked', False):
        v0_norm = float(np.linalg.norm(vecs[0]))
        if abs(v0_norm - 1.0) > 0.01:
            logger.warning(f"Input embeddings may not be L2-normalized "
                           f"(first vector norm={v0_norm:.4f}). "
                           f"Cosine via dot product will be incorrect.")
        compute_centroid._norm_checked = True
    centroid = np.mean(vecs, axis=0).astype(np.float32)
    norm = np.linalg.norm(centroid)
    if norm > 0:
        centroid = centroid / norm
    return centroid


def build_query_topics(query_cuis, embeddings, params=None):
    """Form topics from query CUIs using embedding similarity.

    Same principle as chunk topic formation: group by cosine, compute centroids.
    Handles all sizes:
      1-3 CUIs: each is its own topic (singleton)
      4+ CUIs:  HAC clustering at cosine distance 0.5

    Args:
        query_cuis: set/list of CUI strings (after reduction)
        embeddings: dict {cui: numpy array}
        params: optional dict overriding DEFAULTS

    Returns:
        dict {topic_id: {"members": [...], "topic_cui": str, "centroid": array}}
    """
    p = {**DEFAULTS, **(params or {})}
    cuis = sorted(query_cuis)
    if not cuis:
        return {}

    vecs = {c: embeddings[c] for c in cuis if c in embeddings}
    if not vecs:
        return {}

    # few CUIs: each is its own topic
    if len(vecs) <= p["query_singleton_max"]:
        topics = {}
        for i, cui in enumerate(sorted(vecs.keys())):
            centroid = compute_centroid([cui], vecs)
            topics[str(i)] = {
                "members": [cui],
                "topic_cui": cui,
                "centroid": centroid,
            }
        return topics

    # 4+ CUIs: HAC clustering — adaptive distance from data
    from scipy.cluster.hierarchy import fcluster, linkage
    from scipy.spatial.distance import pdist

    cui_list = sorted(vecs.keys())
    mat = np.array([vecs[c] for c in cui_list])
    dists = pdist(mat, metric="cosine")
    Z = linkage(dists, method="average")
    # adaptive: use median pairwise distance as cut point
    # dense queries (similar CUIs) → low median → tight clusters
    # sparse queries (diverse CUIs) → high median → loose clusters
    t = float(np.median(dists)) if len(dists) > 0 else p["query_hac_dist"]
    t = min(0.8, max(0.2, t))  # safety clamp: prevent extreme clustering
    labels = fcluster(Z, t=t, criterion="distance")

    topics = {}
    for label in sorted(set(labels)):
        members = [cui_list[i] for i, l in enumerate(labels) if l == label]
        centroid = compute_centroid(members, vecs)
        # pick medoid: member closest to centroid
        best_cui = members[0]
        if centroid is not None and len(members) > 1:
            best_sim = -1.0
            for m in members:
                if m in vecs:
                    s = float(np.dot(vecs[m], centroid))
                    if s > best_sim:
                        best_sim = s
                        best_cui = m
        topics[str(label)] = {
            "members": members,
            "topic_cui": best_cui,
            "centroid": centroid,
        }
    return topics


# ── ChunkMatcher ──────────────────────────────────────────────────────────────

class ChunkMatcher:
    """Three-signal clinical chunk retrieval.

    Filter: CUI overlap OR hierarchy subsumption → candidates
    Score candidates with:
      1. CUI overlap ratio  (W=0.40) — exact matches / query CUI count
      2. Vector similarity   (W=0.30) — cosine of embedding centroids
      3. Lin similarity      (W=0.30) — BMA of best pairwise Lin via MICA
    """

    def __init__(self, graph=None, ic_map=None, params=None):
        self.graph = graph
        self.ic_map = ic_map or {}
        self.p = {**DEFAULTS, **(params or {})}
        self._ancestor_cache = {}
        self._lin_cache = {}       # (c1,c2) → (lin, mica, match_type)

    def _get_ancestors(self, cui):
        """BFS ancestors up to anc_depth hops, cached.

        First 2 hops: always follow parents (catch immediate clinical ancestors
        even if they have low IC — e.g., a broad disease parent behind which
        sits a specific meaningful grandparent).
        Hop 3+: prune parents where ic(parent) < ic_prune_ratio * ic(start_cui).
        """
        if cui in self._ancestor_cache:
            return self._ancestor_cache[cui]
        result = {cui}
        if self.graph is not None and self.graph.has_node(cui):
            start_ic = self.ic_map.get(cui, 0.0)
            ic_floor = self.p["ic_prune_ratio"] * start_ic
            frontier = {cui}
            for hop in range(self.p["anc_depth"]):
                nxt = set()
                for n in frontier:
                    for parent in self.graph.predecessors(n):
                        if parent not in result:
                            # grace period: first 2 hops always follow
                            if hop < 2 or self.ic_map.get(parent, 0.0) >= ic_floor:
                                result.add(parent)
                                nxt.add(parent)
                frontier = nxt
                if not frontier:
                    break
        result = frozenset(result)
        self._ancestor_cache[cui] = result
        return result

    def _lin_sim(self, c1, c2, c1_anc, c2_anc):
        """Lin similarity between two CUIs given precomputed ancestors."""
        if c1 == c2:
            return 1.0, c1, "exact"
        # cache: order-independent key
        key = (min(c1, c2), max(c1, c2))
        cached = self._lin_cache.get(key)
        if cached is not None:
            return cached
        result = self._compute_lin(c1, c2, c1_anc, c2_anc)
        self._lin_cache[key] = result
        return result

    def _compute_lin(self, c1, c2, c1_anc, c2_anc):
        """Actual Lin computation (called once per unique pair).

        All IC thresholds are relative to the CUIs being compared.
        No absolute numbers. Adapts to any IC distribution.
        """
        ic1 = self.ic_map.get(c1, 0.0)
        ic2 = self.ic_map.get(c2, 0.0)
        denom = ic1 + ic2
        if denom < 1e-9:
            return 0.0, None, "no_match"
        ratio = self.p["sibling_ic_ratio"]
        # subsumption (one IS the ancestor of the other)
        # ancestor must be at least ratio × the more specific CUI
        max_ic = max(ic1, ic2)
        if c1 in c2_anc:
            if ic1 >= ratio * max_ic:
                return min(2.0 * ic1 / denom, 1.0), c1, "subsumption"
        if c2 in c1_anc:
            if ic2 >= ratio * max_ic:
                return min(2.0 * ic2 / denom, 1.0), c2, "subsumption"
        # shared ancestor — MICA
        shared = c1_anc & c2_anc
        if not shared:
            return 0.0, None, "no_match"
        # ancestor must be less specific than both CUIs
        min_ic = min(ic1, ic2)
        valid = [c for c in shared if self.ic_map.get(c, 0.0) < min_ic]
        if not valid:
            return 0.0, None, "no_match"
        mica = max(valid, key=lambda c: self.ic_map.get(c, 0.0))
        mica_ic = self.ic_map.get(mica, 0.0)
        # mica must be at least ratio × min IC of both CUIs
        if mica_ic < ratio * min_ic:
            return 0.0, None, "no_match"
        return min(2.0 * mica_ic / denom, 1.0), mica, "shared_ancestor"

    def match(self, query_cuis, query_embedding, chunks, top_k=10, query_topics=None):
        """Match query against stored chunks using three signals.

        CUI matches are weighted by IDF (inverse document frequency).
        A CUI appearing in every chunk has IDF=0 — no discriminative power.
        A CUI appearing in 1 chunk has high IDF — strong signal.

        Args:
            query_cuis: list/set of query CUI strings (after reduction)
            query_embedding: numpy array (centroid) or None
            chunks: dict from ChunkStore.get_all()
            top_k: max results

        Returns:
            list[ChunkMatch] sorted by score descending
        """
        t0 = time.perf_counter()
        query_cuis = set(query_cuis)
        if not query_cuis or not chunks:
            return []

        has_graph = self.graph is not None and len(self.ic_map) > 0
        n_chunks = len(chunks)

        # ── Compute IDF for each CUI across all chunks ───────────────────
        # IDF = log(N / df) where df = number of chunks containing the CUI
        # CUI in all chunks → IDF = 0 (useless). CUI in 1 chunk → IDF high.
        import math
        cui_doc_freq = {}
        for chunk_data in chunks.values():
            for cui in chunk_data.get("cuis", set()):
                cui_doc_freq[cui] = cui_doc_freq.get(cui, 0) + 1

        def idf(cui):
            df = cui_doc_freq.get(cui, 0)
            if df == 0 or df >= n_chunks:
                return 0.0   # not in any chunk OR in every chunk → no discriminative power
            return math.log(n_chunks / df)

        # precompute query ancestors
        query_ancestors = {}
        if has_graph:
            for q in query_cuis:
                query_ancestors[q] = self._get_ancestors(q)

        # precompute all stored CUI ancestors (cached)
        if has_graph:
            for chunk_data in chunks.values():
                for cui in chunk_data["cuis"]:
                    self._get_ancestors(cui)

        # collect query topic centroids for topic-vs-topic filter
        query_topic_centroids = []
        if query_topics:
            for qt_info in query_topics.values():
                qc = qt_info.get("centroid")
                if qc is not None:
                    query_topic_centroids.append(qc)

        results = []
        scored_chunk_ids = set()

        for chunk_id, chunk_data in chunks.items():
            chunk_cuis = chunk_data["cuis"]
            doc_id = chunk_data["doc_id"]
            if not chunk_cuis:
                continue

            # ── Topic filter: query topics vs chunk topics ────────────────
            # Each query topic centroid tested against each chunk topic centroid.
            # cosine >= 0.3 → keep that chunk topic's CUIs for scoring.
            # Focused centroids (per-topic) beat averaged blob (per-chunk).
            # Fallback: no topics or no centroids → score all CUIs.
            stored_topics = chunk_data.get("topics", {})
            if stored_topics and query_topic_centroids:
                matched_topic_ids = set()
                for tid, t_info in stored_topics.items():
                    tc = t_info.get("centroid")
                    if tc is not None:
                        for qtc in query_topic_centroids:
                            sim = float(np.dot(qtc, tc))
                            if sim >= self.p["topic_filter_sim"]:
                                matched_topic_ids.add(tid)
                                break
                    else:
                        # no centroid (old data) — check exact CUI overlap
                        topic_members = set(t_info.get("members", []))
                        if query_cuis & topic_members:
                            matched_topic_ids.add(tid)

                if matched_topic_ids:
                    topic_filtered_cuis = set()
                    for tid in matched_topic_ids:
                        topic_filtered_cuis.update(
                            stored_topics[tid].get("members", []))
                    all_topic_cuis = set()
                    for t_info in stored_topics.values():
                        all_topic_cuis.update(t_info.get("members", []))
                    orphan_cuis = chunk_cuis - all_topic_cuis
                    scoring_cuis = topic_filtered_cuis | orphan_cuis
                else:
                    scoring_cuis = chunk_cuis
            elif stored_topics and query_embedding is not None:
                # no query topics but have query centroid — fall back to blob
                matched_topic_ids = set()
                for tid, t_info in stored_topics.items():
                    tc = t_info.get("centroid")
                    if tc is not None:
                        sim = float(np.dot(query_embedding, tc))
                        if sim >= self.p["topic_filter_sim"]:
                            matched_topic_ids.add(tid)
                    else:
                        topic_members = set(t_info.get("members", []))
                        if query_cuis & topic_members:
                            matched_topic_ids.add(tid)
                if matched_topic_ids:
                    topic_filtered_cuis = set()
                    for tid in matched_topic_ids:
                        topic_filtered_cuis.update(
                            stored_topics[tid].get("members", []))
                    all_topic_cuis = set()
                    for t_info in stored_topics.values():
                        all_topic_cuis.update(t_info.get("members", []))
                    orphan_cuis = chunk_cuis - all_topic_cuis
                    scoring_cuis = topic_filtered_cuis | orphan_cuis
                else:
                    scoring_cuis = chunk_cuis
            else:
                scoring_cuis = chunk_cuis

            # ── Filter: exact CUI overlap OR hierarchy (both directions) ──
            exact_overlap = query_cuis & scoring_cuis

            hierarchy_query_hits = set()  # query CUIs matched via hierarchy
            hierarchy_chunk_hits = set()  # chunk CUIs matched via hierarchy
            shared_ancestor_hits = {}     # {query_cui: (chunk_cui, mica, mica_ic)}
            if has_graph and len(exact_overlap) < len(query_cuis):
                unmatched_query = query_cuis - exact_overlap
                for q_cui in unmatched_query:
                    q_anc = query_ancestors.get(q_cui, frozenset())
                    matched = False
                    for d_cui in scoring_cuis:
                        if d_cui in exact_overlap:
                            continue
                        d_anc = self._ancestor_cache.get(d_cui, frozenset())
                        # Direction 1: query CUI is ancestor of chunk CUI
                        # Direction 2: chunk CUI is ancestor of query CUI
                        # NOTE: filter is intentionally more permissive than Lin scoring.
                        # Filter admits any structural ancestor. Lin applies IC ratio gates.
                        # Filter false positives are OK — they get low scores downstream.
                        if q_cui in d_anc or d_cui in q_anc:
                            hierarchy_query_hits.add(q_cui)
                            hierarchy_chunk_hits.add(d_cui)
                            matched = True
                            break
                    # Direction 3: shared ancestor (sibling match)
                    #   e.g., query "Medical-seizure" and chunk "Focal epilepsy"
                    #   both have "Seizure" as ancestor but neither is parent of other
                    if not matched:
                        best_mica_ic = 0.0
                        best_pair = None
                        q_ic = self.ic_map.get(q_cui, 0.0)
                        sib_ratio = self.p["sibling_ic_ratio"]
                        for d_cui in scoring_cuis:
                            if d_cui in exact_overlap:
                                continue
                            d_anc = self._ancestor_cache.get(d_cui, frozenset())
                            shared = q_anc & d_anc
                            if shared:
                                d_ic = self.ic_map.get(d_cui, 0.0)
                                min_ic = min(q_ic, d_ic)
                                # shared ancestor must be less specific than both
                                # AND at least sibling_ic_ratio × min IC (relative gate)
                                ic_gate = sib_ratio * min_ic
                                valid = [c for c in shared
                                         if ic_gate <= self.ic_map.get(c, 0.0) < min_ic]
                                if valid:
                                    mica = max(valid, key=lambda c: self.ic_map.get(c, 0.0))
                                    mica_ic = self.ic_map.get(mica, 0.0)
                                    if mica_ic > best_mica_ic:
                                        best_mica_ic = mica_ic
                                        best_pair = (d_cui, mica, mica_ic)
                        if best_pair:
                            hierarchy_query_hits.add(q_cui)
                            hierarchy_chunk_hits.add(best_pair[0])
                            shared_ancestor_hits[q_cui] = best_pair

            all_matched_chunk_cuis = exact_overlap | hierarchy_chunk_hits
            if not (exact_overlap or hierarchy_query_hits):
                continue

            scored_chunk_ids.add(chunk_id)

            # ── Signal 1: IDF-weighted CUI overlap (W=0.40) ────────────────
            # CUIs appearing in every chunk have IDF=0 — no discriminative power.
            # CUIs appearing in 1 chunk have high IDF — strong signal.
            matched_query_cuis = set(exact_overlap)
            if has_graph:
                for q_cui in query_cuis - exact_overlap:
                    q_anc = query_ancestors.get(q_cui, frozenset())
                    found = False
                    for d_cui in scoring_cuis:
                        d_anc = self._ancestor_cache.get(d_cui, frozenset())
                        if q_cui in d_anc or d_cui in q_anc:
                            matched_query_cuis.add(q_cui)
                            found = True
                            break
                    # count sibling matches (shared ancestor) if parent-child didn't fire
                    if not found and q_cui in shared_ancestor_hits:
                        matched_query_cuis.add(q_cui)

            idf_matched = sum(idf(q) for q in matched_query_cuis)
            idf_total = sum(idf(q) for q in query_cuis)
            if idf_total > 0:
                cui_ratio = min(idf_matched / idf_total, 1.0)
            else:
                # all query CUIs in every chunk → simple count fallback
                cui_ratio = len(matched_query_cuis) / len(query_cuis)
            matched_query_count = len(matched_query_cuis)

            # ── Signal 2: Vector similarity (W=0.30) ─────────────────────
            vector_sim = 0.0
            chunk_emb = chunk_data.get("embedding")
            has_vectors = query_embedding is not None and chunk_emb is not None
            if has_vectors:
                vector_sim = float(np.dot(query_embedding, chunk_emb))
                vector_sim = max(0.0, min(1.0, vector_sim))
                # sharpening: raise to exponent (default=1, off; set >1 to increase spread)
                vector_sim = vector_sim ** self.p["vector_sharpening"]

            # ── Signal 3: Lin similarity — IDF-weighted, non-exact only ────
            # Lin measures hierarchy quality for non-exact pairs ONLY.
            # When all query CUIs are exact: Lin=1.0 (best possible agreement).
            # This is consistent with adaptive reranking which uses stored lin_score.
            # TopicIndex uses z-score where this becomes relative (see TopicIndex.match).
            lin_details = []
            lin_weighted_sum = 0.0
            lin_weight_total = 0.0
            if has_graph:
                non_exact_q = query_cuis - (query_cuis & scoring_cuis)
                if not non_exact_q:
                    # all exact: Lin=1.0 (hierarchy fully agrees with exact match)
                    lin_avg = 1.0
                    for q_cui in query_cuis & scoring_cuis:
                        lin_details.append(CUIMatchDetail(q_cui, q_cui, q_cui, 1.0, "exact"))
                else:
                    for q_cui in non_exact_q:
                        q_anc = query_ancestors.get(q_cui, frozenset())
                        best_lin = 0.0
                        best_detail = CUIMatchDetail(q_cui, None, None, 0.0, "no_match")
                        for d_cui in scoring_cuis:
                            d_anc = self._ancestor_cache.get(d_cui, frozenset())
                            lin, mica, mtype = self._lin_sim(q_cui, d_cui, q_anc, d_anc)
                            if lin > best_lin:
                                best_lin = lin
                                best_detail = CUIMatchDetail(
                                    q_cui, d_cui, mica, round(lin, 4), mtype)
                                if lin >= 1.0:
                                    break
                        w = idf(q_cui)
                        lin_weighted_sum += best_lin * w
                        lin_weight_total += w
                        lin_details.append(best_detail)
                    for q_cui in query_cuis & scoring_cuis:
                        lin_details.append(CUIMatchDetail(q_cui, q_cui, q_cui, 1.0, "exact"))
                    lin_avg = (lin_weighted_sum / lin_weight_total) if lin_weight_total > 0 else 0.0
            else:
                lin_avg = len(exact_overlap) / len(query_cuis)

            # ── Raw scores (combined later with adaptive weights) ─────────
            if has_vectors and has_graph:
                score = (self.p["w_cui"] * cui_ratio +
                         self.p["w_vec"] * vector_sim +
                         self.p["w_lin"] * lin_avg)
            elif has_vectors:
                w_total = self.p["w_cui"] + self.p["w_vec"]
                score = (self.p["w_cui"] / w_total) * cui_ratio + (self.p["w_vec"] / w_total) * vector_sim
            elif has_graph:
                w_total = self.p["w_cui"] + self.p["w_lin"]
                score = (self.p["w_cui"] / w_total) * cui_ratio + (self.p["w_lin"] / w_total) * lin_avg
            else:
                score = cui_ratio

            if score < self.p["score_min"]:
                continue

            # ── Topic grouping ────────────────────────────────────────────
            topics_matched = {}
            stored_topics = chunk_data.get("topics", {})
            if stored_topics:
                for tid, t_info in stored_topics.items():
                    topic_members = set(t_info.get("members", []))
                    hits = all_matched_chunk_cuis & topic_members
                    if hits:
                        topics_matched[tid] = {
                            "topic_cui": t_info.get("topic_cui"),
                            "matched_cuis": sorted(hits),
                            "total_members": len(topic_members),
                        }

            lin_details.sort(key=lambda d: (-d.lin_sim, d.match_type != "exact"))

            results.append(ChunkMatch(
                chunk_id=chunk_id,
                document_id=doc_id,
                score=round(score, 4),
                cui_overlap=matched_query_count,
                cui_overlap_ratio=round(cui_ratio, 4),
                vector_sim=round(vector_sim, 4),
                lin_score=round(lin_avg, 4),
                total_chunk_cuis=len(chunk_cuis),
                total_query_cuis=len(query_cuis),
                overlapping_cuis=sorted(matched_query_cuis),
                topics_matched=topics_matched,
                lin_details=lin_details
            ))

        # ── Adaptive reranking (ChunkMatcher backward compat ONLY) ──────
        # TopicIndex uses z-score normalization instead (see TopicIndex.match).
        # This variance-based approach is kept for old data without topic centroids.
        # Not equivalent to z-score — produces different rankings.
        if len(results) >= 2:
            cui_vals = [r.cui_overlap_ratio for r in results]
            vec_vals = [r.vector_sim for r in results]
            lin_vals = [r.lin_score for r in results]

            cui_std = np.std(cui_vals) if len(cui_vals) > 1 else 0.0
            vec_std = np.std(vec_vals) if len(vec_vals) > 1 else 0.0
            lin_std = np.std(lin_vals) if len(lin_vals) > 1 else 0.0

            total_std = cui_std + vec_std + lin_std
            if total_std > 0:
                # weight each signal by its variance (ability to discriminate)
                w_cui = cui_std / total_std
                w_vec = vec_std / total_std
                w_lin = lin_std / total_std

                for r in results:
                    new_score = (w_cui * r.cui_overlap_ratio +
                                 w_vec * r.vector_sim +
                                 w_lin * r.lin_score)
                    # replace score in the dataclass
                    object.__setattr__(r, 'score', round(new_score, 4))

        results.sort(key=lambda r: (-r.score, -r.cui_overlap, r.chunk_id))

        # ── Pass 2: Vector fallback for remaining slots ──────────────
        # If CUI filter found fewer than top_k, fill with vector-similar chunks.
        # These have no CUI match but high embedding similarity.
        if query_embedding is not None and len(results) < top_k:
            vector_candidates = []
            for chunk_id, chunk_data in chunks.items():
                if chunk_id in scored_chunk_ids:
                    continue
                chunk_emb = chunk_data.get("embedding")
                if chunk_emb is None:
                    continue
                vsim = float(np.dot(query_embedding, chunk_emb))
                vsim = max(0.0, min(1.0, vsim))
                if vsim >= self.p["vector_fallback_min"]:
                    vector_candidates.append((chunk_id, chunk_data, vsim))
            vector_candidates.sort(key=lambda x: -x[2])

            for chunk_id, chunk_data, vsim in vector_candidates[:top_k - len(results)]:
                # NOTE: fallback scores use manual weight, not z-score.
                # These results are not directly comparable to main scoring.
                # ChunkMatcher backward compat only — TopicIndex has no fallback.
                results.append(ChunkMatch(
                    chunk_id=chunk_id,
                    document_id=chunk_data["doc_id"],
                    score=round(self.p["w_vec"] * vsim, 4),  # vector weight only
                    cui_overlap=0,
                    cui_overlap_ratio=0.0,
                    vector_sim=round(vsim, 4),
                    lin_score=0.0,
                    total_chunk_cuis=len(chunk_data.get("cuis", set())),
                    total_query_cuis=len(query_cuis),
                    overlapping_cuis=[],
                    topics_matched={},
                    lin_details=[]
                ))

        elapsed = (time.perf_counter() - t0) * 1000
        logger.debug(f"    ChunkMatcher: {len(chunks)} chunks → "
                     f"{len(results)} matches ({elapsed:.1f}ms)")
        return results[:top_k]

    @staticmethod
    def explain(result, terms=None):
        """Human-readable explanation."""
        terms = terms or {}
        lines = [
            f"Chunk: {result.chunk_id}  Doc: {result.document_id}",
            f"  Score: {result.score:.3f}  "
            f"(CUI: {result.cui_overlap_ratio:.2f}, "
            f"Vec: {result.vector_sim:.3f}, "
            f"Lin: {result.lin_score:.3f})"
        ]
        if result.topics_matched:
            for tid, t_info in sorted(result.topics_matched.items()):
                t_cui = t_info.get("topic_cui")
                t_label = terms.get(t_cui, t_cui) if t_cui else "(ungrouped)"
                hit_names = [terms.get(c, c) for c in t_info["matched_cuis"]]
                lines.append(
                    f"  Topic {tid} [{t_label}]: "
                    f"{len(t_info['matched_cuis'])}/{t_info['total_members']} CUIs hit "
                    f"({', '.join(hit_names)})")
        if result.overlapping_cuis:
            cui_names = [terms.get(c, c) for c in result.overlapping_cuis]
            lines.append(f"  Exact CUIs: {', '.join(cui_names)}")
        for d in result.lin_details:
            if d.match_type == "exact":
                continue
            if d.match_type == "no_match":
                q_term = terms.get(d.query_cui, d.query_cui)
                lines.append(f"    ✗ {q_term} — no hierarchy match")
            else:
                q_term = terms.get(d.query_cui, d.query_cui)
                d_term = terms.get(d.chunk_cui, d.chunk_cui) if d.chunk_cui else "?"
                mica_term = terms.get(d.mica_cui, d.mica_cui) if d.mica_cui else "?"
                lines.append(
                    f"    ~ {d.match_type} (Lin={d.lin_sim:.3f}): "
                    f"{q_term} ↔ {d_term} via [{mica_term}]")
        return "\n".join(lines)


