"""
Wraps topic formation (stages 6-8) into a standalone module.
Input: surviving CUI codes from CUISummarizer.
Output: labeled topics with subtopics and centroids.
"""

import os, time, pickle, logging
import numpy as np
import networkx
from google.cloud import bigquery

from cui_reduction_system import (
    MetadataFetcher, ICComputer, EmbeddingFetcher,
    HierarchicalTopicBuilder, fetch_preferred_terms,
)

log = logging.getLogger("cui_topics")
log.setLevel(logging.INFO)
log.propagate = False
if not log.handlers:
    log.addHandler(logging.StreamHandler())


class CUITopics:

    def __init__(self, project_id, dataset_id, hierarchy_path, ic_path,
                 embedding_table="cui_embeddings"):
        with open(hierarchy_path, "rb") as f:
            self._graph = pickle.load(f)
        with open(ic_path, "rb") as f:
            self._ic_pre = pickle.load(f)

        self._bq = bigquery.Client(project=project_id)
        self._pid = project_id
        self._did = dataset_id
        self._meta = MetadataFetcher(self._bq, project_id, dataset_id)
        self._ic = ICComputer(self._graph, self._ic_pre)
        self._emb = EmbeddingFetcher(self._bq, project_id, dataset_id, embedding_table)

    def build_topics(self, cuis):
        """
        cuis: list of CUI strings (concise set from CUISummarizer)
        returns dict with topics list + metrics
        """
        t0 = time.perf_counter()

        if not cuis:
            return {"topics": [], "metrics": self._zero_metrics(0.0)}

        cuis = list(dict.fromkeys(cuis))
        n_in = len(cuis)

        # fetch everything we need
        metadata = self._meta.fetch(cuis)
        ic_map = self._ic.compute(cuis, metadata)
        embeddings = self._emb.fetch(cuis)
        terms = fetch_preferred_terms(self._bq, self._pid, self._did, cuis)

        # build topics from hierarchy
        h_topics = HierarchicalTopicBuilder.build(cuis, self._graph, ic_map)
        if not h_topics:
            return {"topics": [], "metrics": self._zero_metrics(self._ms(t0))}

        # label: grouping ancestor if available, else highest-IC member
        for tid, t in h_topics.items():
            g = t.get("_grouping_cui")
            if g:
                t["topic_cui"] = g
            elif t.get("members"):
                t["topic_cui"] = max(t["members"], key=lambda c: ic_map.get(c, 0.0))

        # grab terms for any label CUIs we don't have yet
        label_cuis = {t["topic_cui"] for t in h_topics.values() if t.get("topic_cui")}
        missing = label_cuis - set(terms)
        if missing:
            terms.update(fetch_preferred_terms(self._bq, self._pid, self._did, missing))

        # centroids: mean of member embeddings, L2-normed
        centroids = {}
        for tid, t in h_topics.items():
            vecs = [embeddings[c] for c in t.get("members", []) if c in embeddings]
            if not vecs:
                centroids[tid] = None
                continue
            mu = np.mean(vecs, axis=0).astype(np.float32)
            n = np.linalg.norm(mu)
            centroids[tid] = (mu / n).tolist() if n > 0 else None

        # format
        topics_out = []
        for tid in sorted(h_topics):
            t = h_topics[tid]
            tc = t.get("topic_cui") or ""

            members = []
            for c in t.get("members", []):
                m = metadata.get(c)
                members.append({
                    "cui": c,
                    "preferred_term": terms.get(c, c),
                    "ic": round(ic_map.get(c, 0.0), 4),
                    "semantic_types": list(m.semantic_types) if m and m.semantic_types else [],
                })

            subtopics = []
            for stid in sorted(t.get("subtopics", {})):
                st = t["subtopics"][stid]
                sc = st.get("subtopic_cui") or ""
                st_members = [{"cui": c,
                               "preferred_term": terms.get(c, c),
                               "ic": round(ic_map.get(c, 0.0), 4)}
                              for c in st.get("members", [])]
                subtopics.append({
                    "subtopic_id": stid,
                    "subtopic_cui": sc,
                    "subtopic_label": terms.get(sc, sc) if sc else "",
                    "members": st_members,
                })

            topics_out.append({
                "topic_id": tid,
                "topic_cui": tc,
                "topic_label": terms.get(tc, tc) if tc else "",
                "members": members,
                "subtopics": subtopics,
                "centroid": centroids.get(tid),
            })

        ms = self._ms(t0)
        n_topics = len(topics_out)
        n_single = sum(1 for t in topics_out if len(t["members"]) == 1)
        log.info(f"{n_in} CUIs -> {n_topics} topics ({n_single} singletons) ({ms:.0f}ms)")

        return {
            "topics": topics_out,
            "metrics": {
                "input_cui_count": n_in,
                "topic_count": n_topics,
                "singleton_count": n_single,
                "processing_time_ms": round(ms, 1),
            },
        }

    @staticmethod
    def _zero_metrics(ms):
        return {"input_cui_count": 0, "topic_count": 0,
                "singleton_count": 0, "processing_time_ms": round(ms, 1)}

    @staticmethod
    def _ms(t0):
        return (time.perf_counter() - t0) * 1000

    def close(self):
        self._emb.close()
