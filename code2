def load_pickles_from_gcs(bucket_name, prefix):
    """Load all pickle files from a GCS folder."""
    client = storage.Client()
    bucket = client.bucket(bucket_name)
    blobs = list(bucket.list_blobs(prefix=prefix))
    print(f"  Found {len(blobs)} blobs in gs://{bucket_name}/{prefix}")
    results = []
    for blob in blobs:
        if blob.name.endswith("/"):
            continue
        if blob.name.endswith((".pk", ".pkl", ".pickle")):
            data = pickle.loads(blob.download_as_bytes())
            fname = blob.name.split("/")[-1]
            results.append((fname, data))
            print(f"  Loaded: {fname}")
        else:
            print(f"  Skipped: {blob.name.split('/')[-1]}")
    print(f"Total pickle files: {len(results)}")
    return results


def parse_pickle(data):
    """Parse pickle into list of (entity_text, sentence, [cuis], {cui: distance})."""
    text = data.get("text", "")
    entities = []
    extracted = data.get("extracted", {})
    for key, block in extracted.items():
        for item in block.get("matching_items", []):
            entity_text = item[0]
            sentence = item[1]
            cui_list = item[2] if len(item) > 2 else []
            cuis, distances = [], {}
            for entry in cui_list:
                cuis.append(entry[0])
                distances[entry[0]] = entry[1]
            if cuis:
                entities.append((entity_text, sentence, cuis, distances))
    return text, entities


def fetch_preferred_terms(bq, project_id, dataset_id, cuis):
    """Fetch preferred terms from BQ for display only."""
    if not cuis:
        return {}
    terms = {}
    cuis = list(cuis)
    for i in range(0, len(cuis), 500):
        batch = cuis[i:i+500]
        query = f"""
        SELECT CUI, STR
        FROM `{project_id}.{dataset_id}.MRCONSO`
        WHERE CUI IN UNNEST(@cuis) AND LAT = 'ENG' AND ISPREF = 'Y' AND TS = 'P' AND STT = 'PF'
        """
        jc = bigquery.QueryJobConfig(query_parameters=[
            bigquery.ArrayQueryParameter("cuis", "STRING", batch)])
        for row in bq.query(query, job_config=jc).result():
            if row.CUI not in terms:
                terms[row.CUI] = row.STR
    for c in cuis:
        if c not in terms:
            terms[c] = c
    return terms


# ── cell 3: run ─────────────────────────────────────────────────────────────

def process_one_pickle(fname, data, system, bq):
    """Process one pickle file. Returns structured output dict."""
    text, entities = parse_pickle(data)
    if not entities:
        print(f"\n  FILE: {fname} — no entities found")
        return None

    print(f"\n{'='*80}")
    print(f"CASE: {fname}")
    print(f"TEXT: {text[:150]}...")
    print(f"ENTITIES: {len(entities)}")
    total_cuis = sum(len(c) for _, _, c, _ in entities)
    print(f"TOTAL INPUT CUIs: {total_cuis}")
    print(f"{'='*80}")

    # ── step 1: batch reduction ──
    batch_inputs = [(cuis, entity_text, distances)
                    for entity_text, sentence, cuis, distances in entities]
    results = system.reduce_batch(batch_inputs)
    per_entity_results = list(zip(
        [(e[0], e[1]) for e in entities],  # (entity_text, sentence)
        results))

    all_surviving_cuis = set()
    for _, result in per_entity_results:
        all_surviving_cuis.update(result.all_reduced_cuis)

    # ── step 2: preferred terms for ALL cuis ──
    all_cuis_for_terms = set()
    for _, _, cuis, _ in entities:
        all_cuis_for_terms.update(cuis)
    all_cuis_for_terms.update(all_surviving_cuis)
    terms = fetch_preferred_terms(bq, PROJECT_ID, DATASET_ID, all_cuis_for_terms)

    # ── step 3: case-level topics ──
    surviving_list = list(all_surviving_cuis)
    embeddings = system.emb_fetcher.fetch(surviving_list)
    with_emb = [c for c in surviving_list if c in embeddings]

    case_topics = {}
    if len(with_emb) >= 2:
        case_topics = TopicBuilder.build(with_emb, embeddings)
    elif with_emb:
        case_topics = {0: with_emb}

    # ── step 4: build output + print ──
    case_output = {
        "file": fname,
        "text": text,
        "entity_count": len(entities),
        "total_input_cuis": total_cuis,
        "total_surviving_cuis": len(all_surviving_cuis),
        "entities": [],
        "topics": []
    }

    for (entity_text, sentence), result in per_entity_results:
        entity_out = {
            "entity": entity_text,
            "sentence": sentence,
            "input_count": result.input_count,
            "after_sab": result.after_filter_count,
            "after_hierarchy": result.after_hierarchy_count,
            "final_count": result.after_redundancy_count,
            "cuis": []
        }

        print(f"\n  ENTITY: \"{entity_text}\"")
        print(f"  {result.input_count} → SAB:{result.after_filter_count} "
              f"→ Hier:{result.after_hierarchy_count} → Final:{result.after_redundancy_count}")

        for e in result.confidence:
            explains_count = len(e.explains_cuis)
            cui_entry = {
                "cui": e.cui,
                "preferred_term": terms.get(e.cui, e.cui),
                "confidence": e.confidence,
                "extraction_proximity": e.extraction_proximity,
                "centrality": e.centrality,
                "retention_power": e.retention_power,
                "explains_count": explains_count,
                "explains_cuis": [
                    {"cui": ec, "preferred_term": terms.get(ec, ec)}
                    for ec in e.explains_cuis
                ]
            }
            entity_out["cuis"].append(cui_entry)

        # print top 5
        if result.confidence:
            for e in result.confidence[:5]:
                exp = len(e.explains_cuis)
                exp_str = f"  explains {exp}" if exp > 0 else ""
                print(f"    {e.cui}  conf={e.confidence:.3f}  "
                      f"prox={e.extraction_proximity:.3f} cent={e.centrality:.3f} "
                      f"ret={e.retention_power:.3f}{exp_str}  |  {terms.get(e.cui, e.cui)}")

        case_output["entities"].append(entity_out)

    # topics
    print(f"\n  {'─'*60}")
    print(f"  CASE-LEVEL TOPICS: {len(case_topics)} topics, {len(with_emb)} CUIs")
    print(f"  {'─'*60}")

    for tid, members in sorted(case_topics.items()):
        topic_out = {
            "topic_id": tid,
            "cui_count": len(members),
            "cuis": [{"cui": c, "preferred_term": terms.get(c, c)} for c in members]
        }
        case_output["topics"].append(topic_out)

        print(f"\n  Topic {tid} ({len(members)} CUIs)")
        for c in members[:5]:
            print(f"    {c}  |  {terms.get(c, c)}")
        if len(members) > 5:
            print(f"    ... and {len(members) - 5} more")

    print(f"\n  SUMMARY: {len(entities)} entities → "
          f"{total_cuis} input CUIs → {len(all_surviving_cuis)} surviving → "
          f"{len(case_topics)} topics")

    return case_output


