# =====================================================================
#  EXTRACTION RESULT -- output builders + Approach C narrative gen
# =====================================================================

class ExtractionResult:

    def __init__(self, original_query, expansion, intents, context, processing_time):
        self.original_query = original_query
        self.expansion = expansion
        self.intents = intents
        self.context = context
        self.processing_time = processing_time
        self.timestamp = datetime.now(timezone.utc).isoformat()

    # ---- cleaning helpers ----

    @staticmethod
    def _clean_list(vals):
        cleaned = []
        for v in vals:
            if " - " in v:
                key, desc = v.split(" - ", 1)
                cleaned.append(key.replace("_", " ") + " - " + desc)
            else:
                cleaned.append(v.replace("_", " "))
        return cleaned

    @staticmethod
    def _dedup_by_prefix(vals):
        """Deduplicate values by their prefix (before ' - ').
        Keeps first seen description for each prefix.
        Fixes Issue 1: duplicate retrieval context entries."""
        seen = {}
        for v in vals:
            prefix = v.split(" - ", 1)[0].strip().lower() if " - " in v else v.strip().lower()
            if prefix not in seen:
                seen[prefix] = v
        return sorted(seen.values())

    @staticmethod
    def _word_overlap(a, b):
        wa = set(re.split(r'[\s\-]+', a.lower()))
        wb = set(re.split(r'[\s\-]+', b.lower()))
        wa.discard('')
        wb.discard('')
        if not wa or not wb:
            return 0.0
        return len(wa & wb) / len(wa | wb)

    # ---- APPROACH C: Code-generated narrative from structured fields ----
    #
    # WHY CODE, NOT LLM:
    #   - LLM generates 5 structured fields (excellent at clinical workflow reasoning)
    #   - Code assembles narrative (zero blanks, zero essay drift, consistent structure)
    #   - temporal_scope drives sentence count: one sentence per temporal phase
    #   - Simple concepts (2 phases) get 2 sentences; complex (3-4 phases) get 3-4
    #   - Data drives length, not a hardcoded count
    #
    # WHY NARRATIVE, NOT FLAT CONCAT OR TAGGED:
    #   - Narrative gives best topic modeling separation ratio (4.0x)
    #   - Sentence scaffolding gets de-weighted by embedding models
    #   - Clinical terms dominate signal; between-cluster noise stays at 0.055
    #   - Flat concat: 3.4x separation. Tagged: 2.3x separation.
    #
    # STRUCTURE MATCHES GOLD STANDARD FROM CLINICAL DEPLOYMENT DOC:
    #   Phase 1: "[concept] is first documented in [docs] by [author] at [setting]..."
    #   Phase 2: "It is subsequently tracked in [docs] by [author] at [setting]..."
    #   Phase 3: "Over time, it is referenced in [docs] by [author] at [setting]..."

    @staticmethod
    def _build_narrative(concept_name, doc_types, author_roles,
                         temporal_scope, content_signals, clinical_setting):
        """Build context narrative deterministically from structured fields."""
        if not temporal_scope or not doc_types or not author_roles:
            return ""

        def pfx(v):
            return v.split(" - ", 1)[0].replace("_", " ") if " - " in v else v.replace("_", " ")

        docs = [pfx(v) for v in doc_types]
        auths = [pfx(v) for v in author_roles]
        temps = [pfx(v) for v in temporal_scope]
        sigs = [pfx(v) for v in content_signals] if content_signals else []
        setts = [pfx(v) for v in clinical_setting] if clinical_setting else []

        n_phases = len(temps)

        def distribute(items, n):
            if not items or n == 0:
                return [items or []]
            cs = max(1, len(items) // n)
            chunks = []
            for i in range(n):
                start = i * cs
                if i == n - 1:
                    chunks.append(items[start:])
                else:
                    chunks.append(items[start:start + cs])
            return chunks

        doc_chunks = distribute(docs, n_phases)
        sig_chunks = distribute(sigs, n_phases)

        sentences = []
        for i, phase in enumerate(temps):
            author = auths[i % len(auths)]
            setting = setts[i % len(setts)] if setts else "clinical setting"
            phase_docs = doc_chunks[i] if i < len(doc_chunks) else docs[-1:]
            phase_sigs = sig_chunks[i] if i < len(sig_chunks) else []

            docs_str = ", ".join(phase_docs)
            sigs_str = ", ".join(phase_sigs) if phase_sigs else ""

            if i == 0:
                sig_part = f", capturing {sigs_str}" if sigs_str else ""
                sentences.append(
                    f"{concept_name} is first documented in {docs_str} "
                    f"by the {author} at the {setting} during {phase}"
                    f"{sig_part}.")
            elif i == n_phases - 1 and n_phases > 2:
                sig_part = f" to track {sigs_str}" if sigs_str else ""
                sentences.append(
                    f"Over time, it is referenced in {docs_str} "
                    f"by the {author} at the {setting} during {phase}"
                    f"{sig_part}.")
            else:
                sig_part = f", monitoring {sigs_str}" if sigs_str else ""
                sentences.append(
                    f"It is subsequently tracked in {docs_str} "
                    f"by the {author} at the {setting} during {phase}"
                    f"{sig_part}.")

        return " ".join(sentences)

    # ---- context lookup (3-pass: exact -> substring guarded -> word overlap) ----

    def _find_context(self, atomic_concept):
        if not self.context:
            return None
        key = atomic_concept.strip().lower()
        # Pass 1: exact match
        for cc in self.context.concepts_with_context:
            if cc.atomic_concept.strip().lower() == key:
                return cc
        # Pass 2: substring (guarded: both >= 5 chars, ratio >= 0.5)
        if len(key) >= 5:
            for cc in self.context.concepts_with_context:
                cl = cc.atomic_concept.strip().lower()
                if len(cl) >= 5 and (cl in key or key in cl):
                    ratio = min(len(key), len(cl)) / max(len(key), len(cl))
                    if ratio >= 0.5:
                        return cc
        # Pass 3: word overlap (Jaccard >= 0.5)
        best_score, best_cc = 0.0, None
        for cc in self.context.concepts_with_context:
            score = self._word_overlap(atomic_concept, cc.atomic_concept)
            if score > best_score:
                best_score = score
                best_cc = cc
        if best_cc and best_score >= 0.5:
            return best_cc
        return None

    # ---- context builders ----

    def _build_ctx(self, atomic_concept):
        """Build RetrievalContext for a single atomic concept.
        Narrative is generated in code from the 5 structured fields."""
        cc = self._find_context(atomic_concept)
        if not cc:
            return RetrievalContext()
        cd = self._clean_list(cc.document_types)
        ca = self._clean_list(cc.author_roles)
        ct = self._clean_list(cc.temporal_scope)
        cs = self._clean_list(cc.content_signals)
        cse = self._clean_list(cc.clinical_setting)
        narrative = self._build_narrative(atomic_concept, cd, ca, ct, cs, cse)
        return RetrievalContext(
            document_types=cd, author_roles=ca, temporal_scope=ct,
            content_signals=cs, clinical_setting=cse,
            context_narrative=narrative)

    def _build_intent_ctx(self, intent_title):
        """Build merged RetrievalContext across all concepts in an intent.
        Deduplicates by prefix, then generates narrative in code."""
        if not self.context:
            return RetrievalContext()
        doc, auth, temp, sig, sett = [], [], [], [], []
        title_key = intent_title.strip().lower()
        for cc in self.context.concepts_with_context:
            if cc.intent_title.strip().lower() == title_key:
                doc.extend(cc.document_types)
                auth.extend(cc.author_roles)
                temp.extend(cc.temporal_scope)
                sig.extend(cc.content_signals)
                sett.extend(cc.clinical_setting)
        if not any([doc, auth, temp, sig, sett]):
            return RetrievalContext()
        dd = self._clean_list(self._dedup_by_prefix(doc))
        da = self._clean_list(self._dedup_by_prefix(auth))
        dt = self._clean_list(self._dedup_by_prefix(temp))
        ds = self._clean_list(self._dedup_by_prefix(sig))
        dse = self._clean_list(self._dedup_by_prefix(sett))
        narrative = self._build_narrative(intent_title, dd, da, dt, ds, dse)
        return RetrievalContext(
            document_types=dd, author_roles=da, temporal_scope=dt,
            content_signals=ds, clinical_setting=dse,
            context_narrative=narrative)

    # ---- 4 output builders ----

    def to_intent_extraction(self):
        return Format_IntentExtraction(
            user_query=self.original_query,
            intents=[IntentSummaryItem(
                intent_title=i.intent_title, description=i.description)
                for i in self.intents.intents],
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
            timestamp=self.timestamp).model_dump()

    def to_final_queries(self):
        """Iterates atomic_concepts directly as candidates.
        Fixes Issue 4+6: atomic_concept = candidate (identical).
        _build_ctx always finds context since Step 3 keys = atomic_concepts."""
        candidates = []
        idx = 0
        seen = set()
        for i in self.intents.intents:
            for sn in i.sub_natures:
                for concept in sn.atomic_concepts:
                    key = concept.strip().lower()
                    if key in seen:
                        continue
                    seen.add(key)
                    idx += 1
                    candidates.append(FinalCandidateItem(
                        candidate_id=f"fc_{idx:03d}",
                        intent_title=i.intent_title,
                        atomic_concept=concept.strip(),
                        candidate=concept.strip(),
                        retrieval_context=self._build_ctx(concept)))
        return Format_FinalQueries(
            user_query=self.original_query,
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
            total_candidates=len(candidates),
            final_candidates=candidates,
            timestamp=self.timestamp).model_dump()

    def to_nature_breakdown(self):
        return Format_NatureBreakdown(
            is_clinical=self.intents.is_clinical,
            reason=self.intents.reason,
            original_query=self.intents.original_query,
            total_intents_detected=self.intents.total_intents_detected,
            intents=[IntentWithoutQueries(
                intent_title=i.intent_title, description=i.description,
                nature=i.nature, sub_natures=i.sub_natures)
                for i in self.intents.intents],
            timestamp=self.timestamp).model_dump()

    def to_full_pipeline(self):
        """Uses final_candidates (not final_queries) populated from atomic_concepts.
        Fixes Issue 5: consistent naming across both output formats."""
        return Format_FullPipeline(
            is_clinical=self.intents.is_clinical,
            reason=self.intents.reason,
            original_query=self.original_query,
            expanded_query=self.expansion.expanded_query,
            total_intents_detected=self.intents.total_intents_detected,
            intents=[IntentWithContext(
                intent_title=i.intent_title, description=i.description,
                nature=i.nature, sub_natures=i.sub_natures,
                final_candidates=[c for sn in i.sub_natures
                                  for c in sn.atomic_concepts],
                retrieval_context=self._build_intent_ctx(i.intent_title))
                for i in self.intents.intents],
            timestamp=self.timestamp).model_dump()

    def to_all_formats(self):
        return {
            "intent_extraction": self.to_intent_extraction(),
            "final_queries": self.to_final_queries(),
            "nature_breakdown": self.to_nature_breakdown(),
            "full_pipeline": self.to_full_pipeline(),
        }


# =====================================================================
#  PIPELINE -- 3 LLM calls per query
# =====================================================================

class ContextualIntentPipeline:

    def __init__(self, project, location="us-central1", model="gemini-2.5-flash"):
        self.client = genai.Client(vertexai=True, project=project, location=location)
        self.project = project
        self.location = location
        self.model_name = model

    def _extract_json(self, response):
        if hasattr(response, 'text'):
            text = response.text
        elif hasattr(response, 'candidates') and response.candidates:
            text = response.candidates[0].content.parts[0].text
        else:
            text = str(response)
        if not text or not text.strip():
            raise ValueError("Empty or blocked LLM response")
        text = re.sub(r'```json\s*', '', text)
        text = re.sub(r'```\s*', '', text).strip()
        return json.loads(text)

    def _call_model(self, prompt, response_schema, context_query="", max_tokens=8192):
        try:
            config = types.GenerateContentConfig(
                temperature=0, top_p=0.2, seed=34,
                max_output_tokens=max_tokens,
                response_mime_type="application/json",
                response_schema=response_schema)
            response = self.client.models.generate_content(
                model=self.model_name, contents=prompt, config=config)
            data = self._extract_json(response)
            return response_schema.model_validate(data)
        except Exception as e:
            print(f"Model error: {e}")
            if response_schema == QueryExpansionOutput:
                return QueryExpansionOutput(expanded_query=context_query or "")
            elif response_schema == IntentExtractionResponse:
                return IntentExtractionResponse(
                    is_clinical=False, reason=f"Processing error: {str(e)}",
                    total_intents_detected=0, intents=[])
            elif response_schema == ContextualEnvironmentOutput:
                return ContextualEnvironmentOutput(concepts_with_context=[])
            raise

    # -- Step 1: Expansion --

    def expand_query(self, query):
        return self._call_model(
            QUERY_EXPANSION_PROMPT.format(query=query),
            QueryExpansionOutput, query, max_tokens=2048)

    # -- Step 2: Intent Extraction --

    def extract_intents(self, original_query, expanded_query):
        response = self._call_model(
            INTENT_EXTRACTION_PROMPT.format(
                expanded_query=expanded_query,
                timestamp=datetime.now(timezone.utc).isoformat()),
            IntentExtractionResponse, original_query)
        return IntentExtractionOutput(
            is_clinical=response.is_clinical, reason=response.reason,
            original_query=original_query, expanded_query=expanded_query,
            total_intents_detected=len(response.intents),
            intents=response.intents)

    # -- Step 3: Context Generation (structured fields only, no narrative) --

    @staticmethod
    def _prepare_context_input(intents):
        out, seen = [], set()
        for i in intents:
            for sn in i.sub_natures:
                for c in sn.atomic_concepts:
                    key = c.strip().lower()
                    if key and key not in seen:
                        out.append({"atomic_concept": c.strip(),
                                    "intent_title": i.intent_title})
                        seen.add(key)
        return out

    @staticmethod
    def _has_content(cc):
        """Validate that all 5 structured fields are populated.
        No narrative check needed -- narrative is built in code."""
        return bool(cc.document_types and cc.author_roles
                    and cc.temporal_scope and cc.content_signals
                    and cc.clinical_setting)

    def generate_context(self, original_query, expanded_query, intents):
        if not intents:
            return ContextualEnvironmentOutput(concepts_with_context=[])
        concepts = self._prepare_context_input(intents)
        if not concepts:
            return ContextualEnvironmentOutput(concepts_with_context=[])
        result = self._call_model(
            CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                original_query=original_query,
                expanded_query=expanded_query,
                concepts_json=json.dumps(concepts, indent=2),
                concept_count=len(concepts)),
            ContextualEnvironmentOutput, max_tokens=16384)

        # Validate: retry any concepts with missing structured fields
        covered = {cc.atomic_concept.strip().lower()
                   for cc in result.concepts_with_context
                   if self._has_content(cc)}
        missing = [c for c in concepts
                   if c["atomic_concept"].strip().lower() not in covered]
        if missing:
            missing_keys = {c["atomic_concept"].strip().lower() for c in missing}
            result.concepts_with_context = [
                cc for cc in result.concepts_with_context
                if cc.atomic_concept.strip().lower() not in missing_keys]
            print(f"Step 3: {len(covered)}/{len(concepts)} have content, "
                  f"retrying {len(missing)} blank/missing...")
            retry = self._call_model(
                CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                    original_query=original_query,
                    expanded_query=expanded_query,
                    concepts_json=json.dumps(missing, indent=2),
                    concept_count=len(missing)),
                ContextualEnvironmentOutput, max_tokens=16384)
            result.concepts_with_context.extend(retry.concepts_with_context)
        return result

    # -- Orchestrator --

    def extract(self, query, verbose=False):
        if not query or not query.strip():
            raise ValueError("Empty query provided")
        start_time = datetime.now(timezone.utc)
        expansion = self.expand_query(query)
        intents = self.extract_intents(query, expansion.expanded_query)
        context = None
        if intents.is_clinical and intents.intents:
            context = self.generate_context(
                query, expansion.expanded_query, intents.intents)
        processing_time = (datetime.now(timezone.utc) - start_time).total_seconds()
        if verbose:
            print(f"Query: {query}")
            print(f"Expanded: {expansion.expanded_query}")
            if intents.is_clinical:
                nq = len({c.strip().lower() for i in intents.intents
                          for sn in i.sub_natures for c in sn.atomic_concepts})
                nc = len(context.concepts_with_context) if context else 0
                print(f"Clinical | Intents: {intents.total_intents_detected} | "
                      f"Candidates: {nq} | Contexts: {nc}")
            else:
                print(f"Non-clinical | Reason: {intents.reason}")
            print(f"Time: {processing_time:.2f}s")
        return ExtractionResult(query, expansion, intents, context, processing_time)

    def run(self, query, output_format="full_pipeline", verbose=False):
        try:
            result = self.extract(query, verbose)
            return getattr(result, f"to_{output_format}")()
        except Exception as e:
            if verbose:
                print(f"Error: {e}\n")
            return {"error": str(e), "query": query,
                    "timestamp": datetime.now(timezone.utc).isoformat()}


