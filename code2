# =====================================================================
#  EXTRACTION RESULT — builds normalized output
# =====================================================================

class ExtractionResult:

    def __init__(self, original_query: str, normalized_query: str,
                 expansion: QueryExpansionOutput,
                 intents: IntentExtractionOutput,
                 context: Optional[ContextualEnvironmentOutput],
                 processing_time: float, model_name: str,
                 steps: List[StepStatus]):
        self.original_query = original_query
        self.normalized_query = normalized_query
        self.expansion = expansion
        self.intents = intents
        self.context = context
        self.processing_time = processing_time
        self.model_name = model_name
        self.steps = steps
        self.timestamp = datetime.now(timezone.utc).isoformat()

    # -- helpers --

    @staticmethod
    def _parse_field(raw: str) -> ContextField:
        """Parse 'snake_case_term - definition' into structured pair."""
        if " - " in raw:
            key, desc = raw.split(" - ", 1)
            return ContextField(key=key.strip(), description=desc.strip())
        return ContextField(key=raw.strip(), description="")

    def _find_context(self, term: str) -> OutputContext:
        """Look up Step 3 context for an atomic concept."""
        if not self.context:
            return OutputContext()
        key = term.strip().lower()
        for cc in self.context.concepts_with_context:
            if cc.atomic_concept.strip().lower() == key:
                return OutputContext(
                    document_types=[self._parse_field(v) for v in cc.document_types],
                    author_roles=[self._parse_field(v) for v in cc.author_roles],
                    temporal_scope=[self._parse_field(v) for v in cc.temporal_scope],
                    content_signals=[self._parse_field(v) for v in cc.content_signals],
                    clinical_setting=[self._parse_field(v) for v in cc.clinical_setting],
                    context_stories=cc.context_stories,
                )
        return OutputContext()

    @staticmethod
    def _completeness(ctx: OutputContext) -> float:
        """Score 0.0-1.0 based on how many context fields are populated."""
        fields = [ctx.document_types, ctx.author_roles, ctx.temporal_scope,
                  ctx.content_signals, ctx.clinical_setting, ctx.context_stories]
        filled = sum(1 for f in fields if f)
        return round(filled / len(fields), 2)

    # -- output builder --

    def to_output(self) -> Dict[str, Any]:
        """Build single normalized output."""
        int_n, sn_n, con_n = 0, 0, 0
        out_intents = []
        out_concepts = []
        with_ctx, without_ctx = 0, 0
        seen_terms = {}  # lowercase → con_id (dedup across intents)

        for intent in self.intents.intents:
            int_n += 1
            int_id = f"int_{int_n:03d}"
            intent_concept_ids = []

            out_sub_natures = []
            for sn in intent.sub_natures:
                sn_n += 1
                sn_id = f"sn_{sn_n:03d}"
                out_sub_natures.append(OutputSubNature(
                    id=sn_id, category_path=sn.category_path))

                for term in sn.atomic_concepts:
                    term_key = term.strip().lower()
                    if term_key in seen_terms:
                        # dedup: concept already exists, just add reference
                        intent_concept_ids.append(seen_terms[term_key])
                        continue

                    con_n += 1
                    con_id = f"con_{con_n:03d}"
                    seen_terms[term_key] = con_id
                    intent_concept_ids.append(con_id)

                    ctx = self._find_context(term)
                    score = self._completeness(ctx)
                    if ctx.document_types:
                        with_ctx += 1
                    else:
                        without_ctx += 1

                    out_concepts.append(OutputConcept(
                        id=con_id,
                        term=term,
                        intent_id=int_id,
                        sub_nature_id=sn_id,
                        context=ctx,
                        context_completeness=score,
                    ))

            out_intents.append(OutputIntent(
                id=int_id, title=intent.intent_title,
                description=intent.description, nature=intent.nature,
                sub_natures=out_sub_natures,
                concept_ids=intent_concept_ids))

        return PipelineOutput(
            pipeline=OutputPipelineMeta(
                query=self.original_query,
                normalized_query=self.normalized_query,
                expanded_query=self.expansion.expanded_query,
                abbreviations_expanded=self.expansion.abbreviations_expanded,
                is_clinical=self.intents.is_clinical,
                rejected_reason=self.intents.reason,
                model=self.model_name,
                processing_time_ms=int(self.processing_time * 1000),
                timestamp=self.timestamp,
                steps=self.steps,
            ),
            summary=OutputSummary(
                total_intents=int_n,
                total_concepts=con_n,
                concepts_with_context=with_ctx,
                concepts_without_context=without_ctx,
            ),
            intents=out_intents,
            concepts=out_concepts,
        ).model_dump()


# =====================================================================
#  PIPELINE
# =====================================================================

class ContextualIntentPipeline:

    def __init__(self, project: str, location: str = "us-central1",
                 model: str = "gemini-2.5-flash"):
        self.client = genai.Client(vertexai=True, project=project, location=location)
        self.project = project
        self.location = location
        self.model_name = model

    @staticmethod
    def _normalize_query(query: str) -> str:
        """Normalize input: strip, collapse whitespace, sentence case."""
        q = re.sub(r'\s+', ' ', query.strip())
        if q.isupper():
            q = q.capitalize()
        if q.endswith('?'):
            pass
        elif q.endswith('.'):
            q = q[:-1].strip()
        return q

    def _extract_json(self, response) -> Dict[str, Any]:
        if hasattr(response, 'text'):
            text = response.text
        elif hasattr(response, 'candidates') and response.candidates:
            text = response.candidates[0].content.parts[0].text
        else:
            text = str(response)

        text = re.sub(r'```json\s*', '', text)
        text = re.sub(r'```\s*', '', text).strip()

        if not text.endswith('}') and not text.endswith(']'):
            raise ValueError(f"Truncated JSON response ({len(text)} chars)")

        return json.loads(text)

    def _call_model(self, prompt: str, response_schema: type[BaseModel],
                    max_tokens: int = 8096) -> BaseModel:
        config = types.GenerateContentConfig(
            temperature=0.1,
            top_p=0.95,
            top_k=4,
            seed=34,
            max_output_tokens=max_tokens,
            response_mime_type="application/json",
            response_schema=response_schema,
        )
        response = self.client.models.generate_content(
            model=self.model_name, contents=prompt, config=config
        )
        data = self._extract_json(response)
        return response_schema.model_validate(data)

    # -- Step 1 --

    def expand_query(self, query: str) -> tuple[QueryExpansionOutput, StepStatus]:
        step_start = datetime.now(timezone.utc)
        try:
            result = self._call_model(
                QUERY_EXPANSION_PROMPT.format(query=query),
                QueryExpansionOutput)
            ms = int((datetime.now(timezone.utc) - step_start).total_seconds() * 1000)
            return result, StepStatus(step="expansion", status="success", duration_ms=ms)
        except Exception as e:
            ms = int((datetime.now(timezone.utc) - step_start).total_seconds() * 1000)
            return (QueryExpansionOutput(expanded_query=query),
                    StepStatus(step="expansion", status="fallback",
                               detail=str(e), duration_ms=ms))

    # -- Step 2 --

    def extract_intents(self, original_query: str,
                        expanded_query: str) -> tuple[IntentExtractionOutput, StepStatus]:
        step_start = datetime.now(timezone.utc)
        try:
            response = self._call_model(
                INTENT_EXTRACTION_PROMPT.format(
                    original_query=original_query,
                    expanded_query=expanded_query,
                    timestamp=datetime.now(timezone.utc).isoformat()),
                IntentExtractionResponse)

            output = IntentExtractionOutput(
                is_clinical=response.is_clinical,
                reason=response.reason,
                original_query=original_query,
                expanded_query=expanded_query,
                total_intents_detected=len(response.intents),
                intents=response.intents,
            )
            ms = int((datetime.now(timezone.utc) - step_start).total_seconds() * 1000)
            return output, StepStatus(step="intent_extraction", status="success", duration_ms=ms)
        except Exception as e:
            ms = int((datetime.now(timezone.utc) - step_start).total_seconds() * 1000)
            return (IntentExtractionOutput(
                        is_clinical=False, reason=f"Processing error: {e}",
                        original_query=original_query, expanded_query=expanded_query),
                    StepStatus(step="intent_extraction", status="fallback",
                               detail=str(e), duration_ms=ms))

    # -- Step 3 --

    @staticmethod
    def _prepare_context_input(intents: List[Intent]) -> List[Dict]:
        out, seen = [], set()
        for i in intents:
            for sn in i.sub_natures:
                for c in sn.atomic_concepts:
                    key = c.strip().lower()
                    if key and key not in seen:
                        out.append({"atomic_concept": c.strip(),
                                    "intent_title": i.intent_title})
                        seen.add(key)
        return out

    def generate_context(self, original_query: str, expanded_query: str,
                         intents: List[Intent]) -> tuple[ContextualEnvironmentOutput, StepStatus]:
        step_start = datetime.now(timezone.utc)

        if not intents:
            return (ContextualEnvironmentOutput(concepts_with_context=[]),
                    StepStatus(step="context_generation", status="success",
                               detail="no intents", duration_ms=0))

        concepts = self._prepare_context_input(intents)
        if not concepts:
            return (ContextualEnvironmentOutput(concepts_with_context=[]),
                    StepStatus(step="context_generation", status="success",
                               detail="no concepts", duration_ms=0))

        try:
            result = self._call_model(
                CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                    original_query=original_query,
                    expanded_query=expanded_query,
                    concepts_json=json.dumps(concepts, indent=2),
                    concept_count=len(concepts)),
                ContextualEnvironmentOutput,
                max_tokens=16384)

            # Validate coverage
            returned = {cc.atomic_concept.strip().lower()
                        for cc in result.concepts_with_context}
            missing = [c for c in concepts
                       if c["atomic_concept"].strip().lower() not in returned]

            retry_detail = None
            if missing:
                retry_detail = f"initial: {len(returned)}/{len(concepts)}, retrying {len(missing)}"
                retry = self._call_model(
                    CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                        original_query=original_query,
                        expanded_query=expanded_query,
                        concepts_json=json.dumps(missing, indent=2),
                        concept_count=len(missing)),
                    ContextualEnvironmentOutput,
                    max_tokens=16384)
                result.concepts_with_context.extend(retry.concepts_with_context)

                # Check if retry covered everything
                still_returned = {cc.atomic_concept.strip().lower()
                                  for cc in result.concepts_with_context}
                still_missing = [c for c in concepts
                                 if c["atomic_concept"].strip().lower() not in still_returned]
                if still_missing:
                    retry_detail += f", still missing: {len(still_missing)}"

            ms = int((datetime.now(timezone.utc) - step_start).total_seconds() * 1000)
            status = "success" if not missing else "success" if not retry_detail or "still missing" not in (retry_detail or "") else "partial"
            return (result,
                    StepStatus(step="context_generation", status=status,
                               detail=retry_detail, duration_ms=ms))

        except Exception as e:
            ms = int((datetime.now(timezone.utc) - step_start).total_seconds() * 1000)
            return (ContextualEnvironmentOutput(concepts_with_context=[]),
                    StepStatus(step="context_generation", status="error",
                               detail=str(e), duration_ms=ms))

    # -- Orchestrator --

    def extract(self, query: str, verbose: bool = False) -> ExtractionResult:
        if not query or not query.strip():
            raise ValueError("Empty query provided")

        start_time = datetime.now(timezone.utc)
        normalized = self._normalize_query(query)
        steps = []

        # Step 1
        expansion, step1 = self.expand_query(normalized)
        steps.append(step1)

        # Step 2
        intents, step2 = self.extract_intents(normalized, expansion.expanded_query)
        steps.append(step2)

        # Step 3
        context = None
        if intents.is_clinical and intents.intents:
            context, step3 = self.generate_context(
                normalized, expansion.expanded_query, intents.intents)
            steps.append(step3)

        processing_time = (datetime.now(timezone.utc) - start_time).total_seconds()

        if verbose:
            print(f"Query: {query}")
            if normalized != query:
                print(f"Normalized: {normalized}")
            print(f"Expanded: {expansion.expanded_query}")
            if intents.is_clinical:
                nc = sum(len(sn.atomic_concepts) for i in intents.intents for sn in i.sub_natures)
                ctx_n = len(context.concepts_with_context) if context else 0
                print(f"Clinical | Intents: {intents.total_intents_detected} | "
                      f"Concepts: {nc} | Contexts: {ctx_n}")
            else:
                print(f"Non-clinical | Reason: {intents.reason}")
            for s in steps:
                flag = "✓" if s.status == "success" else "⚠" if s.status == "fallback" else "✗"
                detail = f" ({s.detail})" if s.detail else ""
                print(f"  {flag} {s.step}: {s.status}{detail} [{s.duration_ms}ms]")
            print(f"Time: {processing_time:.2f}s")

        return ExtractionResult(query, normalized, expansion, intents, context,
                                processing_time, self.model_name, steps)

    def run(self, query: str, verbose: bool = False) -> Dict[str, Any]:
        try:
            result = self.extract(query, verbose)
            return result.to_output()
        except Exception as e:
            if verbose:
                print(f"Error: {e}\n")
            return {"error": str(e), "query": query,
                    "timestamp": datetime.now(timezone.utc).isoformat()}


