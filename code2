# %% Cell 1: Read all pickle files from GCS folder

import pickle
from google.cloud import storage, bigquery
from collections import defaultdict

bucket_name = "<YOUR_BUCKET>"
folder_path = "<YOUR_FOLDER>/"  # e.g. "concept_coding_output/"

gcs_client = storage.Client()
bucket = gcs_client.bucket(bucket_name)

# Read all .pk files
cases = {}
for blob in bucket.list_blobs(prefix=folder_path):
    if blob.name.endswith(".pk"):
        case_name = blob.name.split("/")[-1].replace(".pk", "")
        with blob.open("rb") as f:
            cases[case_name] = pickle.load(f)
        print(f"Loaded: {case_name}")

print(f"\nTotal cases loaded: {len(cases)}")


# %% Cell 2: Extract CUIs + distances from each case

DISTANCE_THRESHOLD = 0.30

def extract_cuis(case_data, threshold=DISTANCE_THRESHOLD):
    """Extract CUIs from concept coding pickle. Keep best distance per CUI."""
    extracted = case_data.get("extracted", {})
    cui_best = {}

    for entity_key, entity_data in extracted.items():
        if not isinstance(entity_data, dict):
            continue
        for item in entity_data.get("matching_items", []):
            if len(item) < 3:
                continue
            for match in item[2]:
                cui, distance = match[0], match[1]
                if distance <= threshold:
                    if cui not in cui_best or distance < cui_best[cui]:
                        cui_best[cui] = distance

    return cui_best


cuis_per_case = {}
for case_name, case_data in cases.items():
    cuis_per_case[case_name] = extract_cuis(case_data)
    print(f"{case_name}: {len(cuis_per_case[case_name])} CUIs")

all_cuis = set()
for v in cuis_per_case.values():
    all_cuis.update(v.keys())
print(f"\nTotal unique CUIs across all cases: {len(all_cuis)}")


# %% Cell 3: Fetch preferred terms for all CUIs

bq_client = bigquery.Client(project="<YOUR_PROJECT>")

def get_preferred_terms(cuis: set, project_id: str, dataset_id: str, desc_table: str) -> dict:
    """Fetch preferred term for each CUI from BigQuery."""
    if not cuis:
        return {}
    cui_list = list(cuis)
    terms = {}
    # Batch in chunks of 2000
    for i in range(0, len(cui_list), 2000):
        batch = cui_list[i:i+2000]
        query = f"""
            SELECT CUI as cui, STR as preferred_term
            FROM `{project_id}.{dataset_id}.{desc_table}`
            WHERE CUI IN UNNEST(@cuis)
            AND LAT = 'ENG'
            AND ISPREF = 'Y'
            AND TS = 'P'
            AND STT = 'PF'
            QUALIFY ROW_NUMBER() OVER (PARTITION BY CUI ORDER BY LENGTH(STR)) = 1
        """
        job_config = bigquery.QueryJobConfig(
            query_parameters=[bigquery.ArrayQueryParameter("cuis", "STRING", batch)]
        )
        rows = bq_client.query(query, job_config=job_config).result()
        for row in rows:
            terms[row.cui] = row.preferred_term

    return terms


project_id = "<YOUR_PROJECT>"
dataset_id = "<YOUR_DATASET>"
desc_table = "<YOUR_MRCONSO_TABLE>"  # or your CUI description table

preferred_terms = get_preferred_terms(all_cuis, project_id, dataset_id, desc_table)
print(f"Preferred terms fetched: {len(preferred_terms)} / {len(all_cuis)}")


# %% Cell 4: CUI Reduction per case

# --- Uses your existing EnhancedCUIReducer ---

