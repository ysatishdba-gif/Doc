#  EXTRACTION RESULT
# =====================================================================

class ExtractionResult:

    def __init__(self, original_query, expansion, intents, context,
                 processing_time):
        self.original_query = original_query
        self.expansion = expansion
        self.intents = intents
        self.context = context
        self.processing_time = processing_time
        self.timestamp = datetime.now(timezone.utc).isoformat()

    @staticmethod
    def _clean(v):
        if not v:
            return ""
        if " - " in v:
            k, d = v.split(" - ", 1)
            return k.replace("_", " ") + " - " + d
        return v.replace("_", " ")

    @staticmethod
    def _pfx(v):
        if not v:
            return ""
        return (v.split(" - ", 1)[0].replace("_", " ")
                if " - " in v else v.replace("_", " "))

    @staticmethod
    def _join(items):
        parts = [ExtractionResult._pfx(v) for v in (items or []) if v]
        if not parts:
            return ""
        if len(parts) == 1:
            return parts[0]
        if len(parts) == 2:
            return f"{parts[0]} and {parts[1]}"
        return ", ".join(parts[:-1]) + f", and {parts[-1]}"

    @staticmethod
    def _dedup(values):
        seen, out = set(), []
        for v in (values or []):
            if not v:
                continue
            k = v.split(" - ", 1)[0].strip().lower()
            if k and k not in seen:
                out.append(v)
                seen.add(k)
        return out

    @staticmethod
    def _flatten_and_build(concept_name, phases):
        docs, auths, temps, sigs, setts = [], [], [], [], []
        sentences = []
        for p in (phases or []):
            if not p.document_types or not p.author_roles:
                continue
            if p.phase_name:
                temps.append(p.phase_name)
            docs.extend(p.document_types or [])
            auths.extend(p.author_roles or [])
            sigs.extend(p.content_signals or [])
            setts.extend(p.clinical_settings or [])
            d = ExtractionResult._join(p.document_types)
            a = ExtractionResult._join(p.author_roles)
            se = ExtractionResult._join(p.clinical_settings)
            si = ExtractionResult._join(p.content_signals)
            parts = [concept_name, f"documented in {d}", f"by {a}"]
            if se:
                parts.append(f"at {se}")
            if si:
                parts.append(f"capturing {si}")
            sentences.append(", ".join(parts) + ".")
        cl = ExtractionResult._clean
        dd = ExtractionResult._dedup
        return (dd([cl(v) for v in docs]),
                dd([cl(v) for v in auths]),
                dd([cl(v) for v in temps]),
                dd([cl(v) for v in sigs]),
                dd([cl(v) for v in setts]),
                sentences)

    def _get_phases(self, atomic_concept):
        if not self.context or not self.context.concepts_with_context:
            return []
        key = atomic_concept.strip().lower()
        for cc in self.context.concepts_with_context:
            if cc.atomic_concept.strip().lower() == key:
                return cc.temporal_phases or []
        return []

    def _build_ctx(self, concept_name):
        phases = self._get_phases(concept_name)
        if not phases:
            return RetrievalContext()
        docs, auths, temps, sigs, setts, sents = (
            self._flatten_and_build(concept_name, phases))
        return RetrievalContext(
            document_types=docs, author_roles=auths,
            temporal_scope=temps, content_signals=sigs,
            clinical_setting=setts, context_sentences=sents)

    def _build_intent_ctx(self, intent_title):
        if not self.context or not self.context.concepts_with_context:
            return RetrievalContext()
        all_phases = []
        key = intent_title.strip().lower()
        for cc in self.context.concepts_with_context:
            if cc.intent_title.strip().lower() == key:
                all_phases.extend(cc.temporal_phases or [])
        if not all_phases:
            return RetrievalContext()
        docs, auths, temps, sigs, setts, sents = (
            self._flatten_and_build(intent_title, all_phases))
        return RetrievalContext(
            document_types=docs, author_roles=auths,
            temporal_scope=temps, content_signals=sigs,
            clinical_setting=setts, context_sentences=sents)

    def to_intent_extraction(self):
        return Format_IntentExtraction(
            user_query=self.original_query,
            intents=[IntentSummaryItem(
                intent_title=i.intent_title, description=i.description)
                for i in self.intents.intents],
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
            timestamp=self.timestamp).model_dump()

    def to_final_queries(self):
        candidates, seen, idx = [], set(), 0
        for i in self.intents.intents:
            for sn in i.sub_natures:
                for c in sn.atomic_concepts:
                    key = c.strip().lower()
                    if not key or key in seen:
                        continue
                    seen.add(key)
                    idx += 1
                    candidates.append(FinalCandidateItem(
                        candidate_id=f"fc_{idx:03d}",
                        intent_title=i.intent_title,
                        atomic_concept=c.strip(),
                        candidate=c.strip(),
                        retrieval_context=self._build_ctx(c.strip())))
        return Format_FinalQueries(
            user_query=self.original_query,
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
            total_candidates=len(candidates),
            final_candidates=candidates,
            timestamp=self.timestamp).model_dump()

    def to_nature_breakdown(self):
        return Format_NatureBreakdown(
            is_clinical=self.intents.is_clinical,
            reason=self.intents.reason,
            original_query=self.intents.original_query,
            total_intents_detected=self.intents.total_intents_detected,
            intents=[IntentWithoutQueries(
                intent_title=i.intent_title, description=i.description,
                nature=i.nature, sub_natures=i.sub_natures)
                for i in self.intents.intents],
            timestamp=self.timestamp).model_dump()

    def to_full_pipeline(self):
        return Format_FullPipeline(
            is_clinical=self.intents.is_clinical,
            reason=self.intents.reason,
            original_query=self.original_query,
            expanded_query=self.expansion.expanded_query,
            total_intents_detected=self.intents.total_intents_detected,
            intents=[IntentWithContext(
                intent_title=i.intent_title, description=i.description,
                nature=i.nature, sub_natures=i.sub_natures,
                final_candidates=[c for sn in i.sub_natures
                                  for c in sn.atomic_concepts],
                retrieval_context=self._build_intent_ctx(i.intent_title))
                for i in self.intents.intents],
            timestamp=self.timestamp).model_dump()

    def to_all_formats(self):
        return {
            "intent_extraction": self.to_intent_extraction(),
            "final_queries": self.to_final_queries(),
            "nature_breakdown": self.to_nature_breakdown(),
            "full_pipeline": self.to_full_pipeline(),
        }


# =====================================================================
#  PIPELINE
# =====================================================================

class ContextualIntentPipeline:

    def __init__(self, project, location="us-central1",
                 model="gemini-2.5-flash"):
        self.client = genai.Client(
            vertexai=True, project=project, location=location)
        self.model_name = model

    def _call(self, prompt, schema, fallback=None, max_tokens=8192):
        for attempt in range(2):
            try:
                config = types.GenerateContentConfig(
                    temperature=0, top_p=0.2, seed=34,
                    max_output_tokens=max_tokens,
                    response_mime_type="application/json",
                    response_schema=schema)
                resp = self.client.models.generate_content(
                    model=self.model_name, contents=prompt, config=config)
                text = (resp.text if hasattr(resp, 'text') and resp.text
                        else resp.candidates[0].content.parts[0].text)
                if not text or not text.strip():
                    raise ValueError("Empty LLM response")
                text = re.sub(r'^```(?:json)?\s*', '',
                              text.strip()).rstrip('`').strip()
                return schema.model_validate(json.loads(text))
            except Exception as e:
                if attempt == 0:
                    print(f"  Retry: {str(e)[:100]}")
                    continue
                print(f"  Failed: {str(e)[:150]}")
                if fallback is not None:
                    return fallback
                raise
        return fallback

    def extract(self, query, verbose=False):
        if not query or not query.strip():
            raise ValueError("Empty query")
        start = datetime.now(timezone.utc)

        expansion = self._call(
            QUERY_EXPANSION_PROMPT.format(query=query),
            QueryExpansionOutput,
            fallback=QueryExpansionOutput(expanded_query=query),
            max_tokens=2048)

        intents = self._call(
            INTENT_EXTRACTION_PROMPT.format(
                expanded_query=expansion.expanded_query,
                timestamp=datetime.now(timezone.utc).isoformat()),
            IntentExtractionResponse,
            fallback=IntentExtractionResponse(
                is_clinical=False, reason="LLM call failed"),
            max_tokens=8192)
        intent_out = IntentExtractionOutput(
            is_clinical=intents.is_clinical, reason=intents.reason,
            original_query=query, expanded_query=expansion.expanded_query,
            total_intents_detected=len(intents.intents),
            intents=intents.intents)

        context = None
        if intent_out.is_clinical and intent_out.intents:
            concepts, seen = [], set()
            for i in intent_out.intents:
                for sn in i.sub_natures:
                    for c in sn.atomic_concepts:
                        k = c.strip().lower()
                        if k and k not in seen:
                            concepts.append({"atomic_concept": c.strip(),
                                             "intent_title": i.intent_title})
                            seen.add(k)
            if concepts:
                context = self._call(
                    CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                        original_query=query,
                        expanded_query=expansion.expanded_query,
                        concepts_json=json.dumps(concepts, indent=2),
                        concept_count=len(concepts)),
                    ContextualEnvironmentOutput,
                    fallback=ContextualEnvironmentOutput(),
                    max_tokens=32768)
                covered = {cc.atomic_concept.strip().lower()
                           for cc in context.concepts_with_context
                           if cc.temporal_phases}
                missing = [c for c in concepts
                           if c["atomic_concept"].strip().lower()
                           not in covered]
                if missing:
                    print(f"  Retrying {len(missing)} missing concepts...")
                    retry = self._call(
                        CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                            original_query=query,
                            expanded_query=expansion.expanded_query,
                            concepts_json=json.dumps(missing, indent=2),
                            concept_count=len(missing)),
                        ContextualEnvironmentOutput,
                        fallback=ContextualEnvironmentOutput(),
                        max_tokens=32768)
                    context.concepts_with_context.extend(
                        retry.concepts_with_context)

        elapsed = (datetime.now(timezone.utc) - start).total_seconds()
        if verbose:
            nc = len(context.concepts_with_context) if context else 0
            print(f"  {query[:60]} | {elapsed:.1f}s | "
                  f"intents={len(intent_out.intents)} contexts={nc}")

        return ExtractionResult(
            query, expansion, intent_out, context, elapsed)

    def run(self, query, output_format="full_pipeline", verbose=False):
        try:
            result = self.extract(query, verbose)
            return getattr(result, f"to_{output_format}")()
        except Exception as e:
            return {"error": str(e), "query": query,
                    "timestamp": datetime.now(timezone.utc).isoformat()}


