# =====================================================================
#  EXTRACTION RESULT
# =====================================================================

class ExtractionResult:

    def __init__(self, original_query, expansion, intents, context,
                 processing_time):
        self.original_query = original_query
        self.expansion = expansion
        self.intents = intents
        self.context = context
        self.processing_time = processing_time
        self.timestamp = datetime.now(timezone.utc).isoformat()

    # ---- cleaning helpers ----

    @staticmethod
    def _clean_list(vals):
        """Remove underscores between words in context values."""
        cleaned = []
        for v in vals:
            if " - " in v:
                key, desc = v.split(" - ", 1)
                cleaned.append(key.replace("_", " ") + " - " + desc)
            else:
                cleaned.append(v.replace("_", " "))
        return cleaned

    @staticmethod
    def _clean_phase(phase):
        """Clean underscores in all fields of a TemporalPhase."""
        clean = ExtractionResult._clean_list
        return TemporalPhase(
            phase_name=phase.phase_name.replace("_", " ") if " - " not in phase.phase_name
                else phase.phase_name.split(" - ", 1)[0].replace("_", " ") + " - " + phase.phase_name.split(" - ", 1)[1],
            document_types=clean(phase.document_types),
            author_roles=clean(phase.author_roles),
            content_signals=clean(phase.content_signals),
            clinical_settings=clean(phase.clinical_settings))

    @staticmethod
    def _dedup_phases(phases_list):
        """Deduplicate phases by phase_name prefix across multiple concepts.
        Merges fields from phases with the same name."""
        merged = {}
        for phase in phases_list:
            key = phase.phase_name.split(" - ", 1)[0].strip().lower()
            if key not in merged:
                merged[key] = TemporalPhase(
                    phase_name=phase.phase_name,
                    document_types=list(phase.document_types),
                    author_roles=list(phase.author_roles),
                    content_signals=list(phase.content_signals),
                    clinical_settings=list(phase.clinical_settings))
            else:
                existing = merged[key]
                seen_docs = {d.split(" - ", 1)[0].strip().lower()
                             for d in existing.document_types}
                for d in phase.document_types:
                    if d.split(" - ", 1)[0].strip().lower() not in seen_docs:
                        existing.document_types.append(d)
                        seen_docs.add(d.split(" - ", 1)[0].strip().lower())
                seen_auths = {a.split(" - ", 1)[0].strip().lower()
                              for a in existing.author_roles}
                for a in phase.author_roles:
                    if a.split(" - ", 1)[0].strip().lower() not in seen_auths:
                        existing.author_roles.append(a)
                        seen_auths.add(a.split(" - ", 1)[0].strip().lower())
                seen_sigs = {s.split(" - ", 1)[0].strip().lower()
                             for s in existing.content_signals}
                for s in phase.content_signals:
                    if s.split(" - ", 1)[0].strip().lower() not in seen_sigs:
                        existing.content_signals.append(s)
                        seen_sigs.add(s.split(" - ", 1)[0].strip().lower())
                seen_setts = {se.split(" - ", 1)[0].strip().lower()
                              for se in existing.clinical_settings}
                for se in phase.clinical_settings:
                    if se.split(" - ", 1)[0].strip().lower() not in seen_setts:
                        existing.clinical_settings.append(se)
                        seen_setts.add(se.split(" - ", 1)[0].strip().lower())
        return list(merged.values())

    @staticmethod
    def _word_overlap(a, b):
        """Word-level Jaccard similarity."""
        wa = set(re.split(r'[\s\-]+', a.lower()))
        wb = set(re.split(r'[\s\-]+', b.lower()))
        wa.discard('')
        wb.discard('')
        if not wa or not wb:
            return 0.0
        return len(wa & wb) / len(wa | wb)

    # ---- sentence builder ----

    @staticmethod
    def _build_sentences(concept_name, phases):
        """Build one sentence per phase. Each sentence is:
        - Self-contained (entity name repeated, no pronouns)
        - Domain-specific only (no temporal scaffolding words)
        - Embedding-ready for topic modeling

        No 'first documented', 'subsequently tracked', 'over time'.
        These workflow words are identical across all concepts and
        dilute domain signal in vector space.

        Each sentence = one phase = one data point for topic model.
        Multiple sentences per entity = more data points = better clustering."""
        if not phases:
            return []

        def pfx(v):
            return v.split(" - ", 1)[0].replace("_", " ") if " - " in v else v.replace("_", " ")

        def join_items(items):
            cleaned = [pfx(v) for v in items]
            if not cleaned:
                return ""
            if len(cleaned) == 1:
                return cleaned[0]
            if len(cleaned) == 2:
                return f"{cleaned[0]} and {cleaned[1]}"
            return ", ".join(cleaned[:-1]) + f", and {cleaned[-1]}"

        sentences = []
        for phase in phases:
            docs = join_items(phase.document_types)
            auths = join_items(phase.author_roles)
            sigs = join_items(phase.content_signals)
            setts = join_items(phase.clinical_settings)

            if not docs or not auths:
                continue

            parts = [concept_name]
            parts.append(f"documented in {docs}")
            parts.append(f"by {auths}")
            if setts:
                parts.append(f"at {setts}")
            if sigs:
                parts.append(f"capturing {sigs}")

            sentences.append(", ".join(parts) + ".")

        return sentences

    # ---- context lookup ----

    def _find_context(self, atomic_concept):
        """3-pass lookup: exact -> substring guarded -> word overlap."""
        if not self.context:
            return None
        key = atomic_concept.strip().lower()
        # Pass 1: exact
        for cc in self.context.concepts_with_context:
            if cc.atomic_concept.strip().lower() == key:
                return cc
        # Pass 2: substring (both >= 5 chars, ratio >= 0.5)
        if len(key) >= 5:
            for cc in self.context.concepts_with_context:
                cl = cc.atomic_concept.strip().lower()
                if len(cl) >= 5 and (cl in key or key in cl):
                    ratio = min(len(key), len(cl)) / max(len(key), len(cl))
                    if ratio >= 0.5:
                        return cc
        # Pass 3: word overlap (Jaccard >= 0.5)
        best_score, best_cc = 0.0, None
        for cc in self.context.concepts_with_context:
            score = self._word_overlap(atomic_concept, cc.atomic_concept)
            if score > best_score:
                best_score = score
                best_cc = cc
        if best_cc and best_score >= 0.5:
            return best_cc
        return None

    # ---- context builders ----

    def _build_ctx(self, atomic_concept):
        """Build RetrievalContext for a single atomic concept."""
        cc = self._find_context(atomic_concept)
        if not cc:
            return RetrievalContext()
        cleaned_phases = [self._clean_phase(p) for p in cc.temporal_phases]
        sentences = self._build_sentences(atomic_concept, cleaned_phases)
        return RetrievalContext(
            context_sentences=sentences,
            temporal_phases=cleaned_phases)

    def _build_intent_ctx(self, intent_title):
        """Build merged RetrievalContext across all concepts in an intent.
        Deduplicates phases by name, merges fields within same phase."""
        if not self.context:
            return RetrievalContext()
        all_phases = []
        title_key = intent_title.strip().lower()
        for cc in self.context.concepts_with_context:
            if cc.intent_title.strip().lower() == title_key:
                all_phases.extend(cc.temporal_phases)
        if not all_phases:
            return RetrievalContext()
        cleaned = [self._clean_phase(p) for p in all_phases]
        deduped = self._dedup_phases(cleaned)
        sentences = self._build_sentences(intent_title, deduped)
        return RetrievalContext(
            context_sentences=sentences,
            temporal_phases=deduped)

    # ---- 4 output builders ----

    def to_intent_extraction(self):
        return Format_IntentExtraction(
            user_query=self.original_query,
            intents=[IntentSummaryItem(
                intent_title=i.intent_title, description=i.description)
                for i in self.intents.intents],
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
            timestamp=self.timestamp).model_dump()

    def to_final_queries(self):
        """atomic_concepts iterated directly as candidates.
        atomic_concept = candidate (identical, no matching layer)."""
        candidates = []
        idx = 0
        seen = set()
        for i in self.intents.intents:
            for sn in i.sub_natures:
                for concept in sn.atomic_concepts:
                    key = concept.strip().lower()
                    if key in seen:
                        continue
                    seen.add(key)
                    idx += 1
                    candidates.append(FinalCandidateItem(
                        candidate_id=f"fc_{idx:03d}",
                        intent_title=i.intent_title,
                        atomic_concept=concept.strip(),
                        candidate=concept.strip(),
                        retrieval_context=self._build_ctx(concept)))
        return Format_FinalQueries(
            user_query=self.original_query,
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
            total_candidates=len(candidates),
            final_candidates=candidates,
            timestamp=self.timestamp).model_dump()

    def to_nature_breakdown(self):
        return Format_NatureBreakdown(
            is_clinical=self.intents.is_clinical,
            reason=self.intents.reason,
            original_query=self.intents.original_query,
            total_intents_detected=self.intents.total_intents_detected,
            intents=[IntentWithoutQueries(
                intent_title=i.intent_title, description=i.description,
                nature=i.nature, sub_natures=i.sub_natures)
                for i in self.intents.intents],
            timestamp=self.timestamp).model_dump()

    def to_full_pipeline(self):
        """final_candidates populated from atomic_concepts."""
        return Format_FullPipeline(
            is_clinical=self.intents.is_clinical,
            reason=self.intents.reason,
            original_query=self.original_query,
            expanded_query=self.expansion.expanded_query,
            total_intents_detected=self.intents.total_intents_detected,
            intents=[IntentWithContext(
                intent_title=i.intent_title, description=i.description,
                nature=i.nature, sub_natures=i.sub_natures,
                final_candidates=[c for sn in i.sub_natures
                                  for c in sn.atomic_concepts],
                retrieval_context=self._build_intent_ctx(i.intent_title))
                for i in self.intents.intents],
            timestamp=self.timestamp).model_dump()

    def to_all_formats(self):
        return {
            "intent_extraction": self.to_intent_extraction(),
            "final_queries": self.to_final_queries(),
            "nature_breakdown": self.to_nature_breakdown(),
            "full_pipeline": self.to_full_pipeline(),
        }


# =====================================================================
#  PIPELINE -- 3 LLM calls per query
# =====================================================================

class ContextualIntentPipeline:

    def __init__(self, project, location="us-central1",
                 model="gemini-2.5-flash"):
        self.client = genai.Client(
            vertexai=True, project=project, location=location)
        self.project = project
        self.location = location
        self.model_name = model

    def _extract_json(self, response):
        if hasattr(response, 'text'):
            text = response.text
        elif hasattr(response, 'candidates') and response.candidates:
            text = response.candidates[0].content.parts[0].text
        else:
            text = str(response)
        if not text or not text.strip():
            raise ValueError("Empty or blocked LLM response")
        text = re.sub(r'```json\s*', '', text)
        text = re.sub(r'```\s*', '', text).strip()
        return json.loads(text)

    def _call_model(self, prompt, response_schema, context_query="",
                    max_tokens=8192):
        try:
            config = types.GenerateContentConfig(
                temperature=0, top_p=0.2, seed=34,
                max_output_tokens=max_tokens,
                response_mime_type="application/json",
                response_schema=response_schema)
            response = self.client.models.generate_content(
                model=self.model_name, contents=prompt, config=config)
            data = self._extract_json(response)
            return response_schema.model_validate(data)
        except Exception as e:
            print(f"Model error: {e}")
            if response_schema == QueryExpansionOutput:
                return QueryExpansionOutput(
                    expanded_query=context_query or "")
            elif response_schema == IntentExtractionResponse:
                return IntentExtractionResponse(
                    is_clinical=False,
                    reason=f"Processing error: {str(e)}",
                    total_intents_detected=0, intents=[])
            elif response_schema == ContextualEnvironmentOutput:
                return ContextualEnvironmentOutput(
                    concepts_with_context=[])
            raise

    # -- Step 1: Expansion --

    def expand_query(self, query):
        return self._call_model(
            QUERY_EXPANSION_PROMPT.format(query=query),
            QueryExpansionOutput, query, max_tokens=2048)

    # -- Step 2: Intent Extraction --

    def extract_intents(self, original_query, expanded_query):
        response = self._call_model(
            INTENT_EXTRACTION_PROMPT.format(
                expanded_query=expanded_query,
                timestamp=datetime.now(timezone.utc).isoformat()),
            IntentExtractionResponse, original_query)
        return IntentExtractionOutput(
            is_clinical=response.is_clinical, reason=response.reason,
            original_query=original_query, expanded_query=expanded_query,
            total_intents_detected=len(response.intents),
            intents=response.intents)

    # -- Step 3: Context (phase-grouped structured fields) --

    @staticmethod
    def _prepare_context_input(intents):
        out, seen = [], set()
        for i in intents:
            for sn in i.sub_natures:
                for c in sn.atomic_concepts:
                    key = c.strip().lower()
                    if key and key not in seen:
                        out.append({"atomic_concept": c.strip(),
                                    "intent_title": i.intent_title})
                        seen.add(key)
        return out

    @staticmethod
    def _has_content(cc):
        """Validate at least one temporal_phase with all fields populated."""
        if not cc.temporal_phases:
            return False
        for phase in cc.temporal_phases:
            if (phase.document_types and phase.author_roles
                    and phase.content_signals and phase.clinical_settings):
                return True
        return False

    def generate_context(self, original_query, expanded_query, intents):
        if not intents:
            return ContextualEnvironmentOutput(concepts_with_context=[])
        concepts = self._prepare_context_input(intents)
        if not concepts:
            return ContextualEnvironmentOutput(concepts_with_context=[])
        result = self._call_model(
            CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                original_query=original_query,
                expanded_query=expanded_query,
                concepts_json=json.dumps(concepts, indent=2),
                concept_count=len(concepts)),
            ContextualEnvironmentOutput, max_tokens=16384)

        # Validate and retry blanks
        covered = {cc.atomic_concept.strip().lower()
                   for cc in result.concepts_with_context
                   if self._has_content(cc)}
        missing = [c for c in concepts
                   if c["atomic_concept"].strip().lower() not in covered]
        if missing:
            missing_keys = {c["atomic_concept"].strip().lower()
                           for c in missing}
            result.concepts_with_context = [
                cc for cc in result.concepts_with_context
                if cc.atomic_concept.strip().lower() not in missing_keys]
            print(f"Step 3: {len(covered)}/{len(concepts)} have content, "
                  f"retrying {len(missing)} blank/missing...")
            retry = self._call_model(
                CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                    original_query=original_query,
                    expanded_query=expanded_query,
                    concepts_json=json.dumps(missing, indent=2),
                    concept_count=len(missing)),
                ContextualEnvironmentOutput, max_tokens=16384)
            result.concepts_with_context.extend(
                retry.concepts_with_context)
        return result

    # -- Orchestrator --

    def extract(self, query, verbose=False):
        if not query or not query.strip():
            raise ValueError("Empty query provided")
        start_time = datetime.now(timezone.utc)
        expansion = self.expand_query(query)
        intents = self.extract_intents(query, expansion.expanded_query)
        context = None
        if intents.is_clinical and intents.intents:
            context = self.generate_context(
                query, expansion.expanded_query, intents.intents)
        processing_time = (
            datetime.now(timezone.utc) - start_time).total_seconds()
        if verbose:
            print(f"Query: {query}")
            print(f"Expanded: {expansion.expanded_query}")
            if intents.is_clinical:
                nq = len({c.strip().lower() for i in intents.intents
                          for sn in i.sub_natures
                          for c in sn.atomic_concepts})
                nc = len(context.concepts_with_context) if context else 0
                print(f"Clinical | Intents: "
                      f"{intents.total_intents_detected} | "
                      f"Candidates: {nq} | Contexts: {nc}")
            else:
                print(f"Non-clinical | Reason: {intents.reason}")
            print(f"Time: {processing_time:.2f}s")
        return ExtractionResult(
            query, expansion, intents, context, processing_time)

    def run(self, query, output_format="full_pipeline", verbose=False):
        try:
            result = self.extract(query, verbose)
            return getattr(result, f"to_{output_format}")()
        except Exception as e:
            if verbose:
                print(f"Error: {e}\n")
            return {"error": str(e), "query": query,
                    "timestamp": datetime.now(timezone.utc).isoformat()}


