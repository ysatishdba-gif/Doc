#  EXTRACTION RESULT


class ExtractionResult:

    def __init__(self, original_query: str, expansion: QueryExpansionOutput,
                 intents: IntentExtractionOutput,
                 context: Optional[ContextualEnvironmentOutput],
                 processing_time: float):
        self.original_query = original_query
        self.expansion = expansion
        self.intents = intents
        self.context = context
        self.processing_time = processing_time
        self.timestamp = datetime.now(timezone.utc).isoformat()

    # -- helpers --

    @staticmethod
    def _clean_list(vals: List[str]) -> List[str]:
        """Remove underscores between words in context values and stories."""
        cleaned = []
        for v in vals:
            if " - " in v:
                key, desc = v.split(" - ", 1)
                cleaned.append(key.replace("_", " ") + " - " + desc)
            else:
                cleaned.append(v.replace("_", " "))
        return cleaned

    @staticmethod
    def _word_overlap(a: str, b: str) -> float:
        """Word-level Jaccard similarity."""
        wa = set(re.split(r'[\s\-]+', a.lower()))
        wb = set(re.split(r'[\s\-]+', b.lower()))
        wa.discard('')
        wb.discard('')
        if not wa or not wb:
            return 0.0
        return len(wa & wb) / len(wa | wb)

    def _find_context(self, atomic_concept: str) -> Optional[ConceptContext]:
        """3-pass lookup: exact → substring → word overlap."""
        if not self.context:
            return None
        key = atomic_concept.strip().lower()
        for cc in self.context.concepts_with_context:
            if cc.atomic_concept.strip().lower() == key:
                return cc
        for cc in self.context.concepts_with_context:
            cl = cc.atomic_concept.strip().lower()
            if cl in key or key in cl:
                return cc
        best_score, best_cc = 0.0, None
        for cc in self.context.concepts_with_context:
            score = self._word_overlap(atomic_concept, cc.atomic_concept)
            if score > best_score:
                best_score = score
                best_cc = cc
        if best_cc and best_score >= 0.5:
            return best_cc
        return None

    def _build_ctx(self, atomic_concept: str) -> RetrievalContext:
        cc = self._find_context(atomic_concept)
        if not cc:
            return RetrievalContext()
        return RetrievalContext(
            document_types=self._clean_list(cc.document_types),
            author_roles=self._clean_list(cc.author_roles),
            temporal_scope=self._clean_list(cc.temporal_scope),
            content_signals=self._clean_list(cc.content_signals),
            clinical_setting=self._clean_list(cc.clinical_setting),
            context_stories=self._clean_list(cc.context_stories),
        )

    def _build_intent_ctx(self, intent_title: str) -> RetrievalContext:
        if not self.context:
            return RetrievalContext()
        doc, auth, temp, sig, sett = set(), set(), set(), set(), set()
        stories = []
        for cc in self.context.concepts_with_context:
            if cc.intent_title == intent_title:
                doc.update(cc.document_types)
                auth.update(cc.author_roles)
                temp.update(cc.temporal_scope)
                sig.update(cc.content_signals)
                sett.update(cc.clinical_setting)
                stories.extend(cc.context_stories)
        if not any([doc, auth, temp, sig, sett]):
            return RetrievalContext()
        return RetrievalContext(
            document_types=self._clean_list(sorted(doc)),
            author_roles=self._clean_list(sorted(auth)),
            temporal_scope=self._clean_list(sorted(temp)),
            content_signals=self._clean_list(sorted(sig)),
            clinical_setting=self._clean_list(sorted(sett)),
            context_stories=self._clean_list(stories),
        )

    def _match_concept(self, query: str, concepts: List[str]) -> str:
        ql = query.lower().strip()
        for c in concepts:
            if c.lower().strip() == ql:
                return c
        for c in concepts:
            cl = c.lower().strip()
            if cl in ql or ql in cl:
                return c
        best_score, best_match = 0.0, None
        for c in concepts:
            score = self._word_overlap(query, c)
            if score > best_score:
                best_score = score
                best_match = c
        if best_match and best_score >= 0.5:
            return best_match
        return query

    # -- 4 output builders --

    def to_intent_extraction(self) -> Dict[str, Any]:
        return Format_IntentExtraction(
            user_query=self.original_query,
            intents=[IntentSummaryItem(intent_title=i.intent_title, description=i.description)
                     for i in self.intents.intents],
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
            timestamp=self.timestamp,
        ).model_dump()

    def to_final_queries(self) -> Dict[str, Any]:
        candidates = []
        idx = 0
        for i in self.intents.intents:
            concepts = [c for sn in i.sub_natures for c in sn.atomic_concepts]
            for q in i.final_queries:
                idx += 1
                matched = self._match_concept(q, concepts)
                candidates.append(FinalCandidateItem(
                    candidate_id=f"fc_{idx:03d}",
                    intent_title=i.intent_title,
                    atomic_concept=matched,
                    candidate=q,
                    retrieval_context=self._build_ctx(matched),
                ))
        return Format_FinalQueries(
            user_query=self.original_query,
            is_clinical=self.intents.is_clinical,
            rejected_reason=self.intents.reason,
            total_candidates=len(candidates),
            final_candidates=candidates,
            timestamp=self.timestamp,
        ).model_dump()

    def to_nature_breakdown(self) -> Dict[str, Any]:
        return Format_NatureBreakdown(
            is_clinical=self.intents.is_clinical,
            reason=self.intents.reason,
            original_query=self.intents.original_query,
            total_intents_detected=self.intents.total_intents_detected,
            intents=[IntentWithoutQueries(
                intent_title=i.intent_title, description=i.description,
                nature=i.nature, sub_natures=i.sub_natures,
            ) for i in self.intents.intents],
            timestamp=self.timestamp,
        ).model_dump()

    def to_full_pipeline(self) -> Dict[str, Any]:
        return Format_FullPipeline(
            is_clinical=self.intents.is_clinical,
            reason=self.intents.reason,
            original_query=self.original_query,
            expanded_query=self.expansion.expanded_query,
            total_intents_detected=self.intents.total_intents_detected,
            intents=[IntentWithContext(
                intent_title=i.intent_title, description=i.description,
                nature=i.nature, sub_natures=i.sub_natures,
                final_queries=i.final_queries,
                retrieval_context=self._build_intent_ctx(i.intent_title),
            ) for i in self.intents.intents],
            timestamp=self.timestamp,
        ).model_dump()

    def to_all_formats(self) -> Dict[str, Dict[str, Any]]:
        return {
            "intent_extraction": self.to_intent_extraction(),
            "final_queries": self.to_final_queries(),
            "nature_breakdown": self.to_nature_breakdown(),
            "full_pipeline": self.to_full_pipeline(),
        }



#  PIPELINE — 3 calls per query, speed optimized


class ContextualIntentPipeline:

    def __init__(self, project: str, location: str = "us-central1",
                 model: str = "gemini-2.5-flash"):
        self.client = genai.Client(vertexai=True, project=project, location=location)
        self.project = project
        self.location = location
        self.model_name = model

    def _extract_json(self, response) -> Dict[str, Any]:
        if hasattr(response, 'text'):
            text = response.text
        elif hasattr(response, 'candidates') and response.candidates:
            text = response.candidates[0].content.parts[0].text
        else:
            text = str(response)
        text = re.sub(r'```json\s*', '', text)
        text = re.sub(r'```\s*', '', text).strip()
        return json.loads(text)

    def _call_model(self, prompt: str, response_schema: type[BaseModel],
                    context_query: str = "", max_tokens: int = 8096) -> BaseModel:
        try:
            config = types.GenerateContentConfig(
                temperature=0,
                top_p=0.2,
                seed=34,
                max_output_tokens=max_tokens,
                response_mime_type="application/json",
                response_schema=response_schema,
            )
            response = self.client.models.generate_content(
                model=self.model_name, contents=prompt, config=config
            )
            data = self._extract_json(response)
            return response_schema.model_validate(data)

        except Exception as e:
            print(f"Model error: {e}")
            if response_schema == QueryExpansionOutput:
                return QueryExpansionOutput(expanded_query=context_query or "")
            elif response_schema == IntentExtractionResponse:
                return IntentExtractionResponse(
                    is_clinical=False,
                    reason=f"Processing error: {str(e)}",
                    total_intents_detected=0, intents=[],
                )
            elif response_schema == ContextualEnvironmentOutput:
                return ContextualEnvironmentOutput(concepts_with_context=[])
            raise

    # -- Step 1: Expansion (lightweight, fast) --

    def expand_query(self, query: str) -> QueryExpansionOutput:
        return self._call_model(
            QUERY_EXPANSION_PROMPT.format(query=query),
            QueryExpansionOutput, query, max_tokens=2048)

    # -- Step 2: Intent Extraction --

    def extract_intents(self, original_query: str,
                        expanded_query: str) -> IntentExtractionOutput:
        response = self._call_model(
            INTENT_EXTRACTION_PROMPT.format(
                expanded_query=expanded_query,
                timestamp=datetime.now(timezone.utc).isoformat()),
            IntentExtractionResponse, original_query)

        return IntentExtractionOutput(
            is_clinical=response.is_clinical,
            reason=response.reason,
            original_query=original_query,
            expanded_query=expanded_query,
            total_intents_detected=len(response.intents),
            intents=response.intents,
        )

    # -- Step 3: Context Generation --

    @staticmethod
    def _prepare_context_input(intents: List[Intent]) -> List[Dict]:
        out, seen = [], set()
        for i in intents:
            for sn in i.sub_natures:
                for c in sn.atomic_concepts:
                    key = c.strip().lower()
                    if key and key not in seen:
                        out.append({"atomic_concept": c.strip(),
                                    "intent_title": i.intent_title})
                        seen.add(key)
        return out

    @staticmethod
    def _has_content(cc: ConceptContext) -> bool:
        return bool(cc.document_types and cc.author_roles and cc.content_signals)

    def generate_context(self, original_query: str, expanded_query: str,
                         intents: List[Intent]) -> ContextualEnvironmentOutput:
        if not intents:
            return ContextualEnvironmentOutput(concepts_with_context=[])

        concepts = self._prepare_context_input(intents)
        if not concepts:
            return ContextualEnvironmentOutput(concepts_with_context=[])

        result = self._call_model(
            CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                original_query=original_query,
                expanded_query=expanded_query,
                concepts_json=json.dumps(concepts, indent=2),
                concept_count=len(concepts)),
            ContextualEnvironmentOutput, max_tokens=16384)

        # Validate content quality, retry blanks
        covered = {cc.atomic_concept.strip().lower()
                   for cc in result.concepts_with_context if self._has_content(cc)}
        missing = [c for c in concepts
                   if c["atomic_concept"].strip().lower() not in covered]

        if missing:
            missing_keys = {c["atomic_concept"].strip().lower() for c in missing}
            result.concepts_with_context = [
                cc for cc in result.concepts_with_context
                if cc.atomic_concept.strip().lower() not in missing_keys]

            print(f"Step 3: {len(covered)}/{len(concepts)} have content, "
                  f"retrying {len(missing)} blank/missing...")
            retry = self._call_model(
                CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                    original_query=original_query,
                    expanded_query=expanded_query,
                    concepts_json=json.dumps(missing, indent=2),
                    concept_count=len(missing)),
                ContextualEnvironmentOutput, max_tokens=16384)
            result.concepts_with_context.extend(retry.concepts_with_context)

        return result

    # -- Orchestrator: 3 sequential calls --

    def extract(self, query: str, verbose: bool = False) -> ExtractionResult:
        if not query or not query.strip():
            raise ValueError("Empty query provided")

        start_time = datetime.now(timezone.utc)

        # Call 1: Expansion
        expansion = self.expand_query(query)

        # Call 2: Intent Extraction
        intents = self.extract_intents(query, expansion.expanded_query)

        # Call 3: Context Generation
        context = None
        if intents.is_clinical and intents.intents:
            context = self.generate_context(
                query, expansion.expanded_query, intents.intents)

        processing_time = (datetime.now(timezone.utc) - start_time).total_seconds()

        if verbose:
            print(f"Query: {query}")
            print(f"Expanded: {expansion.expanded_query}")
            if intents.is_clinical:
                nq = sum(len(i.final_queries) for i in intents.intents)
                nc = len(context.concepts_with_context) if context else 0
                print(f"Clinical | Intents: {intents.total_intents_detected} | "
                      f"Candidates: {nq} | Contexts: {nc}")
            else:
                print(f"Non-clinical | Reason: {intents.reason}")
            print(f"Time: {processing_time:.2f}s")

        return ExtractionResult(query, expansion, intents, context, processing_time)

    def run(self, query: str,
            output_format: Literal["intent_extraction", "final_queries",
                                   "nature_breakdown", "full_pipeline"] = "full_pipeline",
            verbose: bool = False) -> Dict[str, Any]:
        try:
            result = self.extract(query, verbose)
            return getattr(result, f"to_{output_format}")()
        except Exception as e:
            if verbose:
                print(f"Error: {e}\n")
            return {"error": str(e), "query": query,
                    "timestamp": datetime.now(timezone.utc).isoformat()}



#  UTILITIES


def save_json(data: Dict, filename: str):
    with open(filename, 'w') as f:
        json.dump(data, f, indent=2)
    print(f"{filename}")


def run_single_query(pipeline, query: str, idx: int):
    result = pipeline.extract(query, verbose=True)
    all_fmts = result.to_all_formats()
    prefix = f"query{idx}"
    for name, data in all_fmts.items():
        save_json(data, f"{prefix}_{name}.json")
    print("-" * 60)
    return {"query": query, "status": "completed",
            "files": [f"{prefix}_{n}.json" for n in all_fmts]}



