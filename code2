class IntentWithContext(BaseModel):
    intent_title: str
    description: str
    nature: str
    sub_natures: List[SubNature]
    final_candidates: List[str]
    retrieval_context: RetrievalContext = Field(default_factory=RetrievalContext)


class FinalCandidateItem(BaseModel):
    candidate_id: str
