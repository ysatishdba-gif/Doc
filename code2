    dataset_id,
    subnet_api_url="<YOUR_SUBNET_API_URL>",
    cui_description_table=desc_table,
    cui_embeddings_table="<YOUR_EMBEDDING_TABLE>",
    cui_narrower_table="<YOUR_DESCENDANTS_TABLE>"
