class RetrievalContext(BaseModel):
    """Each context_sentence is one phase -- self-contained, embedding-ready.
    Entity name repeated in every sentence (no pronouns).
    No temporal scaffolding (no 'first documented', 'subsequently').
    Only domain-specific clinical terms for clean topic modeling signal.
    temporal_phases preserved for programmatic filtering."""
    context_sentences: List[str] = Field(default_factory=list)
    temporal_phases: List[TemporalPhase] = Field(default_factory=list)


class IntentSummaryItem(BaseModel):
    intent_title: str
    description: str


class IntentWithoutQueries(BaseModel):
    intent_title: str
    description: str
