def save_json(data, filename):
    with open(filename, 'w') as f:
        json.dump(data, f, indent=2)
    print(f"  Saved: {filename}")


if __name__ == "__main__":
    PROJECT_ID = PROJECT_ID
    LOCATION = LOCATION
    MODEL_VERSION = MODEL_VERSION

    pipeline = ContextualIntentPipeline(
        project=PROJECT_ID, location=LOCATION, model=MODEL_VERSION)

    queries = [
        "HAVE YOU RECEIVED ANY TREATMENT FOR YOUR CANCER?",
        "sever caugh",
        "summarize the patient info",
    ]

    def run_query(args):
        idx, q = args
        result = pipeline.extract(q, verbose=True)
        for name, data in result.to_all_formats().items():
            save_json(data, f"query{idx}_{name}.json")
        return {"query": q, "status": "done"}

    with ThreadPoolExecutor(max_workers=4) as ex:
        list(ex.map(run_query, enumerate(queries, 1)))
