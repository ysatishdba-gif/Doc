    print(f"TOTAL INPUT CUIs: {total_cuis}")
    print(f"{'='*80}")

    # ── step 1: CUI reduction — ONE batch call for all entities ──
    batch_inputs = []
    for entity_text, sentence, cuis, distances in entities:
        batch_inputs.append((cuis, entity_text, distances))

    results = system.reduce_batch(batch_inputs)
    per_entity_results = list(zip([e[0] for e in entities], results))

    # collect all surviving CUIs
    all_surviving_cuis = set()
    for _, result in per_entity_results:
        all_surviving_cuis.update(result.all_reduced_cuis)

    # ── step 2: fetch preferred terms once for ALL cuis (display only) ──
    all_cuis_for_terms = set()
    for _, _, cuis, _ in entities:
        all_cuis_for_terms.update(cuis)
    all_cuis_for_terms.update(all_surviving_cuis)
    terms = fetch_preferred_terms(bq, PROJECT_ID, DATASET_ID, all_cuis_for_terms)

    # ── step 3: build topics across ALL surviving cuis in this case ──
    surviving_list = list(all_surviving_cuis)
    embeddings = system.emb_fetcher.fetch(surviving_list)
    with_emb = [c for c in surviving_list if c in embeddings]

    case_topics = {}
    if len(with_emb) >= 2:
        case_topics = TopicBuilder.build(with_emb, embeddings)
    elif with_emb:
        case_topics = {0: with_emb}

    metadata = system.fetcher.fetch(with_emb)

    # ── step 4: print per-entity results ──
    for entity_text, result in per_entity_results:
        print(f"\n  ENTITY: \"{entity_text}\"")
        print(f"  {result.input_count} → SAB:{result.after_filter_count} "
              f"→ Hier:{result.after_hierarchy_count} → Final:{result.after_redundancy_count}")
        if result.confidence:
            print(f"  Top CUIs:")
            for e in result.confidence[:5]:
                print(f"    {e.cui}  conf={e.confidence:.3f}  "
                      f"prox={e.extraction_proximity:.3f} cent={e.centrality:.3f} "
                      f"ret={e.retention_power:.3f}  |  {terms.get(e.cui, e.cui)}")

    # ── step 5: print case-level topics ──
    print(f"\n  {'─'*60}")
    print(f"  CASE-LEVEL TOPICS ({len(case_topics)} topics from {len(with_emb)} surviving CUIs)")
    print(f"  {'─'*60}")

    for tid, members in sorted(case_topics.items()):
        stypes = set()
        for c in members:
            m = metadata.get(c)
            if m and m.semantic_types:
                stypes.update(m.semantic_types)

        print(f"\n  Topic {tid} ({len(members)} CUIs) — {', '.join(sorted(stypes)) or 'Unknown'}")
        for c in members[:5]:
            print(f"    {c}  |  {terms.get(c, c)}")
        if len(members) > 5:
            print(f"    ... and {len(members) - 5} more")

    print(f"\n  TOTAL: {len(all_surviving_cuis)} unique CUIs across {len(entities)} entities")


