#  PIPELINE
# ═══════════════════════════════════════════════════════════════════════

MAX_RETRIES = 2
RETRY_DELAY = 1.0
MAX_CONCEPTS_PER_CALL = 50


class ContextualIntentPipeline:

    def __init__(self, project: str, location: str = "us-central1",
                 model: str = "gemini-2.5-flash"):
        self.client = genai.Client(vertexai=True, project=project, location=location)
        self.project = project
        self.location = location
        self.model_name = model

    # ── FIX #1: Safe JSON extraction ──

    @staticmethod
    def _extract_json(response, request_id: str = "") -> Dict[str, Any]:
        """Extract JSON with balanced-brace parsing instead of greedy regex."""
        text = response.text if hasattr(response, 'text') else str(response)

        # Strip markdown fences
        text = re.sub(r'```json\s*', '', text)
        text = re.sub(r'```\s*', '', text).strip()

        # Attempt 1: direct parse (works when response_schema enforced)
        try:
            return json.loads(text)
        except json.JSONDecodeError:
            pass

        # Attempt 2: find outermost balanced braces
        depth = 0
        start = -1
        for i, ch in enumerate(text):
            if ch == '{':
                if depth == 0:
                    start = i
                depth += 1
            elif ch == '}':
                depth -= 1
                if depth == 0 and start >= 0:
                    try:
                        return json.loads(text[start:i + 1])
                    except json.JSONDecodeError:
                        pass
                    break

        logger.error(f"[{request_id}] JSON extraction failed. Raw: {text[:500]}")
        raise ValueError("Could not parse JSON from model response")

    # ── FIX #3, #7: Model call with retry — no silent fallbacks ──

    def _call_model(self, prompt: str, schema: type[BaseModel],
                    stage: str, request_id: str = "") -> BaseModel:
        """Call model with retry. Raises PipelineError — never fakes data."""
        last_error = None

        for attempt in range(MAX_RETRIES + 1):
            try:
                config = types.GenerateContentConfig(
                    temperature=0.1,
                    top_p=1,
                    seed=34,
                    max_output_tokens=8096,
                    response_mime_type="application/json",
                    response_schema=schema,
                )
                response = self.client.models.generate_content(
                    model=self.model_name, contents=prompt, config=config
                )
                parsed = self._extract_json(response, request_id)
                result = schema.model_validate(parsed)

                if attempt > 0:
                    logger.info(f"[{request_id}] {stage}: succeeded on retry {attempt}")
                return result

            except Exception as e:
                last_error = e
                logger.warning(f"[{request_id}] {stage}: attempt {attempt + 1}/"
                               f"{MAX_RETRIES + 1} failed: {type(e).__name__}: {e}")
                if attempt < MAX_RETRIES:
                    time.sleep(RETRY_DELAY * (attempt + 1))

        raise PipelineError(
            message=f"Failed after {MAX_RETRIES + 1} attempts: {last_error}",
            stage=stage,
            original_error=last_error
        )

    # ── Step 1 ──

    def expand_query(self, query: str, request_id: str = "") -> QueryExpansionOutput:
        return self._call_model(
            QUERY_EXPANSION_PROMPT.format(query=query),
            QueryExpansionOutput, stage="expansion", request_id=request_id)

    # ── Step 2 ──

    def extract_intents(self, original_query: str, expanded_query: str,
                        request_id: str = "") -> IntentExtractionOutput:
        response = self._call_model(
            INTENT_EXTRACTION_PROMPT.format(
                expanded_query=expanded_query,
                timestamp=datetime.utcnow().isoformat()),
            IntentExtractionResponse, stage="intent_extraction",
            request_id=request_id)

        return IntentExtractionOutput(
            is_clinical=response.is_clinical,
            reason=response.reason,
            original_query=original_query,
            expanded_query=expanded_query,
            total_intents_detected=len(response.intents),
            intents=response.intents,
        )

    # ── Step 3 ──

    @staticmethod
    def _prepare_context_input(intents: List[Intent]) -> List[Dict]:
        """Flatten to one entry per atomic concept."""
        out = []
        seen = set()
        for i in intents:
            for sn in i.sub_natures:
                for c in sn.atomic_concepts:
                    key = c.strip().lower()
                    if key and key not in seen:
                        out.append({
                            "atomic_concept": c.strip(),
                            "intent_title": i.intent_title,
                        })
                        seen.add(key)
        return out

    def generate_context(self, original_query: str, expanded_query: str,
                         intents: List[Intent],
                         request_id: str = "") -> ContextualEnvironmentOutput:
        if not intents:
            return ContextualEnvironmentOutput(concepts_with_context=[])

        concepts = self._prepare_context_input(intents)
        if not concepts:
            return ContextualEnvironmentOutput(concepts_with_context=[])

        # FIX #9: Cap concept array to avoid token overflow
        if len(concepts) > MAX_CONCEPTS_PER_CALL:
            logger.warning(f"[{request_id}] Truncating concepts: "
                           f"{len(concepts)} → {MAX_CONCEPTS_PER_CALL}")
            concepts = concepts[:MAX_CONCEPTS_PER_CALL]

        return self._call_model(
            CONTEXTUAL_ENVIRONMENT_PROMPT.format(
                original_query=original_query,
                expanded_query=expanded_query,
                concepts_json=json.dumps(concepts, indent=2)),
            ContextualEnvironmentOutput, stage="contextual_environment",
            request_id=request_id)

    # ── Orchestrator (FIX #14, #18) ──

    def extract(self, query: str, verbose: bool = False) -> ExtractionResult:
        if not query or not query.strip():
            raise ValueError("Empty query")

        request_id = str(uuid.uuid4())[:8]
        stage_timings = {}

        logger.info(f"[{request_id}] Starting pipeline: {query[:100]}")

        # Step 1
        t0 = time.time()
        expansion = self.expand_query(query, request_id)
        stage_timings["expansion"] = round(time.time() - t0, 3)

        # Step 2
        t0 = time.time()
        intents = self.extract_intents(query, expansion.expanded_query, request_id)
        stage_timings["intent_extraction"] = round(time.time() - t0, 3)

        # Step 3
        context = None
        if intents.is_clinical and intents.intents:
            t0 = time.time()
            context = self.generate_context(
                query, expansion.expanded_query, intents.intents, request_id)
            stage_timings["contextual_environment"] = round(time.time() - t0, 3)

        total_time = sum(stage_timings.values())

        if verbose:
            print(f"[{request_id}] Query: {query}")
            print(f"[{request_id}] Expanded: {expansion.expanded_query}")
            if intents.is_clinical:
                nq = sum(len(i.final_queries) for i in intents.intents)
                nc = len(context.concepts_with_context) if context else 0
                print(f"[{request_id}] Clinical | Intents: {len(intents.intents)} | "
                      f"Queries: {nq} | Concepts: {nc}")
            else:
                print(f"[{request_id}] Non-clinical: {intents.reason}")
            for stage, t in stage_timings.items():
                print(f"[{request_id}]   {stage}: {t:.3f}s")
            print(f"[{request_id}] Total: {total_time:.3f}s\n")

        logger.info(f"[{request_id}] Complete: {total_time:.3f}s | stages={stage_timings}")

        return ExtractionResult(
            query, expansion, intents, context, total_time,
            stage_timings=stage_timings, request_id=request_id)

    def run(self, query: str,
            output_format: Literal["intent_extraction", "final_queries",
                                   "nature_breakdown", "full_pipeline"] = "full_pipeline",
            verbose: bool = False) -> Dict[str, Any]:
        try:
            result = self.extract(query, verbose)
            output = getattr(result, f"to_{output_format}")()
            # FIX #18: Attach observability metadata
            output["_meta"] = {
                "request_id": result.request_id,
                "processing_time": result.processing_time,
                "stage_timings": result.stage_timings,
                "model": self.model_name,
            }
            return output
        except PipelineError as e:
            # FIX #14: Structured error with stage, type, and traceback
            logger.error(f"Pipeline failed: {e}")
            return {
                "error": str(e),
                "error_type": type(e.original_error).__name__ if e.original_error else "PipelineError",
                "stage": e.stage,
                "query": query,
                "timestamp": datetime.utcnow().isoformat(),
            }
        except Exception as e:
            logger.error(f"Unexpected error: {e}")
            return {
                "error": str(e),
                "error_type": type(e).__name__,
                "stage": "unknown",
                "query": query,
                "timestamp": datetime.utcnow().isoformat(),
            }


