class StepStatus(BaseModel):
    """Per-step execution status for observability."""
    step: str
    status: str  # "success" | "fallback" | "error"
    detail: Optional[str] = None
    duration_ms: Optional[int] = None


class OutputSummary(BaseModel):
    total_intents: int = 0
    total_concepts: int = 0
    concepts_with_context: int = 0
    concepts_without_context: int = 0


class OutputPipelineMeta(BaseModel):
    query: str
    normalized_query: str
    expanded_query: str
