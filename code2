def load_pickles_from_gcs(bucket_name, prefix):
    client = storage.Client()
    bucket = client.bucket(bucket_name)
    blobs = list(bucket.list_blobs(prefix=prefix))
    print(f"  Found {len(blobs)} blobs in gs://{bucket_name}/{prefix}")
    results = []
    for blob in blobs:
        if blob.name.endswith("/"):
            continue
        if blob.name.endswith((".pk", ".pkl", ".pickle")):
            data = pickle.loads(blob.download_as_bytes())
            fname = blob.name.split("/")[-1]
            results.append((fname, data))
            print(f"  Loaded: {fname}")
    print(f"Total pickle files: {len(results)}")
    return results


def parse_pickle(data):
    text = data.get("text", "")
    entities = []
    extracted = data.get("extracted", {})
    for key, block in extracted.items():
        for item in block.get("matching_items", []):
            entity_text = item[0]
            sentence = item[1]
            cui_list = item[2] if len(item) > 2 else []
            cuis, distances = [], {}
            for entry in cui_list:
                cuis.append(entry[0])
                distances[entry[0]] = entry[1]
            if cuis:
                entities.append((entity_text, sentence, cuis, distances))
    return text, entities


def fetch_preferred_terms(bq, project_id, dataset_id, cuis):
    if not cuis:
        return {}
    terms = {}
    cuis = list(cuis)
    for i in range(0, len(cuis), 500):
        batch = cuis[i:i+500]
        query = f"""
        SELECT CUI, STR
        FROM `{project_id}.{dataset_id}.MRCONSO`
        WHERE CUI IN UNNEST(@cuis) AND LAT = 'ENG' AND ISPREF = 'Y' AND TS = 'P' AND STT = 'PF'
        """
        jc = bigquery.QueryJobConfig(query_parameters=[
            bigquery.ArrayQueryParameter("cuis", "STRING", batch)])
        for row in bq.query(query, job_config=jc).result():
            if row.CUI not in terms:
                terms[row.CUI] = row.STR
    for c in cuis:
        if c not in terms:
            terms[c] = c
    return terms


def save_csv(path, headers, rows):
    with open(path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(headers)
        w.writerows(rows)


# ── cell 3: run ─────────────────────────────────────────────────────────────

def process_one_pickle(fname, data, system, bq):
    text, entities = parse_pickle(data)
    if not entities:
        print(f"  {fname} — no entities found")
        return

    case_name = fname.rsplit(".", 1)[0]
    print(f"\n{'='*80}")
    print(f"CASE: {fname}")
    print(f"TEXT: {text[:150]}...")
    print(f"ENTITIES: {len(entities)}, TOTAL INPUT CUIs: {sum(len(c) for _, _, c, _ in entities)}")
    print(f"{'='*80}")

    # ── step 1: batch reduction ──
    batch_inputs = [(cuis, entity_text, distances)
                    for entity_text, sentence, cuis, distances in entities]
    results = system.reduce_batch(batch_inputs)
    per_entity_results = list(zip(entities, results))

    all_surviving_cuis = set()
    for _, result in per_entity_results:
        all_surviving_cuis.update(result.all_reduced_cuis)

    # ── step 2: preferred terms for ALL cuis ──
    all_cuis = set()
    for _, _, cuis, _ in entities:
        all_cuis.update(cuis)
    all_cuis.update(all_surviving_cuis)
    # also collect explains cuis
    for _, result in per_entity_results:
        for e in result.confidence:
            all_cuis.update(e.explains_cuis)
    terms = fetch_preferred_terms(bq, PROJECT_ID, DATASET_ID, all_cuis)

    # ── step 3: case-level topics ──
    surviving_list = list(all_surviving_cuis)
    embeddings = system.emb_fetcher.fetch(surviving_list)
    with_emb = [c for c in surviving_list if c in embeddings]

    case_topics = {}
    if len(with_emb) >= 2:
        case_topics = TopicBuilder.build(with_emb, embeddings)
    elif with_emb:
        case_topics = {0: with_emb}

    # ── step 4: flat entity CSV ──
    # columns: entity | cui | preferred_term | confidence | prox | cent | ret | explains_count | explains
    # explains = pipe-separated "CUI:Term" pairs in one cell
    entity_rows = []
    for (entity_text, sentence, cuis, distances), result in per_entity_results:
        print(f"\n  ENTITY: \"{entity_text}\"  "
              f"({result.input_count} → {result.after_redundancy_count})")
        for e in result.confidence:
            explains_str = " | ".join(
                f"{ec}:{terms.get(ec, ec)}" for ec in e.explains_cuis
            ) if e.explains_cuis else ""
            entity_rows.append([
                entity_text,
                e.cui,
                terms.get(e.cui, e.cui),
                round(e.confidence, 4),
                round(e.extraction_proximity, 3),
                round(e.centrality, 3),
                round(e.retention_power, 3),
                len(e.explains_cuis),
                explains_str
            ])
            # print top 5 per entity
            if len(entity_rows) <= 5 or entity_rows[-1][0] != entity_rows[-6][0]:
                exp = len(e.explains_cuis)
                exp_s = f"  explains {exp}" if exp else ""
                print(f"    {e.cui}  conf={e.confidence:.3f}{exp_s}  |  {terms.get(e.cui, e.cui)}")

    entity_csv = os.path.join(OUTPUT_DIR, f"{case_name}_entities.csv")
    save_csv(entity_csv,
             ["entity", "cui", "preferred_term", "confidence", "prox", "cent", "ret",
              "explains_count", "explains"],
             entity_rows)

    # ── step 5: flat topic CSV ──
    # columns: topic_id | cui | preferred_term
    topic_rows = []
    print(f"\n  TOPICS: {len(case_topics)} topics, {len(with_emb)} CUIs")
    for tid, members in sorted(case_topics.items()):
        print(f"    Topic {tid}: {len(members)} CUIs")
        for c in members:
            topic_rows.append([tid, c, terms.get(c, c)])

    topic_csv = os.path.join(OUTPUT_DIR, f"{case_name}_topics.csv")
    save_csv(topic_csv, ["topic_id", "cui", "preferred_term"], topic_rows)

    print(f"\n  Saved: {entity_csv}")
    print(f"  Saved: {topic_csv}")


