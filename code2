for case_name, cui_dict in cuis_per_case.items():
    cui_list = list(cui_dict.keys())
    if not cui_list:
        reduced_per_case[case_name] = []
        continue

    final_cuis, stats = reducer.reduce(
        cui_list,
        ic_percentile=75,
        similarity_threshold=0.88,
        distance_from_centroid_threshold=0.3
    )
    reduced_per_case[case_name] = final_cuis
    print(f"{case_name}: {len(cui_list)} → {len(final_cuis)} "
          f"({stats.total_reduction_pct:.1f}% reduced)")

# Show reduced CUIs with preferred terms
print("\n" + "=" * 60)
for case_name, cuis in reduced_per_case.items():
    print(f"\n{case_name} — Reduced CUIs:")
    for cui in cuis:
        term = preferred_terms.get(cui, "N/A")
        print(f"  {cui}: {term}")


