# ── Step 1 ──

class QueryExpansionOutput(BaseModel):
    expanded_query: str
    abbreviations_expanded: List[str] = Field(default_factory=list)


# ── Step 2 ──

class SubNature(BaseModel):
    category_path: str
    atomic_concepts: List[str] = Field(default_factory=list)

    @field_validator('category_path')
    @classmethod
    def normalize_separator(cls, v: str) -> str:
        if not isinstance(v, str):
            v = str(v)
        v = v.replace("/", " >> ")
        v = re.sub(r'\s*>{1,2}\s*', ' >> ', v).strip()
        if '>>' not in v:
            v = f"{v} >> General"
        return v


class FinalQueryItem(BaseModel):
    """LLM-generated query with explicit source concept mapping."""
    query: str
    source_concept: str = ""


class Intent(BaseModel):
    intent_title: str
    description: str = ""
    nature: str = ""
    sub_natures: List[SubNature] = Field(default_factory=list)
    final_queries: List[FinalQueryItem] = Field(default_factory=list)

    # FIX #12: Post-validation — log uncovered concepts
    @model_validator(mode='after')
    def validate_query_coverage(self) -> 'Intent':
        if not self.sub_natures or not self.final_queries:
            return self
        all_concepts = {c.lower().strip() for sn in self.sub_natures
                        for c in sn.atomic_concepts if c.strip()}
        covered = {fq.source_concept.lower().strip() for fq in self.final_queries
                    if fq.source_concept.strip()}
        uncovered = all_concepts - covered
        if uncovered:
            logger.warning(f"Intent '{self.intent_title}': "
                           f"uncovered atomic concepts: {uncovered}")
        return self


class IntentExtractionResponse(BaseModel):
    """What Gemini returns — no pipeline metadata."""
    is_clinical: bool
    reason: Optional[str] = None
    total_intents_detected: int = 0
    intents: List[Intent] = Field(default_factory=list)

    # FIX #10A: Override count with ground truth — intentional, not a bug
    @model_validator(mode='after')
    def fix_intent_count(self) -> 'IntentExtractionResponse':
        self.total_intents_detected = len(self.intents)
        return self


class IntentExtractionOutput(BaseModel):
    """Full pipeline output — LLM response + metadata we attach."""
    is_clinical: bool
    reason: Optional[str] = None
    error_detail: Optional[str] = None  # FIX #10B: Separate error from reason
    original_query: str
    expanded_query: str
    total_intents_detected: int = 0
    intents: List[Intent] = Field(default_factory=list)


