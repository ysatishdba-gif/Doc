class ContextField(BaseModel):
    """Structured key-description pair for machine + human readability."""
    key: str
    description: str


class OutputContext(BaseModel):
    """Full documentation footprint for a concept."""
    document_types: List[ContextField] = Field(default_factory=list)
    author_roles: List[ContextField] = Field(default_factory=list)
    temporal_scope: List[ContextField] = Field(default_factory=list)
    content_signals: List[ContextField] = Field(default_factory=list)
    clinical_setting: List[ContextField] = Field(default_factory=list)
    context_stories: List[str] = Field(default_factory=list)


class OutputSubNature(BaseModel):
    id: str
    category_path: str


class OutputIntent(BaseModel):
    id: str
    title: str
    description: str
    nature: str
    sub_natures: List[OutputSubNature]
    concept_ids: List[str]


class OutputConcept(BaseModel):
