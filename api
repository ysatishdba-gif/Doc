"""
CUI Reduction Runner — API
Extracts CUIs via API, reduction, topics, representatives, anchors, CSVs.

Usage:
    python run_cui_reduction_api.py

    # Or import:
    from run_cui_reduction_api import process_text
"""

import os
import csv
import numpy as np
from google.cloud import bigquery

from config import (
    PROJECT_ID, DATASET_ID, EMBEDDING_TABLE, CACHE_DIR, ALLOWED_SABS,
    API_URL, TOP_K, TOP_P, CLUSTER_SET, COMBINED, OUTPUT_DIR,
    hierarchy, ic_precomputed
)
from cui_reduction_system import (
    CUIReductionSystem, CUIExtractor, HierarchicalTopicBuilder, Evaluator,
    TopicRepresentativeSelector, TopicAnchorAssigner
)
from topic_matcher import ChunkStore


# ── shared instances (initialized once) ──────────────────────────────────────

system = CUIReductionSystem(
    project_id=PROJECT_ID, dataset_id=DATASET_ID, full_network=hierarchy,
    allowed_sabs=ALLOWED_SABS, embedding_table=EMBEDDING_TABLE,
    ic_scores=ic_precomputed, cache_dir=CACHE_DIR)

extractor = CUIExtractor(
    api_url=API_URL, top_k=TOP_K, top_p=TOP_P,
    cluster_set=CLUSTER_SET, combined=COMBINED, cache_dir=CACHE_DIR)

evaluator = Evaluator(hierarchy)
bq = bigquery.Client(project=PROJECT_ID)
os.makedirs(OUTPUT_DIR, exist_ok=True)


# ── helpers ──────────────────────────────────────────────────────────────────

def fetch_preferred_terms(cuis):
    if not cuis:
        return {}
    terms, cuis = {}, list(cuis)
    for i in range(0, len(cuis), 500):
        batch = cuis[i:i+500]
        query = f"""
        SELECT CUI, STR
        FROM `{PROJECT_ID}.{DATASET_ID}.MRCONSO`
        WHERE CUI IN UNNEST(@cuis) AND LAT = 'ENG' AND ISPREF = 'Y' AND TS = 'P' AND STT = 'PF'
        """
        jc = bigquery.QueryJobConfig(query_parameters=[
            bigquery.ArrayQueryParameter("cuis", "STRING", batch)])
        for row in bq.query(query, job_config=jc).result():
            if row.CUI not in terms:
                terms[row.CUI] = row.STR
    for c in cuis:
        if c not in terms:
            terms[c] = c
    return terms


def save_csv(path, headers, rows):
    with open(path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(headers)
        w.writerows(rows)


# ── core pipeline: text → anchors ────────────────────────────────────────────

def process_text(text_list, context, label="doc"):
    """Full pipeline: text → extract → reduce → topics → reps → anchors.

    Args:
        text_list: list of phrases to extract CUIs from
        context: surrounding text for extraction context
        label: name for output (e.g. "doc", case name)

    Returns:
        dict with keys: anchors, ic_map, terms, h_topics, topic_reps,
                        entity_results, all_embeddings, metadata
        or None if nothing extracted
    """
    context_list = [context] * len(text_list)
    per_phrase = extractor.extract(text_list, context_list)
    extractor._cache.flush()

    print(f"\n[{label}] Extracted CUIs for {len(per_phrase)} phrases")
    for phrase, cui_dists in per_phrase.items():
        print(f"  \"{phrase}\": {len(cui_dists)} CUIs")

    if not per_phrase:
        print(f"[{label}] No CUIs extracted")
        return None

    batch_inputs = [(list(cd.keys()), ph, cd) for ph, cd in per_phrase.items()]
    results = system.reduce_batch(batch_inputs)
    entity_results = [(batch_inputs[i][1], results[i]) for i in range(len(results))]

    all_surviving, all_cuis = set(), set()
    for entity_text, result in entity_results:
        all_surviving.update(result.all_reduced_cuis)
        for e in result.confidence:
            all_cuis.update(e.explains_cuis)
        for a in result.audit_trail:
            all_cuis.add(a.removed_cui)
            if a.kept_cui:
                all_cuis.add(a.kept_cui)
    all_cuis.update(all_surviving)
    for ph, cd in per_phrase.items():
        all_cuis.update(cd.keys())

    if not all_surviving:
        print(f"[{label}] No CUIs survived reduction")
        return None

    ic_map = system.ic_computer.compute(list(all_surviving), {})
    h_topics = HierarchicalTopicBuilder.build(list(all_surviving), hierarchy, ic_map)

    terms = fetch_preferred_terms(all_cuis)

    embeddings = system.emb_fetcher.fetch(list(all_surviving))
    removed_embs = system.emb_fetcher.fetch(list(all_cuis - all_surviving))
    all_embeddings = {**embeddings, **removed_embs}

    metadata = system.fetcher.fetch(list(all_cuis))
    topic_reps = TopicRepresentativeSelector.select(
        h_topics, metadata, all_embeddings, ic_map, hierarchy)
    HierarchicalTopicBuilder.label_topics(h_topics, topic_reps)

    # fetch terms for topic labels (ancestor CUIs not in original text)
    label_cuis = {t["topic_cui"] for t in h_topics.values() if t.get("topic_cui")}
    missing_label_terms = label_cuis - set(terms.keys())
    if missing_label_terms:
        terms.update(fetch_preferred_terms(missing_label_terms))

    anchors = TopicAnchorAssigner.assign(topic_reps, ic_map, hierarchy)

    anchor_cuis_for_terms = set(a.anchor_cui for a in anchors)
    anchor_cuis_for_terms.update(c for a in anchors for c in a.ancestor_cuis or [])
    extra_terms = fetch_preferred_terms(anchor_cuis_for_terms - set(terms.keys()))
    terms.update(extra_terms)

    print(f"[{label}] {sum(len(cd) for cd in per_phrase.values())} raw CUIs "
          f"→ {len(all_surviving)} surviving → {len(h_topics)} topics "
          f"→ {len(anchors)} anchors")
    for a in anchors:
        rep_terms_list = [terms.get(rc, rc) for rc in a.rep_cuis]
        print(f"    {a.anchor_cui} | {terms.get(a.anchor_cui, a.anchor_cui)} "
              f"(IC={a.anchor_ic:.1f}, reps=[{', '.join(rep_terms_list)}], "
              f"topics={a.topic_ids})")

    return {
        "surviving_cuis": all_surviving,
        "anchors": anchors,
        "ic_map": ic_map,
        "terms": terms,
        "h_topics": h_topics,
        "topic_reps": topic_reps,
        "entity_results": entity_results,
        "all_embeddings": all_embeddings,
        "metadata": metadata,
    }


# ── CSV writers ──────────────────────────────────────────────────────────────

INCLUDE_SUBTOPICS = False   # set True to include subtopic columns in topics CSV

def write_csvs(result, label="doc"):
    """Write all CSVs from a process_text result."""
    terms = result["terms"]
    h_topics = result["h_topics"]

    # ── entities CSV (unchanged) ─────────────────────────────────────────
    entity_rows = []
    for entity_text, r in result["entity_results"]:
        for e in r.confidence:
            explains_str = " | ".join(
                f"{ec}:{terms.get(ec, ec)}" for ec in e.explains_cuis
            ) if e.explains_cuis else ""
            entity_rows.append([
                entity_text, e.cui, terms.get(e.cui, e.cui),
                round(e.confidence, 4), round(e.extraction_proximity, 3),
                round(e.centrality, 3), round(e.retention_power, 3),
                len(e.explains_cuis), explains_str])
    save_csv(os.path.join(OUTPUT_DIR, f"{label}_entities.csv"),
             ["entity", "cui", "preferred_term", "confidence", "prox", "cent", "ret",
              "explains_count", "explains"], entity_rows)

    # ── topics CSV: topic_id + label + CUIs ────────────────────────────────
    topic_rows = []
    if INCLUDE_SUBTOPICS:
        for tid, t in sorted(h_topics.items()):
            t_label_cui = t.get("topic_cui") or ""
            t_label = terms.get(t_label_cui, t_label_cui) if t_label_cui else ""
            for stid, st in sorted(t.get("subtopics", {}).items()):
                st_cui = st["subtopic_cui"] or ""
                st_name = terms.get(st_cui, st_cui) if st_cui else ""
                for c in st["members"]:
                    topic_rows.append([tid, t_label, stid, st_name, c, terms.get(c, c)])
            for c in sorted(t.get("ungrouped", [])):
                topic_rows.append([tid, t_label, "", "", c, terms.get(c, c)])
        save_csv(os.path.join(OUTPUT_DIR, f"{label}_topics.csv"),
                 ["topic_id", "topic_label", "subtopic_id", "subtopic_name",
                  "cui", "preferred_term"], topic_rows)
    else:
        for tid, t in sorted(h_topics.items()):
            t_label_cui = t.get("topic_cui") or ""
            t_label = terms.get(t_label_cui, t_label_cui) if t_label_cui else ""
            for c in t["members"]:
                topic_rows.append([tid, t_label, c, terms.get(c, c)])
        save_csv(os.path.join(OUTPUT_DIR, f"{label}_topics.csv"),
                 ["topic_id", "topic_label", "cui", "preferred_term"], topic_rows)

    # ── representatives CSV: one rep per row, simple ─────────────────────
    rep_rows = []
    for tid in sorted(result["topic_reps"].keys()):
        for r in result["topic_reps"][tid]:
            rep_rows.append([
                tid, r.cui, terms.get(r.cui, r.cui),
                r.method, r.member_count, round(r.ic_score, 2),
                " | ".join(f"{m}:{terms.get(m, m)}" for m in r.members)])
    save_csv(os.path.join(OUTPUT_DIR, f"{label}_representatives.csv"),
             ["topic_id", "rep_cui", "rep_term", "method", "member_count",
              "ic_score", "members"], rep_rows)

    # ── anchors CSV: what gets stored for matching ───────────────────────
    anchor_rows = []
    for a in result["anchors"]:
        rep_detail = " | ".join(f"{rc}:{terms.get(rc, rc)}" for rc in a.rep_cuis)
        topic_detail_parts = []
        for tid in a.topic_ids:
            t = h_topics.get(tid, {})
            member_count = len(t.get("members", []))
            topic_detail_parts.append(f"topic_{tid}({member_count} CUIs)")
        topic_detail = " | ".join(topic_detail_parts)

        anchor_rows.append([
            a.anchor_cui, terms.get(a.anchor_cui, a.anchor_cui),
            round(a.anchor_ic, 2),
            rep_detail,
            len(a.topic_ids), topic_detail,
            len(a.ancestor_cuis) if a.ancestor_cuis else 0])
    save_csv(os.path.join(OUTPUT_DIR, f"{label}_anchors.csv"),
             ["anchor_cui", "anchor_term", "anchor_ic",
              "representatives", "topics_covered", "topic_details",
              "ancestor_count"], anchor_rows)

    print(f"[{label}] CSVs written to {OUTPUT_DIR}")


def run_evaluation(result, label="doc"):
    flat_topics = {tid: t["members"] for tid, t in result["h_topics"].items()}
    metric_rows = evaluator.intrinsic_metrics(
        label, result["entity_results"], flat_topics, result["all_embeddings"])
    recon_rows = evaluator.reconstruction_check(
        label, result["entity_results"], result["all_embeddings"],
        result["metadata"], result["terms"])
    save_csv(os.path.join(OUTPUT_DIR, f"{label}_eval_metrics.csv"),
             Evaluator.metric_headers(), metric_rows)
    save_csv(os.path.join(OUTPUT_DIR, f"{label}_eval_reconstruction.csv"),
             Evaluator.reconstruction_headers(), recon_rows)
    suspect = sum(1 for r in recon_rows if "SUSPECT" in str(r[-1]))
    ok = sum(1 for r in recon_rows if r[-1] == "OK")
    total = len(recon_rows)
    if total:
        print(f"[{label}] Evaluation: {ok}/{total} OK, {suspect}/{total} SUSPECT")
    return metric_rows, recon_rows


# ── main ─────────────────────────────────────────────────────────────────────

if __name__ == "__main__":

    # ── INPUT (edit these) ───────────────────────────────────────────────
    CONTEXT = (
        "Patient presented with left knee pain and swelling for the past three days. "
        "Pain worsens with weight bearing and climbing stairs. No history of trauma. "
        "Mild effusion noted on examination."
    )
    TEXT_LIST = [
        "left knee pain",
        "swelling",
        "weight bearing pain",
        "climbing stairs difficulty",
        "knee effusion",
    ]

    # ═════════════════════════════════════════════════════════════════════
    # Process + store
    # ═════════════════════════════════════════════════════════════════════
    CHUNK_ID = "api_chunk_1"
    STORE_PATH = os.path.join(OUTPUT_DIR, "chunk_store.pkl")

    result = process_text(TEXT_LIST, CONTEXT, label="api")
    if result:
        write_csvs(result, label="api")
        run_evaluation(result, label="api")

        # store surviving CUIs for matching
        store = ChunkStore()
        store.add(CHUNK_ID, "api_doc",
                  result["surviving_cuis"], topics=result["h_topics"])
        store.save(STORE_PATH)

        stats = store.stats()
        print(f"\n  Stored: {stats['total_cuis']} surviving CUIs "
              f"for {stats['chunks']} chunk(s)")
        print(f"  Store saved to: {STORE_PATH}")

    print(f"\n{'='*80}\nDONE\n{'='*80}")
