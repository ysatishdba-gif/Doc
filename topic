def log(msg, level="INFO"):
    getattr(logger, level.lower(), logger.info)(msg)


_timings = defaultdict(list)
_timing_lock = threading.Lock()


def timed(name):
    def dec(fn):
        def wrapper(*a, **kw):
            t0 = time.perf_counter()
            try:
                return fn(*a, **kw)
            finally:
                with _timing_lock:
                    _timings[name].append(
                        (time.perf_counter() - t0) * 1000)
        return wrapper
    return dec


