_timings = defaultdict(list)
_timing_lock = threading.Lock()


def timed(name):
    def dec(fn):
        def wrapper(*a, **kw):
            t0 = time.perf_counter()
            try:
                return fn(*a, **kw)
            finally:
                with _timing_lock:
                    _timings[name].append(
                        (time.perf_counter() - t0) * 1000)
        return wrapper
    return dec


# --- Otsu threshold helper ---
def _otsu_threshold(values):
    """Find threshold that maximizes between-class variance (Otsu's method)."""
    arr = np.sort(values)
    n = len(arr)
    if n < 2:
        return float(arr[0]) if n == 1 else 0.0
    best_t, best_var = float(arr[0]), -1.0
    total_mean = np.mean(arr)
    for i in range(1, n):
        if arr[i] == arr[i - 1]:
            continue
        w0 = i / n
        w1 = 1.0 - w0
        m0 = np.mean(arr[:i])
        m1 = np.mean(arr[i:])
        var = w0 * w1 * (m0 - m1) ** 2
        if var > best_var:
            best_var = var
            best_t = float(arr[i])
    return best_t


# ancestor cache — cleared per pipeline run to avoid stale data
_ancestor_cache = {}

def _get_ancestors(graph, cui, depth):
    """Collect all ancestors up to `depth` hops. Cached per (cui, depth)."""
    key = (cui, depth)
    if key in _ancestor_cache:
        return _ancestor_cache[key]
    if graph is None or not graph.has_node(cui):
        _ancestor_cache[key] = frozenset()
        return frozenset()
    ancestors = set()
    frontier = {cui}
    for _ in range(depth):
        next_frontier = set()
        for node in frontier:
            for parent in graph.predecessors(node):
                if parent not in ancestors:
                    ancestors.add(parent)
                    next_frontier.add(parent)
        frontier = next_frontier
        if not frontier:
            break
    result = frozenset(ancestors)
    _ancestor_cache[key] = result
    return result


def _clear_ancestor_cache():
    """Call at start of each pipeline run."""
    _ancestor_cache.clear()


def _compute_component_depth(graph, ancestor_depth):
    """Derive component separation depth from graph structure.

    Component separation needs SHALLOW depth to keep body-site variants
    in separate components. Too deep -> everything merges into one component.

    Uses ~40% of ancestor_depth, bounded by graph density.
    Shallow graphs (mean_in <= 1.5): depth 1
    Normal graphs: fraction of ancestor_depth
    """
    in_degrees = [d for _, d in graph.in_degree()]
    mean_in = np.mean(in_degrees) if in_degrees else 1.0
    if mean_in <= 1.5:
        return 1
    derived = max(1, int(round(ancestor_depth * 0.4)))
    n_nodes = graph.number_of_nodes()
    if n_nodes > 0:
        max_depth_for_nodes = max(1, int(np.log(np.sqrt(n_nodes)) / np.log(mean_in)))
        derived = min(derived, max_depth_for_nodes)
    return max(1, min(derived, ancestor_depth))


def _compute_ancestor_depth(graph):
    """Derive ancestor lookup depth from graph structure.

    Goal: enough hops so CUIs on different branches have non-overlapping
    ancestor sets, but not so many that everything converges to shared roots.

    Uses mean in-degree: at depth d, expected ancestors ~ mean_in_degree^d.
    We want ~10-50 ancestors for meaningful Jaccard comparison.
    Solve: mean_in_degree^d ~ 20  ->  d = log(20) / log(mean_in_degree).
    Clamped to [1, 5] since beyond 5 most UMLS paths converge.
    """
    in_degrees = [d for _, d in graph.in_degree()]
    mean_in = np.mean(in_degrees)
    if mean_in <= 1.0:
        return 3
    depth = int(round(np.log(20) / np.log(mean_in)))
    return max(1, min(depth, 5))


