# --- Infrastructure constants (safety caps, not algorithmic) ---
_SUBGRAPH_MAX_NODES = 200_000
_WALK_MAX_VISITED = 10_000
_PARENT_IC_CACHE_SIZE = 100_000
_BQ_BATCH_SIZE = 5000


@dataclass
class ReductionConfig:
    """All algorithmic thresholds — passed to CUIReductionSystem.

    Override for domain-specific tuning. Defaults are reasonable
    starting points for general clinical NLP.
    """
    # sibling IC: fallback when Otsu has < 10 data points.
    # in production, Otsu computes this from the data.
    sibling_ic_fallback: float = 8.0

    # rare concept protection: min IC + max close neighbors
    # to qualify as "isolated and worth protecting"
    rare_concept_ic_floor: float = 10.0
    rare_concept_max_neighbors: int = 1

    # cross-topic dedup: max cosine distance ceiling
    # (actual threshold is data-driven p5, this is the cap)
    cross_topic_max_dist: float = 0.05

    # confidence score weights (must sum to 1.0)
    confidence_w_ic: float = 0.45
    confidence_w_retention: float = 0.30
    confidence_w_type_uniq: float = 0.25


