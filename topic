#  4- Text Utilities
def normalize_term(term):
    t = unicodedata.normalize("NFKD", term).lower()
    t = re.sub(r"[^a-z0-9\s]", "", t)
    t = re.sub(r"\s+", " ", t).strip()
    return t


def tokenize_term(normalized):
    if not normalized:
        return frozenset()
    return frozenset(normalized.split())


def terms_diverge(tokens_a, tokens_b):
    if not tokens_a or not tokens_b:
        return False
    return len(tokens_a & tokens_b) == 0


def qualifier_conflict(tokens_a, tokens_b):
    if not tokens_a or not tokens_b:
        return False
    shared = tokens_a & tokens_b
    only_a = tokens_a - tokens_b
    only_b = tokens_b - tokens_a
    if not only_a and not only_b:
        return False
    total = len(tokens_a | tokens_b)
    overlap_ratio = len(shared) / total if total > 0 else 0
    if overlap_ratio >= 0.5 and 1 <= len(only_a) <= 2 and 1 <= len(only_b) <= 2:
        return True
    return False


#  5- LRU Cache with optional disk persistence
class Cache:
    def __init__(self, max_size, persist_path=None):
        self._max = max_size
        self._d = OrderedDict()
        self._lock = threading.Lock()
        self._persist_path = persist_path
        self._dirty = False
        if persist_path:
            self._load()

    def _load(self):
        """Load cache from disk if file exists."""
        import pickle
        try:
            if self._persist_path and os.path.exists(self._persist_path):
                with open(self._persist_path, "rb") as f:
                    data = pickle.load(f)
                if isinstance(data, dict):
                    # load up to max_size most recent entries
                    items = list(data.items())[-self._max:]
                    self._d = OrderedDict(items)
                    log(f"    Cache loaded: {len(self._d)} entries from {self._persist_path}")
        except Exception as e:
            log(f"    Cache load failed ({self._persist_path}): {e}", level="WARNING")

    def flush(self):
        """Persist cache to disk."""
        import pickle
        if not self._persist_path or not self._dirty:
            return
        try:
            os.makedirs(os.path.dirname(self._persist_path) or ".", exist_ok=True)
            with self._lock:
                with open(self._persist_path, "wb") as f:
                    pickle.dump(dict(self._d), f, protocol=pickle.HIGHEST_PROTOCOL)
                self._dirty = False
                log(f"    Cache saved: {len(self._d)} entries to {self._persist_path}")
        except Exception as e:
            log(f"    Cache save failed ({self._persist_path}): {e}", level="WARNING")

    def get(self, key):
        with self._lock:
            if key in self._d:
                self._d.move_to_end(key)
                return self._d[key]
        return None

    def put(self, key, val):
        with self._lock:
            if key in self._d:
                self._d.move_to_end(key)
            self._d[key] = val
            self._dirty = True
            while len(self._d) > self._max:
                self._d.popitem(last=False)

    def __len__(self):
        return len(self._d)


#  6-BigQuery
_BQ_BATCH = 5000

class MetadataFetcher:
    def __init__(self, bq, pid, did, cache_dir=None):
        self.bq = bq
        self.pid = pid
        self.did = did
        path = os.path.join(cache_dir, "metadata_cache.pkl") if cache_dir else None
        self._cache = Cache(50_000, persist_path=path)

    @timed("metadata_fetch")
    def fetch(self, cuis):
        result = {}
        missing = []
        for c in cuis:
            cached = self._cache.get(c)
            if cached is not None:
                result[c] = cached
            else:
                missing.append(c)
        if not missing:
            return result
        for i in range(0, len(missing), _BQ_BATCH):
            batch = missing[i:i + _BQ_BATCH]
            query = f"""
            WITH ranked AS (
              SELECT CUI, STR, SAB, ISPREF,
                ROW_NUMBER() OVER (
                  PARTITION BY CUI
                  ORDER BY
                    CASE SAB
                      WHEN 'SNOMEDCT_US' THEN 0
                      WHEN 'ICD10CM' THEN 1
                      WHEN 'ICD10PCS' THEN 2
                      WHEN 'ICD9CM' THEN 3
                      WHEN 'LNC' THEN 4
                      ELSE 5
                    END,
                    CASE WHEN ISPREF='Y' THEN 0 ELSE 1 END,
                    LENGTH(STR) DESC
                ) AS rn
              FROM `{self.pid}.{self.did}.MRCONSO`
              WHERE CUI IN UNNEST(@cuis) AND LAT = 'ENG'
            ),
            sab_pref AS (
              SELECT CUI, SAB, STR,
                ROW_NUMBER() OVER (
                  PARTITION BY CUI, SAB
                  ORDER BY
                    CASE WHEN ISPREF='Y' THEN 0 ELSE 1 END,
                    LENGTH(STR) DESC
                ) AS sab_rn
              FROM `{self.pid}.{self.did}.MRCONSO`
              WHERE CUI IN UNNEST(@cuis) AND LAT = 'ENG'
                AND SAB IN ('SNOMEDCT_US','ICD10CM','ICD10PCS','ICD9CM','LNC')
            )
            SELECT
              r.CUI AS cui,
              MAX(CASE WHEN r.rn = 1 THEN r.STR END) AS pref_term,
              ARRAY_AGG(DISTINCT s.TUI IGNORE NULLS) AS tuis,
              ARRAY_AGG(DISTINCT s.STY IGNORE NULLS) AS stys,
              ARRAY_AGG(DISTINCT c2.SAB IGNORE NULLS) AS sabs,
              ARRAY_AGG(DISTINCT sp.STR IGNORE NULLS) AS sab_terms
            FROM ranked r
            LEFT JOIN `{self.pid}.{self.did}.MRSTY` s ON r.CUI = s.CUI
            LEFT JOIN `{self.pid}.{self.did}.MRCONSO` c2 ON r.CUI = c2.CUI AND c2.LAT = 'ENG'
            LEFT JOIN sab_pref sp ON r.CUI = sp.CUI AND sp.sab_rn = 1
            WHERE r.rn = 1
            GROUP BY r.CUI
            """
            jc = bigquery.QueryJobConfig(query_parameters=[
                bigquery.ArrayQueryParameter("cuis", "STRING", batch)])
            for row in self.bq.query(query, job_config=jc, timeout=300).result():
                term = row.pref_term or row.cui
                norm = normalize_term(term)
                sab_tok = set()
                for t in (row.sab_terms or []):
                    sab_tok.update(tokenize_term(normalize_term(t)))
                pref_tok = tokenize_term(norm)
                combined = frozenset(sab_tok | pref_tok) if sab_tok else pref_tok
                meta = CUIMetadata(
                    cui=row.cui, preferred_term=term, normalized_term=norm,
                    all_tokens=combined,
                    semantic_types=list(row.stys or []),
                    semantic_type_ids=list(row.tuis or []),
                    ic_score=0.0, source_vocabs=list(row.sabs or []))
                self._cache.put(row.cui, meta)
                result[row.cui] = meta
        return result


#  7- IC Scores
class ICComputer:
    def __init__(self, graph, precomputed=None):
        self.graph = graph
        self.precomputed = precomputed or {}
        self._cache = Cache(100_000)
        self._total = max(graph.number_of_nodes(), 1)

    @timed("ic_compute")
    def compute(self, cuis, metadata):
        result = {}
        for cui in cuis:
            if cui in self.precomputed:
                ic = self.precomputed[cui]
            else:
                cached = self._cache.get(cui)
                if cached is not None:
                    ic = cached
                else:
                    desc = self._count_descendants(cui)
                    ic = -np.log((desc + 1) / self._total)
                    self._cache.put(cui, ic)
            result[cui] = ic
            m = metadata.get(cui)
            if m:
                m.ic_score = ic
        return result

    def _count_descendants(self, cui):
        if not self.graph.has_node(cui):
            return 0
        visited = set()
        q = deque([cui])
        while q:
            n = q.popleft()
            for child in self.graph.successors(n):
                if child not in visited:
                    visited.add(child)
                    q.append(child)
        return len(visited)


#  8- Filters
class SABFilter:
    def __init__(self, allowed):
        self.allowed = set(allowed)

    @timed("sab_filter")
    def run(self, cuis, metadata):
        kept, audit = [], []
        for cui in cuis:
            m = metadata.get(cui)
            if not m:
                audit.append(AuditEntry(cui, "", "", "", "no_metadata", "CUI not found in BQ"))
                continue
            if not any(s in self.allowed for s in m.source_vocabs):
                audit.append(AuditEntry(cui, m.preferred_term, "", "", "sab_filtered",
                    f"vocabs {m.source_vocabs} not in allowed"))
                continue
            kept.append(cui)
        return kept, audit


class SemanticTypeFilter:
    def __init__(self, excluded):
        self.excluded = set(excluded) if excluded else set()

    @timed("semtype_filter")
    def run(self, cuis, metadata):
        if not self.excluded:
            return cuis, []
        kept, audit = [], []
        for cui in cuis:
            m = metadata.get(cui)
            if not m or not m.semantic_types:
                kept.append(cui)
                continue
            if all(st in self.excluded for st in m.semantic_types):
                audit.append(AuditEntry(cui, m.preferred_term, "", "", "semtype_excluded",
                    f"all types {m.semantic_types} excluded"))
                continue
            kept.append(cui)
        return kept, audit


class TermDeduplicator:
    @staticmethod
    @timed("term_dedup")
    def run(cuis, metadata, ic_map):
        groups = defaultdict(list)
        for cui in cuis:
            m = metadata.get(cui)
            key = m.normalized_term if m else cui
            groups[key].append(cui)
        kept, audit = [], []
        for term, members in groups.items():
            best = max(members, key=lambda c: ic_map.get(c, 0))
            kept.append(best)
            for c in members:
                if c != best:
                    bm = metadata.get(best)
                    cm = metadata.get(c)
                    audit.append(AuditEntry(
                        c, cm.preferred_term if cm else "",
                        best, bm.preferred_term if bm else "",
                        "term_dedup", f"identical norm term '{term}'"))
        return kept, audit


#  9- Hierarchy Reduction
class HierarchyReducer:
    def __init__(self, graph):
        self.graph = graph

    @timed("hierarchy_reduce")
    def run(self, cuis, ic_map, metadata):
        cui_set = set(cuis)
        edges = set()
        parent_children = defaultdict(set)
        for cui in cuis:
            if not self.graph.has_node(cui):
                continue
            for parent in self.graph.predecessors(cui):
                if parent in cui_set and parent != cui:
                    parent_children[parent].add(cui)
                    edges.add((parent, cui))
        to_remove = {}
        for parent, children in parent_children.items():
            p_ic = ic_map.get(parent, 0)
            p_meta = metadata.get(parent)
            p_types = set(p_meta.semantic_types) if p_meta and p_meta.semantic_types else set()
            for child in children:
                c_ic = ic_map.get(child, 0)
                if c_ic < p_ic:
                    continue
                c_meta = metadata.get(child)
                c_types = set(c_meta.semantic_types) if c_meta and c_meta.semantic_types else set()
                if p_types and c_types and not (p_types & c_types):
                    continue
                if parent not in to_remove or c_ic > to_remove[parent][1]:
                    to_remove[parent] = (child, c_ic, p_ic)
        remove_set = set(to_remove.keys())
        surviving = [c for c in cuis if c not in remove_set]
        audit = []
        for parent, (child, c_ic, p_ic) in to_remove.items():
            pm = metadata.get(parent)
            cm = metadata.get(child)
            audit.append(AuditEntry(
                parent, pm.preferred_term if pm else "",
                child, cm.preferred_term if cm else "",
                "ancestor_subsumed", f"child IC {c_ic:.2f} >= parent IC {p_ic:.2f}"))
        return surviving, audit, edges


#  10- Embedding Fetch
class EmbeddingFetcher:
    def __init__(self, bq, pid, did, embedding_table, cache_dir=None):
        self.bq = bq
        self.pid = pid
        self.did = did
        self.table = embedding_table
        path = os.path.join(cache_dir, "embedding_cache.pkl") if cache_dir else None
        self._cache = Cache(50_000, persist_path=path)
        self._pool = ThreadPoolExecutor(max_workers=4)

    def _fetch_batch(self, batch):
        rows = []
        query = f"""
        SELECT cui, embedding
        FROM `{self.pid}.{self.did}.{self.table}`
        WHERE cui IN UNNEST(@cuis)
        """
        jc = bigquery.QueryJobConfig(query_parameters=[
            bigquery.ArrayQueryParameter("cuis", "STRING", batch)])
        for row in self.bq.query(query, job_config=jc, timeout=300).result():
            raw = row.embedding
            if raw is None or len(raw) == 0:
                continue
            vec = np.array(raw, dtype=np.float32)
            if not np.all(np.isfinite(vec)):
                continue
            norm = np.linalg.norm(vec)
            if norm == 0:
                continue
            vec = vec / norm
            rows.append((row.cui, vec))
        return rows

    @timed("embedding_fetch")
    def fetch(self, cuis):
        result, missing = {}, []
        for c in cuis:
            cached = self._cache.get(c)
            if cached is not None:
                result[c] = cached
            else:
                missing.append(c)
        if not missing:
            return result
        batches = [missing[i:i + _BQ_BATCH] for i in range(0, len(missing), _BQ_BATCH)]
        futures = [self._pool.submit(self._fetch_batch, b) for b in batches]
        for f in futures:
            for cui, vec in f.result():
                self._cache.put(cui, vec)
                result[cui] = vec
        fetched = len(result) - (len(cuis) - len(missing))  # newly fetched count
        coverage = len(result) / len(cuis) * 100 if cuis else 0
        dim = next(iter(result.values())).shape[0] if result else 0
        log(f"    Embeddings: {len(result)}/{len(cuis)} ({coverage:.1f}%) | "
            f"dim={dim} | cache_hits={len(cuis)-len(missing)} | fetched={fetched}")
        return result


#  11- ScaNN Topic Builder
class TopicBuilder:
    @staticmethod
    @timed("scann_topics")
    def build(cuis, embeddings, k_neighbors=20):
        cuis = sorted(cuis)
        np.random.seed(42)
        matrix = np.array([embeddings[c] for c in cuis], dtype=np.float32)
        n = len(cuis)
        dim = matrix.shape[1] if matrix.ndim == 2 else 0
        if n < 2 or dim == 0:
            return {i: [c] for i, c in enumerate(cuis)}
        k = min(k_neighbors, n - 1)
        k = max(k, 1)
        num_leaves = min(max(2, int(np.sqrt(n))), n)
        builder = scann.scann_ops_pybind.builder(matrix, k, "dot_product")
        if n >= 16 and dim >= 2:
            dims_per_block = 2 if dim % 2 == 0 else 1
            builder = (
                builder
                .tree(num_leaves=num_leaves,
                      num_leaves_to_search=max(1, num_leaves // 5),
                      training_sample_size=min(n, 250_000))
                .score_ah(dims_per_block, anisotropic_quantization_threshold=0.2)
                .reorder(min(k * 4, n)))
        else:
            builder = builder.score_brute_force()
        searcher = builder.build()
        neighbors, scores = searcher.search_batched(matrix)
        kth_dists = []
        for i in range(n):
            valid = scores[i][scores[i] > -1e30]
            if len(valid) > 0:
                kth_dists.append(1.0 - float(valid[-1]))
        if kth_dists:
            threshold = float(np.mean(kth_dists))
        else:
            all_sims = matrix @ matrix.T
            np.fill_diagonal(all_sims, -np.inf)
            threshold = float(1.0 - np.mean(all_sims[all_sims > -np.inf]))

        # build weighted NetworkX graph for Louvain
        G = networkx.Graph()
        G.add_nodes_from(range(n))
        for i in range(n):
            for j_pos in range(len(neighbors[i])):
                j = int(neighbors[i][j_pos])
                if j < 0 or j >= n or j == i:
                    continue
                dist = 1.0 - float(scores[i][j_pos])
                if dist < threshold:
                    weight = 1.0 - dist  # higher similarity = higher weight
                    if G.has_edge(i, j):
                        G[i][j]["weight"] = max(G[i][j]["weight"], weight)
                    else:
                        G.add_edge(i, j, weight=weight)

        # Louvain community detection
        communities = networkx.community.louvain_communities(
            G, weight="weight", seed=42)

        # recursive split: if community > sqrt(N), re-apply Louvain
        max_size = max(2, int(np.sqrt(n)))
        final_communities = []
        queue = list(communities)
        while queue:
            comm = queue.pop(0)
            if len(comm) <= max_size:
                final_communities.append(comm)
                continue
            # build subgraph and re-run Louvain at higher resolution
            subG = G.subgraph(comm).copy()
            if subG.number_of_edges() == 0:
                final_communities.append(comm)
                continue
            sub_comms = networkx.community.louvain_communities(
                subG, weight="weight", seed=42, resolution=2.0)
            if len(sub_comms) <= 1:
                # Louvain can't split further, accept it
                final_communities.append(comm)
            else:
                # re-queue for further splitting if still too large
                queue.extend(sub_comms)

        # merge singletons into nearest community
        idx_map = {c: i for i, c in enumerate(cuis)}
        groups = {}
        label = 0
        singleton_indices = []
        for comm in final_communities:
            members = [cuis[i] for i in comm]
            if len(members) == 1:
                singleton_indices.append(comm.pop() if isinstance(comm, set) else list(comm)[0])
            else:
                groups[label] = members
                label += 1

        if singleton_indices and groups:
            # compute centroid per group
            group_centroids = {}
            for gid, members in groups.items():
                vecs = [matrix[idx_map[c]] for c in members if c in idx_map]
                if vecs:
                    cent = np.mean(vecs, axis=0)
                    norm = np.linalg.norm(cent)
                    group_centroids[gid] = cent / norm if norm > 0 else cent
            for si in singleton_indices:
                vec = matrix[si]
                best_gid = max(group_centroids,
                               key=lambda g: float(np.dot(vec, group_centroids[g])))
                groups[best_gid].append(cuis[si])
        elif singleton_indices:
            # all singletons, no groups to merge into
            for si in singleton_indices:
                groups[label] = [cuis[si]]
                label += 1

        return groups


#  12a- Relevance Filter (density-based core detection)
class RelevanceFilter:
    """Finds query-relevant CUIs via extraction density, no terms needed.

    The extraction API returns many CUIs about the actual query topic (dense cluster)
    plus scattered CUIs from related but irrelevant body sites (sparse periphery).
    This filter recovers that signal structurally:

    1. k-NN density: mean cosine to 10 nearest neighbors per CUI
    2. Otsu on density -> core (dense) vs periphery (sparse)
    3. Anchor centroid = normalized mean of core embeddings
    4. Relevance = cosine(each CUI, anchor centroid)
    5. Otsu on relevance -> keep above threshold
    """

    @staticmethod
    @timed("relevance_filter")
    def run(cuis, embeddings):
        with_emb = [c for c in cuis if c in embeddings]
        without_emb = [c for c in cuis if c not in embeddings]
        n = len(with_emb)
        if n < 4:
            return cuis, []

        cui_list = sorted(with_emb)
        matrix = np.array([embeddings[c] for c in cui_list], dtype=np.float32)

        # Step 1: k-NN density via ScaNN — sqrt-scaled neighborhood
        k = min(max(1, int(np.sqrt(n))), n - 1)
        num_leaves = min(max(2, int(np.sqrt(n))), n)
        builder = scann.scann_ops_pybind.builder(matrix, k, "dot_product")
        if n >= 16 and matrix.shape[1] >= 2:
            dims_per_block = 2 if matrix.shape[1] % 2 == 0 else 1
            builder = (
                builder
                .tree(num_leaves=num_leaves,
                      num_leaves_to_search=max(1, num_leaves // 5),
                      training_sample_size=min(n, 250_000))
                .score_ah(dims_per_block, anisotropic_quantization_threshold=0.2)
                .reorder(min(k * 4, n)))
        else:
            builder = builder.score_brute_force()
        searcher = builder.build()
        _, scores = searcher.search_batched(matrix)

        # density = mean cosine similarity to k neighbors
        density = np.zeros(n, dtype=np.float32)
        for i in range(n):
            valid = scores[i][scores[i] > -1e30]
            if len(valid) > 0:
                density[i] = float(np.mean(valid))

        # Step 2: Otsu on density -> core vs periphery
        density_threshold = _otsu_threshold(density)
        core_mask = density >= density_threshold
        core_indices = np.where(core_mask)[0]

        if len(core_indices) < 2:
            return cuis, []

        # Step 3: anchor centroid from core CUIs
        core_vecs = matrix[core_indices]
        anchor = np.mean(core_vecs, axis=0).astype(np.float32)
        anchor_norm = np.linalg.norm(anchor)
        if anchor_norm == 0:
            return cuis, []
        anchor = anchor / anchor_norm

        # Step 4: relevance = cosine to anchor centroid
        relevance = matrix @ anchor  # dot product with unit vectors = cosine

        # Step 5: Otsu on relevance -> keep above threshold
        rel_threshold = _otsu_threshold(relevance)

        kept_set = set()
        audit = []
        for i, cui in enumerate(cui_list):
            if relevance[i] >= rel_threshold:
                kept_set.add(cui)
            else:
                audit.append(AuditEntry(
                    cui, "", "", "", "irrelevant",
                    f"relevance {relevance[i]:.3f} < threshold {rel_threshold:.3f} | "
                    f"density {density[i]:.3f}"))

        # always keep CUIs without embeddings
        for c in without_emb:
            kept_set.add(c)

        kept = [c for c in cuis if c in kept_set]
        log(f"    Relevance: core={len(core_indices)}/{n} "
            f"(density_t={density_threshold:.3f}) | "
            f"rel_t={rel_threshold:.3f} | "
            f"kept={len(kept)}/{len(cuis)}")
        return kept, audit


#  12b- Embedding Reduction
class EmbeddingReducer:
    @staticmethod
    @timed("embedding_reduce")
    def run(cuis, metadata, embeddings, ic_map, hierarchy_edges, graph=None, ancestor_depth=3):
        type_groups = defaultdict(list)
        for cui in cuis:
            meta = metadata.get(cui)
            if meta and meta.semantic_types:
                for sty in meta.semantic_types:
                    type_groups[sty].append(cui)
            else:
                type_groups["Unknown"].append(cui)
        all_topics = {}
        globally_surviving = set()
        removal_candidates = {}
        tid = 0
        for sty in sorted(type_groups):
            group_cuis = sorted(set(type_groups[sty]))
            with_emb = [c for c in group_cuis if c in embeddings]
            without_emb = [c for c in group_cuis if c not in embeddings]
            for c in without_emb:
                globally_surviving.add(c)
            if len(with_emb) <= 1:
                all_topics[f"topic_{tid}"] = group_cuis
                for c in group_cuis:
                    globally_surviving.add(c)
                tid += 1
                continue
            scann_topics = TopicBuilder.build(with_emb, embeddings)
            sizes = sorted([len(v) for v in scann_topics.values()], reverse=True)
            log(f"      [{sty}] {len(with_emb)} CUIs -> {len(scann_topics)} topics "
                f"(max={sizes[0]}, top5={sizes[:5]})")
            for t_cuis in scann_topics.values():
                topic_id = f"topic_{tid}"
                tid += 1
                if len(t_cuis) <= 1:
                    all_topics[topic_id] = t_cuis
                    for c in t_cuis:
                        globally_surviving.add(c)
                    continue
                surviving, removed = _reduce_topic(
                    t_cuis, embeddings, metadata, ic_map, hierarchy_edges, graph, ancestor_depth)
                all_topics[topic_id] = surviving
                for c in surviving:
                    globally_surviving.add(c)
                for entry in removed:
                    removal_candidates[entry.removed_cui] = entry
            for cui in without_emb:
                all_topics[f"topic_{tid}"] = [cui]
                tid += 1
        final_audit = []
        for cui, entry in removal_candidates.items():
            if cui not in globally_surviving:
                final_audit.append(entry)
        seen = set()
        surviving = []
        for t_cuis in all_topics.values():
            for c in t_cuis:
                if c in globally_surviving and c not in seen:
                    seen.add(c)
                    surviving.append(c)
        cleaned = {}
        for topic_id, t_cuis in all_topics.items():
            members = []
            seen_t = set()
            for c in t_cuis:
                if c in globally_surviving and c not in seen_t:
                    seen_t.add(c)
                    members.append(c)
            if members:
                cleaned[topic_id] = members
        return cleaned, surviving, final_audit


def _reduce_topic(t_cuis, embeddings, metadata, ic_map, hierarchy_edges, graph=None, ancestor_depth=3):
    matrix = np.array([embeddings[c] for c in t_cuis])
    sim = matrix @ matrix.T
    np.clip(sim, -1, 1, out=sim)
    dist = 1.0 - sim
    np.fill_diagonal(dist, 0)
    dist = np.maximum(dist, 0)
    if np.any(~np.isfinite(dist)):
        dist = np.nan_to_num(dist, nan=1.0, posinf=1.0, neginf=0.0)
    n = len(t_cuis)
    idx = {c: i for i, c in enumerate(t_cuis)}
    upper = dist[np.triu_indices(n, k=1)]
    if len(upper) == 0 or np.std(upper) < 1e-9:
        return t_cuis, []
    guardrail = float(np.median(upper))
    tight_t = float(np.mean(upper) - np.std(upper))
    nonzero = upper[upper > 0]
    floor = float(np.min(nonzero)) if len(nonzero) > 0 else float(np.finfo(np.float32).eps)
    tight_t = max(tight_t, floor)
    tight_t = min(tight_t, guardrail)

    # --- FIX A: compute topic centroid, pass to _resolve_group ---
    centroid = np.mean(matrix, axis=0).astype(np.float32)
    c_norm = np.linalg.norm(centroid)
    if c_norm > 0:
        centroid = centroid / c_norm
    else:
        centroid = None

    condensed = squareform(dist, checks=False)
    Z = linkage(condensed, method="average")
    labels = fcluster(Z, t=tight_t, criterion="distance")
    r_groups = defaultdict(list)
    for cui, lbl in zip(t_cuis, labels):
        r_groups[lbl].append(cui)
    all_kept, all_removed = [], []
    for r_cuis in r_groups.values():
        kept, removed = _resolve_group(
            r_cuis, metadata, ic_map, hierarchy_edges, dist, idx,
            tight_t, guardrail, embeddings, centroid, graph, ancestor_depth)
        all_kept.extend(kept)
        all_removed.extend(removed)
    return all_kept, all_removed


# winner by centrality (IC is flat across 97% of CUIs, effectively noise)
def _resolve_group(r_cuis, metadata, ic_map, hierarchy_edges, dist, index_map,
                   tight_t, guardrail, embeddings, centroid, graph=None, ancestor_depth=3):
    if len(r_cuis) <= 1:
        return r_cuis, []

    # pick winner by centrality to topic centroid (primary signal)
    # IC used only as tiebreaker when centrality is unavailable
    def _composite(c):
        if centroid is not None and c in embeddings:
            return max(float(np.dot(embeddings[c], centroid)), 0.0)
        return ic_map.get(c, 0)

    best = max(r_cuis, key=_composite)
    b_meta = metadata.get(best)
    b_types = set(b_meta.semantic_types) if b_meta and b_meta.semantic_types else set()

    # precompute winner's ancestors for overlap guard
    best_ancestors = _get_ancestors(graph, best, ancestor_depth)

    kept = [best]
    audit = []
    for c in r_cuis:
        if c == best:
            continue
        c_meta = metadata.get(c)
        c_types = set(c_meta.semantic_types) if c_meta and c_meta.semantic_types else set()
        if c_types and b_types and not (c_types & b_types):
            kept.append(c)
            continue
        if (c, best) in hierarchy_edges or (best, c) in hierarchy_edges:
            kept.append(c)
            continue
        # ancestor overlap guard: zero overlap in 2-level ancestors = different
        # ontological branches (e.g. "gout of right foot" vs "gout of left knee")
        if best_ancestors:
            c_ancestors = _get_ancestors(graph, c, ancestor_depth)
            if c_ancestors and len(best_ancestors & c_ancestors) == 0:
                kept.append(c)
                continue
        if c_meta and b_meta and terms_diverge(c_meta.all_tokens, b_meta.all_tokens):
            kept.append(c)
            continue
        if c_meta and b_meta and qualifier_conflict(c_meta.all_tokens, b_meta.all_tokens):
            kept.append(c)
            continue
        ci = index_map.get(c)
        bi = index_map.get(best)
        pair_dist = dist[ci, bi] if ci is not None and bi is not None else 0.0
        audit.append(AuditEntry(
            removed_cui=c,
            removed_term=c_meta.preferred_term if c_meta else "",
            kept_cui=best,
            kept_term=b_meta.preferred_term if b_meta else "",
            reason="embedding_redundant",
            detail=f"dist {pair_dist:.3f} < tight {tight_t:.3f} | "
                   f"guard {guardrail:.3f}"))
    return kept, audit


#  13- Cross-Topic Dedup
class CrossTopicDedup:
    @staticmethod
    @timed("cross_topic_dedup")
    def run(surviving, embeddings, metadata, ic_map, graph=None, ancestor_depth=3):
        with_emb = [c for c in surviving if c in embeddings]
        if len(with_emb) <= 1:
            return surviving, []
        matrix = np.array([embeddings[c] for c in with_emb], dtype=np.float32)
        idx_map = {c: i for i, c in enumerate(with_emb)}

        # global centroid for tiebreaking (replaces flat IC)
        global_cent = np.mean(matrix, axis=0).astype(np.float32)
        g_norm = np.linalg.norm(global_cent)
        if g_norm > 0:
            global_cent = global_cent / g_norm

        sim = matrix @ matrix.T
        np.clip(sim, -1, 1, out=sim)
        dist = 1.0 - sim
        np.fill_diagonal(dist, 999.0)
        upper = dist[np.triu_indices(len(with_emb), k=1)]
        upper = upper[upper < 999.0]
        if len(upper) == 0:
            return surviving, []
        threshold = float(np.percentile(upper, 5))
        threshold = min(threshold, 0.05)
        removed = set()
        audit = []
        for i in range(len(with_emb)):
            if with_emb[i] in removed:
                continue
            for j in range(i + 1, len(with_emb)):
                if with_emb[j] in removed:
                    continue
                if dist[i, j] > threshold:
                    continue
                ci, cj = with_emb[i], with_emb[j]
                ci_meta = metadata.get(ci)
                cj_meta = metadata.get(cj)
                ci_tok = ci_meta.all_tokens if ci_meta else frozenset()
                cj_tok = cj_meta.all_tokens if cj_meta else frozenset()
                if qualifier_conflict(ci_tok, cj_tok):
                    continue
                if terms_diverge(ci_tok, cj_tok):
                    continue
                # ancestor overlap guard
                if graph is not None:
                    ci_anc = _get_ancestors(graph, ci, ancestor_depth)
                    cj_anc = _get_ancestors(graph, cj, ancestor_depth)
                    if ci_anc and cj_anc and len(ci_anc & cj_anc) == 0:
                        continue
                # tiebreak by centrality to global centroid (IC is flat)
                ci_cent = float(np.dot(embeddings[ci], global_cent))
                cj_cent = float(np.dot(embeddings[cj], global_cent))
                if ci_cent >= cj_cent:
                    keep, drop = ci, cj
                else:
                    keep, drop = cj, ci
                removed.add(drop)
                km = metadata.get(keep)
                dm = metadata.get(drop)
                audit.append(AuditEntry(
                    removed_cui=drop,
                    removed_term=dm.preferred_term if dm else "",
                    kept_cui=keep,
                    kept_term=km.preferred_term if km else "",
                    reason="cross_topic_dedup",
                    detail=f"dist {dist[idx_map[keep], idx_map[drop]]:.4f} "
                           f"< threshold {threshold:.4f}"))
        final = [c for c in surviving if c not in removed]
        return final, audit


#  14- Confidence Scorer
class ConfidenceScorer:
    """Scores each surviving CUI by 3 structural signals.

    IC is flat across 97% of UMLS leaf nodes (all = 14.8), so centrality
    and retention carry the signal. IC kept as minor tiebreaker.

    confidence = 0.15 * normalized_IC          (tiebreaker when available)
               + 0.55 * embedding_centrality   (cosine to own topic centroid)
               + 0.30 * retention_power        (log-scaled absorbed CUI count)
    """

    @staticmethod
    @timed("confidence_score")
    def score(surviving, metadata, ic_map, audit_trail,
              embeddings, cui_topic, topic_centroids):
        explains = defaultdict(list)
        for entry in audit_trail:
            if entry.kept_cui and entry.removed_cui:
                explains[entry.kept_cui].append(entry.removed_cui)

        ics = [ic_map.get(c, 0) for c in surviving]
        ic_min = min(ics) if ics else 0
        ic_max = max(ics) if ics else 1
        ic_range = ic_max - ic_min if ic_max > ic_min else 1.0

        max_retained = max((len(v) for v in explains.values()), default=0)

        entries = []
        retention_map = {}
        for cui in surviving:
            m = metadata.get(cui)
            ic = ic_map.get(cui, 0)
            retained = explains.get(cui, [])
            retention_map[cui] = retained

            norm_ic = (ic - ic_min) / ic_range

            topic_id = cui_topic.get(cui)
            centroid = topic_centroids.get(topic_id) if topic_id else None
            if centroid is not None and cui in embeddings:
                centrality = max(float(np.dot(embeddings[cui], centroid)), 0.0)
            else:
                centrality = 0.0

            if max_retained > 0:
                retention_power = np.log1p(len(retained)) / np.log1p(max_retained)
            else:
                retention_power = 0.0

            confidence = (0.15 * norm_ic
                        + 0.55 * centrality
                        + 0.30 * retention_power)

            entries.append(ConfidenceEntry(
                cui=cui, term=m.preferred_term if m else cui,
                confidence=round(confidence, 4),
                ic_norm=round(norm_ic, 3),
                centrality=round(centrality, 3),
                retention_power=round(retention_power, 3),
                semantic_types=list(m.semantic_types) if m else [],
                explains_cuis=retained))

        entries.sort(key=lambda e: e.confidence, reverse=True)
        sorted_cuis = [e.cui for e in entries]
        return sorted_cuis, entries, retention_map


#  15- Pipeline
class CUIReductionSystem:
    def __init__(self, project_id, dataset_id, full_network,
                 allowed_sabs, embedding_table,
                 excluded_semantic_types=None, ic_scores=None,
                 cache_dir=None):
        self.bq = bigquery.Client(project=project_id)
        self.cache_dir = cache_dir
        self.fetcher = MetadataFetcher(self.bq, project_id, dataset_id, cache_dir=cache_dir)
        self.ic_computer = ICComputer(full_network, ic_scores)
        self.sab_filter = SABFilter(allowed_sabs)
        self.semtype_filter = SemanticTypeFilter(excluded_semantic_types or set())
        self.hierarchy_reducer = HierarchyReducer(full_network)
        self.emb_fetcher = EmbeddingFetcher(
            self.bq, project_id, dataset_id, embedding_table, cache_dir=cache_dir)

    @timed("full_pipeline")
    def reduce(self, cuis, context_string):
        results = self.reduce_batch([(cuis, context_string)])
        return results[0]

    @timed("batch_pipeline")
    def reduce_batch(self, inputs):
        t0 = time.perf_counter()
        all_cuis = set()
        for cuis, _ in inputs:
            all_cuis.update(cuis)
        log(f"[Batch] {len(inputs)} texts, {len(all_cuis)} unique CUIs")

        metadata = self.fetcher.fetch(list(all_cuis))
        log(f"[Batch] Metadata: {len(metadata)}/{len(all_cuis)} matched")

        ic_map = self.ic_computer.compute(list(all_cuis), metadata)
        log(f"[Batch] IC Scores: {len(ic_map)} computed")
        ancestor_depth = _compute_ancestor_depth(self.hierarchy_reducer.graph)
        log(f"[Batch] Ancestor depth: {ancestor_depth} (mean_in_degree={np.mean([d for _, d in self.hierarchy_reducer.graph.in_degree()]):.2f})")

        # first pass: run filters + hierarchy (no embeddings needed)
        per_text = []
        all_post_hier = set()
        for cuis, context_string in inputs:
            if not cuis:
                per_text.append((context_string, [], [], set(), []))
                continue
            label = context_string[:50]
            log(f"\n  [{label}]")
            after_sab, sab_audit = self.sab_filter.run(cuis, metadata)
            log(f"    SAB Filter: {len(cuis)} -> {len(after_sab)} (removed {len(cuis) - len(after_sab)})")
            after_sty, sty_audit = self.semtype_filter.run(after_sab, metadata)
            log(f"    Semtype Filter: {len(after_sab)} -> {len(after_sty)} (removed {len(after_sab) - len(after_sty)})")
            after_term, term_audit = TermDeduplicator.run(after_sty, metadata, ic_map)
            log(f"    Term Dedup: {len(after_sty)} -> {len(after_term)} (removed {len(after_sty) - len(after_term)})")
            after_hier, hier_audit, hier_edges = self.hierarchy_reducer.run(after_term, ic_map, metadata)
            log(f"    Hierarchy: {len(after_term)} -> {len(after_hier)} (removed {len(after_term) - len(after_hier)})")
            audit = sab_audit + sty_audit + term_audit + hier_audit
            all_post_hier.update(after_hier)
            per_text.append((context_string, cuis, after_hier, hier_edges, audit))

        # fetch embeddings only for post-hierarchy survivors
        log(f"\n[Batch] Fetching embeddings for {len(all_post_hier)} post-hierarchy CUIs "
            f"(skipped {len(all_cuis) - len(all_post_hier)})")
        all_embeddings = self.emb_fetcher.fetch(list(all_post_hier))

        # second pass: embedding-based stages
        results = []
        for context_string, cuis, after_hier, hier_edges, all_audit in per_text:
            t_start = time.perf_counter()
            if not after_hier:
                results.append(self._empty(context_string, t_start, all_audit))
                continue
            embeddings = {c: all_embeddings[c] for c in after_hier if c in all_embeddings}
            emb_cov = len(embeddings) / len(after_hier) if after_hier else 0

            # relevance filter: density-based core detection
            after_rel, rel_audit = RelevanceFilter.run(after_hier, embeddings)
            all_audit.extend(rel_audit)
            if len(after_rel) < len(after_hier):
                log(f"    Relevance Filter: {len(after_hier)} -> {len(after_rel)} (removed {len(after_hier) - len(after_rel)})")
                # narrow embeddings to relevant CUIs only
                embeddings = {c: embeddings[c] for c in after_rel if c in embeddings}

            topics, surviving, emb_audit = EmbeddingReducer.run(
                after_rel, metadata, embeddings, ic_map, hier_edges,
                self.hierarchy_reducer.graph, ancestor_depth)
            all_audit.extend(emb_audit)
            log(f"    Embedding Reduction: {len(after_rel)} -> {len(surviving)} (removed {len(after_rel) - len(surviving)})")
            topics_out = {}
            for topic_id, t_cuis in topics.items():
                if not t_cuis:
                    continue
                topic_types = set()
                cui_terms = {}
                for c in t_cuis:
                    m = metadata.get(c)
                    if m and m.semantic_types:
                        topic_types.update(m.semantic_types)
                    cui_terms[c] = m.preferred_term if m else c
                topics_out[topic_id] = TopicInfo(
                    topic_id=topic_id, semantic_types=topic_types or {"Unknown"},
                    cuis=t_cuis, cui_terms=cui_terms)
            log(f"    Topics: {len(surviving)} CUIs -> {len(topics_out)} topics")
            before_xtd = len(surviving)
            surviving, xtd_audit = CrossTopicDedup.run(
                surviving, embeddings, metadata, ic_map,
                self.hierarchy_reducer.graph, ancestor_depth)
            all_audit.extend(xtd_audit)
            if xtd_audit:
                log(f"    Cross-Topic Dedup: {before_xtd} -> {len(surviving)} (removed {before_xtd - len(surviving)})")

            # compute topic centroids for confidence scorer
            cui_topic = {}
            for topic_id, topic in topics_out.items():
                for c in topic.cuis:
                    cui_topic[c] = topic_id
            topic_centroids = {}
            for topic_id, topic in topics_out.items():
                vecs = [embeddings[c] for c in topic.cuis if c in embeddings]
                if vecs:
                    cent = np.mean(vecs, axis=0).astype(np.float32)
                    norm = np.linalg.norm(cent)
                    if norm > 0:
                        cent = cent / norm
                    topic_centroids[topic_id] = cent

            sorted_cuis, confidence, retention_map = ConfidenceScorer.score(
                surviving, metadata, ic_map, all_audit,
                embeddings, cui_topic, topic_centroids)

            # --- FIX B: Otsu filter on confidence — actually drop low-confidence CUIs ---
            before_conf = len(sorted_cuis)
            if len(confidence) > 2:
                conf_vals = np.array([e.confidence for e in confidence])
                if np.std(conf_vals) > 1e-6:
                    conf_threshold = _otsu_threshold(conf_vals)
                    kept_entries = [e for e in confidence if e.confidence >= conf_threshold]
                    if kept_entries:
                        confidence = kept_entries
                        sorted_cuis = [e.cui for e in confidence]
                        surviving = sorted_cuis
                        # audit dropped CUIs
                        dropped = set(retention_map.keys()) - set(sorted_cuis)
                        for cui in dropped:
                            m = metadata.get(cui)
                            all_audit.append(AuditEntry(
                                cui, m.preferred_term if m else "",
                                "", "", "low_confidence",
                                f"conf below Otsu threshold {conf_threshold:.3f}"))
                        log(f"    Confidence filter: {before_conf} -> {len(sorted_cuis)} "
                            f"(Otsu threshold={conf_threshold:.3f})")
            # --- END FIX B ---

            final_set = set(sorted_cuis)
            before_prune = len(topics_out)
            pruned_topics = {}
            for topic_id, topic in topics_out.items():
                kept_cuis = [c for c in topic.cuis if c in final_set]
                if not kept_cuis:
                    continue
                kept_terms = {c: topic.cui_terms[c] for c in kept_cuis if c in topic.cui_terms}
                pruned_topics[topic_id] = TopicInfo(
                    topic_id=topic_id, semantic_types=topic.semantic_types,
                    cuis=kept_cuis, cui_terms=kept_terms)
            topics_out = pruned_topics
            log(f"    Topics after pruning: {len(topics_out)} (dropped {before_prune - len(topics_out)} empty)")
            audited = {e.removed_cui for e in all_audit}
            survived = set(surviving)
            unaccounted = set(cuis) - survived - audited
            if unaccounted:
                for cui in unaccounted:
                    m = metadata.get(cui)
                    all_audit.append(AuditEntry(
                        cui, m.preferred_term if m else "", "", "", "unaccounted",
                        "CUI not in surviving or audit trail"))
            elapsed = (time.perf_counter() - t_start) * 1000
            log(f"    Final: {len(cuis)} -> {len(surviving)} CUIs, {len(topics_out)} topics ({elapsed:.0f}ms)")
            results.append(ReductionResult(
                context_string=context_string,
                input_count=len(cuis),
                after_filter_count=len(after_hier),
                after_hierarchy_count=len(after_hier),
                after_redundancy_count=len(surviving),
                topics=topics_out,
                all_reduced_cuis=sorted_cuis,
                confidence=confidence,
                retention_map=retention_map,
                audit_trail=all_audit,
                processing_time_ms=elapsed,
                embedding_coverage=emb_cov))
        total = (time.perf_counter() - t0) * 1000
        self._flush_caches()
        return results

    def _flush_caches(self):
        """Persist all caches to disk."""
        self.fetcher._cache.flush()
        self.emb_fetcher._cache.flush()

    def _empty(self, ctx, t0, audit=None):
        return ReductionResult(
            ctx, 0, 0, 0, 0, {}, [], [], {},
            audit or [], (time.perf_counter() - t0) * 1000, 0.0)

    def get_stats(self):
        with _timing_lock:
            out = {}
            for k, v in _timings.items():
                if v:
                    vals = list(v)
                    out[k] = {"count": len(vals), "mean_ms": float(np.mean(vals)),
                              "p99_ms": float(np.percentile(vals, 99))}
            return out


#  16- CUI Extraction(API)
class CUIExtractor:
    def __init__(self, api_url, min_confidence=0.0, top_k=3, cache_dir=None):
        self.url = api_url
        self.min_confidence = min_confidence
        self.top_k = top_k
        path = os.path.join(cache_dir, "extraction_cache.pkl") if cache_dir else None
        self._cache = Cache(10_000, persist_path=path)
        self.session = requests.Session()
        try:
            token = subprocess.run(
                ["gcloud", "auth", "print-identity-token"],
                stdout=subprocess.PIPE, universal_newlines=True,
                timeout=30).stdout.strip()
            self.headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}
        except Exception:
            self.headers = {"Content-Type": "application/json"}
        from requests.adapters import HTTPAdapter
        from urllib3.util.retry import Retry
        retry = Retry(total=3, backoff_factor=1, status_forcelist=[429, 500, 502, 503, 504])
        self.session.mount("https://", HTTPAdapter(max_retries=retry))

    @timed("cui_extraction")
    def extract(self, text):
        # cache key: text + top_k (different top_k = different results)
        cache_key = f"{text}||{self.top_k}"
        cached = self._cache.get(cache_key)
        if cached is not None:
            log(f"    Extraction: {len(cached)} unique CUIs (cached)")
            return cached

        resp = self.session.post(
            self.url, headers=self.headers,
            json={"query_texts": [text], "top_k": self.top_k}, timeout=200)
        resp.raise_for_status()
        data = resp.json()
        cuis = []
        scores_map = {}
        if isinstance(data, dict):
            for val in data.values():
                if not isinstance(val, list):
                    continue
                for item in val:
                    if isinstance(item, dict) and "cui" in item:
                        raw_score = item.get("score", item.get("confidence", 1.0))
                        try:
                            score = float(raw_score)
                        except (ValueError, TypeError):
                            score = 0.0
                        if score >= self.min_confidence:
                            c = str(item["cui"])
                            cuis.append(c)
                            scores_map[c] = score
                    elif isinstance(item, str) and item.strip():
                        cuis.append(item.strip())
        unique = list(set(cuis))
        if scores_map:
            score_vals = list(scores_map.values())
            log(f"    Extraction: {len(unique)} unique CUIs | "
                f"score range [{min(score_vals):.3f}, {max(score_vals):.3f}] | "
                f"mean={np.mean(score_vals):.3f}")
        else:
            log(f"    Extraction: {len(unique)} unique CUIs (no scores)")
        self._cache.put(cache_key, unique)
        return unique


