def gcp_update_header():
    """Updates the global headers with GCP identity token."""
    global headers
    tmp = subprocess.run(
        [GCP_PROJ, 'auth', 'print-identity-token'],
        stdout=subprocess.PIPE,
        universal_newlines=True
    )
    if tmp.returncode == 1:
        raise Exception("❌ Cannot get GCP access token")

    identity_token = str(tmp.stdout).strip()
    headers = {
        "Authorization": f"Bearer {identity_token}",
        "Content-Type": "application/json"
    }

