if __name__ == "__main__":
    # text_list and context_list must be parallel arrays (same length)
    # text_list  = clinical phrases extracted from the patient narrative
    # context_list = the full context repeated for each phrase

    context = "Patient presented with left knee pain and swelling for the past three days. Pain worsens with weight bearing and climbing stairs. No history of trauma. Mild effusion noted on examination."

    text_list = [
        "left knee pain",
        "swelling",
        "weight bearing pain",
        "climbing stairs difficulty",
        "knee effusion",
    ]
    context_list = [context] * len(text_list)

    log(f"\n[Extract] {len(text_list)} phrases, context='{context[:60]}...'")
    for t in text_list:
        log(f"          - '{t}'")
    assert len(text_list) == len(context_list), \
        f"text_list ({len(text_list)}) and context_list ({len(context_list)}) must be same length"

    # one API call returns per-phrase CUIs: { phrase: { cui: distance } }
    per_phrase = extractor.extract(text_list, context_list)

    # each phrase runs through the pipeline separately with its own distances
    inputs = []
    for phrase, cui_dists in per_phrase.items():
        cuis = list(cui_dists.keys())
        inputs.append((cuis, phrase, cui_dists))

    results = system.reduce_batch(inputs)
    extractor._cache.flush()

    # per-phrase output
    for result in results:
        log(f"\n{'=' * 70}")
        log(f"PHRASE: '{result.context_string}'")
        log(f"  {result.input_count} -> SAB:{result.after_filter_count} -> "
            f"Hier:{result.after_hierarchy_count} -> Final:{result.after_redundancy_count} CUIs, "
            f"{len(result.topics)} topics ({result.processing_time_ms:.0f}ms)")

        log(f"\n  -- CUIs ranked by confidence --")
        for entry in result.confidence[:20]:
            explains_n = len(entry.explains_cuis)
            explains_str = f" | explains {explains_n}" if explains_n > 0 else ""
            line = (f"    {entry.cui} | conf={entry.confidence:.3f} "
                    f"prox={entry.extraction_proximity:.3f} "
                    f"cent={entry.centrality:.3f} ret={entry.retention_power:.3f} | "
                    f"{entry.term}{explains_str}")
            log(line)
        if len(result.confidence) > 20:
            log(f"    ... {len(result.confidence) - 20} more")

        # top 5 topics by member count
        sorted_topics = sorted(result.topics.items(),
                               key=lambda t: len(t[1].cuis), reverse=True)
        log(f"\n  -- Top 5 topics (of {len(result.topics)}) --")
        for topic_id, topic in sorted_topics[:5]:
            stypes = ", ".join(sorted(topic.semantic_types)[:3])
            cui_list = ", ".join(f"{c} ({topic.cui_terms.get(c, c)})"
                                for c in topic.cuis[:5])
            more = f" +{len(topic.cuis) - 5} more" if len(topic.cuis) > 5 else ""
            log(f"    {topic_id} ({len(topic.cuis)} CUIs) [{stypes}]")
            log(f"      {cui_list}{more}")
