#  [11] Louvain Topic Builder (Replaces ScaNN connected components)

class TopicBuilder:
    @staticmethod
    @timed("louvain_topics")
    def build(cuis, embeddings, k_neighbors=20):
        """
        Build topic communities using Louvain on cosine similarity graph.
        This replaces ScaNN connected-components clustering.
        """

        cuis = sorted(cuis)
        n = len(cuis)

        if n <= 1:
            return {0: cuis}

        # Build embedding matrix
        matrix = np.array([embeddings[c] for c in cuis], dtype=np.float32)

        # Cosine similarity (embeddings already normalized)
        sim = matrix @ matrix.T
        np.clip(sim, -1, 1, out=sim)

        # Build weighted graph
        G = nx.Graph()
        for i in range(n):
            G.add_node(i)

        # Use k-nearest neighbors to sparsify graph
        k = min(k_neighbors, n - 1)

        for i in range(n):
            sims = sim[i]
            nn_idx = np.argsort(-sims)[1:k+1]  # skip self (index 0)
            for j in nn_idx:
                weight = float(sims[j])
                if weight > 0:  # only positive similarity edges
                    G.add_edge(i, j, weight=weight)

        # Run Louvain community detection
        communities = nx.community.louvain_communities(
            G,
            weight="weight",
            seed=42
        )

        # Convert to CUI groups
        groups = {}
        for label, comm in enumerate(communities):
            groups[label] = [cuis[i] for i in comm]

        return groups
