_FAST_PATH_THRESHOLD, _CROSS_TOPIC_DEDUP_MIN = 200, 200
# Minimum CUI count for Louvain to produce meaningful communities.
# Below this threshold the k-NN graph is near-fully-connected (k gets
# capped at n-1) and Louvain produces arbitrary communities driven by
# tie-breaking rather than semantic structure. For small sets, pass
# surviving CUIs directly — HierarchicalTopicBuilder handles them correctly.
# Value = k_neighbors default (20): need more concepts than neighbours
# for the graph to have meaningful sparse structure.
_LOUVAIN_MIN_CUIS = 20
_ANCESTOR_TARGET, _ANCESTOR_DEPTH_CLAMP = 20, (1, 5)
_COMPONENT_DEPTH_RATIO, _COMP_DEPTH_MEAN_THRESHOLD = 0.4, 1.5
_DEFAULT_ANCESTOR_DEPTH = 3
_XTD_KNN_K, _LOUVAIN_SPLIT_RESOLUTION = 10, 2.0
_COSINE_FALLBACK_THRESHOLD = 0.5
# _SINGLETON_MERGE_MIN_SIM: formerly 0.3; now derived at runtime from
#   mean(within_group_cosine_similarities) × 0.5 in TopicBuilder.build()
# _HT_MAX_COVERAGE: formerly 0.6; now derived at runtime as sqrt(N)/N
#   in HierarchicalTopicBuilder.build()
_SILHOUETTE_GAP_RATIO      = 2.0   # largest gap must be > this × median gap to act
_SILHOUETTE_MAX_ITER        = 5     # safety cap on re-split loop iterations
_SILHOUETTE_MIN_COMM_SIZE   = 2     # never attempt to split communities smaller than this
_REP_HAC_THRESHOLD = 0.5
_ANCHOR_IC_MIN, _ANCHOR_BFS_DEPTH, _ANCHOR_IC_MAX_BROAD = 4.0, 4, 3.0
_EVAL_AGGRESSIVE_RATIO, _EVAL_MINIMAL_RATIO = 0.95, 0.10
_EVAL_COMPRESSED_SPREAD, _EVAL_SEPARATION_MIN = 0.1, 0.05
_EVAL_SUSPECT_DIST, _EVAL_RECON_DEPTH = 0.3, 3
# HierarchicalTopicBuilder BFS controls (Stage 6)
# _HTB_IC_GRADIENT_RATIO: at hops 3+, a parent is only followed if
#   IC(parent) >= this ratio × IC(current node). Prevents BFS from
#   entering very broad territory when the IC gradient drops sharply.
#   0.3 means: stop following a parent that has less than 30% of the
#   current node's IC. Set conservatively — 2-hop grace period already
#   ensures direct parents are always included.
_HTB_IC_GRADIENT_RATIO = 0.3
# _HTB_IC_FLOOR_PERCENTILE: used to derive the absolute IC floor for
#   convergence point candidates from the p10 of surviving CUI ICs.
#   Ancestors with IC below this floor are never selected as grouping
#   anchors even if the gradient check would pass.
_HTB_IC_FLOOR_PERCENTILE = 10
_RETRY_TOTAL, _RETRY_BACKOFF = 3, 1
