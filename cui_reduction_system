# ── Clinical context — output of ClinicalContextParser ───────────────────────
# Plain dataclass carrying the four clinical context boolean attributes.
# No hardcoded category names, no enum, no priority dict.
# The booleans are set by ClinicalContextParser using medspacy ConText.

@dataclass
class ClinicalContext:
    """Negation and temporal context for a clinical phrase.

    All fields are set by ClinicalContextParser via medspacy ConText.
    Default (all False) = current, present, not negated.
    """
    negated:      bool = False
    historical:   bool = False
    hypothetical: bool = False
    family:       bool = False

    def is_current(self) -> bool:
        """True if the finding is present and not negated."""
        return not self.negated and not self.historical \
               and not self.hypothetical and not self.family

    @classmethod
    def from_dict(cls, d: dict) -> "ClinicalContext":
        """Restore from a stored dict (e.g. from pickle backfill)."""
        if d is None:
            return cls()
        if isinstance(d, cls):
            return d
        legacy = str(d).lower()
        return cls(
            historical   = legacy in ("historical",),
            hypothetical = legacy in ("hypothetical",),
            family       = legacy in ("family",),
            negated      = False,
        )


