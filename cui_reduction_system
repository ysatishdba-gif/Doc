class MetadataFetcher:
    def __init__(self, bq, pid, did, cache_dir=None):
        self.bq = bq
        self.pid = pid
        self.did = did
        path = os.path.join(cache_dir, "metadata_cache.pkl") if cache_dir else None
        self._cache = Cache(_CACHE_METADATA, persist_path=path)

    @timed("metadata_fetch")
    def fetch(self, cuis):
        result = {}
        missing = []
        for c in cuis:
            cached = self._cache.get(c)
            if cached is not None:
                result[c] = cached
            else:
                missing.append(c)
        if not missing:
            return result
        for i in range(0, len(missing), _BQ_BATCH):
            batch = missing[i:i + _BQ_BATCH]
            query = f"""
            SELECT
              c.CUI AS cui,
              ARRAY_AGG(DISTINCT s.TUI IGNORE NULLS) AS tuis,
              ARRAY_AGG(DISTINCT s.STY IGNORE NULLS) AS stys,
              ARRAY_AGG(DISTINCT c.SAB IGNORE NULLS) AS sabs
            FROM `{self.pid}.{self.did}.MRCONSO` c
            LEFT JOIN `{self.pid}.{self.did}.MRSTY` s ON c.CUI = s.CUI
            WHERE c.CUI IN UNNEST(@cuis) AND c.LAT = 'ENG'
            GROUP BY c.CUI
            """
            jc = bigquery.QueryJobConfig(query_parameters=[
                bigquery.ArrayQueryParameter("cuis", "STRING", batch)])
            for row in self.bq.query(query, job_config=jc, timeout=_BQ_TIMEOUT).result():
                meta = CUIMetadata(
                    cui=row.cui,
                    semantic_types=list(row.stys or []),
                    semantic_type_ids=list(row.tuis or []),
                    ic_score=0.0, source_vocabs=list(row.sabs or []))
                self._cache.put(row.cui, meta)
                result[row.cui] = meta
        return result

class ICComputer:
    def __init__(self, graph, precomputed=None):
        self.graph = graph
        self.precomputed = precomputed or {}
        self._cache = Cache(_CACHE_IC)
        self._total = max(graph.number_of_nodes(), 1)

    @timed("ic_compute")
    def compute(self, cuis, metadata):
        result = {}
        for cui in cuis:
            if cui in self.precomputed:
                ic = self.precomputed[cui]
            else:
                cached = self._cache.get(cui)
                if cached is not None:
                    ic = cached
                else:
                    desc = self._count_descendants(cui)
                    ic = -np.log((desc + 1) / self._total)
                    self._cache.put(cui, ic)
            result[cui] = ic
            m = metadata.get(cui)
            if m:
                m.ic_score = ic
        return result

    def _count_descendants(self, cui):
        if not self.graph.has_node(cui):
            return 0
        visited = set()
        q = deque([cui])
        while q:
            n = q.popleft()
            for child in self.graph.successors(n):
                if child not in visited:
                    visited.add(child)
                    q.append(child)
        return len(visited)

class SABFilter:
    def __init__(self, allowed):
        self.allowed = set(allowed)

    @timed("sab_filter")
    def run(self, cuis, metadata):
        kept, audit = [], []
        for cui in cuis:
            m = metadata.get(cui)
            if not m:
                audit.append(AuditEntry(cui, "", "no_metadata", "CUI not found in BQ"))
                continue
            if not any(s in self.allowed for s in m.source_vocabs):
                audit.append(AuditEntry(cui, "", "sab_filtered",
                    f"vocabs {m.source_vocabs} not in allowed"))
                continue
            kept.append(cui)
        return kept, audit

class HierarchyReducer:
    def __init__(self, graph):
        self.graph = graph

    @timed("hierarchy_reduce")
    def run(self, cuis, ic_map, metadata):
        cui_set = set(cuis)
        edges = set()
        parent_children = defaultdict(set)
        for cui in cuis:
            if not self.graph.has_node(cui):
                continue
            for parent in self.graph.predecessors(cui):
                if parent in cui_set and parent != cui:
                    parent_children[parent].add(cui)
                    edges.add((parent, cui))
        to_remove = {}
        for parent, children in parent_children.items():
            p_ic = ic_map.get(parent, 0)
            p_meta = metadata.get(parent)
            p_types = set(p_meta.semantic_types) if p_meta and p_meta.semantic_types else set()
            for child in children:
                c_ic = ic_map.get(child, 0)
                if c_ic < p_ic:
                    continue
                c_meta = metadata.get(child)
                c_types = set(c_meta.semantic_types) if c_meta and c_meta.semantic_types else set()
                if p_types and c_types and not (p_types & c_types):
                    continue
                if parent not in to_remove or c_ic > to_remove[parent][1]:
                    to_remove[parent] = (child, c_ic, p_ic)
        remove_set = set(to_remove.keys())
        surviving = [c for c in cuis if c not in remove_set]
        audit = []
        for parent, (child, c_ic, p_ic) in to_remove.items():
            audit.append(AuditEntry(
                parent, child,
                "ancestor_subsumed", f"child IC {c_ic:.2f} >= parent IC {p_ic:.2f}"))
        return surviving, audit, edges

class EmbeddingFetcher:
    def __init__(self, bq, pid, did, embedding_table, cache_dir=None):
        self.bq = bq
        self.pid = pid
        self.did = did
        self.table = embedding_table
        path = os.path.join(cache_dir, "embedding_cache.pkl") if cache_dir else None
        self._cache = Cache(_CACHE_EMBEDDING, persist_path=path)
        self._pool = ThreadPoolExecutor(max_workers=_EMB_FETCH_WORKERS)

    def _fetch_batch(self, batch):
        rows = []
        query = f"""
        SELECT cui, embedding
        FROM `{self.pid}.{self.did}.{self.table}`
        WHERE cui IN UNNEST(@cuis)
        """
        jc = bigquery.QueryJobConfig(query_parameters=[
            bigquery.ArrayQueryParameter("cuis", "STRING", batch)])
        for row in self.bq.query(query, job_config=jc, timeout=_BQ_TIMEOUT).result():
            raw = row.embedding
            if raw is None or len(raw) == 0:
                continue
            vec = np.array(raw, dtype=np.float32)
            if not np.all(np.isfinite(vec)):
                continue
            norm = np.linalg.norm(vec)
            if norm == 0:
                continue
            vec = vec / norm
            rows.append((row.cui, vec))
        return rows

    @timed("embedding_fetch")
    def fetch(self, cuis):
        result, missing = {}, []
        for c in cuis:
            cached = self._cache.get(c)
            if cached is not None:
                result[c] = cached
            else:
                missing.append(c)
        if not missing:
            return result
        batches = [missing[i:i + _BQ_BATCH] for i in range(0, len(missing), _BQ_BATCH)]
        futures = [self._pool.submit(self._fetch_batch, b) for b in batches]
        for f in futures:
            for cui, vec in f.result():
                self._cache.put(cui, vec)
                result[cui] = vec
        fetched = len(result) - (len(cuis) - len(missing))  # newly fetched count
        coverage = len(result) / len(cuis) * 100 if cuis else 0
        dim = next(iter(result.values())).shape[0] if result else 0
        log(f"    Embeddings: {len(result)}/{len(cuis)} ({coverage:.1f}%) | "
            f"dim={dim} | cache_hits={len(cuis)-len(missing)} | fetched={fetched}", level="DEBUG")
        return result

def _cosine_knn(matrix, k):
    """k-NN via cosine similarity. Input: L2-normalized (N,D) array. Returns (neighbors, scores)."""
    n, k = matrix.shape[0], min(k, matrix.shape[0] - 1)
    if k < 1:
        return np.zeros((n, 0), dtype=int), np.zeros((n, 0), dtype=np.float32)
    neighbors, sim_scores = np.zeros((n, k), dtype=int), np.zeros((n, k), dtype=np.float32)
    for start in range(0, n, _KNN_BLOCK_SIZE):
        end = min(start + _KNN_BLOCK_SIZE, n)
        sims = matrix[start:end] @ matrix.T
        for i in range(start, end):
            sims[i - start, i] = -np.inf
        top_k_idx = np.argpartition(-sims, k, axis=1)[:, :k]
        # vectorized gather + sort within each row's top-k
        block_size = end - start
        row_idx = np.arange(block_size)[:, None]
        top_k_sims = sims[row_idx, top_k_idx]
        order = np.argsort(-top_k_sims, axis=1)
        row_idx_flat = np.arange(block_size)[:, None]
        neighbors[start:end] = top_k_idx[row_idx_flat, order]
        sim_scores[start:end] = top_k_sims[row_idx_flat, order]
    return neighbors, sim_scores

class TopicBuilder:
    @staticmethod
    @timed("cosine_topics")
    def build(cuis, embeddings, k_neighbors=20):
        cuis = sorted(cuis)
        np.random.seed(_RANDOM_SEED)
        matrix = np.array([embeddings[c] for c in cuis], dtype=np.float32)
        n = len(cuis)
        dim = matrix.shape[1] if matrix.ndim == 2 else 0
        if n < 2 or dim == 0:
            return {i: [c] for i, c in enumerate(cuis)}
        k = min(k_neighbors, n - 1)
        k = max(k, 1)

        neighbors, sim_scores = _cosine_knn(matrix, k)

        kth_dists = []
        for i in range(n):
            valid = sim_scores[i][sim_scores[i] > -1e30]
            if len(valid) > 0:
                kth_dists.append(1.0 - float(valid[-1]))
        if kth_dists:
            threshold = float(np.mean(kth_dists))
        else:
            all_sims = matrix @ matrix.T
            np.fill_diagonal(all_sims, -np.inf)
            valid_sims = all_sims[all_sims > -np.inf]
            if len(valid_sims) > 0:
                threshold = float(1.0 - np.mean(valid_sims))
            else:
                threshold = _COSINE_FALLBACK_THRESHOLD

        G = networkx.Graph()
        G.add_nodes_from(range(n))
        for i in range(n):
            for j_pos in range(len(neighbors[i])):
                j = int(neighbors[i][j_pos])
                if j < 0 or j >= n or j == i:
                    continue
                dist = 1.0 - float(sim_scores[i][j_pos])
                if dist < threshold:
                    weight = 1.0 - dist
                    if G.has_edge(i, j):
                        G[i][j]["weight"] = max(G[i][j]["weight"], weight)
                    else:
                        G.add_edge(i, j, weight=weight)

        communities = networkx.community.louvain_communities(G, weight="weight", seed=_RANDOM_SEED)

        max_size = max(2, int(np.sqrt(n)))
        final_communities = []
        queue = list(communities)
        while queue:
            comm = queue.pop(0)
            if len(comm) <= max_size:
                final_communities.append(comm)
                continue
            # build subgraph and re-run at higher resolution
            subG = G.subgraph(comm).copy()
            if subG.number_of_edges() == 0:
                final_communities.append(comm)
                continue
            sub_comms = networkx.community.louvain_communities(
                subG, weight="weight", seed=_RANDOM_SEED, resolution=_LOUVAIN_SPLIT_RESOLUTION)
            if len(sub_comms) <= 1:
                final_communities.append(comm)
            else:
                queue.extend(sub_comms)

        idx_map = {c: i for i, c in enumerate(cuis)}
        groups = {}
        label = 0
        singleton_indices = []
        for comm in final_communities:
            members = [cuis[i] for i in comm]
            if len(members) == 1:
                singleton_indices.append(comm.pop() if isinstance(comm, set) else list(comm)[0])
            else:
                groups[label] = members
                label += 1

        if singleton_indices and groups:
            group_centroids = {}
            for gid, members in groups.items():
                vecs = [matrix[idx_map[c]] for c in members if c in idx_map]
                if vecs:
                    cent = np.mean(vecs, axis=0)
                    norm = np.linalg.norm(cent)
                    group_centroids[gid] = cent / norm if norm > 0 else cent
            for si in singleton_indices:
                vec = matrix[si]
                best_gid = max(group_centroids,
                               key=lambda g: float(np.dot(vec, group_centroids[g])))
                best_sim = float(np.dot(vec, group_centroids[best_gid]))
                if best_sim >= _SINGLETON_MERGE_MIN_SIM:
                    groups[best_gid].append(cuis[si])
                else:
                    # too dissimilar — keep as own topic
                    groups[label] = [cuis[si]]
                    label += 1
        elif singleton_indices:
            for si in singleton_indices:
                groups[label] = [cuis[si]]
                label += 1

        return groups

class GraphComponentBuilder:
    """Finds connected semantic components using shallow UMLS ancestry.
    Hub ancestors excluded by out-degree (Otsu) and frequency (>sqrt(N)).
    """

    @staticmethod
    @timed("graph_components")
    def build(cuis, graph, ancestor_depth=2):
        if graph is None or len(cuis) < 2:
            return {0: list(cuis)}

        cui_set = set(cuis)
        n = len(cuis)

        cui_ancestors = {}
        all_ancestors = defaultdict(int)
        for c in cuis:
            anc = _get_ancestors(graph, c, ancestor_depth)
            cui_ancestors[c] = anc
            for a in anc:
                all_ancestors[a] += 1

        ancestor_degrees = {}
        for a in all_ancestors:
            if graph.has_node(a):
                ancestor_degrees[a] = graph.out_degree(a)
        hub_ancestors = set()
        if ancestor_degrees:
            deg_vals = np.array(list(ancestor_degrees.values()), dtype=np.float32)
            if np.max(deg_vals) > np.min(deg_vals):
                hub_threshold = _otsu_threshold(deg_vals)
                hub_ancestors.update(a for a, d in ancestor_degrees.items()
                                     if d > hub_threshold)

        freq_threshold = max(2, int(np.sqrt(n)))
        freq_hubs = {a for a, count in all_ancestors.items() if count > freq_threshold}
        hub_ancestors.update(freq_hubs)

        log(f"      Component hub exclusion: {len(hub_ancestors)} ancestors "
            f"(degree={len(hub_ancestors - freq_hubs)}, "
            f"freq={len(freq_hubs)}, freq_threshold={freq_threshold})", level="DEBUG")

        ancestor_to_cuis = defaultdict(set)
        for c in cuis:
            for a in cui_ancestors.get(c, set()):
                if a not in hub_ancestors and a not in cui_set:
                    ancestor_to_cuis[a].add(c)

        max_share = max(2, int(np.sqrt(len(cuis))))
        parent_map = {c: c for c in cuis}
        rank = {c: 0 for c in cuis}

        def find(x):
            while parent_map[x] != x:
                parent_map[x] = parent_map[parent_map[x]]  # path compression
                x = parent_map[x]
            return x

        def union(x, y):
            rx, ry = find(x), find(y)
            if rx == ry:
                return
            if rank[rx] < rank[ry]:
                rx, ry = ry, rx
            parent_map[ry] = rx
            if rank[rx] == rank[ry]:
                rank[rx] += 1

        for a, shared_cuis in ancestor_to_cuis.items():
            if len(shared_cuis) < 2 or len(shared_cuis) > max_share:
                continue
            anchor = next(iter(shared_cuis))
            for c in shared_cuis:
                if c != anchor:
                    union(anchor, c)

        comp_map = defaultdict(list)
        for c in cuis:
            comp_map[find(c)].append(c)
        components = {i: members for i, members in enumerate(comp_map.values())}

        sizes = sorted([len(v) for v in components.values()], reverse=True)
        singleton_count = sum(1 for s in sizes if s == 1)
        log(f"    Graph Components: {len(cuis)} CUIs -> {len(components)} components "
            f"(max={sizes[0]}, singletons={singleton_count}, "
            f"hub_ancestors_excluded={len(hub_ancestors)})", level="DEBUG")
        return components

class HierarchicalTopicBuilder:
    """Build 2-level topic hierarchy from UMLS ancestor convergence.
    Output: {tid: {topic_cui, members, subtopics: {stid: {subtopic_cui, members}}, ungrouped}}.
    """

    @staticmethod
    @timed("hierarchical_topics")
    def build(surviving_cuis, graph, ic_scores, max_depth=5):
        surviving = set(surviving_cuis)
        if len(surviving) < 2 or graph is None or graph.number_of_nodes() == 0:
            if surviving:
                return {0: {"topic_cui": None, "members": sorted(surviving),
                            "subtopics": {}, "ungrouped": sorted(surviving)}}
            return {}

        def _bfs_up(node):
            """BFS ancestors up to max_depth from node."""
            if not graph.has_node(node):
                return set()
            ancestors, frontier = set(), {node}
            for _ in range(max_depth):
                nxt = set()
                for n in frontier:
                    for parent in graph.predecessors(n):
                        if parent not in ancestors:
                            ancestors.add(parent)
                            nxt.add(parent)
                frontier = nxt
                if not frontier:
                    break
            return ancestors

        cui_ancestors = {cui: _bfs_up(cui) for cui in surviving}

        # Step 2: ancestor coverage — which surviving CUIs each ancestor covers
        ancestor_coverage = defaultdict(set)
        for cui in surviving:
            for anc in cui_ancestors.get(cui, set()):
                ancestor_coverage[anc].add(cui)

        # convergence points: ancestors covering 2+ CUIs (not super-broad)
        max_cover = max(2, int(len(surviving) * _HT_MAX_COVERAGE))
        convergence = {anc: members for anc, members in ancestor_coverage.items()
                       if 2 <= len(members) <= max_cover and anc not in surviving}

        if not convergence:
            return {0: {"topic_cui": None, "members": sorted(surviving),
                        "subtopics": {}, "ungrouped": sorted(surviving)}}

        # Subtopics: most specific convergence points (highest IC). Topics: broader groupers.
        by_specificity = sorted(convergence.items(),
                                key=lambda x: (-ic_scores.get(x[0], 0), len(x[1])))

        subtopic_map = {}   # subtopic_cui -> set of members
        assigned = set()    # CUIs already in a subtopic

        for anc, members in by_specificity:
            unassigned = members - assigned
            if len(unassigned) >= 2:
                subtopic_map[anc] = unassigned
                assigned |= unassigned

        topic_coverage = defaultdict(set)
        for sub_cui in subtopic_map:
            for anc in _bfs_up(sub_cui):
                topic_coverage[anc].add(sub_cui)

        # pick topic ancestors that group 2+ subtopics, most specific first
        topic_candidates = {anc: subs for anc, subs in topic_coverage.items()
                            if len(subs) >= 2 and anc not in subtopic_map}
        by_topic_specificity = sorted(topic_candidates.items(),
                                      key=lambda x: (-ic_scores.get(x[0], 0), len(x[1])))

        used_subtopics = set()
        topics = {}
        tid = 0

        for topic_cui, sub_cuis in by_topic_specificity:
            available = sub_cuis - used_subtopics
            if len(available) < 2:
                continue

            # build this topic
            all_members = set()
            subtopics = {}
            stid = 0
            for sc in sorted(available, key=lambda x: -ic_scores.get(x, 0)):
                members = subtopic_map[sc]
                subtopics[stid] = {"subtopic_cui": sc, "members": sorted(members)}
                all_members |= members
                stid += 1

            topics[tid] = {
                "topic_cui": topic_cui,
                "members": sorted(all_members),
                "subtopics": subtopics,
                "ungrouped": []
            }
            used_subtopics |= available
            tid += 1

        for sc in subtopic_map:
            if sc not in used_subtopics:
                members = subtopic_map[sc]
                topics[tid] = {
                    "topic_cui": sc,
                    "members": sorted(members),
                    "subtopics": {0: {"subtopic_cui": sc, "members": sorted(members)}},
                    "ungrouped": []
                }
                tid += 1

        remaining = surviving - assigned
        if remaining:
            for cui in remaining:
                ancs = cui_ancestors.get(cui, set())
                if ancs:
                    # attach to nearest existing topic by highest-IC shared ancestor
                    best_topic, best_ic = None, -1.0
                    for t_id, t_info in topics.items():
                        t_anc_cui = t_info["topic_cui"]
                        if t_anc_cui and t_anc_cui in ancs:
                            t_ic = ic_scores.get(t_anc_cui, 0.0)
                            if t_ic > best_ic:
                                best_ic = t_ic
                                best_topic = t_id
                    if best_topic is not None:
                        topics[best_topic]["members"].append(cui)
                        topics[best_topic]["members"].sort()
                        topics[best_topic]["ungrouped"].append(cui)
                        topics[best_topic]["ungrouped"].sort()
                        continue
                # truly orphaned
                topics[tid] = {
                    "topic_cui": None, "members": [cui],
                    "subtopics": {}, "ungrouped": [cui]
                }
                tid += 1

        log(f"    Hierarchical Topics: {len(surviving)} CUIs -> {len(topics)} topics, "
            f"{len(subtopic_map)} subtopics, "
            f"{len(surviving) - len(assigned)} singletons")

        return topics

class EmbeddingReducer:
    @staticmethod
    @timed("embedding_reduce")
    def run(cuis, metadata, embeddings, ic_map, hierarchy_edges, graph=None, ancestor_depth=3):
        """Full path: components → louvain → per-topic reduction. Fast path for ≤200."""
        n_input = len(cuis)

        if n_input <= _FAST_PATH_THRESHOLD:
            return EmbeddingReducer._fast_path(
                cuis, metadata, embeddings, ic_map, hierarchy_edges, graph, ancestor_depth)

        component_depth = _compute_component_depth(graph, ancestor_depth) if graph else 1
        log(f"    Component depth: {component_depth} (ancestor_depth={ancestor_depth})", level="DEBUG")
        components = GraphComponentBuilder.build(cuis, graph, component_depth)

        all_topics = {}
        globally_surviving = set()
        removal_candidates = {}
        tid = 0
        for comp_id in sorted(components):
            comp_cuis = components[comp_id]
            with_emb = [c for c in comp_cuis if c in embeddings]
            without_emb = [c for c in comp_cuis if c not in embeddings]
            for c in without_emb:
                globally_surviving.add(c)
            if len(with_emb) <= 1:
                all_topics[f"topic_{tid}"] = comp_cuis
                for c in comp_cuis:
                    globally_surviving.add(c)
                tid += 1
                continue

            # within each component, Louvain sub-clustering
            louvain_topics = TopicBuilder.build(with_emb, embeddings)
            sizes = sorted([len(v) for v in louvain_topics.values()], reverse=True)
            if len(with_emb) > 10:
                log(f"      [comp_{comp_id}] {len(with_emb)} CUIs -> {len(louvain_topics)} topics "
                    f"(max={sizes[0]}, top5={sizes[:5]})", level="DEBUG")
            for t_cuis in louvain_topics.values():
                topic_id = f"topic_{tid}"
                tid += 1
                if len(t_cuis) <= 1:
                    all_topics[topic_id] = t_cuis
                    for c in t_cuis:
                        globally_surviving.add(c)
                    continue
                surviving, removed = _reduce_topic(
                    t_cuis, embeddings, metadata, ic_map, hierarchy_edges, graph, ancestor_depth)
                all_topics[topic_id] = surviving
                for c in surviving:
                    globally_surviving.add(c)
                for entry in removed:
                    removal_candidates[entry.removed_cui] = entry
            for cui in without_emb:
                all_topics[f"topic_{tid}"] = [cui]
                tid += 1
        final_audit = [e for c, e in removal_candidates.items() if c not in globally_surviving]
        seen = set()
        surviving = [c for t in all_topics.values() for c in t
                     if c in globally_surviving and not (c in seen or seen.add(c))]
        cleaned = {}
        for tid, t_cuis in all_topics.items():
            members = [c for c in dict.fromkeys(t_cuis) if c in globally_surviving]
            if members:
                cleaned[tid] = members
        return cleaned, surviving, final_audit

    @staticmethod
    def _fast_path(cuis, metadata, embeddings, ic_map, hierarchy_edges, graph, ancestor_depth):
        """Direct pairwise dedup for <=200 CUIs. Skips components/louvain."""
        with_emb = [c for c in cuis if c in embeddings]
        without_emb = [c for c in cuis if c not in embeddings]
        log(f"    Fast path: {len(cuis)} CUIs ({len(with_emb)} with embeddings)", level="DEBUG")
        if len(with_emb) <= 1:
            return {f"topic_0": cuis}, list(cuis), []
        surviving, audit = _reduce_topic(
            with_emb, embeddings, metadata, ic_map, hierarchy_edges, graph, ancestor_depth)
        surviving.extend(without_emb)
        emb_surviving = [c for c in surviving if c in embeddings]
        if len(emb_surviving) >= 2:
            topics = {f"topic_{i}": t for i, t in enumerate(
                TopicBuilder.build(emb_surviving, embeddings).values())}
            tid = len(topics)
            for c in without_emb:
                if c in surviving:
                    topics[f"topic_{tid}"] = [c]; tid += 1
        else:
            topics = {f"topic_0": surviving}
        return topics, surviving, audit

def _reduce_topic(t_cuis, embeddings, metadata, ic_map, hierarchy_edges, graph=None, ancestor_depth=3):
    t_cuis = [c for c in t_cuis if c in embeddings]
    if len(t_cuis) <= 1:
        return t_cuis, []
    matrix = np.array([embeddings[c] for c in t_cuis])
    sim = matrix @ matrix.T
    np.clip(sim, -1, 1, out=sim)
    dist = 1.0 - sim
    np.fill_diagonal(dist, 0)
    dist = np.maximum(dist, 0)
    if np.any(~np.isfinite(dist)):
        dist = np.nan_to_num(dist, nan=1.0, posinf=1.0, neginf=0.0)
    n = len(t_cuis)
    idx = {c: i for i, c in enumerate(t_cuis)}
    upper = dist[np.triu_indices(n, k=1)]
    if len(upper) == 0 or np.std(upper) < 1e-9:
        return t_cuis, []
    tight_t = _otsu_threshold(upper)
    guardrail = float(np.median(upper))
    tight_t = min(tight_t, guardrail)

    # topic centroid for scoring
    centroid = np.mean(matrix, axis=0).astype(np.float32)
    c_norm = np.linalg.norm(centroid)
    if c_norm > 0:
        centroid = centroid / c_norm
    else:
        centroid = None

    condensed = squareform(dist, checks=False)
    Z = linkage(condensed, method="average")
    labels = fcluster(Z, t=tight_t, criterion="distance")
    r_groups = defaultdict(list)
    for cui, lbl in zip(t_cuis, labels):
        r_groups[lbl].append(cui)
    all_kept, all_removed = [], []
    for r_cuis in r_groups.values():
        kept, removed = _resolve_group(
            r_cuis, metadata, ic_map, hierarchy_edges, dist, idx,
            tight_t, guardrail, embeddings, centroid, graph, ancestor_depth)
        all_kept.extend(kept)
        all_removed.extend(removed)
    return all_kept, all_removed

def _resolve_group(r_cuis, metadata, ic_map, hierarchy_edges, dist, index_map,
                   tight_t, guardrail, embeddings, centroid, graph=None, ancestor_depth=3):
    """Keep all CUIs that differ; remove only true duplicates (ALL guards must pass)."""
    if len(r_cuis) <= 1:
        return r_cuis, []

    def _score(c):
        if centroid is not None and c in embeddings:
            return max(float(np.dot(embeddings[c], centroid)), 0.0)
        return ic_map.get(c, 0)

    sorted_cuis = sorted(r_cuis, key=_score, reverse=True)

    kept, audit = [], []
    for c in sorted_cuis:
        is_duplicate_of = None
        for k in kept:
            ki = index_map.get(k)
            ci = index_map.get(c)
            pair_dist = dist[ci, ki] if ci is not None and ki is not None else 1.0
            if pair_dist > tight_t:
                continue
            if _are_cuis_different(c, k, metadata, hierarchy_edges, graph, ancestor_depth):
                continue
            is_duplicate_of = k
            break

        if is_duplicate_of is None:
            kept.append(c)
        else:
            ci = index_map.get(c)
            ki = index_map.get(is_duplicate_of)
            pair_dist = dist[ci, ki] if ci is not None and ki is not None else 0.0
            audit.append(AuditEntry(
                removed_cui=c,
                kept_cui=is_duplicate_of,
                reason="true_duplicate",
                detail=f"dist {pair_dist:.3f} < tight {tight_t:.3f}"))
    return kept, audit

class CrossTopicDedup:
    """Cosine k-NN + guard checks → Union-Find components → keep all that differ."""

    @staticmethod
    @timed("cross_topic_dedup")
    def run(surviving, embeddings, metadata, graph=None, ancestor_depth=3):
        with_emb = [c for c in surviving if c in embeddings]
        if len(with_emb) <= 1:
            return surviving, []
        n = len(with_emb)
        matrix = np.array([embeddings[c] for c in with_emb], dtype=np.float32)

        global_cent = np.mean(matrix, axis=0).astype(np.float32)
        g_norm = np.linalg.norm(global_cent)
        if g_norm > 0:
            global_cent = global_cent / g_norm

        k = min(_XTD_KNN_K, n - 1)
        neighbors, sim_scores = _cosine_knn(matrix, k)

        nn_dists = []
        for i in range(n):
            for j_pos in range(len(neighbors[i])):
                j = int(neighbors[i][j_pos])
                if 0 <= j < n and j != i:
                    nn_dists.append(1.0 - float(sim_scores[i][j_pos]))
        if not nn_dists:
            return surviving, []
        threshold = _otsu_threshold(np.array(nn_dists, dtype=np.float32))

        edges = []
        for i in range(n):
            for j_pos in range(len(neighbors[i])):
                j = int(neighbors[i][j_pos])
                if j < 0 or j >= n or j <= i:
                    continue
                d = 1.0 - float(sim_scores[i][j_pos])
                if d > threshold:
                    continue
                if _are_cuis_different(with_emb[i], with_emb[j], metadata, None, graph, ancestor_depth):
                    continue
                edges.append((i, j, d))
        if not edges:
            return surviving, []

        find, union = _union_find(n)
        for i, j, _ in edges:
            union(i, j)

        comp_members = defaultdict(list)
        for i in range(n):
            comp_members[find(i)].append(i)

        edge_set = {(min(i, j), max(i, j)) for i, j, _ in edges}
        centralities = matrix @ global_cent
        removed, audit = set(), []
        for root, members in comp_members.items():
            if len(members) <= 1:
                continue
            sorted_m = sorted(members, key=lambda i: float(centralities[i]), reverse=True)
            kept_in_comp = []
            for idx in sorted_m:
                dup_of = next((k for k in kept_in_comp
                              if (min(idx, k), max(idx, k)) in edge_set), None)
                if dup_of is None:
                    kept_in_comp.append(idx)
                else:
                    dc, kc = with_emb[idx], with_emb[dup_of]
                    removed.add(dc)
                    audit.append(AuditEntry(dc, kc,
                        "cross_topic_dedup", f"component size={len(members)}"))
        return [c for c in surviving if c not in removed], audit

class ConfidenceScorer:
    """Variance-weighted confidence: prox(extraction), cent(topic centroid), ret(retention power).
    Weights = std of each signal, normalized. Flat signals get near-zero weight.
    """

    @staticmethod
    @timed("confidence_score")
    def score(surviving, metadata, audit_trail,
              embeddings, cui_topic, topic_centroids,
              extraction_distances=None):

        explains = defaultdict(list)
        for entry in audit_trail:
            if entry.kept_cui and entry.removed_cui:
                explains[entry.kept_cui].append(entry.removed_cui)
        max_retained = max((len(v) for v in explains.values()), default=0)

        ext_prox = {}
        if extraction_distances:
            for cui, d in extraction_distances.items():
                if d is not None:
                    ext_prox[cui] = max(1.0 - d, 0.0)
        has_ext = len(ext_prox) > 0

        t_centroids = {}
        topic_members = defaultdict(list)
        for cui, tid in cui_topic.items():
            if cui in embeddings:
                topic_members[tid].append(cui)
        for tid, members in topic_members.items():
            tc = np.mean([embeddings[c] for c in members], axis=0).astype(np.float32)
            tc_norm = np.linalg.norm(tc)
            if tc_norm > 0:
                t_centroids[tid] = tc / tc_norm

        signals, retention_map = [], {}
        raw_cents = []
        for cui in surviving:
            retained = explains.get(cui, [])
            retention_map[cui] = retained
            prox = ext_prox.get(cui, 0.0)
            tid = cui_topic.get(cui)
            tc = t_centroids.get(tid) if tid is not None else None
            if tc is not None and cui in embeddings:
                cent = max(float(np.dot(embeddings[cui], tc)), 0.0)
            else:
                cent = None  # placeholder — filled after median computed
            ret = np.log1p(len(retained)) / np.log1p(max_retained) if max_retained > 0 else 0.0
            signals.append((cui, prox, cent, ret))
            if cent is not None:
                raw_cents.append(cent)
        if not signals:
            return [], [], {}
        # CUIs without embeddings get median centrality (neutral, not penalized)
        median_cent = float(np.median(raw_cents)) if raw_cents else 0.0
        signals = [(cui, prox, cent if cent is not None else median_cent, ret)
                   for cui, prox, cent, ret in signals]

        prox_arr = np.array([s[1] for s in signals])
        cent_arr = np.array([s[2] for s in signals])
        ret_arr  = np.array([s[3] for s in signals])
        if has_ext:
            stds = np.array([prox_arr.std(), cent_arr.std(), ret_arr.std()])
        else:
            stds = np.array([0.0, cent_arr.std(), ret_arr.std()])
        total_std = stds.sum()
        if total_std > 1e-8:
            w = stds / total_std
        else:
            # all signals flat — equal weight fallback
            w = np.array([1/3, 1/3, 1/3]) if has_ext else np.array([0.0, 0.5, 0.5])

        entries = []
        for cui, prox, cent, ret in signals:
            conf = w[0] * prox + w[1] * cent + w[2] * ret
            m = metadata.get(cui)
            entries.append(ConfidenceEntry(
                cui=cui,
                confidence=round(float(conf), 4),
                extraction_proximity=round(prox, 3),
                centrality=round(cent, 3),
                retention_power=round(ret, 3),
                semantic_types=list(m.semantic_types) if m else [],
                explains_cuis=retention_map[cui]))

        entries.sort(key=lambda e: e.confidence, reverse=True)
        sorted_cuis = [e.cui for e in entries]
        log(f"    Confidence weights: prox={w[0]:.2f} cent={w[1]:.2f} ret={w[2]:.2f} "
            f"(stds={stds[0]:.3f}/{stds[1]:.3f}/{stds[2]:.3f})", level="DEBUG")
        return sorted_cuis, entries, retention_map

class CUIReductionSystem:
    def __init__(self, project_id, dataset_id, full_network,
                 allowed_sabs, embedding_table,
                 ic_scores=None,
                 cache_dir=None):
        self.bq = bigquery.Client(project=project_id)
        self.cache_dir = cache_dir
        self.fetcher = MetadataFetcher(self.bq, project_id, dataset_id, cache_dir=cache_dir)
        self.ic_computer = ICComputer(full_network, ic_scores)
        self.sab_filter = SABFilter(allowed_sabs)
        self.hierarchy_reducer = HierarchyReducer(full_network)
        self.emb_fetcher = EmbeddingFetcher(
            self.bq, project_id, dataset_id, embedding_table, cache_dir=cache_dir)

    @timed("full_pipeline")
    def reduce(self, cuis, context_string, extraction_distances=None):
        results = self.reduce_batch([(cuis, context_string, extraction_distances)])
        return results[0]

    @timed("batch_pipeline")
    def reduce_batch(self, inputs):
        """Run pipeline. inputs: list of (cuis, context, [extraction_distances])."""
        t0 = time.perf_counter()
        _clear_ancestor_cache()

        normalized = [(i[0], i[1], i[2] if len(i) > 2 else None) for i in inputs]

        all_cuis = set()
        for cuis, _, _ in normalized:
            all_cuis.update(cuis)

        metadata = self.fetcher.fetch(list(all_cuis))
        ic_map = self.ic_computer.compute(list(all_cuis), metadata)
        ancestor_depth = _compute_ancestor_depth(self.hierarchy_reducer.graph)
        log(f"[Batch] {len(inputs)} phrases, {len(all_cuis)} unique CUIs, "
            f"metadata={len(metadata)}, ancestor_depth={ancestor_depth}")

        per_text = []
        all_filtered = set()
        for cuis, context_string, ext_dists in normalized:
            if not cuis:
                per_text.append((context_string, [], [], [], set(), [], None))
                continue
            after_sab, sab_audit = self.sab_filter.run(cuis, metadata)
            after_hier, hier_audit, hier_edges = self.hierarchy_reducer.run(after_sab, ic_map, metadata)
            log(f"  [{context_string[:50]}] {len(cuis)} -> SAB:{len(after_sab)} -> Hier:{len(after_hier)}")
            audit = sab_audit + hier_audit
            all_filtered.update(after_hier)
            per_text.append((context_string, cuis, after_sab, after_hier, hier_edges, audit, ext_dists))

        log(f"[Batch] Embeddings: {len(all_filtered)} post-filter CUIs")
        all_embeddings = self.emb_fetcher.fetch(list(all_filtered))

        results = []
        for context_string, cuis, after_filter, after_hier, hier_edges, all_audit, ext_dists in per_text:
            t_start = time.perf_counter()
            if not after_hier:
                results.append(self._empty(context_string, t_start, all_audit))
                continue
            embeddings = {c: all_embeddings[c] for c in after_hier if c in all_embeddings}
            emb_cov = len(embeddings) / len(after_hier) if after_hier else 0

            topics, surviving, emb_audit = EmbeddingReducer.run(
                after_hier, metadata, embeddings, ic_map, hier_edges,
                self.hierarchy_reducer.graph, ancestor_depth)
            all_audit.extend(emb_audit)
            log(f"    Embedding Reduction: {len(after_hier)} -> {len(surviving)}", level="DEBUG")

            topics_out = self._build_topics(topics, metadata)

            if len(after_hier) > _CROSS_TOPIC_DEDUP_MIN:  # cross-topic dedup for large inputs only
                before_xtd = len(surviving)
                surviving, xtd_audit = CrossTopicDedup.run(
                    surviving, embeddings, metadata,
                    self.hierarchy_reducer.graph, ancestor_depth)
                all_audit.extend(xtd_audit)
                log(f"    Cross-Topic Dedup: {before_xtd} -> {len(surviving)}", level="DEBUG")

            surviving_set = set(surviving)
            cui_topic = {}
            for topic_id, topic in topics_out.items():
                for c in topic.cuis:
                    if c in surviving_set:
                        cui_topic[c] = topic_id

            sorted_cuis, confidence, retention_map = ConfidenceScorer.score(
                surviving, metadata, all_audit,
                embeddings, cui_topic, {},
                extraction_distances=ext_dists)

            topics_out = self._prune_topics(topics_out, set(sorted_cuis))

            unaccounted = set(cuis) - set(surviving) - {e.removed_cui for e in all_audit}
            for cui in unaccounted:
                all_audit.append(AuditEntry(cui, "", "unaccounted", ""))
            elapsed = (time.perf_counter() - t_start) * 1000
            log(f"    Pipeline: {len(cuis)} -> SAB:{len(after_filter)} -> "
                f"Hier:{len(after_hier)} -> Emb:{len(surviving)} CUIs, "
                f"{len(topics_out)} topics ({elapsed:.0f}ms)")
            results.append(ReductionResult(
                context_string=context_string,
                input_count=len(cuis),
                after_filter_count=len(after_filter),
                after_hierarchy_count=len(after_hier),
                after_redundancy_count=len(surviving),
                topics=topics_out,
                all_reduced_cuis=sorted_cuis,
                confidence=confidence,
                retention_map=retention_map,
                audit_trail=all_audit,
                processing_time_ms=elapsed,
                embedding_coverage=emb_cov))
        total = (time.perf_counter() - t0) * 1000
        self._flush_caches()
        return results

    def _build_topics(self, topics, metadata):
        out = {}
        for tid, t_cuis in topics.items():
            if not t_cuis:
                continue
            types = set()
            for c in t_cuis:
                m = metadata.get(c)
                if m and m.semantic_types:
                    types.update(m.semantic_types)
            out[tid] = TopicInfo(tid, types or {"Unknown"}, t_cuis)
        return out

    @staticmethod
    def _prune_topics(topics_out, keep_set):
        pruned = {}
        for tid, t in topics_out.items():
            kept = [c for c in t.cuis if c in keep_set]
            if kept:
                pruned[tid] = TopicInfo(tid, t.semantic_types, kept)
        return pruned

    def _flush_caches(self):
        self.fetcher._cache.flush()
        self.emb_fetcher._cache.flush()

    def _empty(self, ctx, t0, audit=None):
        return ReductionResult(
            ctx, 0, 0, 0, 0, {}, [], [], {},
            audit or [], (time.perf_counter() - t0) * 1000, 0.0)

    def get_stats(self):
        with _timing_lock:
            out = {}
            for k, v in _timings.items():
                if v:
                    vals = list(v)
                    out[k] = {"count": len(vals), "mean_ms": float(np.mean(vals)),
                              "p99_ms": float(np.percentile(vals, 99))}
            return out

# ── Semantic type → coarse category mapping ──────────────────────────────────
# Based on UMLS Semantic Network (McCray 2003). Maps TUI prefixes and common
# semantic types to 6 coarse categories for representative grouping.
_STY_TO_CATEGORY = {
    # Disorders
    "Disease or Syndrome": "Disease", "Neoplastic Process": "Disease",
    "Mental or Behavioral Dysfunction": "Disease", "Pathologic Function": "Disease",
    "Congenital Abnormality": "Disease", "Acquired Abnormality": "Disease",
    "Injury or Poisoning": "Disease", "Cell or Molecular Dysfunction": "Disease",
    "Anatomical Abnormality": "Disease",
    # Chemicals & Drugs
    "Pharmacologic Substance": "Drug", "Clinical Drug": "Drug",
    "Antibiotic": "Drug", "Organic Chemical": "Drug",
    "Amino Acid, Peptide, or Protein": "Drug", "Hormone": "Drug",
    "Immunologic Factor": "Drug", "Biomedical or Dental Material": "Drug",
    "Vitamin": "Drug", "Enzyme": "Drug", "Receptor": "Drug",
    "Biologically Active Substance": "Drug", "Indicator, Reagent, or Diagnostic Aid": "Drug",
    "Inorganic Chemical": "Drug", "Element, Ion, or Isotope": "Drug",
    "Nucleic Acid, Nucleotide, or Nucleoside": "Drug",
    # Procedures
    "Therapeutic or Preventive Procedure": "Procedure",
    "Diagnostic Procedure": "Procedure", "Laboratory Procedure": "Procedure",
    "Research Activity": "Procedure", "Health Care Activity": "Procedure",
    "Molecular Biology Research Technique": "Procedure",
    "Medical Device": "Procedure", "Manufactured Object": "Procedure",
    "Laboratory or Test Result": "Lab",
    # Findings & Observations
    "Finding": "Finding", "Sign or Symptom": "Finding",
    "Clinical Attribute": "Finding", "Organism Attribute": "Finding",
    "Gene or Genome": "Finding",
    # Anatomy
    "Body Part, Organ, or Organ Component": "Anatomy",
    "Tissue": "Anatomy", "Cell": "Anatomy", "Body Location or Region": "Anatomy",
    "Body Space or Junction": "Anatomy", "Body System": "Anatomy",
    "Body Substance": "Anatomy", "Embryonic Structure": "Anatomy",
    "Fully Formed Anatomical Structure": "Anatomy",
}

_STY_CATEGORY_PRIORITY = ["Disease", "Drug", "Lab", "Procedure", "Finding", "Anatomy"]

def _sty_to_category(semantic_types):
    """Map a list of semantic type strings to a single coarse category.
    Uses priority order: Disease > Drug > Lab > Procedure > Finding > Anatomy."""
    found = set()
    for sty in semantic_types:
        cat = _STY_TO_CATEGORY.get(sty)
        if cat:
            found.add(cat)
    if not found:
        return "Other"
    for cat in _STY_CATEGORY_PRIORITY:
        if cat in found:
            return cat
    return "Other"


class TopicRepresentativeSelector:
    """Select representative CUI(s) for each topic.

    Algorithm (per topic):
      1. Group member CUIs by coarse semantic category (Disease/Drug/Lab/Finding/Procedure/Other)
      2. Within each category group, sub-cluster via HAC on cosine distance
      3. For each sub-cluster, pick representative:
         a. Parent-within-set: if any CUI is ancestor of 2+ others → highest IC ancestor
         b. Embedding medoid: CUI with highest mean cosine to others
         c. Fallback: highest IC
      4. Singletons become their own representative

    References:
      Resnik 1995 (IC-based selection), Pesquita 2009 (set medoid),
      McCray 2003 (UMLS Semantic Network grouping)
    """

    @staticmethod
    @timed("representative_selection")
    def select(h_topics, metadata, embeddings, ic_map, graph=None):
        """Select representatives for all topics.

        Args:
            h_topics: output of HierarchicalTopicBuilder.build()
                      {tid: {topic_cui, members, subtopics, ungrouped}}
            metadata: dict {cui: CUIMetadata}
            embeddings: dict {cui: np.array (normalized)}
            ic_map: dict {cui: float}
            graph: nx.DiGraph (UMLS hierarchy) or None

        Returns:
            dict {topic_id: list[RepresentativeInfo]}
        """
        all_reps = {}
        for tid, tinfo in h_topics.items():
            members = tinfo["members"]
            if not members:
                all_reps[tid] = []
                continue
            all_reps[tid] = TopicRepresentativeSelector._select_for_topic(
                members, metadata, embeddings, ic_map, graph)
        total = sum(len(v) for v in all_reps.values())
        log(f"    Representatives: {total} reps across {len(all_reps)} topics")
        return all_reps

    @staticmethod
    def _select_for_topic(members, metadata, embeddings, ic_map, graph):
        """Select representatives for a single topic's member CUIs."""
        # Step 1: Group by coarse semantic category
        groups = defaultdict(list)
        for cui in members:
            meta = metadata.get(cui)
            stys = meta.semantic_types if meta and meta.semantic_types else []
            cat = _sty_to_category(stys)
            groups[cat].append(cui)

        reps = []
        for cat, cat_cuis in groups.items():
            if len(cat_cuis) == 1:
                reps.append(RepresentativeInfo(
                    cui=cat_cuis[0], category=cat, method="singleton",
                    member_count=1, members=cat_cuis,
                    ic_score=ic_map.get(cat_cuis[0], 0.0)))
                continue

            # Step 2: Sub-cluster within category
            subclusters = TopicRepresentativeSelector._subcluster(
                cat_cuis, embeddings)

            # Step 3: Pick representative per sub-cluster
            for sc_cuis in subclusters:
                rep, method = TopicRepresentativeSelector._pick_representative(
                    sc_cuis, embeddings, ic_map, graph)
                reps.append(RepresentativeInfo(
                    cui=rep, category=cat,
                    method=method,
                    member_count=len(sc_cuis), members=sorted(sc_cuis),
                    ic_score=ic_map.get(rep, 0.0)))

        return reps

    @staticmethod
    def _subcluster(cuis, embeddings):
        """HAC sub-clustering on cosine distance within a semantic category group.
        Returns list of lists (each sub-cluster's CUIs)."""
        # Filter to CUIs with embeddings
        with_emb = [c for c in cuis if c in embeddings]
        without_emb = [c for c in cuis if c not in embeddings]

        if len(with_emb) <= 1:
            # Can't cluster 0 or 1 items; return each CUI as own cluster
            result = [[c] for c in cuis]
            return result

        # Build cosine distance matrix
        vecs = np.array([embeddings[c] for c in with_emb])  # already L2-normalized
        sim = vecs @ vecs.T
        np.clip(sim, -1.0, 1.0, out=sim)
        dist = 1.0 - sim
        np.fill_diagonal(dist, 0.0)

        # HAC with average linkage
        condensed = squareform(dist, checks=False)
        Z = linkage(condensed, method="average")
        labels = fcluster(Z, t=_REP_HAC_THRESHOLD, criterion="distance")

        # Group by cluster label
        cluster_map = defaultdict(list)
        for i, lab in enumerate(labels):
            cluster_map[lab].append(with_emb[i])

        result = list(cluster_map.values())

        # CUIs without embeddings become singletons
        for c in without_emb:
            result.append([c])

        return result

    @staticmethod
    def _pick_representative(sc_cuis, embeddings, ic_map, graph):
        """Pick the best representative from a sub-cluster.
        Priority: parent-within-set → embedding medoid → highest IC.
        Returns: (cui, method_string)"""

        if len(sc_cuis) == 1:
            return sc_cuis[0], "singleton"

        # Strategy A: Parent-within-set (MICA)
        # If any CUI in the sub-cluster is a UMLS ancestor of 2+ others, pick it
        if graph is not None and graph.number_of_nodes() > 0:
            parent_scores = {}
            for candidate in sc_cuis:
                if not graph.has_node(candidate):
                    continue
                # count how many other sub-cluster members this candidate subsumes
                children_in_set = 0
                for other in sc_cuis:
                    if other == candidate:
                        continue
                    if graph.has_node(other):
                        # quick check: is candidate a direct or 2-hop ancestor of other?
                        ancs = _get_ancestors(graph, other, 3)
                        if candidate in ancs:
                            children_in_set += 1
                if children_in_set >= 2:
                    parent_scores[candidate] = (children_in_set, ic_map.get(candidate, 0.0))

            if parent_scores:
                # pick parent that subsumes the most, break ties by highest IC
                best = max(parent_scores, key=lambda c: parent_scores[c])
                return best, "parent_within_set"

        # Strategy B: Embedding medoid
        with_emb = [c for c in sc_cuis if c in embeddings]
        if len(with_emb) >= 2:
            vecs = np.array([embeddings[c] for c in with_emb])
            sim = vecs @ vecs.T
            mean_sim = sim.mean(axis=1)
            best_idx = int(np.argmax(mean_sim))
            return with_emb[best_idx], "embedding_medoid"

        # Strategy C: Highest IC
        best = max(sc_cuis, key=lambda c: ic_map.get(c, 0.0))
        return best, "highest_ic"

    @staticmethod
    def resolve_snomed(bq_client, project_id, dataset_id, all_reps):
        """Resolve representative CUIs to SNOMED codes via MRCONSO.

        Args:
            bq_client: BigQuery client
            project_id: GCP project
            dataset_id: UMLS dataset
            all_reps: dict {topic_id: list[RepresentativeInfo]}

        Returns:
            dict {cui: (snomed_code, snomed_term)} — also mutates RepresentativeInfo in place
        """
        rep_cuis = set()
        for reps in all_reps.values():
            for r in reps:
                rep_cuis.add(r.cui)

        if not rep_cuis:
            return {}

        snomed_map = {}
        cui_list = list(rep_cuis)
        for i in range(0, len(cui_list), 500):
            batch = cui_list[i:i + 500]
            query = f"""
            SELECT CUI, CODE, STR
            FROM `{project_id}.{dataset_id}.MRCONSO`
            WHERE CUI IN UNNEST(@cuis)
              AND SAB = 'SNOMEDCT_US'
              AND ISPREF = 'Y' AND TS = 'P' AND STT = 'PF'
              AND LAT = 'ENG'
            """
            jc = bigquery.QueryJobConfig(query_parameters=[
                bigquery.ArrayQueryParameter("cuis", "STRING", batch)])
            for row in bq_client.query(query, job_config=jc).result():
                if row.CUI not in snomed_map:
                    snomed_map[row.CUI] = (row.CODE, row.STR)

        # mutate in place
        for reps in all_reps.values():
            for r in reps:
                if r.cui in snomed_map:
                    r.snomed_code, r.snomed_term = snomed_map[r.cui]

        resolved = sum(1 for c in rep_cuis if c in snomed_map)
        log(f"    SNOMED resolution: {resolved}/{len(rep_cuis)} representatives mapped")
        return snomed_map


class TopicAnchorAssigner:
    """Assign anchor CUIs to topics for storage and query matching.

    For each topic, groups representatives by category, then finds the most
    specific common ancestor (LCA) that covers all reps in that category.
    If no good LCA exists (IC too low), each rep becomes its own anchor.
    One anchor can cover multiple topics (deduplicated at the end).

    References:
      Resnik 1995 (IC-based ancestor selection),
      Couto & Silva 2011 (disjoint common ancestors for multiple codes)
    """

    @staticmethod
    @timed("anchor_assignment")
    def assign(topic_reps, ic_map, graph=None):
        """Assign anchors to all topics.

        Args:
            topic_reps: dict {topic_id: list[RepresentativeInfo]}
                        output of TopicRepresentativeSelector.select()
            ic_map: dict {cui: float}
            graph: nx.DiGraph (UMLS hierarchy) or None

        Returns:
            list[AnchorInfo] — deduplicated anchors with topic_ids
        """
        # Phase 1: compute raw anchors per (topic, category)
        raw_anchors = []  # list of (anchor_cui, anchor_ic, category, rep_cuis, topic_id)

        for tid, reps in topic_reps.items():
            if not reps:
                continue

            # group reps by category
            cat_groups = defaultdict(list)
            for r in reps:
                cat_groups[r.category].append(r)

            for cat, cat_reps in cat_groups.items():
                rep_cuis = [r.cui for r in cat_reps]

                if len(rep_cuis) == 1:
                    # single rep → anchor is the rep itself
                    raw_anchors.append((
                        rep_cuis[0],
                        ic_map.get(rep_cuis[0], 0.0),
                        cat,
                        rep_cuis,
                        tid
                    ))
                    continue

                # multiple reps in same category → find LCA
                lca = TopicAnchorAssigner._find_lca(
                    rep_cuis, ic_map, graph)

                if lca is not None and ic_map.get(lca, 0.0) >= _ANCHOR_IC_MIN:
                    # good LCA found → single anchor for this category group
                    raw_anchors.append((
                        lca,
                        ic_map.get(lca, 0.0),
                        cat,
                        rep_cuis,
                        tid
                    ))
                else:
                    # no good LCA → too diverse, each rep is its own anchor
                    for rc in rep_cuis:
                        raw_anchors.append((
                            rc,
                            ic_map.get(rc, 0.0),
                            cat,
                            [rc],
                            tid
                        ))

        # Phase 2: deduplicate — same (anchor_cui, category) across topics
        dedup = defaultdict(lambda: {"ic": 0.0, "rep_cuis": set(), "topic_ids": set()})
        for anchor_cui, anchor_ic, cat, reps, tid in raw_anchors:
            key = (anchor_cui, cat)
            dedup[key]["ic"] = max(dedup[key]["ic"], anchor_ic)
            dedup[key]["rep_cuis"].update(reps)
            dedup[key]["topic_ids"].add(tid)

        # Phase 3: precompute ancestors for each anchor
        # IMPORTANT: ancestors include all rep CUIs' ancestors + anchor's ancestors
        # so subsumption matching works for rep-to-rep checks (not just anchor-to-anchor)
        anchors = []
        for (anchor_cui, cat), info in dedup.items():
            anc_set = set()
            if graph is not None:
                # ancestors of the anchor itself
                anc_set |= _get_ancestors(graph, anchor_cui, _ANCHOR_BFS_DEPTH)
                # ancestors of each representative CUI
                for rc in info["rep_cuis"]:
                    anc_set |= _get_ancestors(graph, rc, _ANCHOR_BFS_DEPTH)
            anc_cuis = sorted(anc_set)

            anchors.append(AnchorInfo(
                anchor_cui=anchor_cui,
                anchor_ic=info["ic"],
                category=cat,
                rep_cuis=sorted(info["rep_cuis"]),
                topic_ids=sorted(info["topic_ids"]),
                ancestor_cuis=anc_cuis
            ))

        # sort by IC descending for consistent ordering
        anchors.sort(key=lambda a: (-a.anchor_ic, a.category, a.anchor_cui))

        n_topics = len(set(tid for a in anchors for tid in a.topic_ids))
        n_shared = sum(1 for a in anchors if len(a.topic_ids) > 1)
        log(f"    Anchors: {len(anchors)} anchors across {n_topics} topics "
            f"({n_shared} shared across topics)")
        return anchors

    @staticmethod
    def _find_lca(cuis, ic_map, graph):
        """Find the Least Common Ancestor with highest IC for a set of CUIs.

        Walks up from each CUI, intersects ancestor sets, picks highest IC
        from the intersection. Returns None if no meaningful LCA found.
        """
        if graph is None or graph.number_of_nodes() == 0:
            return None
        if len(cuis) < 2:
            return cuis[0] if cuis else None

        # collect ancestors for each CUI
        per_cui_ancestors = []
        for cui in cuis:
            ancs = _get_ancestors(graph, cui, _ANCHOR_BFS_DEPTH)
            if not ancs:
                return None  # CUI not in graph, can't find LCA
            per_cui_ancestors.append(ancs)

        # intersect all ancestor sets
        common = set(per_cui_ancestors[0])
        for anc_set in per_cui_ancestors[1:]:
            common &= anc_set
            if not common:
                return None  # no common ancestors

        # remove ancestors that are too broad
        candidates = {c for c in common if ic_map.get(c, 0.0) >= _ANCHOR_IC_MAX_BROAD}
        if not candidates:
            return None

        # pick highest IC (most specific common ancestor)
        return max(candidates, key=lambda c: ic_map.get(c, 0.0))

    @staticmethod
    def precompute_anchor_ancestors(anchors, graph, depth=None):
        """Ensure all anchors have their ancestor_cuis populated.
        Includes ancestors of all rep CUIs + anchor CUI.
        Call this if anchors were loaded from storage without ancestors."""
        d = depth or _ANCHOR_BFS_DEPTH
        for a in anchors:
            if a.ancestor_cuis is None or len(a.ancestor_cuis) == 0:
                if graph is not None:
                    anc_set = _get_ancestors(graph, a.anchor_cui, d)
                    for rc in a.rep_cuis:
                        anc_set |= _get_ancestors(graph, rc, d)
                    a.ancestor_cuis = sorted(anc_set)
                else:
                    a.ancestor_cuis = []


class Evaluator:
    """Quality evaluation: intrinsic_metrics (reduction, confidence, topic coherence) +
    reconstruction_check (verify each merge). Both return flat row lists for CSV output.
    """

    def __init__(self, graph):
        self.graph = graph

    def intrinsic_metrics(self, case_name, entity_results, topics, embeddings):
        """Returns rows: [case, metric_type, scope, metric_name, value, flag]"""
        rows = []

        for entity_text, result in entity_results:
            inp = result.input_count
            final = result.after_redundancy_count
            ratio = 1 - (final / inp) if inp > 0 else 0
            flag = ""
            if ratio > _EVAL_AGGRESSIVE_RATIO:
                flag = f"WARNING: very aggressive (>{_EVAL_AGGRESSIVE_RATIO*100:.0f}% removed)"
            elif ratio < _EVAL_MINIMAL_RATIO:
                flag = f"WARNING: minimal reduction (<{_EVAL_MINIMAL_RATIO*100:.0f}% removed)"
            rows.append([case_name, "reduction", entity_text, "input_count", inp, ""])
            rows.append([case_name, "reduction", entity_text, "after_sab", result.after_filter_count, ""])
            rows.append([case_name, "reduction", entity_text, "after_hierarchy", result.after_hierarchy_count, ""])
            rows.append([case_name, "reduction", entity_text, "final_count", final, ""])
            rows.append([case_name, "reduction", entity_text, "reduction_ratio", round(ratio, 3), flag])

        for entity_text, result in entity_results:
            if not result.confidence:
                continue
            scores = [e.confidence for e in result.confidence]
            spread = max(scores) - min(scores)
            std = float(np.std(scores))
            flag = ""
            if spread < _EVAL_COMPRESSED_SPREAD:
                flag = "WARNING: scores too compressed, not discriminating"
            rows.append([case_name, "confidence", entity_text, "min", round(min(scores), 4), ""])
            rows.append([case_name, "confidence", entity_text, "max", round(max(scores), 4), ""])
            rows.append([case_name, "confidence", entity_text, "spread", round(spread, 4), flag])
            rows.append([case_name, "confidence", entity_text, "std", round(std, 4), ""])

        if topics and embeddings:
            intra_sims, inter_sims = [], []
            topic_centroids = {}
            for tid, members in topics.items():
                vecs = [embeddings[c] for c in members if c in embeddings]
                if len(vecs) < 2:
                    continue
                mat = np.array(vecs, dtype=np.float32)
                centroid = mat.mean(axis=0)
                norm = np.linalg.norm(centroid)
                if norm > 0:
                    centroid = centroid / norm
                topic_centroids[tid] = centroid
                sims = mat @ mat.T
                n = len(vecs)
                for i in range(n):
                    for j in range(i+1, n):
                        intra_sims.append(float(sims[i][j]))
            tids = list(topic_centroids.keys())
            for i in range(len(tids)):
                for j in range(i+1, len(tids)):
                    sim = float(np.dot(topic_centroids[tids[i]], topic_centroids[tids[j]]))
                    inter_sims.append(sim)
            avg_intra = float(np.mean(intra_sims)) if intra_sims else 0
            avg_inter = float(np.mean(inter_sims)) if inter_sims else 0
            separation = avg_intra - avg_inter
            flag = "WARNING: topics not well separated" if separation < _EVAL_SEPARATION_MIN else ""
            rows.append([case_name, "topic_coherence", "ALL", "avg_intra_similarity", round(avg_intra, 4), ""])
            rows.append([case_name, "topic_coherence", "ALL", "avg_inter_similarity", round(avg_inter, 4), ""])
            rows.append([case_name, "topic_coherence", "ALL", "separation", round(separation, 4), flag])
            rows.append([case_name, "topic_coherence", "ALL", "topic_count", len(topics), ""])

        reason_counts = defaultdict(int)
        for _, result in entity_results:
            for a in result.audit_trail:
                reason_counts[a.reason] += 1
        for reason, count in sorted(reason_counts.items()):
            rows.append([case_name, "removal_breakdown", "ALL", reason, count, ""])

        return rows

    def reconstruction_check(self, case_name, entity_results, embeddings, metadata, terms):
        """Verify each merge: embedding dist, shared parent/ancestors/semtypes → verdict."""
        rows = []
        check_reasons = {"true_duplicate", "cross_topic_dedup", "ancestor_subsumed"}
        graph = self.graph

        for entity_text, result in entity_results:
            for a in result.audit_trail:
                if a.reason not in check_reasons or not a.removed_cui or not a.kept_cui:
                    continue
                rm, kp = a.removed_cui, a.kept_cui
                cos_dist = round(1.0 - float(np.dot(embeddings[rm], embeddings[kp])), 4) \
                    if rm in embeddings and kp in embeddings else ""
                same_parent, shared_anc, shared_st = "", "", 0
                if graph:
                    r_par = set(graph.predecessors(rm)) if graph.has_node(rm) else set()
                    k_par = set(graph.predecessors(kp)) if graph.has_node(kp) else set()
                    same_parent = "YES" if (r_par & k_par) else "NO"
                    r_anc, k_anc = _get_ancestors(graph, rm, _EVAL_RECON_DEPTH), _get_ancestors(graph, kp, _EVAL_RECON_DEPTH)
                    shared_anc = len(r_anc & k_anc) if r_anc and k_anc else 0
                r_m, k_m = metadata.get(rm), metadata.get(kp)
                r_t = set(r_m.semantic_types) if r_m and r_m.semantic_types else set()
                k_t = set(k_m.semantic_types) if k_m and k_m.semantic_types else set()
                shared_st = len(r_t & k_t) if r_t and k_t else 0
                problems = []
                if cos_dist and cos_dist > _EVAL_SUSPECT_DIST:
                    problems.append(f"distant embedding ({cos_dist})")
                if same_parent == "NO" and shared_anc == 0:
                    problems.append("no shared ancestors")
                if shared_st == 0 and r_t and k_t:
                    problems.append("no shared semantic types")
                verdict = "SUSPECT: " + "; ".join(problems) if problems else "OK"
                rows.append([case_name, entity_text, rm, terms.get(rm, rm),
                    kp, terms.get(kp, kp), a.reason, cos_dist, same_parent,
                    shared_anc, shared_st, verdict])
        return rows

    @staticmethod
    def metric_headers():
        return ["case", "metric_type", "scope", "metric_name", "value", "flag"]

    @staticmethod
    def reconstruction_headers():
        return ["case", "entity", "removed_cui", "removed_term", "kept_cui", "kept_term",
                "reason", "cosine_dist", "same_parent", "shared_ancestors", "shared_semtypes", "verdict"]

class CUIExtractor:
    def __init__(self, api_url, top_k=3, top_p=5000,
                 cluster_set="umls", combined=True, cache_dir=None):
        self.url = api_url
        self.top_k = top_k
        self.top_p = top_p
        self.cluster_set = cluster_set
        self.combined = combined
        path = os.path.join(cache_dir, "extraction_cache.pkl") if cache_dir else None
        self._cache = Cache(_CACHE_EXTRACTION, persist_path=path)
        self.session = requests.Session()
        try:
            token = subprocess.run(
                ["gcloud", "auth", "print-identity-token"],
                stdout=subprocess.PIPE, universal_newlines=True,
                timeout=_GCLOUD_TIMEOUT).stdout.strip()
            self.headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}
        except Exception:
            self.headers = {"Content-Type": "application/json"}
        from requests.adapters import HTTPAdapter
        from urllib3.util.retry import Retry
        retry = Retry(total=_RETRY_TOTAL, backoff_factor=_RETRY_BACKOFF,
                      status_forcelist=list(_RETRY_STATUS_CODES))
        self.session.mount("https://", HTTPAdapter(max_retries=retry))

    @timed("cui_extraction")
    def extract(self, text_list, context_list):
        """Extract CUIs per phrase. Returns {phrase: {cui: distance}}."""
        cache_key = f"{'||'.join(sorted(text_list))}||{self.top_k}||{self.top_p}"
        cached = self._cache.get(cache_key)
        if cached is not None:
            if isinstance(cached, list):
                log("    Cache format outdated (flat list), re-extracting...", level="DEBUG")
            elif isinstance(cached, dict):
                total = sum(len(v) for v in cached.values())
                log(f"    Extraction: {total} CUIs across {len(cached)} phrases (cached)")
                return cached

        payload = {
            "cluster_set": self.cluster_set,
            "text_list": text_list,
            "context_list": context_list,
            "top_k": self.top_k,
            "top_p": self.top_p,
            "combined": self.combined
        }
        try:
            resp = self.session.post(
                self.url, headers=self.headers,
                json=payload, timeout=_API_TIMEOUT)
            resp.raise_for_status()
            data = resp.json()
        except requests.exceptions.RequestException as e:
            log(f"    Extraction API error: {e}", level="ERROR")
            return {}
        except (ValueError, KeyError) as e:
            log(f"    Extraction API response parse error: {e}", level="ERROR")
            return {}

        per_phrase = {}
        output = data.get("output", {})
        for phrase, clusters in output.items():
            if not isinstance(clusters, list):
                continue
            cui_dists = {}
            for cluster in clusters:
                for member in cluster.get("members", []):
                    c = str(member.get("member_code", ""))
                    if c:
                        dist = member.get("member_code_distance")
                        d = float(dist) if dist is not None else None
                        # keep closest distance if CUI appears in multiple clusters
                        if c not in cui_dists or (d is not None and d < cui_dists.get(c, float('inf'))):
                            cui_dists[c] = d
            if cui_dists:
                per_phrase[phrase] = cui_dists

        total = sum(len(v) for v in per_phrase.values())
        log(f"    Extraction: {total} CUIs across {len(per_phrase)} phrases")
        self._cache.put(cache_key, per_phrase)
        return per_phrase
